<!-- views/home.ejs -->
<%
  const NONCE = typeof nonce !== 'undefined' ? nonce : (typeof NONCE !== 'undefined' ? NONCE : '');
%>

<div class="min-vh-100 bg-body-tertiary py-0 py-md-4">
  <div class="container-fluid px-0 px-md-3">

    <!-- HERO -->
    <header class="card border-0 shadow-sm rounded-0 bg-primary bg-gradient text-white mb-4">
      <div class="card-body px-3 px-md-5 py-4 py-md-5">

        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
          <span class="badge rounded-pill text-bg-light text-dark fw-semibold px-3 py-2">
            🚀 Welcome to the Future
          </span>

          <div class="d-flex gap-2" aria-hidden="true">
            <span class="badge rounded-pill text-bg-light"> </span>
            <span class="badge rounded-pill text-bg-info"> </span>
            <span class="badge rounded-pill text-bg-success"> </span>
            <span class="badge rounded-pill text-bg-dark"> </span>
          </div>
        </div>

        <h1 class="display-6 fw-bold mb-2">
          Welcome to <span class="text-warning">Unicoporate.com</span>
        </h1>

        <p class="lead mb-4">
          Empowering people, businesses, and nations — together we build a world where innovation and humanity thrive.
        </p>

        <div class="d-flex flex-column flex-sm-row gap-2 gap-sm-3 mb-4">
          <a href="/business/signup" class="btn btn-success btn-lg fw-semibold">
            🏢 Join as a Business
          </a>
          <a href="/users/signup" class="btn btn-light btn-lg fw-semibold">
            👤 Create Personal Account
          </a>
        </div>

        <div class="row g-2 g-md-3">
          <div class="col-12 col-md-4">
            <div class="p-3 rounded bg-white bg-opacity-10 border border-white border-opacity-25">
              <div class="fw-semibold">🛡️ Trusted marketplace</div>
              <div class="small opacity-75">Built with safety in mind</div>
            </div>
          </div>
          <div class="col-12 col-md-4">
            <div class="p-3 rounded bg-white bg-opacity-10 border border-white border-opacity-25">
              <div class="fw-semibold">💸 Built for growth</div>
              <div class="small opacity-75">Tools that help you scale</div>
            </div>
          </div>
          <div class="col-12 col-md-4">
            <div class="p-3 rounded bg-white bg-opacity-10 border border-white border-opacity-25">
              <div class="fw-semibold">⚡ Fast & mobile-first</div>
              <div class="small opacity-75">Optimized for all devices</div>
            </div>
          </div>
        </div>

      </div>
    </header>

    <!-- MISSION -->
    <section class="card border-0 shadow-sm rounded-0 mb-4">
      <div class="card-header bg-light px-3 px-md-4">
        <div class="d-flex align-items-start gap-3">
          <div class="badge text-bg-primary rounded-pill px-3 py-2">🌍</div>
          <div>
            <h2 class="h5 mb-1 fw-bold">Our Greater Mission</h2>
            <p class="mb-0 text-body-secondary">Commerce with purpose — progress with compassion.</p>
          </div>
        </div>
      </div>
      <div class="card-body px-3 px-md-4">
        <p class="mb-0">
          At <b>Unicoporate.com</b>, our mission goes beyond commerce.
          We are a community of visionaries working to take humanity to a <b>civilization of super power</b> —
          where technology, opportunity, and compassion unite to uplift all people.
          We reform the business world not for profit alone, but for progress, equality, and the betterment of life on Earth.
        </p>
      </div>
    </section>

    <!-- GROWTH -->
    <section class="card border-0 shadow-sm rounded-0 mb-4">
      <div class="card-header bg-light px-3 px-md-4">
        <div class="d-flex align-items-start gap-3">
          <div class="badge text-bg-success rounded-pill px-3 py-2">📈</div>
          <div>
            <h2 class="h5 mb-1 fw-bold">Empowering Growth at Every Level</h2>
            <p class="mb-0 text-body-secondary">Four pillars that help entrepreneurs and communities move forward.</p>
          </div>
        </div>
      </div>

      <div class="card-body px-3 px-md-4">
        <div class="row g-3">
          <div class="col-12 col-md-6">
            <div class="card h-100 border-primary">
              <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span class="badge text-bg-primary">🚀</span>
                  <h3 class="h6 mb-0 fw-bold">Small Business Uplift</h3>
                </div>
                <p class="mb-0">
                  We help small and micro businesses grow into professional, competitive enterprises through mentorship,
                  visibility, and digital transformation.
                </p>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-6">
            <div class="card h-100 border-info">
              <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span class="badge text-bg-info">📚</span>
                  <h3 class="h6 mb-0 fw-bold">Business Training</h3>
                </div>
                <p class="mb-0">
                  Access ongoing <b>business training programs</b> and development workshops that empower entrepreneurs with real-world knowledge.
                </p>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-6">
            <div class="card h-100 border-success">
              <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span class="badge text-bg-success">💰</span>
                  <h3 class="h6 mb-0 fw-bold">Capital Support</h3>
                </div>
                <p class="mb-0">
                  We connect qualified entrepreneurs with <b>investment opportunities</b>, startup funding, and partnership channels for sustainable growth.
                </p>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-6">
            <div class="card h-100 border-dark">
              <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span class="badge text-bg-dark">🤝</span>
                  <h3 class="h6 mb-0 fw-bold">Global Collaboration</h3>
                </div>
                <p class="mb-0">
                  We bridge nations and industries — connecting suppliers, buyers, and innovators to collaborate for global prosperity.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- HUMANITY -->
    <section class="card border-0 shadow-sm rounded-0 mb-4">
      <div class="card-header bg-light px-3 px-md-4">
        <div class="d-flex align-items-start gap-3">
          <div class="badge text-bg-warning rounded-pill px-3 py-2">🕊️</div>
          <div>
            <h2 class="h5 mb-1 fw-bold">Building Heaven on Earth</h2>
            <p class="mb-0 text-body-secondary">Balance: success with wisdom, business with purpose.</p>
          </div>
        </div>
      </div>
      <div class="card-body px-3 px-md-4">
        <p class="mb-0">
          We believe true progress lies in balance — business with purpose, wealth with wisdom, and success with compassion.
          Through every trade, every innovation, and every act of service, we strive to bring <b>heaven on Earth</b> —
          where communities flourish and humanity thrives together in peace, abundance, and creativity.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="card border-0 shadow-sm rounded-0">
      <div class="card-header bg-dark text-white px-3 px-md-4">
        <div class="d-flex align-items-start gap-3">
          <div class="badge text-bg-light text-dark rounded-pill px-3 py-2">✨</div>
          <div>
            <h2 class="h5 mb-1 fw-bold">Be Part of the Movement</h2>
            <p class="mb-0 opacity-75">Sign up today and grow with the Unicoporate community.</p>
          </div>
        </div>
      </div>

      <div class="card-body px-3 px-md-4">
        <p>
          Whether you're an individual, a startup, or an established company — Unicoporate.com welcomes you.
          Join our mission, grow your business, empower your community, and help build the future of civilization.
        </p>

        <div class="d-flex flex-column flex-sm-row gap-2">
          <a href="/business/signup" class="btn btn-success fw-semibold">
            🚀 Business Sign Up
          </a>
          <a href="/users/signup" class="btn btn-primary fw-semibold">
            🙌 Join as a User
          </a>
          <a href="store/contact" class="btn btn-outline-secondary fw-semibold">
            💬 Contact Us
          </a>
        </div>

        <div class="d-flex flex-wrap gap-2 justify-content-center mt-4">
          <span class="badge text-bg-secondary">Purple = dominant brand</span>
          <span class="badge text-bg-primary">Blue = trust</span>
          <span class="badge text-bg-success">Green = growth</span>
          <span class="badge text-bg-dark">Black = premium</span>
        </div>
      </div>
    </section>

  </div>
</div>