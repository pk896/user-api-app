<!-- views/home.ejs -->
<%
  const NONCE = typeof nonce !== 'undefined' ? nonce : '';
  const heroBg =
    (typeof shopHeaderImage !== 'undefined' && shopHeaderImage && shopHeaderImage.image)
      ? shopHeaderImage.image
      : '/images/branding/logo-unincorporate.png';
%>

<style nonce="<%= NONCE %>">
  .home-full-bleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  .home-hero {
    background:
      linear-gradient(rgba(124, 58, 237, .68), rgba(124, 58, 237, .78)),
      url('<%= heroBg %>') center / cover no-repeat;
  }
</style>

<div class="home-full-bleed bg-light">
  <section class="home-hero text-white py-4 py-md-5">
    <div class="container-fluid px-3 px-md-5">
      <div class="row align-items-center g-4">
        <div class="col-lg-8">
          <span class="badge bg-success rounded-pill px-3 py-2 mb-3">Welcome to the Future</span>

          <h1 class="display-5 fw-bold mb-3">
            Welcome to Unicoporate.com
          </h1>

          <p class="lead mb-4">
            Empowering people, businesses, and nations — together we build a world where innovation and humanity thrive.
          </p>

          <div class="d-flex flex-column flex-sm-row gap-2">
            <a href="/business/signup" class="btn btn-success rounded-pill px-4 py-3 fw-semibold">
              Join as a Business
            </a>
            <a href="/users/signup" class="btn btn-light rounded-pill px-4 py-3 fw-semibold text-primary">
              Create Personal Account
            </a>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="bg-white bg-opacity-10 border border-white border-opacity-25 rounded-4 p-3">
            <div class="mb-3">
              <div class="fw-bold">Trusted marketplace</div>
              <div class="small opacity-75">Built with safety in mind</div>
            </div>
            <div class="mb-3">
              <div class="fw-bold">Built for growth</div>
              <div class="small opacity-75">Tools that help you scale</div>
            </div>
            <div>
              <div class="fw-bold">Fast & mobile-first</div>
              <div class="small opacity-75">Optimized for all devices</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <main class="container-fluid px-3 px-md-5 py-3 py-md-4">
    <div class="row g-3">
      <div class="col-12 col-lg-6">
        <section class="h-100 bg-white rounded-0 rounded-md-4 shadow-sm p-3 p-md-4">
          <h2 class="h4 fw-bold text-primary mb-2">Our Greater Mission</h2>
          <p class="mb-0">
            At <b>Unicoporate.com</b>, our mission goes beyond commerce.
            We are a community of visionaries working to take humanity to a <b>civilization of super power</b> —
            where technology, opportunity, and compassion unite to uplift all people.
          </p>
        </section>
      </div>

      <div class="col-12 col-lg-6">
        <section class="h-100 bg-white rounded-0 rounded-md-4 shadow-sm p-3 p-md-4">
          <h2 class="h4 fw-bold text-primary mb-2">Empowering Growth at Every Level</h2>
          <p class="mb-0">
            We help small and micro businesses grow through mentorship, visibility, digital transformation,
            business training, investment opportunities, and global collaboration.
          </p>
        </section>
      </div>

      <div class="col-12">
        <section class="bg-primary text-white rounded-0 rounded-md-4 shadow-sm p-3 p-md-4">
          <h2 class="h4 fw-bold mb-2">Building Heaven on Earth</h2>
          <p class="mb-0">
            We believe true progress lies in balance — business with purpose, wealth with wisdom,
            and success with compassion. Through every trade, every innovation, and every act of service,
            we strive to bring <b>heaven on Earth</b>.
          </p>
        </section>
      </div>

      <div class="col-12">
        <section class="bg-white rounded-0 rounded-md-4 shadow-sm p-3 p-md-4 text-center">
          <h2 class="h4 fw-bold text-primary mb-2">Be Part of the Movement</h2>
          <p class="mb-3">
            Whether you're an individual, a startup, or an established company — Unicoporate.com welcomes you.
          </p>

          <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
            <a href="/business/signup" class="btn btn-success rounded-pill px-4 py-3 fw-semibold">
              Business Sign Up
            </a>
            <a href="/users/signup" class="btn btn-primary rounded-pill px-4 py-3 fw-semibold">
              Join as a User
            </a>
            <a href="/store/contact" class="btn btn-outline-primary rounded-pill px-4 py-3 fw-semibold">
              Contact Us
            </a>
          </div>
        </section>
      </div>
    </div>
  </main>
</div>