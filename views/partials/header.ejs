<!-- views/partials/header.ejs -->
<nav class="navbar navbar-expand-md bg-body sticky-top border-bottom">
  <div class="container-fluid px-3 px-md-4">

    <!-- Brand -->
    <a class="navbar-brand d-flex align-items-center gap-2 fw-bold m-0" href="/" aria-label="Unicoporate Home">
      <img
        src="/images/branding/logo-unincorporate.png"
        alt="Unicoporate"
        width="22"
        height="22"
        loading="eager"
        decoding="async"
        class="rounded"
      />
      <span class="d-none d-sm-inline">Unicoporate</span>
    </a>

    <!-- Mobile toggler -->
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#headerNav"
      aria-controls="headerNav"
      aria-expanded="false"
      aria-label="Toggle menu"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Nav -->
    <div class="collapse navbar-collapse" id="headerNav">

      <!-- Links -->
      <ul class="navbar-nav me-auto mb-2 mb-md-0 gap-md-1">
        <li class="nav-item">
          <a class="nav-link <%= active === 'about' ? 'active' : '' %>" href="/users/about">About</a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= active === 'contact' ? 'active' : '' %>" href="/contact">Contact</a>
        </li>

        <% if (user) { %>
          <li class="nav-item">
            <a class="nav-link <%= active === 'user-dashboard' ? 'active' : '' %>" href="/users/dashboard">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= active === 'profile' ? 'active' : '' %>" href="/users/profile">Profile</a>
          </li>
        <% } else if (business) { %>
          <li class="nav-item">
            <a class="nav-link <%= active === 'business-dashboard' ? 'active' : '' %>" href="/business/dashboard">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= active === 'business-profile' ? 'active' : '' %>" href="/business/profile">Profile</a>
          </li>

          <% if (business.role === 'seller') { %>
            <li class="nav-item">
              <a class="nav-link <%= active === 'products' ? 'active' : '' %>" href="/products/all">Products</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= active === 'add-product' ? 'active' : '' %>" href="/products/add">Add Product</a>
            </li>
          <% } %>
        <% } %>
      </ul>

      <!-- Right side actions -->
      <div class="d-flex flex-column flex-md-row align-items-md-center gap-2">

        <% if (user) { %>
          <span class="small text-body-secondary">
            Hi, <span class="fw-semibold"><%= user.name %></span>
          </span>

          <form action="/users/logout" method="GET" class="m-0">
            <button type="submit" class="btn btn-outline-danger btn-sm w-100 w-md-auto">Logout</button>
          </form>

        <% } else if (business) { %>
          <span class="small text-body-secondary">
            <span class="badge rounded-pill text-bg-secondary me-1">
              <%= business.role ? business.role.toUpperCase() : 'BUSINESS' %>
            </span>
            <span class="fw-semibold"><%= business.name %></span>
          </span>

          <form action="/business/logout" method="POST" class="m-0">
            <button type="submit" class="btn btn-outline-danger btn-sm w-100 w-md-auto">Logout</button>
          </form>

        <% } else { %>
          <a href="/users/login" class="btn btn-primary btn-sm w-100 w-md-auto">User Login</a>
          <a href="/business/login" class="btn btn-outline-secondary btn-sm w-100 w-md-auto">Business</a>
        <% } %>

        <!-- Theme toggle (server POST, same as navbar) -->
        <form method="POST" action="/theme-toggle" class="m-0">
          <button type="submit" class="btn btn-outline-secondary btn-sm w-100 w-md-auto" aria-label="Toggle theme">
            <span class="me-2"><%= themeCss && themeCss.includes('dark') ? '🌞' : '🌙' %></span>
            <span><%= themeCss && themeCss.includes('dark') ? 'Light mode' : 'Dark mode' %></span>
          </button>
        </form>

      </div>
    </div>
  </div>
</nav>