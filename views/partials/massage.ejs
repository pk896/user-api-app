<!-- views/partials/massage.ejs -->
<div class="position-fixed top-0 end-0 p-2 p-md-3 d-flex flex-column gap-2" style="z-index: 1080;">
  <% if (success && success.length > 0) { %>
    <% success.forEach(msg => { %>
      <div class="alert alert-success alert-dismissible fade show shadow-sm mb-0" role="alert">
        <div class="d-flex align-items-start gap-2">
          <span aria-hidden="true">✅</span>
          <div class="flex-grow-1"><%= msg %></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  <% } %>

  <% if (error && error.length > 0) { %>
    <% error.forEach(msg => { %>
      <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-0" role="alert">
        <div class="d-flex align-items-start gap-2">
          <span aria-hidden="true">⚠️</span>
          <div class="flex-grow-1"><%= msg %></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  <% } %>

  <% if (info && info.length > 0) { %>
    <% info.forEach(msg => { %>
      <div class="alert alert-info alert-dismissible fade show shadow-sm mb-0" role="alert">
        <div class="d-flex align-items-start gap-2">
          <span aria-hidden="true">ℹ️</span>
          <div class="flex-grow-1"><%= msg %></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  <% } %>

  <% if (warning && warning.length > 0) { %>
    <% warning.forEach(msg => { %>
      <div class="alert alert-warning alert-dismissible fade show shadow-sm mb-0" role="alert">
        <div class="d-flex align-items-start gap-2">
          <span aria-hidden="true">⚠️</span>
          <div class="flex-grow-1"><%= msg %></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  <% } %>

  <% if (errors && errors.length > 0) { %>
    <% errors.forEach(err => { %>
      <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-0" role="alert">
        <div class="d-flex align-items-start gap-2">
          <span aria-hidden="true">❌</span>
          <div class="flex-grow-1"><%= err.msg || err %></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  <% } %>
</div>