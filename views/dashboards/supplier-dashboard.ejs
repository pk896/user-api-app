                    View Imported Sales
                  </a>
                </div>
              </div>

              <div class="card-body">
                <div class="row g-4">
                  <%
                    const renderLocationRows = (rows, emptyText) => {
                      const safeRows = Array.isArray(rows) ? rows : [];
                      return safeRows;
                    };
                  %>

                  <div class="col-lg-4">
                    <div class="h6 fw-semibold text-primary mb-3">
                      Top 10 Countries
                    </div>

                    <% const countryRows = renderLocationRows(topSellerCountries, 'No countries yet.'); %>

                    <% if (countryRows.length) { %>
                    <div class="list-group list-group-flush">
                      <% countryRows.forEach((row, index) => { %>
                      <div class="list-group-item px-0">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                          <div class="min-w-0">
                            <div class="fw-semibold text-truncate">
                              <span class="badge bg-primary me-2">#<%= index + 1 %></span>
                              <%= row.name || 'Not specified' %>
                            </div>

                            <div class="small text-body-secondary">
                              <%= safeQty(row.sellerCount || 0) %> sellers ·
                              <%= safeQty(row.importedProducts || 0) %> imported products
                            </div>
                          </div>

                          <div class="text-end">
                            <div class="fw-semibold text-success">
                              <%= safeQty(row.importedStock || 0) %>
                            </div>
                            <div class="small text-body-secondary">stock</div>
                          </div>
                        </div>
                      </div>
                      <% }) %>
                    </div>
                    <% } else { %>
                    <div class="alert alert-light border mb-0">
                      No country import data yet.
                    </div>
                    <% } %>
                  </div>

                  <div class="col-lg-4">
                    <div class="h6 fw-semibold text-primary mb-3">
                      Top 10 Provinces / States
                    </div>

                    <% const provinceRows = renderLocationRows(topSellerProvinces, 'No provinces yet.'); %>

                    <% if (provinceRows.length) { %>
                    <div class="list-group list-group-flush">
                      <% provinceRows.forEach((row, index) => { %>
                      <div class="list-group-item px-0">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                          <div class="min-w-0">
                            <div class="fw-semibold text-truncate">
                              <span class="badge bg-primary me-2">#<%= index + 1 %></span>
                              <%= row.name || 'Not specified' %>
                            </div>

                            <div class="small text-body-secondary">
                              <%= safeQty(row.sellerCount || 0) %> sellers ·
                              <%= safeQty(row.importedProducts || 0) %> imported products
                            </div>
                          </div>

                          <div class="text-end">
                            <div class="fw-semibold text-success">
                              <%= safeQty(row.importedStock || 0) %>
                            </div>
                            <div class="small text-body-secondary">stock</div>
                          </div>
                        </div>
                      </div>
                      <% }) %>
                    </div>
                    <% } else { %>
                    <div class="alert alert-light border mb-0">
                      No province/state import data yet.
                    </div>
                    <% } %>
                  </div>

                  <div class="col-lg-4">
                    <div class="h6 fw-semibold text-primary mb-3">
                      Top 10 Cities
                    </div>

                    <% const cityRows = renderLocationRows(topSellerCities, 'No cities yet.'); %>

                    <% if (cityRows.length) { %>
                    <div class="list-group list-group-flush">
                      <% cityRows.forEach((row, index) => { %>
                      <div class="list-group-item px-0">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                          <div class="min-w-0">
                            <div class="fw-semibold text-truncate">
                              <span class="badge bg-primary me-2">#<%= index + 1 %></span>
                              <%= row.name || 'Not specified' %>
                            </div>

                            <div class="small text-body-secondary">
                              <%= safeQty(row.sellerCount || 0) %> sellers ·
                              <%= safeQty(row.importedProducts || 0) %> imported products
                            </div>
                          </div>

                          <div class="text-end">
                            <div class="fw-semibold text-success">
                              <%= safeQty(row.importedStock || 0) %>
                            </div>
                            <div class="small text-body-secondary">stock</div>
                          </div>
                        </div>
                      </div>
                      <% }) %>
                    </div>
                    <% } else { %>
                    <div class="alert alert-light border mb-0">
                      No city import data yet.
                    </div>
                    <% } %>
                  </div>
                </div>
              </div>

              <div class="card-footer bg-transparent">
                <div class="small text-body-secondary">
                  Location interest is calculated from seller businesses that imported this supplier's wholesale products.
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- /.row-->
      </div>
    </div>
    <footer class="footer px-4" style="border-top: 1px solid rgba(0,0,0,.08);">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <a href="/home" class="d-inline-flex align-items-center gap-2 text-decoration-none">
          <img src="/images/branding/logo-unincorporate.png" alt="Unicoporate" width="22" height="22" style="border-radius:6px; object-fit:contain; box-shadow:0 1px 6px rgba(15,23,42,.14);" loading="lazy" decoding="async" />
          <span class="fw-semibold">Unicoporate</span>
        </a>

        <span class="text-body-secondary small">
          © <span id="ft-year"></span> Unicoporate. All rights reserved.
        </span>
      </div>

      <div class="ms-auto d-flex flex-wrap align-items-center gap-3">
        <a class="text-decoration-none" href="/contact">Contact</a>
        <a class="text-decoration-none" href="/privacy">Privacy</a>
        <a class="text-decoration-none" href="/terms">Terms</a>
        <a class="text-decoration-none" href="/users/about">About</a>
      </div>
    </footer>
  </div>
  <!-- CoreUI and necessary plugins-->
  <script src="https://cdn.jsdelivr.net/npm/@coreui/coreui@5.3.0/dist/js/coreui.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/simplebar@6.3.0/dist/simplebar.min.js"></script>
  <script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
    document.addEventListener('DOMContentLoaded', () => {
      const sidebarEl = document.querySelector('#sidebar');
      const toggleSidebar = () => {
        if (window.coreui && sidebarEl) {
          coreui.Sidebar.getOrCreateInstance(sidebarEl).toggle();
        }
      };
      document.querySelector('#sidebarCloseBtn')?.addEventListener('click', toggleSidebar);
      document.querySelector('#sidebarMainToggler')?.addEventListener('click', toggleSidebar);
    });


    const header = document.querySelector('header.header');

    document.addEventListener('scroll', () => {
      if (header) {
        header.classList.toggle('shadow-sm', document.documentElement.scrollTop > 0);
      }
    });
  </script>
  <!-- Plugins and scripts required by this view-->
  <script src="https://cdn.jsdelivr.net/npm/chart.js/dist/chart.umd.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@coreui/chartjs/dist/js/coreui-chartjs.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@coreui/utils/dist/umd/index.js"></script>
  <%- include('partials/supplier-charts') %>
  <script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  </script>
</body>

</html>