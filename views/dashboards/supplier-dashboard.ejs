                          <strong class="<%= productWeeklyGrowth >= 0 ? 'text-success' : 'text-danger' %>">
                            <%= productWeeklySign %><%= productWeeklyGrowth.toFixed(1) %>%
                          </strong>
                          <span>
                            (<%= safeQty(product.currentWeeklySold || 0) %> vs
                            <%= safeQty(product.previousWeeklySold || 0) %>)
                          </span>
                        </div>

                        <div class="small text-body-secondary text-break">
                          Monthly:
                          <strong class="<%= productMonthlyGrowth >= 0 ? 'text-success' : 'text-danger' %>">
                            <%= productMonthlySign %><%= productMonthlyGrowth.toFixed(1) %>%
                          </strong>
                          <span>
                            (<%= safeQty(product.currentMonthlySold || 0) %> vs
                            <%= safeQty(product.previousMonthlySold || 0) %>)
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>
                  <% }) %>
                </div>
                <% } else { %>
                <div class="text-body-secondary small">
                  No sold-stock growth data yet.
                </div>
                <% } %>
              </div>

              <div class="card-footer bg-transparent">
                <a href="/wholesale/supplier/products" class="btn btn-sm btn-outline-success w-100">
                  View Wholesale Products
                </a>
              </div>
            </div>
          </div>
        </div>
        <!-- /.row-->
        <div class="row g-4 mb-4">
          <div class="col-12">
            <div class="card border-0 shadow-sm">
              <div class="card-header bg-primary text-white">
                <div class="d-flex flex-column flex-lg-row justify-content-between gap-2">
                  <div>
                    <div class="fw-semibold">Supplier Performance Overview</div>
                    <div class="small text-white text-opacity-75">
                      Real wholesale request status, product health, and top requesting sellers.
                    </div>
                  </div>

                  <div class="d-flex flex-wrap gap-2">
                    <a href="/wholesale/supplier/requests" class="btn btn-sm btn-light">
                      View Requests
                    </a>
                    <a href="/wholesale/supplier/products" class="btn btn-sm btn-outline-light">
                      Manage Products
                    </a>
                  </div>
                </div>
              </div>

              <div class="card-body">
                <div class="row g-4">
                  <div class="col-lg-6">
                    <div class="h6 fw-semibold text-primary mb-3">
                      Supply Request Status
                    </div>

                    <%
                      const requestStatuses = ['pending', 'approved', 'rejected', 'cancelled'];
                    %>

                    <% requestStatuses.forEach((statusKey) => {
                      const statusRow = requestStatusSummary[statusKey] || {};
                      const statusCount = Number(statusRow.count || 0);
                      const statusQty = Number(statusRow.requestedQty || 0);
                      const statusPercent = requestStatusTotal > 0
                        ? Math.round((statusCount / requestStatusTotal) * 100)
                        : 0;
                    %>
                    <div class="mb-3">
                      <div class="d-flex justify-content-between align-items-center gap-3 mb-1">
                        <div>
                          <span class="badge <%= statusRow.badgeClass || 'bg-secondary' %>">
                            <%= statusRow.label || statusKey %>
                          </span>
                          <span class="small text-body-secondary ms-2">
                            <%= safeQty(statusQty) %> requested units
                          </span>
                        </div>

                        <div class="fw-semibold">
                          <%= safeQty(statusCount) %>
                        </div>
                      </div>

                      <div class="progress progress-thin">
                        <div class="progress-bar <%= statusRow.progressClass || 'bg-secondary' %>" role="progressbar" style="width: <%= statusPercent %>%" aria-valuenow="<%= statusPercent %>" aria-valuemin="0" aria-valuemax="100"></div>
                      </div>
                    </div>
                    <% }) %>

                    <% if (!requestStatusTotal) { %>
                    <div class="alert alert-light border mb-0">
                      No seller supply requests yet.
                    </div>
                    <% } %>
                  </div>

                  <div class="col-lg-6">
                    <div class="h6 fw-semibold text-primary mb-3">
                      Wholesale Product Health
                    </div>

                    <div class="row g-3">
                      <div class="col-6">
                        <div class="border rounded-3 p-3 h-100">
                          <div class="small text-body-secondary">Active Products</div>
                          <div class="fs-4 fw-semibold text-primary">
                            <%= safeQty(productHealthSummary.activeProducts || 0) %>
                          </div>
                        </div>
                      </div>

                      <div class="col-6">
                        <div class="border rounded-3 p-3 h-100">
                          <div class="small text-body-secondary">Total Stock</div>
                          <div class="fs-4 fw-semibold text-success">
                            <%= safeQty(productHealthSummary.totalStock || 0) %>
                          </div>
                        </div>
                      </div>

                      <div class="col-6">
                        <div class="border rounded-3 p-3 h-100">
                          <div class="small text-body-secondary">Low Stock</div>
                          <div class="fs-4 fw-semibold text-warning">
                            <%= safeQty(productHealthSummary.lowStock || 0) %>
                          </div>
                          <div class="small text-body-secondary">
                            1 - 15 units left
                          </div>
                        </div>
                      </div>

                      <div class="col-6">
                        <div class="border rounded-3 p-3 h-100">
                          <div class="small text-body-secondary">Out of Stock</div>
                          <div class="fs-4 fw-semibold text-danger">
                            <%= safeQty(productHealthSummary.outOfStock || 0) %>
                          </div>
                          <div class="small text-body-secondary">
                            0 units available
                          </div>
                        </div>
                      </div>

                      <div class="col-12">
                        <div class="border rounded-3 p-3">
                          <div class="d-flex flex-wrap justify-content-between gap-2">
                            <div>
                              <div class="small text-body-secondary">Draft Products</div>
                              <div class="fw-semibold">
                                <%= safeQty(productHealthSummary.draftProducts || 0) %>
                              </div>
                            </div>

                            <div>
                              <div class="small text-body-secondary">Paused Products</div>
                              <div class="fw-semibold">
                                <%= safeQty(productHealthSummary.pausedProducts || 0) %>
                              </div>
                            </div>

                            <div>
                              <div class="small text-body-secondary">Archived Products</div>
                              <div class="fw-semibold">
                                <%= safeQty(productHealthSummary.archivedProducts || 0) %>
                              </div>
                            </div>

                            <div>
                              <div class="small text-body-secondary">Inventory Value</div>
                              <div class="fw-semibold text-primary">
                                <%= safeMoney(productHealthSummary.inventoryValue || 0) %>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-12">
                    <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-3">
                      <div>
                        <div class="h6 fw-semibold text-primary mb-1">
                          Top Requesting Sellers
                        </div>
                        <div class="small text-body-secondary">
                          Sellers ranked by approved quantity, total requested quantity, and request activity.
                        </div>
                      </div>

                      <a href="/wholesale/supplier/requests" class="btn btn-sm btn-outline-primary align-self-md-start">
                        View All Supply Requests
                      </a>
                    </div>

                    <div class="table-responsive">
                      <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Seller</th>
                            <th class="text-end">Requests</th>
                            <th class="text-end">Approved Qty</th>
                            <th class="text-end">Pending Qty</th>
                            <th class="text-end">Last Request</th>
                          </tr>
                        </thead>

                        <tbody>
                          <% if (topRequestingSellers.length) { %>
                          <% topRequestingSellers.forEach((seller) => { %>
                          <tr>
                            <td>
                              <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-primary">
                                  #<%= safeQty(seller.rank || 0) %>
                                </span>

                                <div class="min-w-0">
                                  <div class="fw-semibold text-truncate">
                                    <%= seller.sellerName || 'Seller account' %>
                                  </div>

                                  <div class="small text-body-secondary text-truncate">
                                    <%= seller.sellerEmail || 'No email' %>
                                  </div>
                                </div>
                              </div>
                            </td>

                            <td class="text-end">
                              <div class="fw-semibold">
                                <%= safeQty(seller.totalRequests || 0) %>
                              </div>
                              <div class="small text-body-secondary">
                                <%= safeQty(seller.approvedRequests || 0) %> approved
                              </div>
                            </td>

                            <td class="text-end">
                              <span class="fw-semibold text-success">
                                <%= safeQty(seller.approvedQty || 0) %>
                              </span>
                            </td>

                            <td class="text-end">
                              <span class="fw-semibold text-warning">
                                <%= safeQty(seller.pendingQty || 0) %>
                              </span>
                            </td>

                            <td class="text-end">
                              <%
                                    const sellerLastRequestDate = seller.lastRequestAt ? new Date(seller.lastRequestAt) : null;
                                    const sellerLastRequestText =
                                      sellerLastRequestDate && !Number.isNaN(sellerLastRequestDate.getTime())
                                        ? sellerLastRequestDate.toLocaleDateString()
                                        : '—';
                                  %>
                              <span class="small text-body-secondary">
                                <%= sellerLastRequestText %>
                              </span>
                            </td>
                          </tr>
                          <% }) %>
                          <% } else { %>
                          <tr>
                            <td colspan="5">
                              <div class="alert alert-light border mb-0">
                                No seller request activity yet.
                              </div>
                            </td>
                          </tr>
                          <% } %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>

              <div class="card-footer bg-transparent">
                <div class="d-flex flex-column flex-md-row justify-content-between gap-2 small text-body-secondary">
                  <div>
                    Request data comes from seller supply requests.
                  </div>
                  <div>
                    Product health comes from your wholesale product inventory.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- /.row-->
        <div class="row g-4 mb-4">
