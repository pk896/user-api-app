                        </div>
                      </div>
                    </div>
                  </div>
                  <% }) %>
                </div>
                <% } else { %>
                <div class="text-body-secondary small">
                  No out-of-stock wholesale products.
                </div>
                <% } %>
              </div>

              <div class="card-footer bg-transparent">
                <a href="/wholesale/supplier/products" class="btn btn-sm btn-outline-danger w-100">
                  Restock Products
                </a>
              </div>
            </div>
          </div>

          <!-- Fastest Growing Wholesale Products -->
          <div class="col-sm-6 col-xl-3">
            <div class="card h-100 border-success">
              <div class="card-body">
                <%
                  const topFastGrowing = supplierFastestGrowingList[0] || null;
                  const weeklyGrowth = Number(topFastGrowing ? topFastGrowing.weeklyGrowthPercent || 0 : 0);
                  const monthlyGrowth = Number(topFastGrowing ? topFastGrowing.monthlyGrowthPercent || 0 : 0);
                  const weeklyGrowthSign = weeklyGrowth > 0 ? '+' : '';
                  const monthlyGrowthSign = monthlyGrowth > 0 ? '+' : '';
                %>

                <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                  <div>
                    <div class="text-body-secondary small text-uppercase fw-semibold">
                      Fastest Growing
                    </div>

                    <div class="fs-4 fw-semibold text-success">
                      <%= weeklyGrowthSign %><%= weeklyGrowth.toFixed(1) %>%
                    </div>

                    <div class="small text-body-secondary">
                      Weekly growth from sold stock
                    </div>
                  </div>

                  <div class="bg-success text-white rounded-3 d-flex align-items-center justify-content-center p-3">
                    <i class="icon icon-lg cil-arrow-top"></i>
                  </div>
                </div>

                <% if (supplierFastestGrowingList.length) { %>
                <div class="list-group list-group-flush">
                  <% supplierFastestGrowingList.slice(0, 10).forEach((product, index) => {
                      const productWeeklyGrowth = Number(product.weeklyGrowthPercent || 0);
                      const productMonthlyGrowth = Number(product.monthlyGrowthPercent || 0);
                      const productWeeklySign = productWeeklyGrowth > 0 ? '+' : '';
                      const productMonthlySign = productMonthlyGrowth > 0 ? '+' : '';
                    %>
                  <div class="list-group-item px-0">
                    <div class="d-flex align-items-center gap-3">
                      <div class="fw-semibold text-success small">
                        #<%= index + 1 %>
                      </div>

                      <img src="<%= product.imageUrl || '/images/branding/logo-unincorporate.png' %>" alt="<%= product.name %>" class="rounded border flex-shrink-0" style="width:46px;height:46px;object-fit:contain;" loading="lazy" decoding="async" onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';">

                      <div class="flex-grow-1 overflow-hidden">
                        <div class="fw-semibold text-body text-truncate d-block w-100">
                          <%= product.name %>
                        </div>

                        <div class="small text-body-secondary text-truncate d-block w-100">
                          <%= product.category || 'Uncategorized' %>
                        </div>

                        <div class="small text-body-secondary text-break">
