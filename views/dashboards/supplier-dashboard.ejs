    </header>
    <div class="body flex-grow-1">
      <div class="container-lg px-4">
        <%
            const CURRENCY = String(typeof baseCurrency !== 'undefined' ? baseCurrency : '').trim().toUpperCase() || 'USD';

            const money = (amount) => {
              if (typeof formatMoney === 'function') {
                return formatMoney(amount);
              }

              const n = Number(amount || 0);

              try {
                const formatted = new Intl.NumberFormat(undefined, {
                  style: 'currency',
                  currency: CURRENCY,
                  minimumFractionDigits: 2,
                  maximumFractionDigits: 2,
                }).format(n);

                if (CURRENCY === 'ZAR') {
                  return formatted.replace(/^ZAR\s?/, 'R');
                }

                return formatted;
              } catch {
                return CURRENCY + ' ' + n.toFixed(2);
              }
            };

            const safeMoney = money;

            const safeQty = (value) => {
              const n = Number(value || 0);
              return Number.isFinite(n) ? n.toLocaleString() : '0';
            };

            const supplierTopSellingList =
              Array.isArray(supplierTopSellingProducts) ? supplierTopSellingProducts : [];

            const supplierLowStockList =
              Array.isArray(supplierLowStockProducts) ? supplierLowStockProducts : [];

            const supplierOutOfStockList =
              Array.isArray(supplierOutOfStockProducts) ? supplierOutOfStockProducts : [];

            const supplierFastestGrowingList =
              Array.isArray(supplierFastestGrowingProducts) ? supplierFastestGrowingProducts : [];

            const firstTopSelling = supplierTopSellingList[0] || null;
            const firstLowStock = supplierLowStockList[0] || null;
            const firstOutOfStock = supplierOutOfStockList[0] || null;
            const firstFastGrowing = supplierFastestGrowingList[0] || null;
          %>
        <div class="row g-4 mb-4">
          <div class="col-sm-6 col-xl-3">
            <div class="card text-white bg-primary">
              <div class="card-body pb-0 d-flex justify-content-between align-items-start">
                <div>
                  <div class="fs-4 fw-semibold">
                    <span id="supplier-total-products">
                      <%= totals && typeof totals.totalProducts !== 'undefined' ? totals.totalProducts : 0 %>
                    </span>
                  </div>

                  <div>Total Products</div>

                  <div class="small text-white text-opacity-75">
                    Total stock:
                    <span id="supplier-total-stock">
                      <%= totals && typeof totals.totalStock !== 'undefined' ? totals.totalStock : 0 %>
                    </span>
                    <span id="supplier-stock-movement-text"></span>
                  </div>
                </div>
                <div class="dropdown">
                  <button class="btn btn-transparent text-white p-0" type="button" data-coreui-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="icon cil-options"></i>
                  </button>
                  <div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="#">Action</a><a class="dropdown-item" href="#">Another action</a><a class="dropdown-item" href="#">Something else here</a></div>
                </div>
              </div>
              <div class="c-chart-wrapper mt-3 mx-3" style="height:70px;">
                <canvas class="chart" id="card-chart1" height="70"></canvas>
              </div>
            </div>
          </div>
          <!-- /.col-->
          <div class="col-sm-6 col-xl-3">
            <div class="card text-white bg-info">
              <div class="card-body pb-0 d-flex justify-content-between align-items-start">
                <div>
                  <div class="fs-4 fw-semibold" id="supplier-sold-stock">0</div>

                  <div>Sold Stock</div>

                  <div class="small text-white text-opacity-75">
                    Revenue:
                    <span id="supplier-sales-revenue" class="fw-semibold">
                      (<%= money(0) %> revenue)
                    </span>
                  </div>
                </div>

                <div class="dropdown">
                  <button class="btn btn-transparent text-white p-0" type="button" data-coreui-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="icon cil-options"></i>
                  </button>

                  <div class="dropdown-menu dropdown-menu-end">
                    <a class="dropdown-item" href="/wholesale/supplier/imported-sales">View imported sales</a>
                    <a class="dropdown-item" href="/wholesale/supplier/requests">View supply requests</a>
                    <a class="dropdown-item" href="/wholesale/supplier/products">Manage products</a>
                  </div>
                </div>
              </div>

              <div class="c-chart-wrapper mt-3 mx-3" style="height:70px;">
                <canvas class="chart" id="card-chart2" height="70"></canvas>
              </div>
            </div>
          </div>
          <!-- /.col-->
          <div class="col-sm-6 col-xl-3">
            <div class="card text-white bg-warning">
              <div class="card-body pb-0 d-flex justify-content-between align-items-start">
                <div>
                  <div class="fs-4 fw-semibold">2.49% <span class="fs-6 fw-normal">(84.7%
                      <svg class="icon">
                        <use xlink:href="https://cdn.jsdelivr.net/npm/@coreui/icons/sprites/free.svg#cil-arrow-top"></use>
                      </svg>)</span></div>
                  <div>Conversion Rate</div>
                </div>
                <div class="dropdown">
                  <button class="btn btn-transparent p-0" type="button" data-coreui-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="icon cil-options"></i>
                  </button>
                  <div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="#">Action</a><a class="dropdown-item" href="#">Another action</a><a class="dropdown-item" href="#">Something else here</a></div>
                </div>
              </div>
              <div class="c-chart-wrapper mt-3" style="height:70px;">
                <canvas class="chart" id="card-chart3" height="70"></canvas>
              </div>
            </div>
          </div>
          <!-- /.col-->
          <div class="col-sm-6 col-xl-3">
            <div class="card text-white bg-danger">
              <div class="card-body pb-0 d-flex justify-content-between align-items-start">
                <div>
                  <div class="fs-4 fw-semibold">44K <span class="fs-6 fw-normal">(-23.6%
                      <svg class="icon">
                        <use xlink:href="https://cdn.jsdelivr.net/npm/@coreui/icons/sprites/free.svg#cil-arrow-bottom"></use>
                      </svg>)</span></div>
                  <div>Sessions</div>
                </div>
                <div class="dropdown">
                  <button class="btn btn-transparent p-0" type="button" data-coreui-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="icon cil-options"></i>
                  </button>
                  <div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="#">Action</a><a class="dropdown-item" href="#">Another action</a><a class="dropdown-item" href="#">Something else here</a></div>
                </div>
              </div>
              <div class="c-chart-wrapper mt-3 mx-3" style="height:70px;">
                <canvas class="chart" id="card-chart4" height="70"></canvas>
              </div>
            </div>
          </div>
          <!-- /.col-->
        </div>
        <!-- /.row-->
        <div class="card mb-4">
          <div class="card-body">
            <div class="d-flex justify-content-between">
              <div>
                <h4 class="card-title mb-0">Supply Requests & Imported Stock</h4>
                <div class="small text-body-secondary" id="supplier-main-chart-range">Last 30 days</div>
              </div>
              <div class="btn-toolbar d-none d-md-block" role="toolbar" aria-label="Toolbar with buttons">
                <div class="btn-group btn-group-toggle mx-3" data-coreui-toggle="buttons">
                  <input class="btn-check" id="supplier-chart-range-day" type="radio" name="supplier-chart-range" autocomplete="off">
                  <label class="btn btn-outline-secondary" for="supplier-chart-range-day"> Day</label>

                  <input class="btn-check" id="supplier-chart-range-month" type="radio" name="supplier-chart-range" autocomplete="off" checked>
                  <label class="btn btn-outline-secondary active" for="supplier-chart-range-month"> Month</label>

                  <input class="btn-check" id="supplier-chart-range-year" type="radio" name="supplier-chart-range" autocomplete="off">
                  <label class="btn btn-outline-secondary" for="supplier-chart-range-year"> Year</label>
                </div>

                <button class="btn btn-primary" type="button" id="refresh-supplier-main-chart">
                  <i class="icon cil-reload"></i>
                </button>
              </div>
            </div>
            <div class="c-chart-wrapper" style="height:300px;margin-top:40px;">
              <canvas class="chart" id="main-chart" height="300"></canvas>
            </div>
          </div>
          <%
            const supplierChartSafe =
              typeof supplierMainChart !== 'undefined' && supplierMainChart ? supplierMainChart : {};

            const chartRequestedTotal = Array.isArray(supplierChartSafe.requestedQty)
              ? supplierChartSafe.requestedQty.reduce((sum, value) => sum + Number(value || 0), 0)
              : 0;

            const chartImportedTotal = Array.isArray(supplierChartSafe.importedStock)
              ? supplierChartSafe.importedStock.reduce((sum, value) => sum + Number(value || 0), 0)
              : 0;

            const chartMaxValue = Math.max(chartRequestedTotal, chartImportedTotal, 1);
            const requestedPercent = Math.min(100, Math.round((chartRequestedTotal / chartMaxValue) * 100));
            const importedPercent = Math.min(100, Math.round((chartImportedTotal / chartMaxValue) * 100));
          %>

          <div class="card-footer">
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4 mb-2 text-center">
              <div class="col">
                <div class="text-body-secondary">Requested Supply Qty</div>
                <div class="fw-semibold text-truncate">
                  <%= safeQty(chartRequestedTotal) %> units
                </div>
                <div class="progress progress-thin mt-2">
                  <div
                    class="progress-bar bg-info"
                    role="progressbar"
                    style="width: <%= requestedPercent %>%"
                    aria-valuenow="<%= requestedPercent %>"
                    aria-valuemin="0"
                    aria-valuemax="100"
                  ></div>
                </div>
              </div>

              <div class="col">
                <div class="text-body-secondary">Imported Seller Stock</div>
                <div class="fw-semibold text-truncate">
                  <%= safeQty(chartImportedTotal) %> units
                </div>
                <div class="progress progress-thin mt-2">
                  <div
                    class="progress-bar bg-success"
                    role="progressbar"
                    style="width: <%= importedPercent %>%"
                    aria-valuenow="<%= importedPercent %>"
                    aria-valuemin="0"
                    aria-valuemax="100"
                  ></div>
                </div>
              </div>

              <div class="col">
                <div class="text-body-secondary">Chart Period</div>
                <div class="fw-semibold text-truncate">Last 7 months</div>
                <div class="progress progress-thin mt-2">
                  <div class="progress-bar bg-primary" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
              </div>

              <div class="col">
                <div class="text-body-secondary">Data Source</div>
                <div class="fw-semibold text-truncate">Supplier DB data</div>
                <div class="progress progress-thin mt-2">
                  <div class="progress-bar bg-warning" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- /.card-->
        <div class="row g-4 mb-4">
          <!-- Top Selling Wholesale Products -->
          <div class="col-sm-6 col-xl-3">
            <div class="card h-100 border-primary">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                  <div>
                    <div class="text-body-secondary small text-uppercase fw-semibold">
                      Top Selling
                    </div>
                    <div class="fs-4 fw-semibold text-primary">
                      <%= safeQty(firstTopSelling ? firstTopSelling.qty : 0) %>
                    </div>
                  </div>

                  <div class="bg-primary text-white rounded-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="icon icon-lg cil-chart-line"></i>
                  </div>
