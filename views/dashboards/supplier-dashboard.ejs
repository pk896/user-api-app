            <div class="card h-100 border-danger">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                  <div>
                    <div class="text-body-secondary small text-uppercase fw-semibold">
                      Out of Stock
                    </div>

                    <div class="fs-4 fw-semibold text-danger">
                      <%= safeQty(totals && typeof totals.outOfStock !== 'undefined' ? totals.outOfStock : supplierOutOfStockList.length) %>
                    </div>

                    <div class="small text-body-secondary">
                      Products with 0 units available
                    </div>
                  </div>

                  <div class="bg-danger text-white rounded-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
