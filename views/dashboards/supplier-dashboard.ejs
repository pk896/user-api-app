  <script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
    document.addEventListener('DOMContentLoaded', () => {
      const sidebarEl = document.querySelector('#sidebar');
      const toggleSidebar = () => {
        if (window.coreui && sidebarEl) {
          coreui.Sidebar.getOrCreateInstance(sidebarEl).toggle();
        }
      };
      document.querySelector('#sidebarCloseBtn')?.addEventListener('click', toggleSidebar);
      document.querySelector('#sidebarMainToggler')?.addEventListener('click', toggleSidebar);
    });


    const header = document.querySelector('header.header');

    document.addEventListener('scroll', () => {
      if (header) {
        header.classList.toggle('shadow-sm', document.documentElement.scrollTop > 0);
      }
    });
  </script>
