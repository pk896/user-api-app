/**
* Dashboard Charts
*
* This module initializes and manages all charts on the main Dashboard page (index.html).
* It includes:
* - Card charts (small charts in statistic cards)
* - Main chart (large chart showing traffic/metrics over time)
* - Custom tooltip configuration using CoreUI's ChartJS utilities
* - Theme-aware chart updates (responds to dark/light mode changes)
*
* All charts use Chart.js with CoreUI's custom styling and color variables.
*/-->

<script nonce="<%= nonce %>">
  // Configure Chart.js defaults for custom tooltips
  Chart.defaults.pointHitDetectionRadius = 1;
  Chart.defaults.plugins.tooltip.enabled = false;
  Chart.defaults.plugins.tooltip.mode = 'index';
  Chart.defaults.plugins.tooltip.position = 'nearest';
  Chart.defaults.plugins.tooltip.external = coreui.ChartJS.customTooltips;
  Chart.defaults.defaultFontColor = coreui.Utils.getStyle('--cui-body-color');
  document.documentElement.addEventListener('ColorSchemeChange', () => {
    cardChart1.data.datasets[0].pointBackgroundColor = coreui.Utils.getStyle('--cui-primary');
    cardChart2.data.datasets[0].pointBackgroundColor = coreui.Utils.getStyle('--cui-info');

    mainChart.options.scales.x.grid.color = coreui.Utils.getStyle('--cui-border-color-translucent');
    mainChart.options.scales.x.ticks.color = coreui.Utils.getStyle('--cui-body-color');

    mainChart.options.scales.yProducts.border.color = coreui.Utils.getStyle('--cui-border-color-translucent');
    mainChart.options.scales.yProducts.grid.color = coreui.Utils.getStyle('--cui-border-color-translucent');

    mainChart.options.scales.yStock.border.color = coreui.Utils.getStyle('--cui-border-color-translucent');

    mainChart.options.plugins.legend.labels.color = coreui.Utils.getStyle('--cui-body-color');

    cardChart1.update();
    cardChart2.update();
    mainChart.update();
  });

  /**
   * Generates a random integer between min and max (inclusive)
   * @param {number} min - Minimum value
   * @param {number} max - Maximum value
   * @returns {number} Random integer between min and max
   */
  const cardChart1 = new Chart(document.getElementById('card-chart1'), {
    type: 'line',
    data: {
      labels: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'],
      datasets: [{
        label: 'Supplier stock movement',
        backgroundColor: 'transparent',
        borderColor: 'rgba(255,255,255,.55)',
        pointBackgroundColor: coreui.Utils.getStyle('--cui-primary'),
        data: [0, 0, 0, 0, 0, 0, 0]
      }]
    },
    options: {
      plugins: {
        legend: {
          display: false
        }
      },
      maintainAspectRatio: false,
      scales: {
        x: {
          border: {
            display: false
          },
          grid: {
            display: false,
            drawBorder: false
          },
          ticks: {
            display: false
          }
        },
        y: {
          display: false,
          grid: {
            display: false
          },
          ticks: {
            display: false
          }
        }
      },
      elements: {
        line: {
          borderWidth: 1,
          tension: 0.4
        },
        point: {
          radius: 4,
          hitRadius: 10,
          hoverRadius: 4
        }
      }
    }
  });

  async function loadSupplierCard1Stats() {
    try {
      const response = await fetch('/business/api/supplier/kpis', {
        method: 'GET',
        credentials: 'same-origin',
        headers: {
          Accept: 'application/json',
        },
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const payload = await response.json();

      if (!payload.ok) {
        throw new Error(payload.message || 'Failed to load supplier stats');
      }

      const totalProducts = Number(payload?.totals?.totalProducts || 0);
      const totalStock = Number(payload?.totals?.totalStock || 0);
      const totalSoldStock = Number(payload?.sales?.totalSoldStock || 0);
      const totalSalesRevenue = Number(payload?.sales?.totalSalesRevenue || 0);
      const salesCurrency = payload?.sales?.currency || 'USD';

      const eligiblePayoutAmount = Number(payload?.payouts?.eligiblePayoutAmount || 0);
      const latestPaidPayoutAmount = Number(payload?.payouts?.latestPaidAmount || 0);
      const payoutCurrency = payload?.payouts?.currency || 'USD';

      const totalRefundedOrders = Number(payload?.refunds?.totalRefundedOrders || 0);
      const totalRefundedProducts = Number(payload?.refunds?.totalRefundedProducts || 0);
      const totalRefundedStock = Number(payload?.refunds?.totalRefundedStock || 0);

      const chartLabels = Array.isArray(payload?.chart?.card1?.labels) ?
        payload.chart.card1.labels :
        [];

      const chartData = Array.isArray(payload?.chart?.card1?.data) ?
        payload.chart.card1.data.map((value) => Number(value || 0)) :
        [];

      const weeklyStockMovement = chartData.reduce((sum, value) => sum + Number(value || 0), 0);

      const totalProductsEl = document.getElementById('supplier-total-products');
      const totalStockEl = document.getElementById('supplier-total-stock');
      const movementTextEl = document.getElementById('supplier-stock-movement-text');

      const soldStockEl = document.getElementById('supplier-sold-stock');
      const salesRevenueEl = document.getElementById('supplier-sales-revenue');

      const eligiblePayoutEl = document.getElementById('supplier-eligible-payout');
      const latestPaidPayoutEl = document.getElementById('supplier-latest-paid-payout');

      const refundedOrdersEl = document.getElementById('supplier-refunded-orders');
      const refundedProductsEl = document.getElementById('supplier-refunded-products');

      if (totalProductsEl) {
        totalProductsEl.textContent = String(totalProducts);
      }

      if (totalStockEl) {
        totalStockEl.textContent = String(totalStock);
      }

      if (soldStockEl) {
        soldStockEl.textContent = String(totalSoldStock);
      }

      if (salesRevenueEl) {
        salesRevenueEl.textContent = `(${formatSupplierCardMoney(totalSalesRevenue, salesCurrency)} revenue)`;
      }

      if (eligiblePayoutEl) {
        eligiblePayoutEl.textContent = formatSupplierCardMoney(eligiblePayoutAmount, payoutCurrency);
      }

      if (latestPaidPayoutEl) {
        latestPaidPayoutEl.textContent = formatSupplierCardMoney(latestPaidPayoutAmount, payoutCurrency);
      }

      if (refundedOrdersEl) {
        refundedOrdersEl.textContent = String(totalRefundedOrders);
      }

      if (refundedProductsEl) {
        refundedProductsEl.textContent = `${totalRefundedProducts} products / ${totalRefundedStock} stock`;
      }

      if (movementTextEl) {
        if (weeklyStockMovement > 0) {
          movementTextEl.textContent =
            ` (+${weeklyStockMovement} added in the last 7 days)`;
        } else if (weeklyStockMovement < 0) {
          movementTextEl.textContent =
            ` (${Math.abs(weeklyStockMovement)} removed in the last 7 days)`;
        } else {
          movementTextEl.textContent =
            ' (no stock movement in the last 7 days)';
        }
      }

      cardChart1.data.labels = chartLabels.length ?
        chartLabels :
        ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

      cardChart1.data.datasets[0].label =
        'Daily Supplier Stock Movement';
      cardChart1.data.datasets[0].data = chartData.length ?
        chartData :
        [0, 0, 0, 0, 0, 0, 0];

      const stockMovementValues =
        cardChart1.data.datasets[0].data.map((value) =>
          Number(value || 0),
        );

      const minimumStockMovement = Math.min(
        ...stockMovementValues,
        0,
      );

      const maximumStockMovement = Math.max(
        ...stockMovementValues,
        0,
      );

      const stockMovementRange = Math.max(
        maximumStockMovement - minimumStockMovement,
        1,
      );

      const stockMovementPadding = Math.max(
        Math.ceil(stockMovementRange * 0.2),
        1,
      );

      cardChart1.options.scales.y.min =
        minimumStockMovement - stockMovementPadding;

      cardChart1.options.scales.y.max =
        maximumStockMovement + stockMovementPadding;

      const soldChartLabels = Array.isArray(payload?.chart?.card2?.labels)
        ? payload.chart.card2.labels
        : [];

      const soldChartData = Array.isArray(payload?.chart?.card2?.data)
        ? payload.chart.card2.data.map((value) => Number(value || 0))
        : [];

      cardChart2.data.labels = soldChartLabels.length
        ? soldChartLabels
        : ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

      cardChart2.data.datasets[0].label = 'Sold Stock Movement';
      cardChart2.data.datasets[0].data = soldChartData.length
        ? soldChartData
        : [0, 0, 0, 0, 0, 0, 0];

      const maxSoldChartValue = Math.max(...cardChart2.data.datasets[0].data, 1);

      cardChart2.options.scales.y.min = 0;
      cardChart2.options.scales.y.max = Math.ceil(maxSoldChartValue * 1.2);

      const payoutChartLabels = Array.isArray(payload?.chart?.card3?.labels)
        ? payload.chart.card3.labels
        : [];

      const payoutChartData = Array.isArray(payload?.chart?.card3?.data)
        ? payload.chart.card3.data.map((value) => Number(value || 0))
        : [];

      cardChart3.data.labels = payoutChartLabels.length
        ? payoutChartLabels
        : ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

      cardChart3.data.datasets[0].label = 'Paid Payout Movement';
      cardChart3.data.datasets[0].data = payoutChartData.length
        ? payoutChartData
        : [0, 0, 0, 0, 0, 0, 0];

      const maxPayoutChartValue = Math.max(...cardChart3.data.datasets[0].data, 1);

      cardChart3.options.scales.y.min = 0;
      cardChart3.options.scales.y.max = Math.ceil(maxPayoutChartValue * 1.2);

      const refundChartLabels = Array.isArray(payload?.chart?.card4?.labels)
        ? payload.chart.card4.labels
        : [];

      const refundChartData = Array.isArray(payload?.chart?.card4?.data)
        ? payload.chart.card4.data.map((value) => Number(value || 0))
        : [];

      cardChart4.data.labels = refundChartLabels.length
        ? refundChartLabels
        : ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

      cardChart4.data.datasets[0].label = 'Refunded Products Movement';
      cardChart4.data.datasets[0].data = refundChartData.length
        ? refundChartData
        : [0, 0, 0, 0, 0, 0, 0];

      const maxRefundChartValue = Math.max(...cardChart4.data.datasets[0].data, 1);

      cardChart4.options.scales.y.min = 0;
      cardChart4.options.scales.y.max = Math.ceil(maxRefundChartValue * 1.2);

      cardChart4.update();
      cardChart3.update();
      cardChart2.update();
      cardChart1.update();
    } catch (error) {
      console.error('❌ Failed to load supplier card 1 stats:', error);
    }
  }

  const cardChart2 = new Chart(document.getElementById('card-chart2'), {
    type: 'line',
    data: {
      labels: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'],
      datasets: [{
        label: 'Sold Stock Movement',
        backgroundColor: 'transparent',
        borderColor: 'rgba(255,255,255,.55)',
        pointBackgroundColor: coreui.Utils.getStyle('--cui-info'),
        data: [0, 0, 0, 0, 0, 0, 0]
      }]
    },
    options: {
      plugins: {
        legend: {
          display: false
        }
      },
      maintainAspectRatio: false,
      scales: {
        x: {
          border: {
            display: false
          },
          grid: {
            display: false,
            drawBorder: false
          },
          ticks: {
            display: false
          }
        },
        y: {
          display: false,
          grid: {
            display: false
          },
          ticks: {
            display: false
          }
        }
      },
      elements: {
        line: {
          borderWidth: 1,
          tension: 0.4
        },
        point: {
          radius: 4,
          hitRadius: 10,
          hoverRadius: 4
        }
      }
    }
  });

  // eslint-disable-next-line no-unused-vars
  const cardChart3 = new Chart(document.getElementById('card-chart3'), {
    type: 'line',
    data: {
      labels: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'],
      datasets: [{
        label: 'Paid Payout Movement',
        backgroundColor: 'rgba(255,255,255,.2)',
        borderColor: 'rgba(255,255,255,.55)',
        data: [0, 0, 0, 0, 0, 0, 0],
        fill: true
      }]
    },
    options: {
      plugins: {
        legend: {
          display: false
        }
      },
      maintainAspectRatio: false,
      scales: {
        x: {
          display: false
        },
        y: {
          display: false
        }
      },
      elements: {
        line: {
          borderWidth: 2,
          tension: 0.4
        },
        point: {
          radius: 0,
          hitRadius: 10,
          hoverRadius: 4
        }
      }
    }
  });

  // eslint-disable-next-line no-unused-vars
  const cardChart4 = new Chart(document.getElementById('card-chart4'), {
    type: 'bar',
    data: {
      labels: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'],
      datasets: [{
        label: 'Refunded Products Movement',
        backgroundColor: 'rgba(255,255,255,.2)',
        borderColor: 'rgba(255,255,255,.55)',
        data: [0, 0, 0, 0, 0, 0, 0],
        barPercentage: 0.6
      }]
    },
    options: {
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        x: {
          grid: {
            display: false,
            drawTicks: false
          },
          ticks: {
            display: false
          }
        },
        y: {
          border: {
            display: false
          },
          grid: {
            display: false,
            drawBorder: false,
            drawTicks: false
          },
          ticks: {
            display: false
          }
        }
      }
    }
  });

  let supplierMainChartRange = 'month';

  function formatSupplierCardMoney(value, currency = 'USD') {
    const amount = Number(value || 0);
    const safeCurrency = String(currency || 'USD').trim().toUpperCase() || 'USD';

    try {
      const formatted = new Intl.NumberFormat(undefined, {
        style: 'currency',
        currency: safeCurrency,
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }).format(amount);

      if (safeCurrency === 'ZAR') {
        return formatted.replace(/^ZAR\s?/, 'R');
      }

      return formatted;
    } catch {
      return `${safeCurrency} ${amount.toFixed(2)}`;
    }
  }

  function formatSupplierCompactNumber(value) {
    const amount = Number(value || 0);

    return new Intl.NumberFormat('en', {
      notation: 'compact',
      maximumFractionDigits: 1,
    }).format(amount);
  }

  function updateSupplierMainChartRangeButtons(activeRange) {
    const dayInput = document.getElementById('supplier-chart-range-day');
    const monthInput = document.getElementById('supplier-chart-range-month');
    const yearInput = document.getElementById('supplier-chart-range-year');

    const dayLabel = document.querySelector('label[for="supplier-chart-range-day"]');
    const monthLabel = document.querySelector('label[for="supplier-chart-range-month"]');
    const yearLabel = document.querySelector('label[for="supplier-chart-range-year"]');

    if (dayInput) {
      dayInput.checked = activeRange === 'day';
    }

    if (monthInput) {
      monthInput.checked = activeRange === 'month';
    }

    if (yearInput) {
      yearInput.checked = activeRange === 'year';
    }

    if (dayLabel) {
      dayLabel.classList.toggle('active', activeRange === 'day');
    }

    if (monthLabel) {
      monthLabel.classList.toggle('active', activeRange === 'month');
    }

    if (yearLabel) {
      yearLabel.classList.toggle('active', activeRange === 'year');
    }
  }

  const mainChart = new Chart(document.getElementById('main-chart'), {
    type: 'line',
    data: {
      labels: [],
      datasets: [
        {
          label: 'Supplier Products Imported by Sellers',
          yAxisID: 'yProducts',
          backgroundColor: 'rgba(124, 58, 237, 0.12)',
          borderColor: '#7C3AED',
          pointBackgroundColor: '#7C3AED',
          pointBorderColor: '#ffffff',
          pointHoverBackgroundColor: '#ffffff',
          pointHoverBorderColor: '#7C3AED',
          borderWidth: 3,
          tension: 0.35,
          fill: true,
          data: [0]
        },
        {
          label: 'Total Stock Imported by Sellers',
          yAxisID: 'yStock',
          backgroundColor: 'transparent',
          borderColor: '#22C55E',
          pointBackgroundColor: '#22C55E',
          pointBorderColor: '#ffffff',
          pointHoverBackgroundColor: '#ffffff',
          pointHoverBorderColor: '#22C55E',
          borderWidth: 2,
          tension: 0.35,
          fill: false,
          data: [0]
        }
      ]
    },
    options: {
      maintainAspectRatio: false,
      interaction: {
        intersect: false,
        mode: 'index'
      },
      plugins: {
        legend: {
          display: true,
          labels: {
            color: coreui.Utils.getStyle('--cui-body-color'),
            usePointStyle: true,
            boxWidth: 10
          }
        },
        tooltip: {
          callbacks: {
            label(context) {
              const datasetLabel = context.dataset?.label || '';
              const rawValue = Number(context.raw || 0);

              const shortTooltipLabelMap = {
                'Supplier Products Imported by Sellers': 'Products',
                'Total Stock Imported by Sellers': 'Stock',
              };

              const tooltipLabel = shortTooltipLabelMap[datasetLabel] || datasetLabel;

              return `${tooltipLabel}: ${new Intl.NumberFormat('en-ZA').format(rawValue)}`;
            }
          }
        }
      },
      scales: {
        x: {
          grid: {
            color: coreui.Utils.getStyle('--cui-border-color-translucent'),
            drawOnChartArea: false
          },
          ticks: {
            color: coreui.Utils.getStyle('--cui-body-color')
          }
        },
        yProducts: {
          type: 'linear',
          position: 'left',
          beginAtZero: true,
          min: 0,
          border: {
            color: coreui.Utils.getStyle('--cui-border-color-translucent')
          },
          grid: {
            color: coreui.Utils.getStyle('--cui-border-color-translucent')
          },
          ticks: {
            color: '#7C3AED',
            maxTicksLimit: 6,
            callback(value) {
              return formatSupplierCompactNumber(value);
            }
          }
        },
        yStock: {
          type: 'linear',
          position: 'right',
          beginAtZero: true,
          min: 0,
          border: {
            color: coreui.Utils.getStyle('--cui-border-color-translucent')
          },
          grid: {
            drawOnChartArea: false
          },
          ticks: {
            color: '#22C55E',
            maxTicksLimit: 6,
            callback(value) {
              return formatSupplierCompactNumber(value);
            }
          }
        }
      },
      elements: {
        line: {
          tension: 0.35
        },
        point: {
          radius: 3,
          hitRadius: 10,
          hoverRadius: 5,
          hoverBorderWidth: 2
        }
      }
    }
  });

  async function loadSupplierMainChart(range = supplierMainChartRange) {
    try {
      supplierMainChartRange = range;

      const response = await fetch(
        `/business/api/supplier/trend-overview?range=${encodeURIComponent(range)}`,
        {
          method: 'GET',
          credentials: 'same-origin',
          headers: {
            Accept: 'application/json'
          }
        }
      );

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const payload = await response.json();

      if (!payload.ok) {
        throw new Error(payload.message || 'Failed to load supplier trend overview');
      }

      const labels = Array.isArray(payload?.chart?.labels)
        ? payload.chart.labels
        : [];

      const importedProductsData = Array.isArray(payload?.chart?.importedProducts)
        ? payload.chart.importedProducts.map((value) => Number(value || 0))
        : [];

      const importedStockData = Array.isArray(payload?.chart?.importedStock)
        ? payload.chart.importedStock.map((value) => Number(value || 0))
        : [];

      const rangeEl = document.getElementById('supplier-main-chart-range');
      if (rangeEl) {
        rangeEl.textContent = payload?.rangeLabel || 'Day / Month / Year';
      }

      mainChart.data.labels = labels.length ? labels : ['No data'];
      mainChart.data.datasets[0].data = importedProductsData.length ? importedProductsData : [0];
      mainChart.data.datasets[1].data = importedStockData.length ? importedStockData : [0];

      const maxProductsValue = Math.max(...(importedProductsData.length ? importedProductsData : [0]), 0);
      const maxStockValue = Math.max(...(importedStockData.length ? importedStockData : [0]), 0);

      mainChart.options.scales.yProducts.min = 0;
      mainChart.options.scales.yProducts.max = Math.ceil(Math.max(maxProductsValue, 1) * 1.15);

      mainChart.options.scales.yStock.min = 0;
      mainChart.options.scales.yStock.max = Math.ceil(Math.max(maxStockValue, 1) * 1.15);

      mainChart.update();
      updateSupplierMainChartRangeButtons(range);
    } catch (error) {
      console.error('❌ Failed to load supplier main chart:', error);
    }
  }

  loadSupplierCard1Stats();
  loadSupplierMainChart('month');

  const refreshSupplierMainChartBtn = document.getElementById('refresh-supplier-main-chart');

  if (refreshSupplierMainChartBtn) {
    refreshSupplierMainChartBtn.addEventListener('click', (event) => {
      event.preventDefault();
      loadSupplierMainChart(supplierMainChartRange);
    });
  }

  const supplierChartRangeDay = document.getElementById('supplier-chart-range-day');
  const supplierChartRangeMonth = document.getElementById('supplier-chart-range-month');
  const supplierChartRangeYear = document.getElementById('supplier-chart-range-year');

  if (supplierChartRangeDay) {
    supplierChartRangeDay.addEventListener('change', () => {
      if (supplierChartRangeDay.checked) {
        loadSupplierMainChart('day');
      }
    });
  }

  if (supplierChartRangeMonth) {
    supplierChartRangeMonth.addEventListener('change', () => {
      if (supplierChartRangeMonth.checked) {
        loadSupplierMainChart('month');
      }
    });
  }

  if (supplierChartRangeYear) {
    supplierChartRangeYear.addEventListener('change', () => {
      if (supplierChartRangeYear.checked) {
        loadSupplierMainChart('year');
      }
    });
  }

  //# sourceMappingURL=main.js.map
</script>