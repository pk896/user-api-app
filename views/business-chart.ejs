<!-- views/business-chart.ejs -->

<script
  src="https://cdn.jsdelivr.net/npm/chart.js"
  nonce="<%= nonce %>"
  defer
></script>

<div class="container-fluid px-0 px-md-1">
  <div class="mx-auto col-12 col-lg-11 col-xl-10">

    <!-- Header -->
    <section class="bg-primary bg-gradient text-white shadow-sm px-3 px-md-4 py-4 mb-3">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
          <h1 class="h4 fw-bold mb-1">
            <%= business.name %> Analytics Dashboard
          </h1>
          <p class="mb-0 opacity-75">
            Real-time performance metrics and business insights
          </p>
        </div>

        <button id="refreshBtn" type="button" class="btn btn-light fw-semibold">
          Refresh Data
        </button>
      </div>
    </section>

    <!-- Period Selector -->
    <section class="px-3 px-md-0 mb-3">
      <div class="btn-group w-100 w-md-auto" role="group" aria-label="Period selector">
        <button type="button" class="btn btn-outline-primary active" data-period="daily" data-period-btn="true">7 Days</button>
        <button type="button" class="btn btn-outline-primary" data-period="monthly" data-period-btn="true">30 Days</button>
        <button type="button" class="btn btn-outline-primary" data-period="yearly" data-period-btn="true">12 Months</button>
      </div>
    </section>

    <!-- Metrics -->
    <section class="px-3 px-md-0 mb-3">
      <div class="row g-2 g-md-3">
        <div class="col-12 col-sm-6 col-lg-3">
          <div class="border rounded-3 bg-body shadow-sm p-3 h-100">
            <div class="small text-body-secondary fw-semibold text-uppercase">Total Revenue</div>
            <div class="h3 fw-bold text-primary mb-1" id="totalRevenue">R 0.00</div>
            <div class="small fw-semibold text-success" id="revenueChange">0%</div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
          <div class="border rounded-3 bg-body shadow-sm p-3 h-100">
            <div class="small text-body-secondary fw-semibold text-uppercase">Total Orders</div>
            <div class="h3 fw-bold text-primary mb-1" id="totalOrders">0</div>
            <div class="small fw-semibold text-success" id="ordersChange">0%</div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
          <div class="border rounded-3 bg-body shadow-sm p-3 h-100">
            <div class="small text-body-secondary fw-semibold text-uppercase">Avg. Order Value</div>
            <div class="h3 fw-bold text-primary mb-1" id="avgOrderValue">R 0.00</div>
            <div class="small fw-semibold text-success" id="avgOrderChange">0%</div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
          <div class="border rounded-3 bg-body shadow-sm p-3 h-100">
            <div class="small text-body-secondary fw-semibold text-uppercase">Active Products</div>
            <div class="h3 fw-bold text-primary mb-1" id="activeProducts">0</div>
            <div class="small fw-semibold text-success">In Stock</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Charts -->
    <section class="px-3 px-md-0 mb-3">
      <div class="row g-2 g-md-3">

        <!-- Main Sales Chart -->
        <div class="col-12 col-lg-6">
          <div class="border rounded-3 bg-body shadow-sm p-3 h-100">
            <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
              <div class="fw-semibold">Sales Trend</div>
              <div class="btn-group" role="group" aria-label="Chart type">
                <button type="button" class="btn btn-sm btn-outline-primary active" data-type="line" data-chart-type-btn="true">Line</button>
                <button type="button" class="btn btn-sm btn-outline-primary" data-type="bar" data-chart-type-btn="true">Bar</button>
              </div>
            </div>

            <div class="ratio ratio-16x9">
              <canvas id="mainChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Revenue Breakdown -->
        <div class="col-12 col-lg-6">
          <div class="border rounded-3 bg-body shadow-sm p-3 h-100">
            <div class="fw-semibold mb-2">Revenue Breakdown</div>
            <div class="ratio ratio-16x9">
              <canvas id="revenueChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Orders -->
        <div class="col-12 col-lg-6">
          <div class="border rounded-3 bg-body shadow-sm p-3 h-100">
            <div class="fw-semibold mb-2">Order Volume</div>
            <div class="ratio ratio-16x9">
              <canvas id="ordersChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Products -->
        <div class="col-12 col-lg-6">
          <div class="border rounded-3 bg-body shadow-sm p-3 h-100">
            <div class="fw-semibold mb-2">Product Performance</div>
            <div class="ratio ratio-16x9">
              <canvas id="productsChart"></canvas>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Last Updated -->
    <section class="px-3 px-md-0">
      <div class="small text-body-secondary text-center border-top pt-3">
        Last updated: <span id="lastUpdatedTime">Just now</span>
      </div>
    </section>

    <!-- Loading Overlay (Bootstrap only, no inline style) -->
    <div id="loadingOverlay" class="position-fixed top-0 start-0 w-100 h-100 bg-body bg-opacity-75 d-none">
      <div class="h-100 d-flex flex-column align-items-center justify-content-center text-center px-3">
        <div class="spinner-border" role="status" aria-label="Loading"></div>
      </div>
    </div>

  </div>
</div>

<script nonce="<%= nonce %>">
// ==========================================
// GLOBAL STATE & CONFIGURATION
// ==========================================
let charts = {
  mainChart: null,
  revenueChart: null,
  ordersChart: null,
  productsChart: null
};

let chartData = {
  daily: [],
  monthly: [],
  yearly: []
};

let currentPeriod = 'monthly';
let currentChartType = 'line';
let isLoadingChartData = false;

window.productPerformanceData = [];

// ==========================================
// UTILITY FUNCTIONS
// ==========================================
function showLoading() {
  const overlay = document.getElementById('loadingOverlay');
  if (overlay) overlay.classList.remove('d-none');
}

function hideLoading() {
  const overlay = document.getElementById('loadingOverlay');
  if (overlay) overlay.classList.add('d-none');
}

function showError(message) {
  console.error('❌', message);
  alert(message);
}

function setChange(el, value) {
  if (!el) return;
  const n = Number(value || 0);

  el.classList.remove('text-success', 'text-danger');
  el.classList.add(n >= 0 ? 'text-success' : 'text-danger');

  el.textContent = `${Math.abs(n).toFixed(1)}%`;
}

function updateMetrics(metrics) {
  if (!metrics) return;

  const totalRevenue = Number(metrics.totalRevenue || 0);
  document.getElementById('totalRevenue').textContent = `R ${totalRevenue.toFixed(2)}`;

  document.getElementById('totalOrders').textContent = metrics.totalOrders || 0;

  const avgOrderValue = Number(metrics.avgOrderValue || 0);
  document.getElementById('avgOrderValue').textContent = `R ${avgOrderValue.toFixed(2)}`;

  document.getElementById('activeProducts').textContent = metrics.activeProducts || 0;

  setChange(document.getElementById('revenueChange'), metrics.revenueChange);
  setChange(document.getElementById('ordersChange'), metrics.ordersChange);
  setChange(document.getElementById('avgOrderChange'), metrics.avgOrderChange);
}

// ==========================================
// CHART OPTIONS CONFIGURATION
// ==========================================
function getChartOptions(prefix = '') {
  return {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      title: { display: false },
      tooltip: {
        displayColors: false,
        callbacks: {
          label: function(context) {
            if (context.parsed.y === null || typeof context.parsed.y === 'undefined') return '';
            return prefix + Number(context.parsed.y).toFixed(2);
          }
        }
      }
    },
    scales: {
      y: {
        beginAtZero: true,
        ticks: {
          callback: function(value) {
            return prefix + Number(value).toFixed(0);
          }
        }
      }
    }
  };
}

// ==========================================
// CHART CREATION FUNCTIONS
// ==========================================
function createMainChart() {
  const canvas = document.getElementById('mainChart');
  if (!canvas) return;

  const ctx = canvas.getContext('2d');
  const data = chartData[currentPeriod] || [];
  const labels = data.map(item => item.date || item.time || item.month || 'N/A');
  const values = data.map(item => Number(item.sales) || 0);

  charts.mainChart = new Chart(ctx, {
    type: currentChartType,
    data: {
      labels,
      datasets: [{
        label: 'Revenue',
        data: values,
        borderWidth: 2,
        fill: currentChartType === 'line',
        tension: 0.35
      }]
    },
    options: getChartOptions('R ')
  });
}

function createRevenueChart() {
  const canvas = document.getElementById('revenueChart');
  if (!canvas) return;

  const ctx = canvas.getContext('2d');
  const data = chartData[currentPeriod] || [];
  const last7 = data.slice(-7);
  const labels = last7.map(item => item.date || item.time || item.month || '');
  const values = last7.map(item => Number(item.sales) || 0);

  charts.revenueChart = new Chart(ctx, {
    type: 'bar',
    data: { labels, datasets: [{ label: 'Revenue', data: values }] },
    options: getChartOptions('R ')
  });
}

function createOrdersChart() {
  const canvas = document.getElementById('ordersChart');
  if (!canvas) return;

  const ctx = canvas.getContext('2d');
  const data = chartData[currentPeriod] || [];
  const labels = data.map(item => item.date || item.time || item.month || '');
  const values = data.map(item => Number(item.orders) || 0);

  charts.ordersChart = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets: [{ label: 'Orders', data: values, borderWidth: 2, tension: 0.35, fill: true }] },
    options: getChartOptions('')
  });
}

function createProductsChart() {
  const canvas = document.getElementById('productsChart');
  if (!canvas) return;

  const ctx = canvas.getContext('2d');

  let productData = window.productPerformanceData || [];
  if (productData.length === 0) {
    productData = [{ name: 'No data', sales: 1 }];
  } else {
    productData = productData.map(p => ({
      name: (p.name || 'Unknown').substring(0, 20),
      sales: Number(p.sales) || 1
    })).slice(0, 5);
  }

  const labels = productData.map(p => p.name);
  const values = productData.map(p => p.sales);

  charts.productsChart = new Chart(ctx, {
    type: 'doughnut',
    data: { labels, datasets: [{ data: values }] },
    options: { responsive: true, maintainAspectRatio: false }
  });
}

function createCharts() {
  Object.keys(charts).forEach(key => {
    if (charts[key]) {
      charts[key].destroy();
      charts[key] = null;
    }
  });

  createMainChart();
  createRevenueChart();
  createOrdersChart();
  createProductsChart();
}

function updateChartsInPlace() {
  if (!charts.mainChart) {
    createCharts();
    return;
  }

  const data = chartData[currentPeriod] || [];

  // main chart
  {
    const labels = data.map(item => item.date || item.time || item.month || 'N/A');
    const values = data.map(item => Number(item.sales) || 0);
    charts.mainChart.data.labels = labels;
    charts.mainChart.data.datasets[0].data = values;
    charts.mainChart.update('none');
  }

  // revenue chart
  if (charts.revenueChart) {
    const last7 = data.slice(-7);
    charts.revenueChart.data.labels = last7.map(i => i.date || i.time || i.month || '');
    charts.revenueChart.data.datasets[0].data = last7.map(i => Number(i.sales) || 0);
    charts.revenueChart.update('none');
  }

  // orders chart
  if (charts.ordersChart) {
    charts.ordersChart.data.labels = data.map(i => i.date || i.time || i.month || '');
    charts.ordersChart.data.datasets[0].data = data.map(i => Number(i.orders) || 0);
    charts.ordersChart.update('none');
  }

  // products chart
  if (charts.productsChart) {
    let productData = window.productPerformanceData || [];
    if (productData.length === 0) productData = [{ name: 'No data', sales: 1 }];
    else {
      productData = productData.map(p => ({
        name: (p.name || 'Unknown').substring(0, 20),
        sales: Number(p.sales) || 1
      })).slice(0, 5);
    }

    charts.productsChart.data.labels = productData.map(p => p.name);
    charts.productsChart.data.datasets[0].data = productData.map(p => p.sales);
    charts.productsChart.update('none');
  }
}

// ==========================================
// LOAD CHART DATA FROM API
// ==========================================
async function loadChartData(showSpinner = true) {
  if (isLoadingChartData) return;

  isLoadingChartData = true;
  if (showSpinner) showLoading();

  try {
    const response = await fetch('/business/analytics/chart-data', {
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    });

    if (!response.ok) throw new Error(`HTTP ${response.status}: ${response.statusText}`);

    const data = await response.json();
    if (!data.success) throw new Error(data.message || 'API returned success: false');

    chartData = {
      daily: Array.isArray(data.chartData?.daily) ? data.chartData.daily : [],
      monthly: Array.isArray(data.chartData?.monthly) ? data.chartData.monthly : [],
      yearly: Array.isArray(data.chartData?.yearly) ? data.chartData.yearly : []
    };

    window.productPerformanceData = Array.isArray(data.productPerformance) ? data.productPerformance : [];

    updateMetrics(data.metrics);
    updateChartsInPlace();

    const lastUpdatedEl = document.getElementById('lastUpdatedTime');
    if (lastUpdatedEl) {
      lastUpdatedEl.textContent = new Date().toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' });
    }
  } catch (error) {
    console.error('❌ Failed to load chart data:', error);
    showError(`Failed to load chart data: ${error.message}`);
  } finally {
    if (showSpinner) hideLoading();
    isLoadingChartData = false;
  }
}

// ==========================================
// EVENT LISTENERS
// ==========================================
function initEventListeners() {
  // Period selector buttons (no custom classes)
  document.querySelectorAll('[data-period-btn="true"]').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('[data-period-btn="true"]').forEach(b => b.classList.remove('active'));
      this.classList.add('active');

      currentPeriod = this.dataset.period;
      updateChartsInPlace();
    });
  });

  // Chart type toggle (no custom classes)
  document.querySelectorAll('[data-chart-type-btn="true"]').forEach(btn => {
    btn.addEventListener('click', function() {
      const newType = this.dataset.type;
      if (newType === currentChartType) return;

      document.querySelectorAll('[data-chart-type-btn="true"]').forEach(b => b.classList.remove('active'));
      this.classList.add('active');

      currentChartType = newType;

      if (charts.mainChart) {
        charts.mainChart.destroy();
        charts.mainChart = null;
        createMainChart();
      }
    });
  });

  const refreshBtn = document.getElementById('refreshBtn');
  if (refreshBtn) {
    refreshBtn.addEventListener('click', () => loadChartData(true));
  }
}

// ==========================================
// INITIALIZATION
// ==========================================
document.addEventListener('DOMContentLoaded', function() {
  initEventListeners();
  loadChartData(true);

  setInterval(() => {
    loadChartData(false);
  }, 5 * 60 * 1000);
});
</script>