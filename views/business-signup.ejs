<!-- views/business-signup.ejs -->

<div class="min-vh-100 brand-page-bg py-4">
  <div class="container-fluid px-0 px-md-1">
    <div class="mx-auto col-12 col-lg-11 col-xl-10">

      <!-- Header -->
      <header class="bg-white border-bottom shadow-sm px-3 px-md-4 py-4 text-center mb-3 brand-header">
        <div class="d-inline-flex align-items-center gap-2 px-3 py-2 bg-white border rounded-pill shadow-sm brand-pill">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle text-white p-2 brand-pill-icon">
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
              <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
            </svg>
          </span>
          <div class="text-start">
            <div class="small text-secondary m-0">Business Suite</div>
            <div class="fw-bold m-0 brand-purple-text">Unicoporate</div>
          </div>
        </div>

        <h2 class="mt-3 mb-1 fw-bold brand-purple-text">Create Business Account</h2>
        <p class="text-secondary mb-0">Join our network of verified businesses</p>
      </header>

      <div class="row g-0 g-lg-4 align-items-start">

        <!-- Left: Benefits -->
        <div class="col-12 col-lg-5">
          <section class="text-white shadow-sm px-3 px-md-4 py-4 h-100 brand-hero">
            <h3 class="h5 mb-2 fw-bold text-white">Join Our Business Network</h3>
            <p class="mb-4 text-white-50">
              Connect with thousands of verified businesses, expand your reach, and grow your enterprise with our platform.
            </p>

            <div class="d-flex flex-column gap-3">
              <div class="d-flex gap-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 p-2 brand-hero-icon">
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                  </svg>
                </div>
                <div>
                  <div class="fw-semibold text-white">Verified Businesses</div>
                  <div class="small text-white-50">All businesses undergo verification for trust and security</div>
                </div>
              </div>

              <div class="d-flex gap-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 p-2 brand-hero-icon">
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <path fill="currentColor" d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.1 0 2-.89 2-2V8c0-1.1-.89-2-2-2zm-6 0h-4V4h4v2z" />
                  </svg>
                </div>
                <div>
                  <div class="fw-semibold text-white">Product Management</div>
                  <div class="small text-white-50">Manage inventory, orders, and analytics in one place</div>
                </div>
              </div>

              <div class="d-flex gap-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 p-2 brand-hero-icon">
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                  </svg>
                </div>
                <div>
                  <div class="fw-semibold text-white">Global Network</div>
                  <div class="small text-white-50">Connect with businesses worldwide for growth opportunities</div>
                </div>
              </div>
            </div>

            <div class="row text-center mt-4 g-2">
              <div class="col-4">
                <div class="p-2 rounded brand-stat-card">
                  <div class="fw-bold text-white">10K+</div>
                  <div class="small text-white-50">Businesses</div>
                </div>
              </div>
              <div class="col-4">
                <div class="p-2 rounded brand-stat-card">
                  <div class="fw-bold text-white">50+</div>
                  <div class="small text-white-50">Countries</div>
                </div>
              </div>
              <div class="col-4">
                <div class="p-2 rounded brand-stat-card">
                  <div class="fw-bold text-white">99%</div>
                  <div class="small text-white-50">Satisfaction</div>
                </div>
              </div>
            </div>
          </section>

          <section class="bg-white border-top shadow-sm px-3 px-md-4 py-3">
            <div class="d-flex flex-column flex-sm-row gap-2 align-items-sm-center justify-content-sm-between">
              <div class="text-secondary">Already have an account?</div>
              <a href="/business/login" class="btn fw-semibold brand-outline-purple">
                <span class="me-1">Sign In</span>
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                  <path fill="currentColor" d="M10 17v-3H3v-4h7V7l5 5-5 5z" />
                </svg>
              </a>
            </div>
          </section>
        </div>

        <!-- Right: Form -->
        <div class="col-12 col-lg-7">
          <section class="bg-white shadow-sm px-3 px-md-4 py-4">

            <!-- Progress -->
            <div class="d-flex gap-2 flex-wrap justify-content-between mb-3">
              <span class="badge rounded-pill brand-badge-purple">1 · Business Info</span>
              <span class="badge rounded-pill text-bg-secondary">2 · Verification</span>
              <span class="badge rounded-pill text-bg-secondary">3 · Complete</span>
            </div>

            <!-- Flash Messages -->
            <div class="mb-3">
              <%- include('partials/massage', { success, error, info, warning, errors }) %>
            </div>

            <form id="businessSignupForm" action="/business/signup" method="POST" enctype="multipart/form-data" autocomplete="on" novalidate>

              <!-- Section 1 -->
              <section class="border rounded-3 overflow-hidden mb-3">
                <div class="text-white px-3 py-2 brand-section-purple">
                  <div class="d-flex align-items-center gap-2">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" />
                    </svg>
                    <strong>Business Information</strong>
                  </div>
                </div>
                <div class="bg-light px-3 py-3">
                  <div class="row g-3">
                    <div class="col-12 col-md-6">
                      <label for="name" class="form-label fw-semibold brand-purple-text">Business Name <span class="text-danger">*</span></label>
                      <input id="name" type="text" name="name" placeholder="e.g., Global Enterprises Inc."
                        autocomplete="organization" required
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'name') ? '' : (locals.name || '') %>"/>
                      <div class="form-text">Your registered business name</div>
                    </div>

                    <div class="col-12 col-md-6">
                      <label for="email" class="form-label fw-semibold brand-purple-text">Business Email <span class="text-danger">*</span></label>
                      <input id="email" type="email" name="email" placeholder="admin@company.com"
                        autocomplete="email" inputmode="email" required
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'email') ? '' : (locals.email || '') %>"/>
                      <div class="form-text">Official business email address</div>
                    </div>

                    <div class="col-12">
                      <label for="logo" class="form-label fw-semibold brand-purple-text">Business Logo <span class="text-danger">*</span></label>
                      <input
                        id="logo"
                        type="file"
                        name="logo"
                        accept="image/png,image/jpeg,image/webp,image/gif,image/bmp"
                        required
                        class="form-control brand-focus <%= errors && errors.find(e => e.param === 'logo') ? 'is-invalid' : '' %>"
                      />
                      <div class="form-text">Upload your business logo image. This logo will be used for your business avatar and media pages.</div>
                    </div>
                  </div>
                </div>
              </section>

              <!-- Section 2 -->
              <section class="border rounded-3 overflow-hidden mb-3">
                <div class="text-white px-3 py-2 brand-section-purple">
                  <div class="d-flex align-items-center gap-2">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path fill="currentColor" d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" />
                    </svg>
                    <strong>Account Security</strong>
                  </div>
                </div>
                <div class="bg-light px-3 py-3">
                  <div class="row g-3">
                    <div class="col-12 col-md-6">
                      <label for="password" class="form-label fw-semibold brand-purple-text">Password <span class="text-danger">*</span></label>

                      <div class="input-group">
                        <input id="password" type="password" name="password" placeholder="Create a strong password"
                          autocomplete="new-password" minlength="6" required class="form-control brand-focus" />
                        <button type="button" class="btn btn-outline-secondary toggle-password" data-target="password"
                          aria-label="Toggle password visibility">
                          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                            <path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" />
                          </svg>
                        </button>
                      </div>

                      <div class="mt-2">
                        <div class="d-flex justify-content-between small">
                          <span class="text-body-secondary">Strength</span>
                          <span class="fw-semibold brand-purple-text" id="strengthText">Weak</span>
                        </div>
                        <div class="progress">
                          <div class="progress-bar" id="strengthFill"></div>
                        </div>
                      </div>
                    </div>

                    <div class="col-12 col-md-6">
                      <label class="form-label fw-semibold brand-purple-text">Business Role <span class="text-danger">*</span></label>

                      <div class="row g-2">
                        <div class="col-12 col-md-4">
                          <input class="btn-check" type="radio" name="role" id="role-seller" value="seller" required
                            <%= (locals.role === 'seller') ? 'checked' : '' %>>
                          <label class="btn w-100 brand-outline-purple" for="role-seller">Seller</label>
                        </div>

                        <div class="col-12 col-md-4">
                          <input class="btn-check" type="radio" name="role" id="role-supplier" value="supplier" required
                            <%= (locals.role === 'supplier') ? 'checked' : '' %>>
                          <label class="btn w-100 brand-outline-purple" for="role-supplier">Supplier</label>
                        </div>

                        <div class="col-12 col-md-4">
                          <input class="btn-check" type="radio" name="role" id="role-buyer" value="buyer" required
                            <%= (!locals.role || locals.role === 'buyer') ? 'checked' : '' %>>
                          <label class="btn w-100 brand-outline-purple" for="role-buyer">Buyer</label>
                        </div>
                      </div>

                      <div class="form-text">Choose how this business uses the platform</div>
                    </div>
                  </div>
                </div>
              </section>

              <!-- Section 3 -->
              <section class="border rounded-3 overflow-hidden mb-3">
                <div class="text-white px-3 py-2 brand-section-green">
                  <div class="d-flex align-items-center gap-2">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                    </svg>
                    <strong>Business Details</strong>
                  </div>
                </div>

                <div class="bg-light px-3 py-3">
                  <div class="row g-3">
                    <div class="col-12 col-md-6">
                      <label for="officialNumber" class="form-label fw-semibold brand-purple-text">Business Number <span class="text-danger">*</span></label>
                      <input id="officialNumber" type="text" name="officialNumber" placeholder="Registration/Tax ID"
                        autocomplete="off" required class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'officialNumber') ? '' : (locals.officialNumber || '') %>"/>
                      <div class="form-text">Official business registration number</div>
                    </div>

                    <div class="col-12 col-md-6">
                      <label for="officialNumberType" class="form-label fw-semibold brand-purple-text">Business Number Type</label>
                      <select id="officialNumberType" name="officialNumberType" class="form-select brand-focus">
                        <option value="OTHER" <%= (!locals.officialNumberType || locals.officialNumberType === 'OTHER') ? 'selected' : '' %>>Other</option>
                        <option value="CIPC_REG" <%= (locals.officialNumberType === 'CIPC_REG') ? 'selected' : '' %>>CIPC Registration</option>
                        <option value="VAT" <%= (locals.officialNumberType === 'VAT') ? 'selected' : '' %>>VAT Number</option>
                        <option value="TIN" <%= (locals.officialNumberType === 'TIN') ? 'selected' : '' %>>Tax Identification Number</option>
                      </select>
                    </div>

                    <div class="col-12 col-md-6">
                      <label for="phone" class="form-label fw-semibold brand-purple-text">Business Phone <span class="text-danger">*</span></label>
                      <input id="phone" type="tel" name="phone" placeholder="+1 (555) 123-4567"
                        autocomplete="tel" required class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'phone') ? '' : (locals.phone || '') %>"/>
                    </div>

                    <div class="col-12 col-md-6">
                      <label for="paypalEmail" class="form-label fw-semibold brand-purple-text">
                        PayPal Email <span class="text-body-secondary fw-normal">(optional)</span>
                      </label>
                      <input
                        id="paypalEmail"
                        type="email"
                        name="paypalEmail"
                        placeholder="payments@company.com"
                        autocomplete="email"
                        inputmode="email"
                        class="form-control brand-focus <%= errors && errors.find(e => e.param === 'paypalEmail') ? 'is-invalid' : '' %>"
                        value="<%= errors && errors.find(e => e.param === 'paypalEmail') ? '' : (locals.paypalEmail || '') %>"
                      />
                      <div class="form-text">Used for payouts (only enabled if provided)</div>
                    </div>

                    <!-- Country dropdown -->
                    <div class="col-12">
                      <label class="form-label fw-semibold brand-purple-text">Country (Name) <span class="text-danger">*</span></label>

                      <div class="position-relative" id="signupCountryDropdown">
                        <button
                          type="button"
                          class="btn w-100 d-flex align-items-center justify-content-between brand-outline-purple text-start"
                          id="countrySelected"
                        >
                          <span class="d-inline-flex align-items-center gap-2">
                            <img
                              id="countrySelectedFlagImg"
                              class="border rounded"
                              alt=""
                              aria-hidden="true"
                              width="20"
                              height="15"
                            />
                            <span id="countrySelectedText" class="text-truncate">
                              <%= (errors && errors.find(e => e.param === 'country')) ? 'Select your country' : (locals.country || 'Select your country') %>
                            </span>
                          </span>
                          <span class="ms-2">▾</span>
                        </button>

                        <div
                          class="position-absolute start-0 end-0 mt-1 bg-body border rounded shadow p-2 d-none overflow-auto z-3"
                          id="countryMenu"
                        >
                          <input
                            type="text"
                            id="countrySearch"
                            placeholder="Search country..."
                            autocomplete="off"
                            class="form-control form-control-sm mb-2 brand-focus"
                          />

                          <div class="country-list overflow-auto">
                            <% if (Array.isArray(COUNTRIES)) { %>
                              <% COUNTRIES.forEach(function(c) { %>
                                <div
                                  class="country-option d-flex align-items-center gap-2 px-2 py-1 rounded <%= (locals.country === c.name) ? 'brand-country-active' : '' %>"
                                  role="button"
                                  data-value="<%= c.name %>"
                                  data-code="<%= c.code %>"
                                >
                                  <img
                                    class="border rounded"
                                    src="https://flagcdn.com/20x15/<%= String(c.code || '').toLowerCase() %>.png"
                                    alt=""
                                    loading="lazy"
                                    width="20"
                                    height="15"
                                  />
                                  <span class="country-name flex-grow-1"><%= c.name %></span>
                                </div>
                              <% }) %>
                            <% } %>
                          </div>
                        </div>

                        <select id="country" name="country" required class="d-none">
                          <option value="">Select your country</option>
                          <% if (Array.isArray(COUNTRIES)) { %>
                            <% COUNTRIES.forEach(function(c) { %>
                              <option
                                value="<%= c.name %>"
                                data-code="<%= c.code %>"
                                <%= (locals.country === c.name) ? 'selected' : '' %>
                              >
                                <%= c.name %>
                              </option>
                            <% }) %>
                          <% } %>
                        </select>
                      </div>

                      <div class="form-text">This is for display/legacy screens (Shippo uses ISO2 below)</div>
                    </div>

                    <div class="col-12 col-md-4">
                      <label for="countryCode" class="form-label fw-semibold brand-purple-text">Country Code (ISO 2) <span class="text-danger">*</span></label>
                      <input
                        id="countryCode"
                        type="text"
                        name="countryCode"
                        placeholder="e.g., ZA, US, GB"
                        autocomplete="country"
                        required
                        maxlength="2"
                        class="form-control brand-focus"
                        readonly
                        value="<%= errors && errors.find(e => e.param === 'countryCode') ? '' : (locals.countryCode || '') %>"
                      />
                      <div class="form-text">Auto-filled from the dropdown</div>
                    </div>

                    <div class="col-12 col-md-4">
                      <label for="city" class="form-label fw-semibold brand-purple-text">City <span class="text-danger">*</span></label>
                      <input
                        id="city"
                        type="text"
                        name="city"
                        placeholder="City"
                        autocomplete="address-level2"
                        required
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'city') ? '' : (locals.city || '') %>"
                      />
                    </div>

                    <div class="col-12 col-md-4">
                      <label for="state" class="form-label fw-semibold brand-purple-text">
                        Province / State <span class="text-body-secondary fw-normal">(required for US)</span>
                      </label>
                      <input
                        id="state"
                        type="text"
                        name="state"
                        placeholder="e.g., Gauteng, WC, CA"
                        autocomplete="address-level1"
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'state') ? '' : (locals.state || '') %>"
                      />
                    </div>

                    <div class="col-12 col-md-6">
                      <label for="postalCode" class="form-label fw-semibold brand-purple-text">Postal Code <span class="text-danger">*</span></label>
                      <input
                        id="postalCode"
                        type="text"
                        name="postalCode"
                        placeholder="e.g., 2001"
                        autocomplete="postal-code"
                        required
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'postalCode') ? '' : (locals.postalCode || '') %>"
                      />
                    </div>

                    <div class="col-12">
                      <label for="addressLine1" class="form-label fw-semibold brand-purple-text">Street Address (Line 1) <span class="text-danger">*</span></label>
                      <input
                        id="addressLine1"
                        type="text"
                        name="addressLine1"
                        placeholder="Street number + street name"
                        autocomplete="address-line1"
                        required
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'addressLine1') ? '' : (locals.addressLine1 || '') %>"
                      />
                      <div class="form-text">Shippo street1 (required)</div>
                    </div>

                    <div class="col-12">
                      <label for="addressLine2" class="form-label fw-semibold brand-purple-text">
                        Address Line 2 <span class="text-body-secondary fw-normal">(optional)</span>
                      </label>
                      <input
                        id="addressLine2"
                        type="text"
                        name="addressLine2"
                        placeholder="Building, Suite, Unit, Floor, etc."
                        autocomplete="address-line2"
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'addressLine2') ? '' : (locals.addressLine2 || '') %>"
                      />
                      <div class="form-text">Shippo street2 (optional)</div>
                    </div>
                  </div>
                </div>
              </section>

              <!-- Section 4 -->
              <section class="border rounded-3 overflow-hidden mb-3">
                <div class="text-dark px-3 py-2 brand-section-soft-green">
                  <div class="d-flex align-items-center gap-2">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path fill="currentColor" d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" />
                    </svg>
                    <strong>Authorized Representative</strong>
                  </div>
                </div>

                <div class="bg-light px-3 py-3">
                  <div class="row g-3">
                    <div class="col-12 col-md-6">
                      <label for="representativeFullName" class="form-label fw-semibold brand-purple-text">Full Name <span class="text-danger">*</span></label>
                      <input
                        id="representativeFullName"
                        type="text"
                        name="representative[fullName]"
                        placeholder="John Smith"
                        autocomplete="name"
                        required
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'representative.fullName') ? '' : (locals.representative && locals.representative.fullName || '') %>"
                      />
                      <div class="form-text">Person authorized to manage this account</div>
                    </div>

                    <div class="col-12 col-md-6">
                      <label for="representativePhone" class="form-label fw-semibold brand-purple-text">Cellphone <span class="text-danger">*</span></label>
                      <input
                        id="representativePhone"
                        type="tel"
                        name="representative[phone]"
                        placeholder="+1 (555) 987-6543"
                        autocomplete="tel"
                        required
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'representative.phone') ? '' : (locals.representative && locals.representative.phone || '') %>"
                      />
                    </div>

                    <div class="col-12">
                      <label for="representativeIdNumber" class="form-label fw-semibold brand-purple-text">ID Number <span class="text-danger">*</span></label>
                      <input
                        id="representativeIdNumber"
                        type="text"
                        name="representative[idNumber]"
                        placeholder="Government-issued ID number"
                        autocomplete="off"
                        required
                        class="form-control brand-focus"
                        value="<%= errors && errors.find(e => e.param === 'representative.idNumber') ? '' : (locals.representative && locals.representative.idNumber || '') %>"
                      />
                      <div class="form-text">For identity verification purposes only</div>
                    </div>
                  </div>
                </div>
              </section>

              <!-- Terms -->
              <section class="border rounded-3 bg-light p-3 mb-3">
                <div class="form-check">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    id="terms"
                    name="terms"
                    required
                    <%= (locals.terms === 'on') ? 'checked' : '' %>
                  />
                  <label class="form-check-label" for="terms">
                    I agree to the <a href="/terms" target="_blank" class="brand-link text-decoration-none">Terms of Service</a> and
                    <a href="/privacy" target="_blank" class="brand-link text-decoration-none">Privacy Policy</a>
                  </label>
                </div>
              </section>

              <!-- Submit -->
              <button type="submit" class="btn w-100 py-2 text-white fw-semibold brand-btn-success border-0">
                <span class="me-2">
                  <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                    <path fill="currentColor" d="M9 16.17L4.83 12 3.41 13.41 9 19 21 7l-1.41-1.41z" />
                  </svg>
                </span>
                Create Business Account
              </button>

              <div class="text-center mt-3 text-secondary">
                Already registered? <a href="/business/login" class="text-decoration-none fw-semibold brand-link">Sign in to your account</a>
              </div>
            </form>

          </section>
        </div>

      </div>
    </div>
  </div>
</div>

