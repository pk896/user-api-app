<script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  document.addEventListener("DOMContentLoaded", () => {
    console.log("✅ Business signup loaded with CSP nonce");

    // -----------------------------
    // ✅ Country Dropdown Logic (Bootstrap-only UI; keep same IDs/classes)
    // -----------------------------
    const countrySelect = document.getElementById('country');        // hidden select
    const countryCodeInput = document.getElementById('countryCode'); // readonly input

    const dropdown = document.getElementById('signupCountryDropdown');
    const selectedBtn = document.getElementById('countrySelected');
    const selectedText = document.getElementById('countrySelectedText');
    const selectedFlagImg = document.getElementById('countrySelectedFlagImg');
    const menu = document.getElementById('countryMenu');
    const searchInput = document.getElementById('countrySearch');
    const options = document.querySelectorAll('#signupCountryDropdown .country-option');

    const setSelectedFlag = (code) => {
      if (!selectedFlagImg) return;
      const c = String(code || '').trim().toLowerCase();
      if (!c) {
        selectedFlagImg.removeAttribute('src');
        return;
      }
      selectedFlagImg.src = `https://flagcdn.com/20x15/${c}.png`;
    };

    const syncCodeFromSelect = () => {
      if (!countrySelect || !countryCodeInput) return;
      const opt = countrySelect.options[countrySelect.selectedIndex];
      const code = (opt && opt.dataset && opt.dataset.code) ? String(opt.dataset.code) : '';
      const clean = code.trim();
      countryCodeInput.value = clean;
      setSelectedFlag(clean);
    };

    function openMenu() {
      if (!menu) return;
      menu.hidden = false;
      menu.classList.remove('d-none');

      if (searchInput) {
        searchInput.value = '';
        dropdown.querySelectorAll('.country-option').forEach(opt => opt.classList.remove('d-none'));
        setTimeout(() => searchInput.focus(), 0);
      }
    }

    function closeMenu() {
      if (!menu) return;
      menu.hidden = true;
      menu.classList.add('d-none');
    }

    closeMenu();

    if (selectedBtn && menu && dropdown) {
      selectedBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (menu.classList.contains('d-none')) openMenu();
        else closeMenu();
      });

      document.addEventListener('click', (e) => {
        if (!dropdown.contains(e.target)) closeMenu();
      });
    }

    options.forEach(opt => {
      opt.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        const value = opt.dataset.value || '';
        const code = opt.dataset.code || '';

        if (selectedText) selectedText.textContent = value;

        if (countrySelect) {
          countrySelect.value = value;
          Array.from(countrySelect.options).forEach(o => (o.selected = (o.value === value)));
          countrySelect.dispatchEvent(new Event('change', { bubbles: true }));
        }

        const clean = String(code).trim();
        if (countryCodeInput) countryCodeInput.value = clean;
        setSelectedFlag(clean);

        options.forEach(o => o.classList.remove('bg-primary', 'bg-opacity-10'));
        opt.classList.add('bg-primary', 'bg-opacity-10');

        closeMenu();
      });
    });

    if (searchInput) {
      const filterCountries = () => {
        const term = (searchInput.value || '').toLowerCase().trim();
        const liveOptions = dropdown.querySelectorAll('.country-option');

        liveOptions.forEach(opt => {
          const nameEl = opt.querySelector('.country-name');
          const name = (nameEl ? nameEl.textContent : opt.dataset.value || opt.textContent || '')
            .toLowerCase()
            .trim();

          const shouldHide = term.length > 0 && !name.includes(term);
          opt.classList.toggle('d-none', shouldHide);
        });
      };

      searchInput.addEventListener('input', filterCountries);
      searchInput.addEventListener('keyup', filterCountries);
      searchInput.addEventListener('click', (e) => e.stopPropagation());
    }

    if (countrySelect && countryCodeInput) {
      syncCodeFromSelect();
      countrySelect.addEventListener('change', syncCodeFromSelect);
    }

    // -----------------------------
    // Password strength (Bootstrap progress)
    // -----------------------------
    const passwordInput = document.getElementById('password');
    const strengthFill = document.getElementById('strengthFill');
    const strengthText = document.getElementById('strengthText');

    if (strengthFill) {
      strengthFill.style.width = '0%';
    }

    if (passwordInput && strengthFill && strengthText) {
      passwordInput.addEventListener('input', function() {
        const password = this.value;
        let strength = 0;

        if (password.length >= 6) strength++;
        if (password.length >= 8) strength++;
        if (/[a-z]/.test(password)) strength++;
        if (/[A-Z]/.test(password)) strength++;
        if (/[0-9]/.test(password)) strength++;
        if (/[^A-Za-z0-9]/.test(password)) strength++;

        const pct = Math.min((strength / 6) * 100, 100);
        strengthFill.style.width = pct + '%';

        strengthFill.classList.remove('bg-danger', 'bg-warning', 'bg-success');

        let label = 'Weak';
        if (strength >= 5) { label = 'Strong'; strengthFill.classList.add('bg-success'); }
        else if (strength >= 3) { label = 'Good'; strengthFill.classList.add('bg-warning'); }
        else { label = 'Weak'; strengthFill.classList.add('bg-danger'); }

        strengthText.textContent = label;
      });

      strengthFill.classList.add('bg-danger');
    }

    // Toggle password visibility
    document.querySelectorAll('.toggle-password').forEach(button => {
      const targetId = button.getAttribute('data-target');
      const input = document.getElementById(targetId);
      if (!input) return;

      button.addEventListener('click', () => {
        input.type = (input.type === 'password') ? 'text' : 'password';
      });
    });

    // Basic validation (Bootstrap is-invalid)
    const form = document.getElementById('businessSignupForm');
    if (form) {
      form.addEventListener('submit', function(e) {
        let isValid = true;
        let firstErrorField = null;

        const requiredFields = this.querySelectorAll('[required]');
        requiredFields.forEach(field => {
          const isRadio = field.type === 'radio';
          const isCheckbox = field.type === 'checkbox';
          let valid = false;

          if (isRadio) {
            const group = this.querySelectorAll(`input[name="${field.name}"]`);
            valid = Array.from(group).some(r => r.checked);
          } else if (isCheckbox) {
            valid = field.checked;
          } else {
            valid = field.value && field.value.trim() !== '';
          }

          if (!valid) {
            isValid = false;
            if (!firstErrorField) firstErrorField = field;
            if (!isRadio && !isCheckbox) field.classList.add('is-invalid');
          } else {
            if (!isRadio && !isCheckbox) field.classList.remove('is-invalid');
          }
        });

        if (!isValid) {
          e.preventDefault();
          if (firstErrorField) {
            (firstErrorField.closest('.btn') || firstErrorField).scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }
      });
    }
  });
</script>