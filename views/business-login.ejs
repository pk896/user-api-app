<!-- views/business-login.ejs -->

<div class="min-vh-100 brand-page-bg pt-0 pb-0 pt-lg-4 pb-lg-4">
  <div class="container-fluid px-0 px-md-1">
    <div class="col-12 col-lg-10 col-xl-9 mx-lg-auto px-0" id="businessLoginPageBlock">

      <div class="row g-0 g-lg-4 align-items-stretch justify-content-center">

        <!-- Left: Hero -->
        <div class="d-none d-lg-block col-lg-6">
          <section class="h-100 shadow-sm px-3 px-md-4 py-4 text-white brand-hero">
            <div class="d-flex flex-column h-100">

              <!-- Brand -->
              <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 p-3 brand-hero-icon">
                  <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                    <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10
                      10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5
                      1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                  </svg>
                </div>
                <div>
                  <div class="small text-white-50">Business Suite</div>
                  <div class="h5 mb-0 fw-bold text-white">Unicoporate</div>
                </div>
              </div>

              <!-- Copy -->
              <div class="mb-4">
                <h2 class="h4 mb-2 fw-bold text-white">Business Login</h2>
                <p class="mb-0 text-white-50">
                  Sign in to manage products, track sales, and connect with other verified businesses worldwide.
                </p>
              </div>

              <!-- Pills -->
              <div class="d-flex flex-column gap-3 mb-4">
                <div class="d-flex gap-3 p-3 rounded-3 border brand-feature-card">
                  <span class="badge rounded-pill brand-badge-light">●</span>
                  <div>
                    <div class="fw-semibold text-white">Product Management</div>
                    <div class="small text-white-50">Update inventory and pricing in seconds.</div>
                  </div>
                </div>

                <div class="d-flex gap-3 p-3 rounded-3 border brand-feature-card">
                  <span class="badge rounded-pill brand-badge-light">●</span>
                  <div>
                    <div class="fw-semibold text-white">Analytics Dashboard</div>
                    <div class="small text-white-50">See sales and growth at a glance.</div>
                  </div>
                </div>

                <div class="d-flex gap-3 p-3 rounded-3 border brand-feature-card">
                  <span class="badge rounded-pill brand-badge-light">●</span>
                  <div>
                    <div class="fw-semibold text-white">Business Network</div>
                    <div class="small text-white-50">Work with trusted partners globally.</div>
                  </div>
                </div>
              </div>

              <!-- Footer CTA -->
              <div class="mt-auto d-flex flex-column flex-sm-row align-items-sm-center justify-content-sm-between gap-2">
                <div class="small text-white-50">New to Unicoporate?</div>
                <a href="/business/signup" class="btn btn-light fw-semibold brand-purple-text">
                  <span class="me-1 d-inline-flex align-items-center">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                    </svg>
                  </span>
                  Create business account
                </a>
              </div>

            </div>
          </section>
        </div>

        <!-- Right: Login Form -->
        <div class="col-12 col-lg-6 col-xl-5" id="businessLoginFormBlock">
          <section class="h-100 shadow-sm px-3 px-md-4 py-4 rounded-0 rounded-lg-3 <%= themeCss && themeCss.includes('dark') ? 'bg-dark text-light brand-dark-panel' : 'bg-white' %>">
            <header class="mb-3">
              <h2 class="h4 mb-1 fw-bold brand-purple-text">Sign in to your business</h2>
              <p class="mb-0 <%= themeCss && themeCss.includes('dark') ? 'text-light opacity-75' : 'text-secondary' %>">
                Use your registered business email and password.
              </p>
            </header>

            <!-- Flash from server -->
            <div class="mb-3">
              <%- include('partials/massage', { success, error, info, warning, errors }) %>
            </div>

            <form
              id="businessLoginForm"
              action="/business/login"
              method="POST"
              autocomplete="on"
              novalidate
            >
              <!-- Email -->
              <div class="mb-3">
                <label for="email" class="form-label fw-semibold brand-purple-text">
                  Business Email <span class="text-danger">*</span>
                </label>

                <div class="input-group">
                  <span class="input-group-text brand-input-icon <%= themeCss && themeCss.includes('dark') ? 'brand-input-icon-dark' : '' %>">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path fill="currentColor"
                        d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2
                           2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8l8
                           5 8-5v10zm-8-7L4 6h16l-8 5z" />
                    </svg>
                  </span>
                  <input
                    id="email"
                    type="email"
                    name="email"
                    class="form-control brand-focus"
                    placeholder="admin@company.com"
                    autocomplete="username"
                    inputmode="email"
                    required
                  />
                </div>

                <div class="form-text">Enter your registered business email.</div>
              </div>

              <!-- Password -->
              <div class="mb-3">
                <label for="password" class="form-label fw-semibold brand-purple-text">
                  Password <span class="text-danger">*</span>
                </label>

                <div class="input-group">
                  <span class="input-group-text brand-input-icon <%= themeCss && themeCss.includes('dark') ? 'brand-input-icon-dark' : '' %>">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path fill="currentColor"
                        d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7
                           6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2
                           2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6
                           9c-1.1 0-2-.9-2-2s.9-2 2-2
                           2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71
                           1.39-3.1 3.1-3.1 1.71 0 3.1 1.39
                           3.1 3.1v2z" />
                    </svg>
                  </span>
                  <input
                    id="password"
                    type="password"
                    name="password"
                    class="form-control brand-focus"
                    placeholder="Enter your password"
                    autocomplete="current-password"
                    required
                  />
                  <button
                    id="togglePassword"
                    type="button"
                    class="btn btn-outline-secondary"
                    aria-label="Toggle password visibility"
                  >
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path fill="currentColor"
                        d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73
                           4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12
                           17c-2.76 0-5-2.24-5-5s2.24-5
                           5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3
                           1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" />
                    </svg>
                  </button>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-2">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="remember" name="remember" />
                    <label class="form-check-label" for="remember">Remember me</label>
                  </div>

                  <a href="/business/password/forgot" class="fw-semibold text-decoration-none brand-link">
                    Forgot password?
                  </a>
                </div>
              </div>

              <!-- Submit -->
              <button type="submit" class="btn w-100 py-2 fw-semibold text-white brand-btn-success border-0">
                <span class="me-2 d-inline-flex align-items-center">
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <path fill="currentColor" d="M10 17v-3H3v-4h7V7l5 5-5 5z" />
                  </svg>
                </span>
                Sign In
              </button>

              <!-- Social -->
              <div class="mt-4">
                <div class="d-flex align-items-center gap-2 small <%= themeCss && themeCss.includes('dark') ? 'text-light opacity-75' : 'text-body-secondary' %>">
                  <div class="flex-grow-1 border-top"></div>
                  <span>Or continue with</span>
                  <div class="flex-grow-1 border-top"></div>
                </div>

                <div class="row g-2 mt-2">
                  <div class="col-12 col-md-6">
                    <button type="button" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                        <path fill="#EA4335"
                              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92
                                 c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57
                                 c2.08-1.92 3.28-4.74 3.28-8.09z" />
                        <path fill="#34A853"
                              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23
                                 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99
                                 20.53 7.7 23 12 23z" />
                        <path fill="#FBBC05"
                              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43
                                 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                        <path fill="#4285F4"
                              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97
                                 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84C6.71 7.31
                                 9.14 5.38 12 5.38z" />
                      </svg>
                      <span>Google</span>
                    </button>
                  </div>

                  <div class="col-12 col-md-6 d-block d-md-none">
                    <a href="/business/signup" class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2">
                      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                        <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                      </svg>
                      <span>Create business account</span>
                    </a>
                  </div>
                </div>
              </div>

            </form>
          </section>
        </div>

      </div>

    </div>
  </div>
</div>

<style nonce="<%= nonce %>">
  .brand-page-bg {
    background-color: #f8f5ff;
  }

  @media (max-width: 767.98px) {
    #businessLoginPageBlock {
      padding-left: 0 !important;
      padding-right: 0 !important;
      width: auto;
      max-width: none;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }

    #businessLoginFormBlock {
      padding-left: 0 !important;
      padding-right: 0 !important;
    }

    #businessLoginFormBlock > section {
      border-radius: 0 !important;
    }
  }

  .brand-purple-text {
    color: #7C3AED !important;
  }

  .brand-link {
    color: #7C3AED !important;
  }

  .brand-link:hover,
  .brand-link:focus {
    color: #6d28d9 !important;
  }

  .brand-hero {
    background: linear-gradient(135deg, #7C3AED 0%, #6d28d9 100%);
    border-bottom: 4px solid #22C55E;
  }

  .brand-hero-icon {
    background-color: rgba(255, 255, 255, 0.18);
  }

  .brand-feature-card {
    background-color: rgba(255, 255, 255, 0.10);
    border-color: rgba(255, 255, 255, 0.18) !important;
  }

  .brand-badge-light {
    background-color: #dcfce7 !important;
    color: #15803d !important;
  }

  .brand-input-icon {
    background-color: rgba(124, 58, 237, 0.08);
    color: #7C3AED;
    border-color: var(--bs-border-color);
  }

  .brand-input-icon-dark {
    background-color: rgba(124, 58, 237, 0.18);
    color: #c4b5fd;
  }

  .brand-focus:focus {
    border-color: #7C3AED;
    box-shadow: 0 0 0 0.25rem rgba(124, 58, 237, 0.18);
  }

  .brand-btn-success {
    background-color: #22C55E !important;
  }

  .brand-btn-success:hover,
  .brand-btn-success:focus {
    background-color: #16a34a !important;
  }

  .brand-dark-panel {
    border: 1px solid rgba(124, 58, 237, 0.18);
  }
</style>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', function () {
  console.log('✅ Business login page loaded');

  const form = document.getElementById('businessLoginForm');
  const emailInput = document.getElementById('email');
  const passwordInput = document.getElementById('password');
  const togglePassword = document.getElementById('togglePassword');
  const rememberCheckbox = document.getElementById('remember');

  // toggle password
  if (togglePassword && passwordInput) {
    togglePassword.addEventListener('click', function () {
      const isPassword = passwordInput.type === 'password';
      passwordInput.type = isPassword ? 'text' : 'password';
    });
  }

  // basic client validation (just highlight, server still validates)
  if (form && emailInput && passwordInput) {
    form.addEventListener('submit', function (e) {
      let ok = true;

      // ✅ Bootstrap validation classes
      emailInput.classList.remove('is-invalid');
      passwordInput.classList.remove('is-invalid');

      const emailVal = (emailInput.value || '').trim();
      const passVal  = (passwordInput.value || '').trim();

      // ✅ FIXED REGEX (single backslashes)
      if (!emailVal || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
        ok = false;
        emailInput.classList.add('is-invalid');
      }

      if (!passVal) {
        ok = false;
        passwordInput.classList.add('is-invalid');
      }

      if (!ok) {
        e.preventDefault();
        e.stopPropagation();
      }
    });
  }

  // remember me – save email in localStorage
  if (emailInput && rememberCheckbox) {
    const savedFlag = localStorage.getItem('businessRemember') === '1';
    const savedEmail = localStorage.getItem('businessEmail') || '';

    if (savedFlag && savedEmail) {
      emailInput.value = savedEmail;
      rememberCheckbox.checked = true;
    }

    if (form) {
      form.addEventListener('submit', function () {
        if (rememberCheckbox.checked && emailInput.value) {
          localStorage.setItem('businessRemember', '1');
          localStorage.setItem('businessEmail', emailInput.value);
        } else {
          localStorage.removeItem('businessRemember');
          localStorage.removeItem('businessEmail');
        }
      });
    }
  }
});
</script>