<!-- views/business-login.ejs -->
<%
  const NONCE = typeof nonce !== 'undefined' ? nonce : '';
  const IS_DARK = typeof themeCss !== 'undefined' && themeCss && themeCss.includes('dark');

  const heroBg =
    (typeof shopHeaderImage !== 'undefined' && shopHeaderImage && shopHeaderImage.image)
      ? shopHeaderImage.image
      : '/images/branding/logo-unincorporate.png';
%>

<!-- Spinner Start -->
<div
  id="spinner"
  class="show fade bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center"
  style="z-index: 9999;"
>
  <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
    <span class="visually-hidden">Loading...</span>
  </div>
</div>
<!-- Spinner End -->

<style nonce="<%= NONCE %>">
  .business-login-full-bleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  .business-login-hero {
    background:
      linear-gradient(rgba(124, 58, 237, .68), rgba(124, 58, 237, .80)),
      url('<%= heroBg %>') center / cover no-repeat;
  }

  .business-login-focus:focus {
    border-color: #7C3AED;
    box-shadow: 0 0 0 .25rem rgba(124, 58, 237, .18);
  }
</style>

<div class="business-login-full-bleed bg-light">
  <section class="business-login-hero min-vh-100 py-4 py-lg-5">
    <div class="container-fluid px-3 px-md-5">
      <div class="row g-4 align-items-center justify-content-center">

        <div class="col-12 col-lg-6 text-white">
          <span class="badge bg-success rounded-pill px-3 py-2 mb-3">
            Business Suite
          </span>

          <h1 class="display-5 fw-bold mb-3">
            Business Login
          </h1>

          <p class="lead mb-4">
            Sign in to manage products, track sales, and connect with other verified businesses worldwide.
          </p>

          <div class="row g-3">
            <div class="col-12">
              <div class="bg-white bg-opacity-10 border border-white border-opacity-25 rounded-4 p-3">
                <div class="fw-bold">Product Management</div>
                <div class="small opacity-75">Update inventory and pricing in seconds.</div>
              </div>
            </div>

            <div class="col-12">
              <div class="bg-white bg-opacity-10 border border-white border-opacity-25 rounded-4 p-3">
                <div class="fw-bold">Analytics Dashboard</div>
                <div class="small opacity-75">See sales and growth at a glance.</div>
              </div>
            </div>

            <div class="col-12">
              <div class="bg-white bg-opacity-10 border border-white border-opacity-25 rounded-4 p-3">
                <div class="fw-bold">Business Network</div>
                <div class="small opacity-75">Work with trusted partners globally.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-lg-5">
          <section class="shadow-sm rounded-4 p-3 p-md-4 <%= IS_DARK ? 'bg-dark text-light' : 'bg-white' %>">
            <header class="mb-3">
              <h2 class="h4 fw-bold text-primary mb-1">
                Sign in to your business
              </h2>
              <p class="mb-0 <%= IS_DARK ? 'text-light opacity-75' : 'text-secondary' %>">
                Use your registered business email and password.
              </p>
            </header>

            <div class="mb-3">
              <%- include('partials/massage', { success, error, info, warning, errors }) %>
            </div>

            <form
              id="businessLoginForm"
              action="/business/login"
              method="POST"
              autocomplete="on"
              novalidate
            >
              <div class="mb-3">
                <label for="email" class="form-label fw-semibold text-primary">
                  Business Email <span class="text-danger">*</span>
                </label>

                <input
                  id="email"
                  type="email"
                  name="email"
                  class="form-control py-3 business-login-focus"
                  placeholder="admin@company.com"
                  autocomplete="username"
                  inputmode="email"
                  required
                >

                <div class="form-text">
                  Enter your registered business email.
                </div>
              </div>

              <div class="mb-3">
                <label for="password" class="form-label fw-semibold text-primary">
                  Password <span class="text-danger">*</span>
                </label>

                <div class="input-group">
                  <input
                    id="password"
                    type="password"
                    name="password"
                    class="form-control py-3 business-login-focus"
                    placeholder="Enter your password"
                    autocomplete="current-password"
                    required
                  >

                  <button
                    id="togglePassword"
                    type="button"
                    class="btn btn-outline-secondary px-3"
                    aria-label="Toggle password visibility"
                  >
                    Show
                  </button>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-2">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="remember" name="remember">
                    <label class="form-check-label" for="remember">Remember me</label>
                  </div>

                  <a href="/business/password/forgot" class="fw-semibold text-decoration-none text-primary">
                    Forgot password?
                  </a>
                </div>
              </div>

              <button
                id="businessLoginSubmitBtn"
                type="submit"
                class="btn btn-success w-100 rounded-pill py-3 fw-semibold d-flex align-items-center justify-content-center gap-2"
              >
                <span
                  id="businessLoginSpinner"
                  class="spinner-border spinner-border-sm d-none"
                  aria-hidden="true"
                ></span>
                <span id="businessLoginSubmitText">Sign In</span>
              </button>

              <div class="text-center mt-4">
                <span class="<%= IS_DARK ? 'text-light opacity-75' : 'text-secondary' %>">
                  New to Unicoporate?
                </span>
                <a href="/business/signup" class="fw-semibold text-decoration-none text-primary">
                  Create business account
                </a>
              </div>
            </form>
          </section>
        </div>

      </div>
    </div>
  </section>
</div>

<script nonce="<%= NONCE %>">
document.addEventListener('DOMContentLoaded', function () {
  const form = document.getElementById('businessLoginForm');
  const emailInput = document.getElementById('email');
  const passwordInput = document.getElementById('password');
  const togglePassword = document.getElementById('togglePassword');
  const rememberCheckbox = document.getElementById('remember');

  const submitBtn = document.getElementById('businessLoginSubmitBtn');
  const submitSpinner = document.getElementById('businessLoginSpinner');
  const submitText = document.getElementById('businessLoginSubmitText');

  if (togglePassword && passwordInput) {
    togglePassword.addEventListener('click', function () {
      const isPassword = passwordInput.type === 'password';
      passwordInput.type = isPassword ? 'text' : 'password';
      togglePassword.textContent = isPassword ? 'Hide' : 'Show';
    });
  }

  if (form && emailInput && passwordInput) {
    form.addEventListener('submit', function (event) {
      let ok = true;

      emailInput.classList.remove('is-invalid');
      passwordInput.classList.remove('is-invalid');

      const emailVal = String(emailInput.value || '').trim();
      const passVal = String(passwordInput.value || '').trim();

      if (!emailVal || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
        ok = false;
        emailInput.classList.add('is-invalid');
      }

      if (!passVal) {
        ok = false;
        passwordInput.classList.add('is-invalid');
      }

      if (!ok) {
        event.preventDefault();
        event.stopPropagation();
        return;
      }

      if (submitBtn && submitSpinner && submitText) {
        submitBtn.disabled = true;
        submitSpinner.classList.remove('d-none');
        submitText.textContent = 'Signing in...';
      }
    });
  }

  if (emailInput && rememberCheckbox) {
    const savedFlag = localStorage.getItem('businessRemember') === '1';
    const savedEmail = localStorage.getItem('businessEmail') || '';

    if (savedFlag && savedEmail) {
      emailInput.value = savedEmail;
      rememberCheckbox.checked = true;
    }

    if (form) {
      form.addEventListener('submit', function () {
        if (rememberCheckbox.checked && emailInput.value) {
          localStorage.setItem('businessRemember', '1');
          localStorage.setItem('businessEmail', emailInput.value);
        } else {
          localStorage.removeItem('businessRemember');
          localStorage.removeItem('businessEmail');
        }
      });
    }
  }

  const pageSpinner = document.getElementById('spinner');

  if (pageSpinner) {
    window.addEventListener('load', function () {
      setTimeout(function () {
        pageSpinner.classList.remove('show');

        setTimeout(function () {
          pageSpinner.classList.add('d-none');
        }, 300);
      }, 700);
    });
  }
});
</script>