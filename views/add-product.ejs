<!-- views/add-product.ejs -->
<!-- Spinner Start -->
<div
  id="spinner"
  class="show fade bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center"
  style="z-index: 9999;"
>
  <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
    <span class="visually-hidden">Loading...</span>
  </div>
</div>
<!-- Spinner End -->

<%
  const form = oldInput || {};
  const errors = fieldErrors || {};

  function valueOf(name, fallback = '') {
    const value = form[name];
    return value === undefined || value === null ? fallback : value;
  }

  function hasError(name) {
    return !!errors[name];
  }
%>

<div class="container-fluid py-4 bg-dark min-vh-100">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-xl-10">
        <div class="card shadow-lg border-0 overflow-hidden">
          <div class="card-body p-3 p-md-4 p-lg-5">
            <div class="mb-4">
              <span class="badge bg-primary-subtle text-primary border border-primary-subtle text-uppercase small">
                Business · Product Setup
              </span>
              <h1 class="h3 mt-3 mb-2 text-primary">➕ Add New Product</h1>
              <p class="text-muted mb-0">
                Capture a clean product card for your shop in under a minute.
              </p>
            </div>

            <div id="toast-container" class="position-fixed top-0 end-0 p-3" style="z-index: 1080;"></div>

            <% if (Array.isArray(error) && error.length) { %>
              <div class="alert alert-danger border-0 shadow-sm mt-3" role="alert">
                <div class="fw-semibold mb-1 text-primary">Please fix the highlighted fields</div>
                <div><%= error[0] %></div>
              </div>
            <% } %>

            <% if (Array.isArray(success) && success.length) { %>
              <div class="alert alert-success border-0 shadow-sm mt-3" role="alert">
                <div><%= success[0] %></div>
              </div>
            <% } %>

            <% if (!business) { %>
              <div class="alert alert-warning border-0 shadow-sm mb-0">
                <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center gap-3">
                  <div class="fs-4">⚠️</div>
                  <div class="flex-grow-1">
                    <h2 class="h6 mb-1">Business account required</h2>
                    <p class="mb-0">You need a business account to add products.</p>
                  </div>
                  <a href="/business/login" class="btn btn-primary pf-btn-primary">Login to continue</a>
                </div>
              </div>
            <% } else { %>
              <form id="addProductForm" action="/products/add" method="POST" enctype="multipart/form-data" novalidate>
                <div class="row g-4">
                  <!-- LEFT COLUMN -->
                  <div class="col-12 col-lg-6">
                    <div class="row g-3">
                      <div class="col-12">
                        <label class="form-label fw-semibold" for="productCustomId">
                          CustomID <span class="badge text-bg-light border ms-1">required</span>
                        </label>
                        <input
                          id="productCustomId"
                          type="text"
                          name="id"
                          placeholder="e.g. PROD-2026A1"
                          required
                          minlength="10"
                          maxlength="36"
                          pattern="^(?=.*[A-Za-z])(?=.*\d)[A-Za-z0-9-]{10,36}$"
                          title="Custom ID must be 10-36 characters, include letters and numbers, and use only letters, numbers, or hyphens."
                          value="<%= valueOf('id') %>"
                          class="form-control pf-input <%= hasError('id') ? 'is-invalid' : '' %>"
                        />
                        <div class="form-text">Custom ID must be unique, 10-36 characters, include both letters and numbers, and may use hyphens.</div>
                        <% if (hasError('id')) { %>
                          <div class="invalid-feedback d-block"><%= errors.id %></div>
                        <% } %>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="productName">
                          Product Name <span class="text-danger">*</span>
                        </label>
                        <input
                          id="productName"
                          type="text"
                          name="name"
                          placeholder="e.g., Orange Juice 1L"
                          required
                          value="<%= valueOf('name') %>"
                          class="form-control pf-input <%= hasError('name') ? 'is-invalid' : '' %>"
                        />
                        <% if (hasError('name')) { %>
                          <div class="invalid-feedback d-block"><%= errors.name %></div>
                        <% } %>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="productPrice">
                          Price <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                          <span class="input-group-text">R</span>
                          <input
                            id="productPrice"
                            type="number"
                            name="price"
                            placeholder="29.99"
                            step="0.01"
                            min="0"
                            required
                            value="<%= valueOf('price') %>"
                            class="form-control pf-input <%= hasError('price') ? 'is-invalid' : '' %>"
                          />
                        </div>
                        <div class="form-text">Enter the selling price you want buyers to see.</div>
                        <% if (hasError('price')) { %>
                          <div class="invalid-feedback d-block"><%= errors.price %></div>
                        <% } %>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="productStock">Stock Quantity</label>
                        <input
                          id="productStock"
                          type="number"
                          name="stock"
                          placeholder="100"
                          min="0"
                          required
                          value="<%= valueOf('stock') %>"
                          class="form-control pf-input"
                        />
                        <div class="form-text">Required. Use 0 for out of stock. You can update stock anytime in Edit Product.</div>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="categorySelect">Category</label>
                        <select id="categorySelect" name="category" class="form-select pf-input pf-select">
                          <option value="">Choose category</option>
                          <% if (Array.isArray(CATEGORIES)) { %>
                            <% CATEGORIES.forEach(function(c){ %>
                              <option value="<%= c.value %>" <%= valueOf('category') === c.value ? 'selected' : '' %>><%= c.label %></option>
                            <% }) %>
                          <% } %>
                        </select>
                        <div class="form-text">Used for filters on the shopping page.</div>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="defaultColor">Default Color</label>
                        <input
                          id="defaultColor"
                          type="text"
                          name="color"
                          placeholder="e.g., Orange / Black / Blue"
                          value="<%= valueOf('color') %>"
                          class="form-control pf-input"
                        />
                        <div class="form-text">Optional fallback color. If empty, the first variant color will be used.</div>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="productKeywords">Search Keywords</label>
                        <input
                          id="productKeywords"
                          type="text"
                          name="keywords"
                          placeholder="e.g., iphone, apple phone, smartphone, ios"
                          value="<%= valueOf('keywords') %>"
                          class="form-control pf-input"
                        />
                        <div class="form-text">Optional. Separate keywords with commas so buyers can find this product in search.</div>
                      </div>
                    </div>
                  </div>

                  <!-- RIGHT COLUMN -->
                  <div class="col-12 col-lg-6">
                    <div class="row g-3">
                      <div class="col-12">
                        <label class="form-label fw-semibold" for="defaultSize">Default Size</label>
                        <input
                          id="defaultSize"
                          type="text"
                          name="size"
                          placeholder="e.g., 1L Bottle / M / Size 7"
                          value="<%= valueOf('size') %>"
                          class="form-control pf-input"
                        />
                        <div class="form-text">Optional fallback size. If empty, the first variant size will be used.</div>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="productQuality">Quality / Grade</label>
                        <select id="productQuality" name="quality" class="form-select pf-input pf-select">
                          <option value="">Select quality...</option>
                          <option value="Premium" <%= valueOf('quality') === 'Premium' ? 'selected' : '' %>>Premium</option>
                          <option value="Standard" <%= valueOf('quality') === 'Standard' ? 'selected' : '' %>>Standard</option>
                          <option value="Economy" <%= valueOf('quality') === 'Economy' ? 'selected' : '' %>>Economy</option>
                          <option value="Wholesale" <%= valueOf('quality') === 'Wholesale' ? 'selected' : '' %>>Wholesale</option>
                        </select>
                        <div class="form-text">Pick the quality level buyers should see.</div>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold">
                          Made In <span class="text-danger">*</span>
                        </label>

                        <div class="pf-country-dropdown position-relative" id="madeDropdown">
                          <div
                            class="pf-country-selected form-control d-flex align-items-center justify-content-between gap-2 <%= hasError('made') ? 'is-invalid' : '' %>"
                            id="madeSelected"
                            tabindex="0"
                            role="button"
                            aria-haspopup="listbox"
                            aria-expanded="false"
                          >
                            <span class="pf-country-selected-left d-flex align-items-center gap-2 min-w-0">
                              <img id="madeSelectedFlagImg" class="pf-flag-img d-none" alt="" aria-hidden="true" />
                              <span id="madeSelectedText" class="text-truncate"><%= valueOf('made') || 'Select country' %></span>
                            </span>
                            <span class="pf-country-arrow small">▾</span>
                          </div>

                          <div class="pf-country-menu dropdown-menu w-100 mt-1 p-0 shadow-sm" id="madeMenu" role="listbox">
                            <div class="p-2 border-bottom">
                              <input
                                type="text"
                                id="madeSearch"
                                placeholder="Search country..."
                                autocomplete="off"
                                class="form-control form-control-sm pf-country-search-input"
                              />
                            </div>

                            <div class="pf-country-list list-group list-group-flush" id="madeList">
                              <% if (Array.isArray(COUNTRIES)) { %>
                                <% COUNTRIES.forEach(function(c) { %>
                                  <button
                                    type="button"
                                    class="pf-country-option list-group-item list-group-item-action d-flex align-items-center gap-2"
                                    data-value="<%= c.name %>"
                                    data-code="<%= c.code %>"
                                    data-flag="<%= c.flag %>"
                                    data-search="<%= String(c.name || '').toLowerCase() %>"
                                    role="option"
                                  >
                                    <img
                                      class="pf-flag-img"
                                      src="https://flagcdn.com/20x15/<%= String(c.code || '').toLowerCase() %>.png"
                                      alt=""
                                      loading="lazy"
                                    />
                                    <span class="pf-country-name text-truncate"><%= c.name %></span>
                                  </button>
                                <% }) %>
                              <% } %>
                            </div>
                          </div>

                          <input type="hidden" name="made" id="made" value="<%= valueOf('made') %>" required />
                          <input type="hidden" name="madeCode" id="madeCode" value="<%= valueOf('madeCode') %>" />
                        </div>

                        <div class="form-text">Search and select a country (e.g., South Africa, Nigeria, United States…)</div>
                        <% if (hasError('made')) { %>
                          <div class="invalid-feedback d-block"><%= errors.made %></div>
                        <% } %>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="manufacturer">Manufacturer</label>
                        <input
                          id="manufacturer"
                          type="text"
                          name="manufacturer"
                          placeholder="e.g., PK's Engineering"
                          value="<%= valueOf('manufacturer') %>"
                          class="form-control pf-input"
                        />
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="typeSelect">
                          Matching Type <span class="text-danger">*</span>
                        </label>
                        <select id="typeSelect" name="type" class="form-select pf-input pf-select <%= hasError('type') ? 'is-invalid' : '' %>" required>
                          <option value="">Choose type</option>
                          <% if (Array.isArray(PRODUCT_TYPES)) { %>
                            <% PRODUCT_TYPES.forEach(function(t){ %>
                              <option value="<%= t.value %>" <%= valueOf('type') === t.value ? 'selected' : '' %>><%= t.label %></option>
                            <% }) %>
                          <% } %>
                        </select>
                        <div class="form-text">
                          Use <strong>clothes</strong> or <strong>shoes</strong> to enable size + color variants on the shop page.
                        </div>
                        <% if (hasError('type')) { %>
                          <div class="invalid-feedback d-block"><%= errors.type %></div>
                        <% } %>
                      </div>

                      <div class="col-12">
                        <label class="form-label fw-semibold" for="description">Description</label>
                        <textarea
                          id="description"
                          name="description"
                          rows="3"
                          placeholder="Short description buyers will see (features, highlights, etc.)"
                          maxlength="500"
                          class="form-control pf-textarea"
                        ><%= valueOf('description') %></textarea>
                        <div class="form-text">Max 500 characters</div>
                      </div>
                    </div>
                  </div>

                  <!-- VARIANTS -->
                  <div class="col-12">
                    <div class="card border rounded-4 shadow-sm">
                      <div class="card-body">
                        <h2 class="h5 text-primary mb-3">Variants & Store Behaviour</h2>

                        <div class="row g-3">
                          <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold" for="productRole">Product Role</label>
                            <select id="productRole" name="role" class="form-select pf-input pf-select">
                              <option value="general" <%= valueOf('role', 'general') === 'general' ? 'selected' : '' %>>General</option>
                              <option value="clothes" <%= valueOf('role') === 'clothes' ? 'selected' : '' %>>Clothes</option>
                              <option value="shoes" <%= valueOf('role') === 'shoes' ? 'selected' : '' %>>Shoes</option>
                              <option value="electronics" <%= valueOf('role') === 'electronics' ? 'selected' : '' %>>Electronics</option>
                              <option value="home" <%= valueOf('role') === 'home' ? 'selected' : '' %>>Home</option>
                              <option value="beauty" <%= valueOf('role') === 'beauty' ? 'selected' : '' %>>Beauty</option>
                              <option value="groceries" <%= valueOf('role') === 'groceries' ? 'selected' : '' %>>Groceries</option>
                            </select>
                            <div class="form-text">Controls how variants behave in the store.</div>
                          </div>

                          <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold" for="variantSizesInput">Variant Sizes</label>
                            <input
                              id="variantSizesInput"
                              type="text"
                              name="sizes"
                              placeholder="e.g., S, M, L or 500ml, 1L"
                              value="<%= valueOf('sizes') %>"
                              class="form-control pf-input <%= hasError('sizes') ? 'is-invalid' : '' %>"
                            />
                            <% if (hasError('sizes')) { %>
                              <div class="invalid-feedback d-block"><%= errors.sizes %></div>
                            <% } %>
                          </div>

                          <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold" for="variantColorsInput">Variant Colors</label>
                            <input
                              id="variantColorsInput"
                              type="text"
                              name="colors"
                              placeholder="e.g., Black, Blue, Red"
                              value="<%= valueOf('colors') %>"
                              class="form-control pf-input <%= hasError('colors') ? 'is-invalid' : '' %>"
                            />
                            <% if (hasError('colors')) { %>
                              <div class="invalid-feedback d-block"><%= errors.colors %></div>
                            <% } %>
                          </div>

                          <div class="col-12">
                            <label class="form-label fw-semibold">Image Per Color</label>

                            <div id="colorImageRows" class="d-flex flex-column gap-2">
                              <div class="pf-color-row row g-2 align-items-center">
                                <div class="col-12 col-md-3">
                                  <input type="text" name="colorImageColors" placeholder="Color" class="form-control pf-input" />
                                </div>
                                <div class="col-12 col-md-4">
                                  <input type="text" name="colorImageUrls" placeholder="Image URL" class="form-control pf-input" />
                                </div>
                                <div class="col-12 col-md-3">
                                  <input type="file" name="colorImageFiles" class="form-control pf-input" />
                                </div>
                                <div class="col-12 col-md-2 d-grid">
                                  <button type="button" class="btn btn-outline-secondary js-remove-color-row">Remove</button>
                                </div>
                              </div>
                            </div>

                            <button type="button" id="addColorImageRow" class="btn btn-outline-primary mt-3">
                              Add another color
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- SHIPPING -->
                  <div class="col-12">
                    <div class="card border rounded-4 shadow-sm">
                      <div class="card-body">
                        <h2 class="h5 text-primary mb-2">📦 Shipping & Package Info</h2>
                        <p class="text-muted small mb-4">
                          <strong>Required.</strong> These measurements are used to calculate Shippo rates at checkout.
                          Enter the size/weight of <strong>ONE item</strong> (without the shipping box).
                        </p>

                        <div class="row g-4">
                          <div class="col-12 col-lg-6">
                            <div class="row g-3">
                              <div class="col-12">
                                <label class="form-label fw-semibold">Item Weight <span class="text-danger">*</span></label>
                                <div class="row g-2">
                                  <div class="col-8">
                                    <input
                                      id="shipWeightValue"
                                      type="number"
                                      name="shipWeightValue"
                                      step="0.001"
                                      min="0"
                                      placeholder="e.g., 0.50"
                                      required
                                      value="<%= valueOf('shipWeightValue') %>"
                                      class="form-control pf-input <%= hasError('shipWeightValue') ? 'is-invalid' : '' %>"
                                    />
                                  </div>
                                  <div class="col-4">
                                    <select name="shipWeightUnit" class="form-select pf-input pf-select">
                                      <option value="kg" <%= valueOf('shipWeightUnit', 'kg') === 'kg' ? 'selected' : '' %>>kg</option>
                                      <option value="g" <%= valueOf('shipWeightUnit') === 'g' ? 'selected' : '' %>>g</option>
                                      <option value="lb" <%= valueOf('shipWeightUnit') === 'lb' ? 'selected' : '' %>>lb</option>
                                      <option value="oz" <%= valueOf('shipWeightUnit') === 'oz' ? 'selected' : '' %>>oz</option>
                                    </select>
                                  </div>
                                </div>
                                <div class="form-text">Weight of ONE item (without box). Example: 0.5 kg.</div>
                                <% if (hasError('shipWeightValue')) { %>
                                  <div class="invalid-feedback d-block"><%= errors.shipWeightValue %></div>
                                <% } %>
                              </div>

                              <div class="col-12">
                                <label class="form-label fw-semibold" for="packagingHint">Packaging Hint (optional)</label>
                                <input
                                  id="packagingHint"
                                  type="text"
                                  name="packagingHint"
                                  placeholder="e.g., small-box / tube / fragile"
                                  value="<%= valueOf('packagingHint') %>"
                                  class="form-control pf-input"
                                />
                                <div class="form-text">Helps auto-packing later. Leave empty if unsure.</div>
                              </div>
                            </div>
                          </div>

                          <div class="col-12 col-lg-6">
                            <div class="row g-3">
                              <div class="col-12">
                                <label class="form-label fw-semibold">Item Dimensions (L × W × H) <span class="text-danger">*</span></label>
                                <div class="row g-2">
                                  <div class="col-6 col-md-3">
                                    <input
                                      id="shipLength"
                                      type="number"
                                      name="shipLength"
                                      step="0.1"
                                      min="0"
                                      placeholder="Length"
                                      required
                                      value="<%= valueOf('shipLength') %>"
                                      class="form-control pf-input <%= hasError('shipLength') ? 'is-invalid' : '' %>"
                                    />
                                  </div>
                                  <div class="col-6 col-md-3">
                                    <input
                                      id="shipWidth"
                                      type="number"
                                      name="shipWidth"
                                      step="0.1"
                                      min="0"
                                      placeholder="Width"
                                      required
                                      value="<%= valueOf('shipWidth') %>"
                                      class="form-control pf-input <%= hasError('shipWidth') ? 'is-invalid' : '' %>"
                                    />
                                  </div>
                                  <div class="col-6 col-md-3">
                                    <input
                                      id="shipHeight"
                                      type="number"
                                      name="shipHeight"
                                      step="0.1"
                                      min="0"
                                      placeholder="Height"
                                      required
                                      value="<%= valueOf('shipHeight') %>"
                                      class="form-control pf-input <%= hasError('shipHeight') ? 'is-invalid' : '' %>"
                                    />
                                  </div>
                                  <div class="col-6 col-md-3">
                                    <select name="shipDimUnit" class="form-select pf-input pf-select">
                                      <option value="cm" <%= valueOf('shipDimUnit', 'cm') === 'cm' ? 'selected' : '' %>>cm</option>
                                      <option value="in" <%= valueOf('shipDimUnit') === 'in' ? 'selected' : '' %>>in</option>
                                    </select>
                                  </div>
                                </div>
                                <div class="form-text">Dimensions of ONE item (without box). Example: 30 × 20 × 10 cm.</div>
                                <% if (hasError('shipLength')) { %>
                                  <div class="invalid-feedback d-block"><%= errors.shipLength %></div>
                                <% } %>
                                <% if (hasError('shipWidth')) { %>
                                  <div class="invalid-feedback d-block"><%= errors.shipWidth %></div>
                                <% } %>
                                <% if (hasError('shipHeight')) { %>
                                  <div class="invalid-feedback d-block"><%= errors.shipHeight %></div>
                                <% } %>
                              </div>

                              <div class="col-12">
                                <label class="form-label fw-semibold d-block">Shipping Flags</label>
                                <div class="d-flex flex-wrap gap-3">
                                  <label class="form-check d-flex align-items-center gap-2 m-0">
                                    <input type="hidden" name="shipSeparately" value="0" />
                                    <input
                                      class="form-check-input mt-0"
                                      type="checkbox"
                                      name="shipSeparately"
                                      value="on"
                                      <%= valueOf('shipSeparately') ? 'checked' : '' %>
                                    />
                                    <span class="form-check-label">Ship separately</span>
                                  </label>

                                  <label class="form-check d-flex align-items-center gap-2 m-0">
                                    <input type="hidden" name="fragile" value="0" />
                                    <input
                                      class="form-check-input mt-0"
                                      type="checkbox"
                                      name="fragile"
                                      value="on"
                                      <%= valueOf('fragile') ? 'checked' : '' %>
                                    />
                                    <span class="form-check-label">Fragile</span>
                                  </label>
                                </div>
                                <div class="form-text">Use if this product must be boxed alone or needs careful handling.</div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- IMAGE -->
                  <div class="col-12">
                    <div class="card border rounded-4 shadow-sm">
                      <div class="card-body">
                        <label class="form-label fw-semibold d-block mb-3">
                          Product Image <span class="text-danger">*</span>
                        </label>

                        <div class="position-relative">
                          <input
                            id="imageFile"
                            type="file"
                            name="imageFile"
                            accept="image/*"
                            required
                            class="position-absolute top-0 start-0 w-100 h-100 opacity-0 <%= hasError('imageFile') ? 'is-invalid' : '' %>"
                            style="cursor:pointer; z-index:2;"
                          />
                          <div class="border border-2 border-dashed rounded-4 p-4 bg-light d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:52px;height:52px;">
                              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M12 5v14m-7-7h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                              </svg>
                            </div>
                            <div>
                              <div class="fw-semibold">Click or tap to upload image</div>
                              <div class="text-muted small">JPG, PNG, GIF or WebP · Max 5MB</div>
                            </div>
                          </div>
                        </div>

                        <% if (hasError('imageFile')) { %>
                          <div class="invalid-feedback d-block"><%= errors.imageFile %></div>
                        <% } %>

                        <div id="previewWrapper" class="mt-3 d-none">
                          <div class="position-relative d-inline-block">
                            <img id="imagePreview" class="img-fluid rounded border" alt="Product preview" style="max-height: 220px;" />
                            <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2 rounded-circle" onclick="removeImage()" aria-label="Remove image">
                              ×
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- STATUS FLAGS -->
                  <div class="col-12">
                    <div class="card border rounded-4 shadow-sm">
                      <div class="card-body">
                        <h2 class="h5 text-primary mb-3">Product Status</h2>

                        <div class="d-flex flex-wrap gap-3">
                          <label class="form-check d-flex align-items-center gap-2 m-0">
                            <input type="hidden" name="isNew" value="0" />
                            <input
                              class="form-check-input mt-0"
                              type="checkbox"
                              name="isNew"
                              value="on"
                              <%= valueOf('isNew') ? 'checked' : '' %>
                            />
                            <span class="form-check-label">New item</span>
                          </label>

                          <label class="form-check d-flex align-items-center gap-2 m-0">
                            <input type="hidden" name="isOnSale" value="0" />
                            <input
                              class="form-check-input mt-0"
                              type="checkbox"
                              name="isOnSale"
                              value="on"
                              <%= valueOf('isOnSale') ? 'checked' : '' %>
                            />
                            <span class="form-check-label">On sale</span>
                          </label>

                          <label class="form-check d-flex align-items-center gap-2 m-0">
                            <input type="hidden" name="isPopular" value="0" />
                            <input
                              class="form-check-input mt-0"
                              type="checkbox"
                              name="isPopular"
                              value="on"
                              <%= valueOf('isPopular') ? 'checked' : '' %>
                            />
                            <span class="form-check-label">Popular</span>
                          </label>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- ACTIONS -->
                  <div class="col-12">
                    <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end">
                      <button type="submit" class="btn btn-primary px-4 pf-btn-primary">
                        <span class="pf-submit-label d-inline-flex align-items-center gap-2">
                          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <path d="M4 8l3 3 5-6M2 8a6 6 0 1112 0A6 6 0 012 8z"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                          <span>Save Product</span>
                        </span>
                        <span class="pf-submit-loading d-none align-items-center gap-2">
                          <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                          <span>Saving...</span>
                        </span>
                      </button>

                      <a href="/products/all" class="btn btn-outline-secondary px-4">
                        <span class="d-inline-flex align-items-center gap-2">
                          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <path d="M10 12L6 8l4-4"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                          <span>Back to Products</span>
                        </span>
                      </a>
                    </div>
                  </div>
                </div>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style nonce="<%= nonce %>">
  .pf-country-menu {
    display: none;
    max-height: 280px;
    overflow: hidden;
    z-index: 1055;
  }

  .pf-country-dropdown.open .pf-country-menu {
    display: block;
  }

  .pf-country-list {
    max-height: 220px;
    overflow-y: auto;
  }

  .pf-country-option.active {
    background-color: rgba(124, 58, 237, 0.08);
    border-color: rgba(124, 58, 237, 0.18);
  }

  .pf-flag-img {
    width: 18px;
    height: 13px;
    object-fit: cover;
    border-radius: 2px;
    flex: 0 0 auto;
  }

  .pf-country-selected {
    cursor: pointer;
    user-select: none;
  }

  .pf-color-row .btn {
    white-space: nowrap;
  }

  @media (max-width: 575.98px) {
    .pf-color-row .btn {
      width: 100%;
    }
  }
</style>

<script nonce="<%= nonce %>">
  (function () {
    const form = document.getElementById('addProductForm');
    if (!form) return;

    const toastContainer = document.getElementById('toast-container');
    const imageInput = document.getElementById('imageFile');
    const previewWrapper = document.getElementById('previewWrapper');
    const imagePreview = document.getElementById('imagePreview');
    const addColorImageRowBtn = document.getElementById('addColorImageRow');
    const colorImageRows = document.getElementById('colorImageRows');

    const madeDropdown = document.getElementById('madeDropdown');
    const madeSelected = document.getElementById('madeSelected');
    const madeMenu = document.getElementById('madeMenu');
    const madeSearch = document.getElementById('madeSearch');
    const madeList = document.getElementById('madeList');
    const madeHidden = document.getElementById('made');
    const madeCodeHidden = document.getElementById('madeCode');
    const madeSelectedText = document.getElementById('madeSelectedText');
    const madeSelectedFlagImg = document.getElementById('madeSelectedFlagImg');

    function showToast(message, type) {
      if (!toastContainer) return;

      const toast = document.createElement('div');
      toast.className = `alert ${type === 'error' ? 'alert-danger' : 'alert-success'} shadow-sm border-0 mb-2`;
      toast.innerHTML = `<div class="small fw-semibold">${message}</div>`;

      toastContainer.appendChild(toast);

      window.setTimeout(function () {
        toast.remove();
      }, 3000);
    }

    function updateImagePreview(file) {
      if (!file || !previewWrapper || !imagePreview) {
        if (previewWrapper) previewWrapper.classList.add('d-none');
        return;
      }

      const reader = new FileReader();
      reader.onload = function (event) {
        imagePreview.src = event.target.result;
        previewWrapper.classList.remove('d-none');
      };
      reader.readAsDataURL(file);
    }

    window.removeImage = function removeImage() {
      if (imageInput) imageInput.value = '';
      if (imagePreview) imagePreview.removeAttribute('src');
      if (previewWrapper) previewWrapper.classList.add('d-none');
    };

    if (imageInput) {
      imageInput.addEventListener('change', function () {
        const file = imageInput.files && imageInput.files[0] ? imageInput.files[0] : null;
        updateImagePreview(file);
      });
    }

    function buildColorRow() {
      const row = document.createElement('div');
      row.className = 'pf-color-row row g-2 align-items-center';
      row.innerHTML = `
        <div class="col-12 col-md-3">
          <input type="text" name="colorImageColors" placeholder="Color" class="form-control pf-input" />
        </div>
        <div class="col-12 col-md-4">
          <input type="text" name="colorImageUrls" placeholder="Image URL" class="form-control pf-input" />
        </div>
        <div class="col-12 col-md-3">
          <input type="file" name="colorImageFiles" class="form-control pf-input" />
        </div>
        <div class="col-12 col-md-2 d-grid">
          <button type="button" class="btn btn-outline-secondary js-remove-color-row">Remove</button>
        </div>
      `;
      return row;
    }

    if (addColorImageRowBtn && colorImageRows) {
      addColorImageRowBtn.addEventListener('click', function () {
        colorImageRows.appendChild(buildColorRow());
      });

      colorImageRows.addEventListener('click', function (event) {
        const removeBtn = event.target.closest('.js-remove-color-row');
        if (!removeBtn) return;

        const rows = colorImageRows.querySelectorAll('.pf-color-row');
        if (rows.length === 1) {
          const inputs = rows[0].querySelectorAll('input');
          inputs.forEach(function (input) {
            input.value = '';
          });
          return;
        }

        const row = removeBtn.closest('.pf-color-row');
        if (row) row.remove();
      });
    }

    function closeCountryDropdown() {
      if (!madeDropdown || !madeSelected) return;
      madeDropdown.classList.remove('open');
      madeSelected.setAttribute('aria-expanded', 'false');
    }

    function openCountryDropdown() {
      if (!madeDropdown || !madeSelected) return;
      madeDropdown.classList.add('open');
      madeSelected.setAttribute('aria-expanded', 'true');
      if (madeSearch) {
        window.setTimeout(function () {
          madeSearch.focus();
        }, 0);
      }
    }

    function setCountry(option) {
      const value = option.getAttribute('data-value') || '';
      const code = option.getAttribute('data-code') || '';

      madeHidden.value = value;
      madeCodeHidden.value = code;
      madeSelectedText.textContent = value || 'Select country';

      if (code) {
        madeSelectedFlagImg.src = `https://flagcdn.com/20x15/${String(code).toLowerCase()}.png`;
        madeSelectedFlagImg.classList.remove('d-none');
      } else {
        madeSelectedFlagImg.removeAttribute('src');
        madeSelectedFlagImg.classList.add('d-none');
      }

      if (madeSelected) {
        madeSelected.classList.remove('is-invalid');
      }

      Array.from(madeList.querySelectorAll('.pf-country-option')).forEach(function (btn) {
        btn.classList.toggle('active', btn === option);
      });

      closeCountryDropdown();
    }

    function filterCountries() {
      if (!madeSearch || !madeList) return;
      const query = String(madeSearch.value || '').trim().toLowerCase();

      Array.from(madeList.querySelectorAll('.pf-country-option')).forEach(function (option) {
        const hay = option.getAttribute('data-search') || '';
        option.classList.toggle('d-none', !!query && !hay.includes(query));
      });
    }

    if (madeSelected) {
      madeSelected.addEventListener('click', function () {
        if (madeDropdown.classList.contains('open')) {
          closeCountryDropdown();
        } else {
          openCountryDropdown();
        }
      });

      madeSelected.addEventListener('keydown', function (event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          if (madeDropdown.classList.contains('open')) {
            closeCountryDropdown();
          } else {
            openCountryDropdown();
          }
        }

        if (event.key === 'Escape') {
          closeCountryDropdown();
        }
      });
    }

    if (madeSearch) {
      madeSearch.addEventListener('input', filterCountries);
      madeSearch.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          closeCountryDropdown();
        }
      });
    }

    if (madeList) {
      madeList.addEventListener('click', function (event) {
        const option = event.target.closest('.pf-country-option');
        if (!option) return;
        setCountry(option);
      });
    }

    document.addEventListener('click', function (event) {
      if (!madeDropdown) return;
      if (!madeDropdown.contains(event.target)) {
        closeCountryDropdown();
      }
    });

    function getFieldMessage(field) {
      if (!field) return 'Please fix the highlighted fields.';

      if (field.name === 'id') {
        return 'Custom ID must be 10-36 characters, include letters and numbers, and use only letters, numbers, or hyphens.';
      }

      if (field.name === 'name') {
        return 'Product name is required.';
      }

      if (field.name === 'price') {
        return 'Please enter a valid price greater than 0.';
      }

      if (field.name === 'imageFile') {
        return 'Product image is required.';
      }

      if (field.name === 'type') {
        return 'Please choose a matching type.';
      }

      if (field.name === 'shipWeightValue') {
        return 'Weight must be greater than 0.';
      }

      if (field.name === 'shipLength') {
        return 'Length must be greater than 0.';
      }

      if (field.name === 'shipWidth') {
        return 'Width must be greater than 0.';
      }

      if (field.name === 'shipHeight') {
        return 'Height must be greater than 0.';
      }

      return field.validationMessage || 'Please fix the highlighted fields.';
    }

    form.addEventListener('submit', function (event) {
      const submitBtn = form.querySelector('button[type="submit"]');
      const submitLabel = submitBtn ? submitBtn.querySelector('.pf-submit-label') : null;
      const submitLoading = submitBtn ? submitBtn.querySelector('.pf-submit-loading') : null;

      if (!madeHidden.value) {
        event.preventDefault();
        showToast('Please select the country in "Made In".', 'error');

        if (madeSelected) {
          madeSelected.classList.add('is-invalid');
        }

        openCountryDropdown();
        return;
      }

      if (madeSelected) {
        madeSelected.classList.remove('is-invalid');
      }

      const invalidField = form.querySelector(':invalid');

      if (invalidField) {
        event.preventDefault();

        invalidField.classList.add('is-invalid');

        if (typeof invalidField.reportValidity === 'function') {
          invalidField.reportValidity();
        }

        if (typeof invalidField.focus === 'function') {
          invalidField.focus();
        }

        showToast(getFieldMessage(invalidField), 'error');
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
      }

      if (submitLabel) {
        submitLabel.classList.add('d-none');
      }

      if (submitLoading) {
        submitLoading.classList.remove('d-none');
        submitLoading.classList.add('d-inline-flex');
      }
    });

    const pageSpinner = document.getElementById('spinner');

    if (pageSpinner) {
      window.addEventListener('load', function () {
        setTimeout(function () {
          pageSpinner.classList.remove('show');

          setTimeout(function () {
            pageSpinner.classList.add('d-none');
          }, 300);
        }, 700);
      });
    }

  })();
</script>