<!-- views/users-signup.ejs -->

<div class="min-vh-100 bg-body-tertiary py-4">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-11 col-md-9 col-lg-7 col-xl-6">

        <!-- Header -->
        <div class="text-center mb-3">
          <div class="d-inline-flex align-items-center gap-2 px-3 py-2 bg-white border rounded-pill shadow-sm">
            <span class="badge text-bg-primary rounded-pill">🚀</span>
            <span class="fw-semibold">Join Our Platform</span>
          </div>
          <p class="text-body-secondary small mt-2 mb-0">
            Use your real email so we can verify your account and send important updates.
          </p>
        </div>

        <!-- Page-local flash messages (kept) -->
        <% (success || []).forEach(msg => { %>
          <div class="alert alert-success d-flex align-items-center gap-2" role="alert">
            <span aria-hidden="true">✅</span>
            <span><%= msg %></span>
          </div>
        <% }) %>

        <% (error || []).forEach(msg => { %>
          <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
            <span aria-hidden="true">⚠️</span>
            <span><%= msg %></span>
          </div>
        <% }) %>

        <!-- Card -->
        <div class="card border-0 shadow-sm">
          <div class="card-body p-3 p-md-4">

            <!-- Step pills + progress -->
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
              <div class="d-flex gap-2 flex-wrap">
                <span class="badge rounded-pill text-bg-primary" id="stepBadge1">1 · Info</span>
                <span class="badge rounded-pill text-bg-secondary" id="stepBadge2">2 · Security</span>
                <span class="badge rounded-pill text-bg-secondary" id="stepBadge3">3 · Terms</span>
              </div>
              <div class="small text-body-secondary">All fields marked * are required</div>
            </div>

            <div class="progress mb-3">
              <div class="progress-bar bg-primary w-25" id="progressFill" role="progressbar" aria-label="Signup progress"></div>
            </div>

            <form
              action="/users/signup"
              method="post"
              autocomplete="off"
              novalidate
              id="signupForm"
            >
              <!-- Section 1 -->
              <div class="border rounded bg-light p-3 mb-3" data-step="1">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span class="badge text-bg-primary rounded-pill">1</span>
                  <h3 class="h6 fw-bold mb-0">Basic Information</h3>
                </div>

                <!-- Email -->
                <div class="mb-3">
                  <label for="email" class="form-label">Contact Email (Gmail/Outlook) <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text" aria-hidden="true">✉️</span>
                    <input
                      type="email"
                      name="email"
                      id="email"
                      required
                      autocomplete="email"
                      inputmode="email"
                      class="form-control"
                      placeholder="you@example.com"
                    />
                  </div>
                  <div class="form-text">We'll send a verification link to this address.</div>
                </div>

                <!-- Username -->
                <div class="mb-3">
                  <label for="username" class="form-label">Username <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text" aria-hidden="true">👤</span>
                    <input
                      type="text"
                      name="username"
                      id="username"
                      minlength="3"
                      maxlength="30"
                      required
                      autocomplete="username"
                      class="form-control"
                      placeholder="your_username"
                    />
                  </div>
                  <div class="d-flex justify-content-between">
                    <div class="form-text">3–30 characters (letters, numbers, . _ -)</div>
                    <div class="form-text" id="usernameCounter">0/30</div>
                  </div>
                </div>

                <!-- Full name -->
                <div class="mb-3">
                  <label for="name" class="form-label">Full Name <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text" aria-hidden="true">📝</span>
                    <input
                      type="text"
                      name="name"
                      id="name"
                      minlength="2"
                      maxlength="80"
                      required
                      autocomplete="name"
                      class="form-control"
                      placeholder="Your full name"
                    />
                  </div>
                </div>

                <!-- Age -->
                <div class="mb-0">
                  <label for="age" class="form-label">Age <span class="text-danger">*</span> <span class="text-body-secondary fw-normal">(must be 16+)</span></label>
                  <div class="input-group">
                    <span class="input-group-text" aria-hidden="true">🎂</span>
                    <input
                      type="number"
                      name="age"
                      id="age"
                      min="16"
                      max="120"
                      step="1"
                      required
                      autocomplete="off"
                      class="form-control"
                      placeholder="16"
                    />
                  </div>
                </div>
              </div>

              <!-- Section 2 -->
              <div class="border rounded bg-light p-3 mb-3" data-step="2">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span class="badge text-bg-primary rounded-pill">2</span>
                  <h3 class="h6 fw-bold mb-0">Security</h3>
                </div>

                <!-- Password -->
                <div class="mb-3">
                  <label for="password" class="form-label">Password <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text" aria-hidden="true">🔒</span>
                    <input
                      type="password"
                      name="password"
                      id="password"
                      required
                      minlength="6"
                      autocomplete="new-password"
                      class="form-control"
                      placeholder="Create a password"
                    />
                    <button
                      type="button"
                      class="btn btn-outline-secondary u-toggle-password"
                      data-target="password"
                      aria-label="Show password"
                    >
                      👁️
                    </button>
                  </div>

                  <div class="mt-2">
                    <div class="d-flex justify-content-between small">
                      <span class="text-body-secondary">Strength</span>
                      <span class="fw-semibold" id="strengthText">Weak</span>
                    </div>
                    <div class="progress">
                      <div class="progress-bar bg-danger w-0" id="strengthFill" role="progressbar" aria-label="Password strength"></div>
                    </div>
                  </div>

                  <div class="mt-2 p-2 border rounded bg-white">
                    <div class="small fw-semibold mb-1">Password must include:</div>
                    <ul class="small mb-0 ps-3">
                      <li id="reqLength">At least 6 characters</li>
                      <li id="reqNumber">One number</li>
                      <li id="reqLetter">One letter</li>
                    </ul>
                  </div>
                </div>

                <!-- Confirm -->
                <div class="mb-0">
                  <label for="confirm" class="form-label">Confirm Password <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text" aria-hidden="true">✓</span>
                    <input
                      type="password"
                      name="confirm"
                      id="confirm"
                      required
                      minlength="6"
                      autocomplete="new-password"
                      class="form-control"
                      placeholder="Repeat your password"
                    />
                    <button
                      type="button"
                      class="btn btn-outline-secondary u-toggle-password"
                      data-target="confirm"
                      aria-label="Show confirm password"
                    >
                      👁️
                    </button>
                  </div>
                </div>
              </div>

              <!-- Section 3 -->
              <div class="border rounded bg-light p-3 mb-3" data-step="3">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span class="badge text-bg-primary rounded-pill">3</span>
                  <h3 class="h6 fw-bold mb-0">Terms &amp; Conditions</h3>
                </div>

                <div class="form-check mb-2">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    name="confirm16"
                    value="1"
                    required
                    id="ageConfirm"
                  />
                  <label class="form-check-label" for="ageConfirm">
                    I confirm I am 16 years or older and agree to the
                    <a href="/terms" class="link-primary">Terms of Service</a> and
                    <a href="/privacy" class="link-primary">Privacy Policy</a>.
                  </label>
                </div>

                <div class="form-check mb-0">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    name="newsletter"
                    value="1"
                    id="newsletter"
                    checked
                  />
                  <label class="form-check-label" for="newsletter">
                    Send me occasional product updates and tips (optional).
                  </label>
                </div>
              </div>

              <!-- Submit (dominant brand green = primary) -->
              <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" id="submitBtn">
                <span class="me-2" aria-hidden="true">✅</span>
                <span class="u-btn-text">Create Account</span>
                <span class="spinner-border spinner-border-sm ms-2 d-none" id="submitSpinner" role="status" aria-hidden="true"></span>
              </button>

              <!-- Divider -->
              <div class="d-flex align-items-center gap-2 my-3">
                <div class="flex-grow-1 border-top"></div>
                <div class="text-body-secondary small">or continue with</div>
                <div class="flex-grow-1 border-top"></div>
              </div>

              <!-- Social -->
              <div class="d-grid gap-2">
                <a href="/auth/google" class="btn btn-outline-secondary d-flex align-items-center justify-content-center gap-2" data-nav="true" rel="noopener">
                  <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                  </svg>
                  <span>Continue with Google</span>
                </a>
                <div class="text-center text-body-secondary small">
                  We'll use your Google email and profile information.
                </div>
              </div>

              <!-- Switch to login -->
              <p class="text-center text-body-secondary small mt-3 mb-0">
                Already have an account?
                <a href="/users/login" data-nav="true" rel="noopener" class="fw-semibold text-decoration-none link-primary">
                  Log in here →
                </a>
              </p>
            </form>

          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  (function () {
    'use strict';

    const form = document.getElementById('signupForm');
    if (!form) return;

    const emailInput = document.getElementById('email');
    const usernameInput = document.getElementById('username');
    const nameInput = document.getElementById('name');
    const ageInput = document.getElementById('age');
    const passwordInput = document.getElementById('password');
    const confirmInput = document.getElementById('confirm');
    const ageConfirm = document.getElementById('ageConfirm');

    const submitBtn = document.getElementById('submitBtn');
    const submitSpinner = document.getElementById('submitSpinner');

    const usernameCounter = document.getElementById('usernameCounter');

    const strengthFill = document.getElementById('strengthFill');
    const strengthText = document.getElementById('strengthText');

    const reqLength = document.getElementById('reqLength');
    const reqNumber = document.getElementById('reqNumber');
    const reqLetter = document.getElementById('reqLetter');

    const progressFill = document.getElementById('progressFill');
    const stepBadge1 = document.getElementById('stepBadge1');
    const stepBadge2 = document.getElementById('stepBadge2');
    const stepBadge3 = document.getElementById('stepBadge3');

    // Keep existing behavior: data-nav links do full navigation
    document.querySelectorAll('a[data-nav="true"]').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        window.location.href = link.href;
      });
    });

    // Username counter
    function updateUsernameCounter() {
      if (!usernameInput || !usernameCounter) return;
      const len = usernameInput.value.length;
      usernameCounter.textContent = len + '/30';
    }
    if (usernameInput) {
      usernameInput.addEventListener('input', updateUsernameCounter);
      updateUsernameCounter();
    }

    // Toggle password visibility
    document.querySelectorAll('.u-toggle-password').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        const field = document.getElementById(targetId);
        if (!field) return;
        field.type = (field.type === 'password') ? 'text' : 'password';
      });
    });

    // Password strength + requirements (Bootstrap progress)
    function setStrengthWidthClass(pct) {
      if (!strengthFill) return;
      strengthFill.classList.remove('w-0','w-25','w-50','w-75','w-100');
      if (pct <= 0) strengthFill.classList.add('w-0');
      else if (pct <= 25) strengthFill.classList.add('w-25');
      else if (pct <= 50) strengthFill.classList.add('w-50');
      else if (pct <= 75) strengthFill.classList.add('w-75');
      else strengthFill.classList.add('w-100');
    }

    function updatePasswordUI() {
      if (!passwordInput || !strengthFill || !strengthText) return;

      const pwd = passwordInput.value || '';
      const hasLength = pwd.length >= 6;
      const hasNumber = /[0-9]/.test(pwd);
      const hasLetter = /[a-zA-Z]/.test(pwd);

      if (reqLength) reqLength.classList.toggle('text-success', hasLength);
      if (reqNumber) reqNumber.classList.toggle('text-success', hasNumber);
      if (reqLetter) reqLetter.classList.toggle('text-success', hasLetter);

      let score = 0;
      if (hasLength) score++;
      if (pwd.length >= 10) score++;
      if (/[A-Z]/.test(pwd) && /[a-z]/.test(pwd)) score++;
      if (hasNumber) score++;
      if (/[^A-Za-z0-9]/.test(pwd)) score++;

      const pct = Math.min(Math.round((score / 5) * 100), 100);
      setStrengthWidthClass(pct);

      strengthFill.classList.remove('bg-danger', 'bg-warning', 'bg-success');

      let label = 'Weak';
      if (pct >= 80) { label = 'Strong'; strengthFill.classList.add('bg-success'); }
      else if (pct >= 45) { label = 'Good'; strengthFill.classList.add('bg-warning'); }
      else { label = 'Weak'; strengthFill.classList.add('bg-danger'); }

      strengthText.textContent = label;
    }

    if (passwordInput) {
      passwordInput.addEventListener('input', updatePasswordUI);
      updatePasswordUI();
    }

    // Step progress (focus-based)
    function setStep(step) {
      if (!progressFill) return;

      progressFill.classList.remove('w-25','w-50','w-75','w-100');
      if (step === 1) progressFill.classList.add('w-25');
      if (step === 2) progressFill.classList.add('w-50');
      if (step === 3) progressFill.classList.add('w-100');

      const setBadge = (el, active) => {
        if (!el) return;
        el.classList.remove('text-bg-primary', 'text-bg-secondary');
        el.classList.add(active ? 'text-bg-primary' : 'text-bg-secondary');
      };

      setBadge(stepBadge1, step === 1);
      setBadge(stepBadge2, step === 2);
      setBadge(stepBadge3, step === 3);
    }

    const step1First = emailInput;
    const step2First = passwordInput;
    const step3First = ageConfirm;

    if (step1First) step1First.addEventListener('focus', () => setStep(1));
    if (step2First) step2First.addEventListener('focus', () => setStep(2));
    if (step3First) step3First.addEventListener('focus', () => setStep(3));
    setStep(1);

    // Validation helpers
    function markInvalid(el, isInvalid) {
      if (!el) return;
      el.classList.toggle('is-invalid', !!isInvalid);
    }

    function isEmailValid(v) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(v || '').trim());
    }

    function isUsernameValid(v) {
      return /^[a-zA-Z0-9._-]{3,30}$/.test(String(v || '').trim());
    }

    // Submit validation (keep normal POST submit)
    form.addEventListener('submit', (e) => {
      const email = (emailInput?.value || '').trim();
      const username = (usernameInput?.value || '').trim();
      const fullName = (nameInput?.value || '').trim();
      const pwd = (passwordInput?.value || '').trim();
      const confirm = (confirmInput?.value || '').trim();
      const ageVal = (ageInput?.value || '').trim();
      const age = parseInt(ageVal, 10);
      const ageOk = !!ageConfirm?.checked;

      let ok = true;

      [emailInput, usernameInput, nameInput, passwordInput, confirmInput, ageInput].forEach(el => markInvalid(el, false));

      if (!isEmailValid(email)) { ok = false; markInvalid(emailInput, true); }
      if (!isUsernameValid(username)) { ok = false; markInvalid(usernameInput, true); }
      if (fullName.length < 2) { ok = false; markInvalid(nameInput, true); }

      if (pwd.length < 6) { ok = false; markInvalid(passwordInput, true); }
      if (pwd !== confirm || confirm.length < 6) { ok = false; markInvalid(confirmInput, true); }

      if (Number.isNaN(age) || age < 16 || age > 120) { ok = false; markInvalid(ageInput, true); }
      if (!ageOk) { ok = false; }

      if (!ok) {
        e.preventDefault();
        alert('Please fix the highlighted fields and confirm you are 16+ and agree to the terms.');
        return;
      }

      if (submitBtn) submitBtn.disabled = true;
      if (submitSpinner) submitSpinner.classList.remove('d-none');
    });

    setTimeout(() => {
      if (emailInput && !emailInput.value) emailInput.focus();
    }, 200);

  })();
</script>