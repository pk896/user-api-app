<!-- views/admin-shippo.ejs -->
<%
  const PAGE_NONCE = typeof nonce !== 'undefined' ? nonce : '';
  const list = Array.isArray(orders) ? orders : [];

  const money = (amt) => {
    if (!amt) return '';
    const v = amt.value ?? amt.amount ?? '';
    const c = amt.currency ?? '';
    return `${v} ${c}`.trim();
  };

  const toArray = (v) => {
    if (!v) return [];
    if (Array.isArray(v)) return v;
    return [String(v)];
  };

  const successList = toArray(success);
  const errorList = toArray(error);
%>

<div class="container-fluid py-3 py-lg-4">
  <div class="row justify-content-center">
    <div class="col-12 col-xxl-11">

      <!-- Header -->
      <div class="card border-brand-purple shadow-sm mb-4">
        <div class="card-header bg-brand-purple text-white py-3">
          <div class="row g-3 align-items-center">
            <div class="col-12 col-lg">
              <div class="d-flex align-items-start gap-3">
                <div class="rounded-3 bg-white bg-opacity-25 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                  <span class="fs-4">🏷️</span>
                </div>
                <div>
                  <h1 class="h3 mb-1 fw-bold">Shippo Labels</h1>
                  <p class="mb-0 text-white-50">
                    Create labels for paid orders and automatically save tracking to the order.
                  </p>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-auto">
              <a class="btn btn-light text-brand-purple fw-semibold w-100" href="/admin">
                Back to Admin
              </a>
            </div>
          </div>
        </div>

        <div class="card-body">
          <div class="row g-3">
            <div class="col-12 col-lg-6">
              <label for="shippoSearch" class="form-label small fw-semibold text-brand-purple text-uppercase mb-1">
                Search
              </label>
              <input
                class="form-control"
                type="search"
                id="shippoSearch"
                placeholder="Search by OrderId, tracking number, carrier, status..."
                autocomplete="off"
              />
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
              <label for="shippoFulfillment" class="form-label small fw-semibold text-brand-purple text-uppercase mb-1">
                Fulfillment
              </label>
              <select class="form-select" id="shippoFulfillment">
                <option value="">All</option>
                <option value="PENDING">PENDING</option>
                <option value="PAID">PAID</option>
                <option value="PACKING">PACKING</option>
                <option value="LABEL_CREATED">LABEL_CREATED</option>
                <option value="SHIPPED">SHIPPED</option>
                <option value="DELIVERED">DELIVERED</option>
                <option value="CANCELLED">CANCELLED</option>
              </select>
            </div>

            <div class="col-12 col-sm-6 col-lg-3 d-flex align-items-end">
              <button type="button" class="btn btn-outline-brand-purple w-100" id="shippoClearFilters">
                Clear filters
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- KPI row -->
      <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-brand-purple shadow-sm h-100">
            <div class="card-body">
              <div class="small text-uppercase fw-semibold text-brand-purple mb-2">Paid Orders</div>
              <div class="display-6 fw-bold"><%= list.length %></div>
              <div class="small text-body-secondary">Showing latest</div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-brand-purple shadow-sm h-100">
            <div class="card-body">
              <div class="small text-uppercase fw-semibold text-brand-purple mb-2">Visible</div>
              <div class="display-6 fw-bold" id="shippoCount"><%= list.length %></div>
              <div class="small text-body-secondary">After filters</div>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-6">
          <div class="card border-brand-purple shadow-sm h-100">
            <div class="card-body">
              <div class="small text-uppercase fw-semibold text-brand-purple mb-2">Tip</div>
              <div class="fw-semibold">View rates first, then buy the label.</div>
              <div class="small text-body-secondary mt-1">
                If Shippo returns no rates, confirm carrier accounts are enabled and addresses are valid.
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Flash messages -->
      <% successList.forEach(msg => { %>
        <div class="alert alert-success shadow-sm" role="alert">✅ <%= msg %></div>
      <% }) %>

      <% errorList.forEach(msg => { %>
        <div class="alert alert-danger shadow-sm" role="alert">❌ <%= msg %></div>
      <% }) %>

      <% if (!list.length) { %>
        <div class="card border-brand-purple shadow-sm">
          <div class="card-body text-center py-5">
            <div class="fs-1 mb-3">📦</div>
            <div class="h4 text-brand-purple fw-bold mb-2">No paid orders found yet</div>
            <div class="text-body-secondary">
              Once orders are paid, they will appear here for label creation.
            </div>
          </div>
        </div>
      <% } else { %>
        <div id="shippoOrdersList" class="d-grid gap-3">
          <% list.forEach((o) => {
            const hasLabel = Boolean(o?.shippo?.labelUrl);
            const rate = o?.shippo?.chosenRate || null;
            const rateText = rate && rate.amount && rate.currency
              ? `${rate.amount} ${rate.currency}${rate.provider ? ' • ' + rate.provider : ''}${rate.service ? ' • ' + rate.service : ''}${rate.estimatedDays != null ? ' • ~' + rate.estimatedDays + 'd' : ''}`
              : '';

            const trackNum =
              String(
                o?.shippingTracking?.trackingNumber ||
                o?.shippingTracking?.number ||
                o?.shippo?.trackingNumber ||
                o?.shippo?.tracking_number ||
                ''
              ).trim();

            const trackUrl =
              String(
                o?.shippingTracking?.trackingUrl ||
                o?.shippingTracking?.tracking_url ||
                o?.shippo?.trackingUrl ||
                o?.shippo?.tracking_url ||
                o?.shippo?.tracking_url_provider ||
                ''
              ).trim();

            const inferFromUrl = (url) => {
              const u = String(url || '').toLowerCase();
              if (!u) return '';
              if (u.includes('dhl')) return 'DHL';
              if (u.includes('fedex')) return 'FEDEX';
              if (u.includes('ups')) return 'UPS';
              if (u.includes('usps') || u.includes('postal')) return 'USPS';
              return '';
            };

            const label =
              String(o?.shippingTracking?.carrierLabel || '').trim();

            const tokenLabel =
              String(o?.shippingTracking?.carrierToken || '').replace(/_/g, ' ').toUpperCase().trim();

            const shippoCarrier =
              String(o?.shippo?.carrier || '').replace(/_/g, ' ').toUpperCase().trim();

            const chosenRateProvider =
              String(o?.shippo?.chosenRate?.provider || '').trim();

            const bad = (s) => {
              const n = String(s || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
              return !n || n === 'UNKNOWN' || n === 'OTHER' || n === 'SHIPPO' || n === 'NULL';
            };

            const carrier =
              (!bad(label) ? label : '') ||
              (!bad(chosenRateProvider) ? chosenRateProvider : '') ||
              inferFromUrl(trackUrl) ||
              (!bad(tokenLabel) ? tokenLabel : '') ||
              (!bad(shippoCarrier) ? shippoCarrier : '') ||
              '';

            const fulfill =
              o.fulfillmentStatus ||
              o.shippingTracking?.status ||
              o.status ||
              'PENDING';

            const createdText = o.createdAt ? new Date(o.createdAt).toLocaleString() : '';
          %>
            <div
              class="card border-brand-purple shadow-sm shippo-order-card"
              data-orderid="<%= o.orderId %>"
              data-fulfillment="<%= String(fulfill || '').toUpperCase() %>"
            >
              <div class="card-header bg-brand-purple-soft">
                <div class="row g-2 align-items-center">
                  <div class="col-12 col-lg">
                    <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2">
                      <div class="fw-bold text-brand-purple font-monospace"><%= o.orderId %></div>
                      <div class="small text-body-secondary">Mongo: <%= String(o._id).slice(-6) %></div>
                    </div>
                  </div>

                  <div class="col-12 col-lg-auto">
                    <div class="d-flex flex-wrap gap-2">
                      <% if (hasLabel) { %>
                        <span class="badge rounded-pill badge-brand-green">Label saved</span>
                      <% } else { %>
                        <span class="badge rounded-pill text-bg-secondary">No label</span>
                      <% } %>

                      <% if (trackNum) { %>
                        <span class="badge rounded-pill text-bg-info">Tracking saved</span>
                      <% } %>

                      <span class="badge rounded-pill text-bg-light border"><%= fulfill %></span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="card-body">
                <div class="row g-4">
                  <div class="col-12 col-xl-8">
                    <div class="row g-3">
                      <div class="col-12 col-md-6 col-xl-3">
                        <div class="small text-body-secondary">Total</div>
                        <div class="fw-bold fs-5"><%= money(o.amount) %></div>
                      </div>

                      <div class="col-12 col-md-6 col-xl-3">
                        <div class="small text-body-secondary">Created</div>
                        <div><%= createdText %></div>
                      </div>

                      <div class="col-12 col-md-6 col-xl-3">
                        <div class="small text-body-secondary">Tracking Number</div>
                        <% if (trackNum) { %>
                          <div class="font-monospace text-break"><%= trackNum %></div>
                        <% } else { %>
                          <div class="text-body-secondary">—</div>
                        <% } %>
                      </div>

                      <div class="col-12 col-md-6 col-xl-3">
                        <div class="small text-body-secondary">Carrier</div>
                        <div><%= carrier || '—' %></div>
                      </div>

                      <div class="col-12">
                        <div class="small text-body-secondary">Label</div>

                        <% if (hasLabel) { %>
                          <div class="d-flex flex-column gap-2 mt-1">
                            <div class="d-flex flex-wrap gap-2">
                              <a
                                class="btn btn-sm btn-brand-purple"
                                href="<%= o.shippo.labelUrl %>"
                                target="_blank"
                                rel="noopener"
                              >
                                Open
                              </a>

                              <button
                                type="button"
                                class="btn btn-sm btn-outline-brand-purple js-copy-label"
                                data-url="<%= o.shippo.labelUrl %>"
                              >
                                Copy
                              </button>

                              <% if (trackUrl) { %>
                                <a
                                  class="btn btn-sm btn-outline-brand-purple"
                                  href="<%= trackUrl %>"
                                  target="_blank"
                                  rel="noopener"
                                >
                                  Tracking link
                                </a>
                              <% } %>
                            </div>

                            <% if (rateText) { %>
                              <div class="small text-body-secondary text-break">
                                Rate: <%= rateText %>
                              </div>
                            <% } %>

                            <div class="small text-body-secondary js-copy-status d-none"></div>
                          </div>
                        <% } else { %>
                          <div class="text-body-secondary mt-1">None</div>
                        <% } %>
                      </div>
                    </div>
                  </div>

                  <div class="col-12 col-xl-4">
                    <div class="d-grid gap-2">
                      <button
                        type="button"
                        class="btn btn-brand-purple js-create"
                        data-orderid="<%= o.orderId %>"
                        data-has-label="<%= hasLabel ? '1' : '0' %>"
                      >
                        <%= hasLabel ? 'Re-use saved label' : 'Open rates' %>
                      </button>

                      <button
                        type="button"
                        class="btn btn-outline-brand-purple js-rates"
                        data-orderid="<%= o.orderId %>"
                      >
                        View rates
                      </button>

                      <a
                        class="btn btn-outline-brand-purple"
                        href="/orders/tracking/<%= o.orderId %>"
                        target="_blank"
                        rel="noopener"
                      >
                        Track page
                      </a>

                      <button
                        type="button"
                        class="btn btn-outline-brand-purple js-fixaddr"
                        data-orderid="<%= o.orderId %>"
                      >
                        Fix address
                      </button>
                    </div>
                  </div>
                </div>

                <div
                  id="result-<%= o.orderId %>"
                  class="result-box border border-brand-purple rounded-3 p-3 mt-4 bg-brand-purple"
                  style="display:none;"
                ></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<style nonce="<%= PAGE_NONCE %>">
  .text-brand-purple { color: #7C3AED !important; }
  .bg-brand-purple { background-color: #7C3AED !important; }
  .bg-brand-purple-soft { background-color: rgba(124, 58, 237, 0.10) !important; }
  .border-brand-purple { border-color: rgba(124, 58, 237, 0.35) !important; }

  .btn-brand-purple {
    background-color: #7C3AED !important;
    border-color: #7C3AED !important;
    color: #fff !important;
  }

  .btn-brand-purple:hover,
  .btn-brand-purple:focus {
    background-color: #6D28D9 !important;
    border-color: #6D28D9 !important;
    color: #fff !important;
  }

  .btn-outline-brand-purple {
    color: #7C3AED !important;
    border-color: #7C3AED !important;
    background-color: transparent !important;
  }

  .btn-outline-brand-purple:hover,
  .btn-outline-brand-purple:focus {
    background-color: #7C3AED !important;
    border-color: #7C3AED !important;
    color: #fff !important;
  }

  .result-box .js-close-result {
    background-color: #fff !important;
    border-color: #fff !important;
    color: #7C3AED !important;
  }

  .result-box .js-close-result:hover,
  .result-box .js-close-result:focus {
    background-color: #22C55E !important;
    border-color: #22C55E !important;
    color: #fff !important;
  }

  .badge-brand-green {
    background-color: #22C55E !important;
    color: #fff !important;
  }

  .result-box {
    background-color: #7C3AED !important;
    color: #fff !important;
  }

  .result-box .text-body-secondary {
    color: rgba(255, 255, 255, 0.82) !important;
  }

  .result-box .text-brand-purple {
    color: #fff !important;
  }

  .result-box .border-brand-purple {
    border-color: rgba(255, 255, 255, 0.35) !important;
  }

  .btn-brand-green {
    background-color: #22C55E !important;
    border-color: #22C55E !important;
    color: #fff !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    line-height: 1 !important;
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }

  .btn-brand-green:hover,
  .btn-brand-green:focus {
    background-color: #FFF4D6 !important;
    border-color: #FFF4D6 !important;
    color: #7C3AED !important;
  }

  .courier-tracking-link {
    color: #22C55E !important;
    font-weight: 700 !important;
    font-size: 2rem !important;
    line-height: 1.2 !important;
    text-decoration: none !important;
    background: transparent !important;
    border: 0 !important;
    padding: 0 !important;
  }

  .courier-tracking-link:hover,
  .courier-tracking-link:focus {
    background: linear-gradient(90deg, #0D6EFD 0%, #22C55E 100%) !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
    background-clip: text !important;
    color: transparent !important;
    text-decoration: none !important;
  }
</style>

<script nonce="<%= PAGE_NONCE %>">
document.addEventListener('DOMContentLoaded', () => {
  const $ = (sel, root = document) => root.querySelector(sel);
  const $$ = (sel, root = document) => Array.from(root.querySelectorAll(sel));

  const searchInput = $('#shippoSearch');
  const fulfillSelect = $('#shippoFulfillment');
  const clearBtn = $('#shippoClearFilters');
  const countEl = $('#shippoCount');

  function norm(s) {
    return String(s || '').toLowerCase().trim();
  }

  function escapeHtml(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function getCards() {
    return $$('.shippo-order-card');
  }

  function showResult(orderId, html) {
    const box = document.getElementById(`result-${orderId}`);
    if (!box) return null;
    box.style.display = '';
    box.innerHTML = html;
    return box;
  }

  function hideResult(orderId) {
    const box = document.getElementById(`result-${orderId}`);
    if (!box) return;
    box.style.display = 'none';
    box.innerHTML = '';
  }

  function applyFilters() {
    const q = norm(searchInput && searchInput.value);
    const f = norm(fulfillSelect && fulfillSelect.value);

    let shown = 0;

    getCards().forEach(card => {
      const orderId = card.getAttribute('data-orderid') || '';
      const fulfill = card.getAttribute('data-fulfillment') || '';
      const text = norm(card.textContent);

      const okQ = !q || norm(orderId).includes(q) || text.includes(q);
      const okF = !f || norm(fulfill) === f;
      const show = okQ && okF;

      card.style.display = show ? '' : 'none';
      if (!show) hideResult(orderId);
      if (show) shown++;
    });

    if (countEl) countEl.textContent = String(shown);
  }

  if (searchInput) searchInput.addEventListener('input', applyFilters);
  if (fulfillSelect) fulfillSelect.addEventListener('change', applyFilters);

  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      if (fulfillSelect) fulfillSelect.value = '';
      applyFilters();
    });
  }

  async function showRates(orderId) {
    showResult(orderId, `<div class="alert alert-secondary mb-0">Loading rates...</div>`);

    const r = await fetch(`/admin/orders/${encodeURIComponent(orderId)}/shippo/rates`, {
      method: 'GET',
      credentials: 'same-origin',
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      }
    });

    const data = await r.json().catch(() => ({}));
    if (!r.ok || !data.ok) {
      showResult(orderId, `<div class="alert alert-danger mb-0">❌ ${escapeHtml(data.message || 'Failed to load rates')}</div>`);
      return;
    }

    const rates = Array.isArray(data.rates) ? data.rates : [];
    const payerRateId = String(data.payerRateId || '').trim();
    const payerHint = data.payerHint || {};
    const payerRecorded = !!data.payerRecorded;
    const payerInThisList = !!data.payerInThisList;

    const norm2 = (s) => String(s || '').toLowerCase().replace(/\s+/g, ' ').trim();

    if (!rates.length) {
      showResult(orderId, `<div class="alert alert-secondary mb-0">No rates returned for this order.</div>`);
      return;
    }

    showResult(orderId, `
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mb-3">
        <div>
          <div class="h5 mb-1 text-brand-purple fw-bold">Available rates</div>
          <div class="small text-body-secondary">Choose a rate to buy a label.</div>
          <div class="small text-body-secondary mt-2">
            Payer rate recorded: ${
              payerRecorded
                ? '<strong class="text-white" style="font-size: 3em; line-height: 1;">YES</strong>'
                : '<strong class="text-danger">NO</strong>'
            }
            ${payerRateId ? `• PayerRateId: <span class="font-monospace text-break">${escapeHtml(payerRateId)}</span>` : ''}
            ${payerRecorded && !payerInThisList ? `• <span class="badge rounded-pill text-bg-secondary">Payer not in this shipment list</span>` : ''}
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          ${
            (payerRecorded && payerInThisList)
              ? `<span class="badge rounded-pill badge-brand-green px-3 py-2">Strict: payer rate only</span>`
              : `
                <button class="btn btn-sm btn-brand-purple js-buy-cheapest" data-orderid="${escapeHtml(orderId)}">Buy cheapest</button>
                <button class="btn btn-sm btn-outline-brand-purple js-buy-fastest" data-orderid="${escapeHtml(orderId)}">Buy fastest</button>
              `
          }
          <button type="button" class="btn btn-sm btn-outline-brand-purple js-close-result" data-orderid="${escapeHtml(orderId)}">Close</button>
        </div>
      </div>

      <div class="row g-3">
        ${
          rates.map((rt) => {
            const rateObjectIdRaw = rt.object_id || rt.id || rt.rateId || rt.objectId || '';
            const rateObjectId = String(rateObjectIdRaw || '').trim();
            const payerId = String(payerRateId || '').trim();

            const hintMatch =
              !payerId &&
              (payerHint && (payerHint.provider || payerHint.service || payerHint.amount)) &&
              (
                (payerHint.provider && norm2(rt.provider) === norm2(payerHint.provider)) ||
                (payerHint.service && norm2(rt.service) === norm2(payerHint.service))
              ) &&
              (
                !payerHint.amount || String(rt.amount) === String(payerHint.amount)
              );

            const isPayer = (payerId && rateObjectId === payerId) || hintMatch;

            const etaText =
              (rt.estimatedDays != null)
                ? `~${escapeHtml(rt.estimatedDays)} days`
                : escapeHtml(rt.durationTerms || '—');

            return `
              <div class="col-12 col-xl-6">
                <div class="card h-100 ${isPayer ? 'border-brand-purple border-2' : 'border'} shadow-sm">
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                      <div>
                        <div class="fw-bold">${escapeHtml(rt.provider || 'Carrier')}</div>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                          <span class="badge rounded-pill bg-brand-purple text-white border-0">${escapeHtml(rt.service || 'Service')}</span>
                          <span class="badge rounded-pill text-bg-light border">ETA: ${etaText}</span>
                          ${isPayer ? `<span class="badge rounded-pill badge-brand-green">Payer chosen</span>` : ``}
                        </div>
                      </div>
                      <div class="fw-bold text-nowrap">${escapeHtml(rt.amount)} ${escapeHtml(rt.currency)}</div>
                    </div>

                    <div class="small fw-semibold text-dark mb-3">
                      RateId: <span class="font-monospace text-dark text-break">${escapeHtml(rateObjectId)}</span>
                    </div>

                    <div class="d-grid">
                      <button
                        type="button"
                        class="btn btn-sm ${isPayer ? 'btn-brand-purple' : 'btn-outline-brand-purple'} js-buy-rate"
                        data-orderid="${escapeHtml(orderId)}"
                        data-rateid="${escapeHtml(rateObjectId)}"
                      >
                        ${isPayer ? 'Buy payer choice' : 'Buy this'}
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            `;
          }).join('')
        }
      </div>
    `);
  }

  async function createLabel(orderId) {
    const btn = document.querySelector(`.js-create[data-orderid="${orderId}"]`);
    const hasLabel = btn && btn.dataset.hasLabel === '1';

    if (hasLabel) {
      const r = await fetch(`/admin/orders/${encodeURIComponent(orderId)}/shippo/create-label`, {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });

      const data = await r.json().catch(() => ({}));
      if (!r.ok || !data.ok) {
        showResult(orderId, `<div class="alert alert-danger mb-0">❌ ${escapeHtml(data.message || 'Shippo failed')}</div>`);
        return;
      }

      showResult(orderId, `
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
          <div>
            <div class="alert alert-success mb-2">✅ Re-used saved label</div>
            ${data.trackingNumber ? `<div class="font-monospace">Tracking: ${escapeHtml(data.trackingNumber)}</div>` : ''}
          </div>

          <div class="d-flex flex-wrap gap-2">
            ${data.labelUrl ? `<a class="btn btn-sm btn-brand-green" href="${data.labelUrl}" target="_blank" rel="noopener">Open label</a>` : ''}
            ${(data.trackingUrl || data.trackingNumber) ? `<a class="btn btn-sm courier-tracking-link" href="${data.trackingUrl || '#'}" target="_blank" rel="noopener">Courier tracking</a>` : ''}
          </div>
        </div>

        <div class="small text-body-secondary mt-2">This label was already saved on the order.</div>
      `);
      return;
    }

    await showRates(orderId);
  }

  $$('.js-rates').forEach(btn => {
    btn.addEventListener('click', () => showRates(btn.dataset.orderid));
  });

  $$('.js-create').forEach(btn => {
    btn.addEventListener('click', () => createLabel(btn.dataset.orderid));
  });

  $$('.js-fixaddr').forEach(btn => {
    btn.addEventListener('click', () => {
      const orderId = btn.dataset.orderid;

      showResult(orderId, `
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
          <div>
            <div class="h5 mb-1 text-brand-purple fw-bold">Fix address</div>
            <div class="small text-body-secondary">Update the shipping address, then create label again.</div>
          </div>

          <div>
            <button type="button" class="btn btn-sm btn-outline-brand-purple js-close-result" data-orderid="${escapeHtml(orderId)}">Close</button>
          </div>
        </div>

        <form class="js-addr-form" data-orderid="${escapeHtml(orderId)}">
          <div class="row g-3">
            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold text-uppercase text-brand-purple">Street 1</label>
              <input class="form-control" name="street1" placeholder="e.g. 1 Market St" required />
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold text-uppercase text-brand-purple">Street 2</label>
              <input class="form-control" name="street2" placeholder="Apartment / Suite (optional)" />
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold text-uppercase text-brand-purple">City</label>
              <input class="form-control" name="city" placeholder="e.g. San Francisco" required />
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold text-uppercase text-brand-purple">State</label>
              <input class="form-control" name="state" placeholder="State/Province (US: 2-letter, else optional)" />
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold text-uppercase text-brand-purple">ZIP</label>
              <input class="form-control" name="zip" placeholder="e.g. 94107" required />
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold text-uppercase text-brand-purple">Country</label>
              <select class="form-select" name="country" required>
                <option value="US" selected>US</option>
                <option value="ZA">ZA</option>
                <option value="GB">GB</option>
                <option value="CA">CA</option>
                <option value="AU">AU</option>
                <option value="DE">DE</option>
                <option value="FR">FR</option>
              </select>
            </div>
          </div>

          <div class="d-flex flex-column flex-sm-row justify-content-sm-end gap-2 mt-3">
            <button type="button" class="btn btn-outline-brand-purple js-fill-demo">Fill example</button>
            <button type="submit" class="btn btn-brand-purple">Save address</button>
          </div>

          <div class="small text-body-secondary mt-3">
            Tip: For US, State should be 2 letters (e.g. CA). Country should be ISO code (e.g. US).
          </div>

          <div class="js-addr-status mt-3"></div>
        </form>
      `);
    });
  });

  document.addEventListener('click', async (e) => {
    const buyBtn = e.target.closest('.js-buy-rate');
    if (!buyBtn) return;

    const orderId = buyBtn.dataset.orderid;
    const rateId = buyBtn.dataset.rateid;

    buyBtn.disabled = true;
    const oldText = buyBtn.textContent;
    buyBtn.textContent = 'Buying...';

    try {
      const r = await fetch(`/admin/orders/${encodeURIComponent(orderId)}/shippo/create-label`, {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ rateId })
      });

      const data = await r.json().catch(() => ({}));

      if (!r.ok || !data.ok) {
        const shippo = data.shippo || {};
        const status = shippo.status ? `<div class="small text-body-secondary">Status: <span class="font-monospace">${escapeHtml(shippo.status)}</span></div>` : '';
        const msgs = shippo.messages ? `<pre class="border rounded bg-light p-3 mb-0 small">${escapeHtml(JSON.stringify(shippo.messages, null, 2))}</pre>` : '';
        const txid = shippo.transactionId ? `<div class="small text-body-secondary">TransactionId: <span class="font-monospace">${escapeHtml(shippo.transactionId)}</span></div>` : '';
        const rid = shippo.rateId ? `<div class="small text-body-secondary">RateId: <span class="font-monospace">${escapeHtml(shippo.rateId)}</span></div>` : '';

        showResult(orderId, `
          <div class="alert alert-danger">❌ ${escapeHtml(data.message || 'Failed to buy label')}</div>
          ${status}${txid}${rid}
          ${msgs}
        `);
        return;
      }

      showResult(orderId, `
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
          <div>
            <div class="alert alert-success mb-2">✅ Label bought</div>
            ${data.trackingNumber ? `<div class="font-monospace">Tracking: ${escapeHtml(data.trackingNumber)}</div>` : ''}
          </div>

          <div class="d-flex flex-wrap gap-2">
            ${data.labelUrl ? `<a class="btn btn-sm btn-brand-purple" href="${data.labelUrl}" target="_blank" rel="noopener">Open label</a>` : ''}
            ${data.trackingUrl ? `<a class="btn btn-sm btn-outline-brand-purple" href="${data.trackingUrl}" target="_blank" rel="noopener">Courier tracking</a>` : ''}
          </div>
        </div>

        <div class="small text-body-secondary mt-2">Refreshing the page to show the saved label...</div>
      `);

      window.location.assign(`/admin/shippo?t=${Date.now()}`);
    } catch (err) {
      showResult(orderId, `<div class="alert alert-danger mb-0">❌ Network error: ${escapeHtml(err.message || 'Request failed')}</div>`);
    } finally {
      buyBtn.disabled = false;
      buyBtn.textContent = oldText;
    }
  });

  document.addEventListener('click', async (e) => {
    const cheapest = e.target.closest('.js-buy-cheapest');
    const fastest = e.target.closest('.js-buy-fastest');
    const btn = cheapest || fastest;
    if (!btn) return;

    const orderId = btn.dataset.orderid;
    const chooseRate = cheapest ? 'cheapest' : 'fastest';

    const r = await fetch(`/admin/orders/${encodeURIComponent(orderId)}/shippo/create-label`, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ chooseRate })
    });

    const data = await r.json().catch(() => ({}));
    if (!r.ok || !data.ok) {
      alert(`❌ ${data.message || 'Failed to buy label'}`);
      return;
    }

    alert(`✅ Label bought (${chooseRate}). Refreshing...`);
    window.location.assign(`/admin/shippo?t=${Date.now()}`);
  });

  document.addEventListener('click', (e) => {
    const close = e.target.closest('.js-close-result');
    if (!close) return;
    hideResult(close.dataset.orderid);
  });

  document.addEventListener('click', (e) => {
    const fill = e.target.closest('.js-fill-demo');
    if (!fill) return;

    const form = fill.closest('.js-addr-form');
    if (!form) return;

    form.street1.value = '1 Market St';
    form.street2.value = '';
    form.city.value = 'San Francisco';
    form.state.value = 'CA';
    form.zip.value = '94107';
    form.country.value = 'US';
  });

  document.addEventListener('submit', async (e) => {
    const form = e.target.closest('.js-addr-form');
    if (!form) return;

    e.preventDefault();

    const orderId = form.dataset.orderid;
    const statusBox = form.querySelector('.js-addr-status');

    const payload = {
      street1: form.street1.value.trim(),
      street2: form.street2.value.trim(),
      city: form.city.value.trim(),
      state: form.state.value.trim(),
      zip: form.zip.value.trim(),
      country: String(form.country.value || 'US').toUpperCase()
    };

    if (statusBox) {
      statusBox.innerHTML = `<div class="alert alert-secondary mb-0">Saving...</div>`;
    }

    const r = await fetch(`/admin/orders/${encodeURIComponent(orderId)}/shippo/update-address`, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify(payload)
    });

    const data = await r.json().catch(() => ({}));

    if (!r.ok || !data.ok) {
      if (statusBox) {
        statusBox.innerHTML = `<div class="alert alert-danger mb-0">❌ ${escapeHtml(data.message || 'Could not update address')}</div>`;
      }
      return;
    }

    if (statusBox) {
      statusBox.innerHTML = `<div class="alert alert-success mb-0">✅ Address updated. Now click “Create label”.</div>`;
    }
  });

  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('.js-copy-label');
    if (!btn) return;

    const url = String(btn.dataset.url || '').trim();
    if (!url) return;

    const original = btn.textContent;

    const flashCopied = () => {
      btn.textContent = 'Copied';
      setTimeout(() => {
        btn.textContent = original;
      }, 900);
    };

    try {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        await navigator.clipboard.writeText(url);
        flashCopied();
        return;
      }

      const ta = document.createElement('textarea');
      ta.value = url;
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);

      flashCopied();
    } catch (err) {
      btn.textContent = 'Failed';
      setTimeout(() => {
        btn.textContent = original;
      }, 900);
    }
  });

  applyFilters();
});
</script>
