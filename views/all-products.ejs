<!-- views/all-products.ejs -->
<!-- Spinner Start -->
<div
  id="spinner"
  class="show fade bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center"
  style="z-index: 9999;"
>
  <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
    <span class="visually-hidden">Loading...</span>
  </div>
</div>
<!-- Spinner End -->

<div class="container-fluid px-0">
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1 text-primary">My Products</h1>
      <% if (business && business.name) { %>
        <p class="text-body-secondary mb-0">Manage products for <strong><%= business.name %></strong></p>
      <% } %>
    </div>

    <% if (business && ["seller", "supplier"].includes(business.role)) { %>
      <div class="d-flex justify-content-md-end">
        <a href="/products/add" class="btn btn-primary">
          <i class="fa-solid fa-plus me-2"></i>Add Product
        </a>
      </div>
    <% } %>
  </div>

  <div id="flash-data"
       data-success="<%= success && success.length > 0 ? success : '' %>"
       data-error="<%= error && error.length > 0 ? error : '' %>"
       hidden>
  </div>

  <div class="toast-container position-fixed bottom-0 end-0 p-3" id="ap-toast-container"></div>

  <% if (!business) { %>
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-4 p-md-5">
            <div class="mb-3 text-warning fs-2">
              <i class="fa-solid fa-lock"></i>
            </div>
            <h2 class="h4 text-primary mb-3">Business Account Required</h2>
            <p class="text-body-secondary mb-4">
              You must be logged in with a business account to view products.
            </p>
            <a href="/business/login" class="btn btn-primary">
              Login to Business Account
            </a>
          </div>
        </div>
      </div>
    </div>

  <% } else if (!products || products.length === 0) { %>
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-4 p-md-5">
            <div class="mb-3 text-brand-green fs-2">
              <i class="fa-solid fa-box-open"></i>
            </div>
            <h2 class="h4 text-primary mb-3">No Products Found</h2>
            <p class="text-body-secondary mb-4">
              No products found for <strong><%= business.name %></strong>.
            </p>

            <% if (["seller", "supplier"].includes(business.role)) { %>
              <a href="/products/add" class="btn btn-primary">
                Add Your First Product
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>

  <% } else { %>

    <div class="row g-3 mb-4">
      <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="small text-body-secondary mb-1">Total Products</div>
            <div class="h3 mb-0 text-primary"><%= products.length %></div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="small text-body-secondary mb-1">In Stock</div>
            <div class="h3 mb-0 text-brand-green">
              <%= products.filter(p => p.stock > 0).length %>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="small text-body-secondary mb-1">Out of Stock</div>
            <div class="h3 mb-0 text-danger">
              <%= products.filter(p => p.stock <= 0).length %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <% products.forEach(product => { %>
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
          <div class="card h-100 border-0 shadow-sm">
            <a href="/store/product/<%= product.customId %>" class="text-decoration-none">
              <div class="bg-body-tertiary d-flex align-items-center justify-content-center position-relative" style="height: 240px;">
                <img
                  src="<%= product.imageUrl %>"
                  alt="<%= product.name %>"
                  loading="lazy"
                  class="img-fluid p-3"
                  style="max-height: 100%; object-fit: contain;"
                />

                <% if (product.stock <= 0) { %>
                  <span class="badge bg-danger position-absolute top-0 end-0 m-2">Out of Stock</span>
                <% } %>
              </div>
            </a>

            <div class="card-body d-flex flex-column">
              <h2 class="h6 mb-2">
                <a href="/store/product/<%= product.customId %>" class="text-decoration-none text-primary">
                  <%= product.name %>
                </a>
              </h2>

              <div class="d-flex justify-content-between align-items-center mb-2 gap-2">
                <span class="fw-bold text-primary">R <%= Number(product.price).toFixed(2) %></span>

                <% if (product.stock > 0) { %>
                  <span class="small text-brand-green fw-semibold"><%= product.stock %> in stock</span>
                <% } else { %>
                  <span class="small text-danger fw-semibold">Out of stock</span>
                <% } %>
              </div>

              <% if (product.category) { %>
                <div class="small text-body-secondary mb-3">
                  <i class="fa-solid fa-tag me-1"></i><%= product.category %>
                </div>
              <% } %>

              <div class="mt-auto d-grid gap-2">
                <% if (["seller", "supplier"].includes(business.role)) { %>
                  <a href="/store/product/<%= product.customId %>" class="btn btn-outline-primary btn-sm">
                    <i class="fa-regular fa-eye me-1"></i>View
                  </a>

                  <a href="/products/edit/<%= product.customId %>" class="btn btn-outline-secondary btn-sm">
                    <i class="fa-regular fa-pen-to-square me-1"></i>Edit
                  </a>

                  <button
                    type="button"
                    class="btn btn-outline-danger btn-sm ap-btn-delete"
                    data-delete-url="/products/delete/<%= product.customId %>"
                    data-product-name="<%= product.name %>">
                    <i class="fa-regular fa-trash-can me-1"></i>Delete
                  </button>

                <% } else if (business.role === "buyer") { %>
                  <a href="/store/product/<%= product.customId %>" class="btn btn-outline-primary btn-sm">
                    <i class="fa-regular fa-eye me-1"></i>View Details
                  </a>

                  <a
                    href="/api/cart/add?pid=<%= product.customId %>"
                    class="btn btn-brand-green btn-sm <%= product.stock <= 0 ? 'disabled' : '' %>"
                    <%= product.stock <= 0 ? 'aria-disabled="true" tabindex="-1" onclick="return false;"' : '' %>>
                    <i class="fa-solid fa-cart-plus me-1"></i>Add to Cart
                  </a>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<div class="modal fade" id="apDeleteModal" tabindex="-1" aria-labelledby="apDeleteModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header">
        <h5 class="modal-title text-primary" id="apDeleteModalLabel">Delete Product</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body">
        <p class="mb-2">This action cannot be undone.</p>
        <p class="mb-0 text-body-secondary">
          The product <strong id="apDeleteProductName">this product</strong> will be permanently removed.
        </p>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" id="apConfirmDelete">Delete</button>
      </div>
    </div>
  </div>
</div>

<script nonce="<%= nonce %>">
document.addEventListener("DOMContentLoaded", () => {
  const toastContainer = document.getElementById("ap-toast-container");
  const flashData = document.getElementById("flash-data");
  const deleteModalEl = document.getElementById("apDeleteModal");
  const confirmDeleteBtn = document.getElementById("apConfirmDelete");
  const deleteProductNameEl = document.getElementById("apDeleteProductName");

  let deleteUrl = null;
  let deleteModal = null;

  if (deleteModalEl && window.bootstrap) {
    deleteModal = new bootstrap.Modal(deleteModalEl);
  }

  function showToast(message, type = "success") {
    if (!toastContainer || !message) return;

    const wrapper = document.createElement("div");
    wrapper.className = "toast align-items-center border-0 text-bg-" + (type === "error" ? "danger" : "success");
    wrapper.setAttribute("role", "alert");
    wrapper.setAttribute("aria-live", "assertive");
    wrapper.setAttribute("aria-atomic", "true");

    wrapper.innerHTML = `
      <div class="d-flex">
        <div class="toast-body">${message}</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
    `;

    toastContainer.appendChild(wrapper);

    if (window.bootstrap) {
      const toast = new bootstrap.Toast(wrapper, { delay: 4000 });
      toast.show();

      wrapper.addEventListener("hidden.bs.toast", () => {
        wrapper.remove();
      });
    }

    if (navigator.vibrate) navigator.vibrate(40);
  }

  if (flashData) {
    const successMsg = flashData.dataset.success?.trim();
    const errorMsg = flashData.dataset.error?.trim();

    if (successMsg) showToast(successMsg, "success");
    if (errorMsg) showToast(errorMsg, "error");
  }

  document.querySelectorAll(".ap-btn-delete").forEach((btn) => {
    btn.addEventListener("click", () => {
      deleteUrl = btn.dataset.deleteUrl;
      const productName = btn.dataset.productName || "this product";

      if (deleteProductNameEl) {
        deleteProductNameEl.textContent = productName;
      }

      if (deleteModal) {
        deleteModal.show();
      }
    });
  });

  if (confirmDeleteBtn) {
    confirmDeleteBtn.addEventListener("click", () => {
      if (!deleteUrl) return;

      confirmDeleteBtn.disabled = true;
      confirmDeleteBtn.innerHTML = "Deleting...";

      window.location.href = deleteUrl;
    });
  }

    document.querySelectorAll('a.btn-brand-green:not(.disabled)').forEach((btn) => {
    btn.addEventListener("click", function () {
      const originalHtml = this.innerHTML;
      this.classList.add("disabled");
      this.setAttribute("aria-disabled", "true");
      this.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i>Adding...';

      setTimeout(() => {
        this.classList.remove("disabled");
        this.removeAttribute("aria-disabled");
        this.innerHTML = originalHtml;
      }, 2000);
    });
  });

  const pageSpinner = document.getElementById('spinner');

  if (pageSpinner) {
    window.addEventListener('load', function () {
      setTimeout(function () {
        pageSpinner.classList.remove('show');

        setTimeout(function () {
          pageSpinner.classList.add('d-none');
        }, 300);
      }, 700);
    });
  }
});
</script>
