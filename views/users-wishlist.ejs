<%
// views/users-wishlist.ejs
// Expects locals: title, themeCss, nonce, items, success, error
const list = Array.isArray(items) ? items : [];
%>

<!-- Spinner Start -->
<div
  id="spinner"
  class="show fade bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center"
  style="z-index: 9999;"
>
  <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
    <span class="visually-hidden">Loading...</span>
  </div>
</div>
<!-- Spinner End -->

<main class="container py-3 py-md-4">
  <!-- Header -->
  <section class="p-4 rounded-4 text-white bg-primary bg-gradient shadow-sm">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2">
      <div>
        <h1 class="h5 h4-sm fw-bold mb-1">❤️ My Wishlist</h1>
        <div class="small opacity-75 d-flex align-items-center flex-wrap gap-2">
          <span>Saved items you can come back to later.</span>
          <span class="badge rounded-pill text-bg-light text-primary fw-semibold">
            <%= list.length %> item(s)
          </span>
        </div>
      </div>

      <a href="/sales" class="btn btn-light rounded-pill fw-semibold">
        🛒 Browse products
      </a>
    </div>
  </section>

  <!-- Empty state -->
  <% if (!list.length) { %>
    <section class="alert alert-secondary border-0 rounded-4 mt-3 mt-md-4 mb-0">
      <div class="fw-bold mb-1">Your wishlist is empty.</div>
      <div class="small text-secondary">
        Go to the shop and tap “♡ Wishlist” on items you love.
      </div>
      <div class="mt-3">
        <a class="btn btn-primary rounded-pill fw-semibold" href="/sales">🛒 Browse products</a>
      </div>
    </section>
  <% } else { %>

    <!-- Grid -->
    <section class="row g-3 mt-2 mt-md-3">
      <% list.forEach((it) => { %>
        <% const p = it && it.product ? it.product : null; %>

        <%
          // robust image fallback
          const imgSrc =
            p && (p.imageUrl || p.image || p.img || p.image_key || p.imageKey)
              ? (p.imageUrl || p.image || p.img || p.image_key || p.imageKey)
              : '/img/placeholder.png';

          // label id for display + actions
          const actionId =
            p && (p.customId || p._id)
              ? String(p.customId || p._id)
              : (it && it.productId ? String(it.productId) : '');

          // product name fallback
          const name =
            p && (p.name || p.title)
              ? String(p.name || p.title)
              : 'Product not available';
        %>

        <div class="col-12 col-sm-6">
          <article class="card border-0 shadow-sm rounded-4 h-100 <%= p ? '' : 'bg-light' %>">
            <div class="card-body p-3">
              <div class="d-flex gap-3">
                <div class="flex-shrink-0">
                  <img
                    class="rounded-4 bg-body-secondary object-fit-cover"
                    src="<%= imgSrc %>"
                    alt="product"
                    width="92"
                    height="92"
                  >
                </div>

                <div class="flex-grow-1">
                  <h3 class="h6 fw-bold mb-2 text-body"><%= name %></h3>

                  <div class="d-flex flex-wrap gap-2 mb-3">
                    <% if (p && p.customId) { %>
                      <span class="badge rounded-pill text-bg-light border text-primary">
                        ID: <%= p.customId %>
                      </span>
                    <% } else if (p && p._id) { %>
                      <span class="badge rounded-pill text-bg-light border text-body">
                        Saved
                      </span>
                    <% } else { %>
                      <span class="badge rounded-pill text-bg-light border text-success">
                        Saved
                      </span>
                    <% } %>

                    <% if (it && it.addedAt) { %>
                      <span class="badge rounded-pill text-bg-light border text-secondary">
                        Added: <%= new Date(it.addedAt).toLocaleDateString() %>
                      </span>
                    <% } %>
                  </div>

                  <div class="d-flex flex-wrap gap-2 align-items-center">
                    <% if (p && p.customId) { %>
                      <a class="btn btn-primary btn-sm rounded-pill fw-semibold" href="/products/view/<%= p.customId %>">
                        👀 View
                      </a>
                    <% } else { %>
                      <a class="btn btn-primary btn-sm rounded-pill fw-semibold" href="/sales">
                        🛒 Back to shop
                      </a>
                    <% } %>

                    <form method="POST" action="/users/wishlist/remove/<%= actionId %>" class="m-0">
                      <button class="btn btn-outline-danger btn-sm rounded-pill fw-semibold" type="submit">
                        🗑️ Remove
                      </button>
                    </form>
                  </div>

                  <% if (!p) { %>
                    <div class="mt-3 small text-secondary">
                      This product is no longer available, but you can remove it from your wishlist.
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </article>
        </div>
      <% }) %>
    </section>

  <% } %>
</main>

<script nonce="<%= nonce %>">
  document.addEventListener('DOMContentLoaded', function () {
    const pageSpinner = document.getElementById('spinner');

    if (pageSpinner) {
      window.addEventListener('load', function () {
        setTimeout(function () {
          pageSpinner.classList.remove('show');

          setTimeout(function () {
            pageSpinner.classList.add('d-none');
          }, 300);
        }, 700);
      });
    }
  });
</script>
