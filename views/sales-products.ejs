<!--views/sales-products.ejs-->
<section class="sales-ministore py-3">
  <style nonce="<%= nonce %>">
    :root{
      --ms-accent:#72AEC8;
      --ms-dark:#212529;
      --ms-light:#f8f9fa;
      --ms-blue:#EDF1F3;
      --ms-gray:#AEAEAE;
    }

    .sales-ministore{
      background: var(--ms-light);
    }

    .sales-toolbar{
      position: sticky;
      top: 0;
      z-index: 1020;
      background: rgba(248,249,250,.96);
      backdrop-filter: blur(8px);
    }

    .sales-search-card{
      border: 0;
      border-radius: 0;
      background: #fff;
      box-shadow: 0 6px 20px rgba(0,0,0,.05);
    }

    .sales-search-card .form-control,
    .sales-search-card .form-select{
      min-height: 44px;
      border-radius: 0;
      border: 1px solid #e9ecef;
      box-shadow: none;
    }

    .sales-search-card .btn{
      min-height: 44px;
      border-radius: 0;
      letter-spacing: .08em;
      text-transform: uppercase;
      background-color: #7C3AED !important;
      border-color: #7C3AED !important;
      color: #fff !important;
    }

    .sales-search-card .btn:hover,
    .sales-search-card .btn:focus,
    .sales-search-card .btn:active{
      background-color: #7C3AED !important;
      border-color: #7C3AED !important;
      color: #fff !important;
    }

    .sales-grid .product-card{
      background: #fff;
      border: 0;
      transition: transform .2s ease, box-shadow .2s ease;
    }

    .sales-grid .product-card:hover{
      transform: translateY(-3px);
      box-shadow: 0 10px 24px rgba(0,0,0,.08);
    }

    .sales-grid .image-holder{
      background: var(--ms-blue);
      aspect-ratio: 1 / 1;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .sales-grid .image-holder img{
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 12px;
      display: block;
    }

    .sales-grid .card-detail{
        padding: 14px 8px 0;
        display: block !important;
        text-align: center;
    }

    .sales-grid h3.card-title{
        font-size: 1rem;
        line-height: 1.3;
        margin: 0 0 8px;
        min-height: 2.6em;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        text-transform: uppercase;
        text-align: center;
    }

    .sales-grid .card-title span{
      color: #212529;
      text-decoration: none;
    }

    .sales-grid .item-price{
        display: block;
        color: var(--ms-accent) !important;
        font-size: 1.15rem;
        font-weight: 700;
        line-height: 1.2;
        text-align: center;
    }

    .sales-empty{
      background: #fff;
      padding: 3rem 1rem;
      text-align: center;
      box-shadow: 0 6px 20px rgba(0,0,0,.05);
    }

    .sales-pager .btn{
      min-width: 120px;
      border-radius: 0;
      text-transform: uppercase;
      letter-spacing: .08em;
      background-color: #7C3AED !important;
      border-color: #7C3AED !important;
      color: #fff !important;
    }

    .sales-pager .btn:hover,
    .sales-pager .btn:focus,
    .sales-pager .btn:active{
      background-color: #7C3AED !important;
      border-color: #7C3AED !important;
      color: #fff !important;
    }

    @media (max-width: 575.98px){
      .sales-toolbar{
        padding-left: 0;
        padding-right: 0;
      }

      .sales-grid{
        margin-left: 0 !important;
        margin-right: 0 !important;
      }

      .sales-grid .col-6{
        padding-left: 0;
        padding-right: 0;
      }

      .sales-grid .image-holder img{
        padding: 8px;
      }

      .sales-grid h3.card-title{
        font-size: .92rem;
        min-height: 2.45em;
      }

      .sales-grid .item-price{
        font-size: 1.02rem;
      }
    }

    .related-products-wrap{
      margin-top: 2rem;
    }

    .related-products-title{
      font-size: 2rem;
      font-weight: 700;
      text-transform: uppercase;
      margin: 0 0 1rem;
      text-align: center;
      color: #7C3AED;
    }

    .related-grid .product-card{
      background: #fff;
      border: 0;
      transition: transform .2s ease, box-shadow .2s ease;
    }

    .related-grid .product-card:hover{
      transform: translateY(-3px);
      box-shadow: 0 10px 24px rgba(0,0,0,.08);
    }

    .related-grid .image-holder{
      background: var(--ms-blue);
      aspect-ratio: 1 / 1;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .related-grid .image-holder img{
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 8px;
      display: block;
    }

    .related-grid .card-detail{
      padding: 14px 8px 0;
      display: block !important;
      text-align: center;
    }

    .related-grid h3.card-title{
      font-size: .95rem;
      line-height: 1.3;
      margin: 0 0 8px;
      min-height: 2.5em;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      text-transform: uppercase;
      text-align: center;
    }

    .related-grid .card-title span{
      color: #7C3AED;
      text-decoration: none;
    }

    .related-grid .item-price{
      display: block;
      color: var(--ms-accent) !important;
      font-size: 1.05rem;
      font-weight: 700;
      line-height: 1.2;
      text-align: center;
    }
  </style>

  <div class="container-fluid px-0 px-md-3">
    <div class="sales-toolbar pb-2">
      <form method="GET" action="/products/sales" class="sales-search-card p-2 p-md-3">
        <div class="row g-2 align-items-center">
          <div class="col-12 col-md-5">
            <input
              id="salesKeywordInput"  
              type="text"
              name="q"
              class="form-control"
              placeholder="Search products..."
              value="<%= selectedQ || '' %>"
            >
          </div>

          <div class="col-8 col-md-5">
            <select id="salesCategorySelect" name="cat" class="form-select">
              <option value="" <%= !selectedCat ? 'selected' : '' %>>All Category</option>
              <% (CATEGORIES || []).forEach(function(category) { %>
                <option
                  value="<%= category.value %>"
                  <%= selectedCat === category.value ? 'selected' : '' %>
                >
                  <%= category.label %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="col-4 col-md-2 d-grid">
            <button id="salesKeywordSearchBtn" type="button" class="btn btn-dark">Search</button>
          </div>
        </div>
      </form>
    </div>

    <% if (!products || !products.length) { %>
      <div class="sales-empty mt-3">
        <h5 class="mb-0">No products found</h5>
      </div>
    <% } else { %>
      <div class="row g-2 g-md-3 mt-1 sales-grid">
        <% products.forEach(product => { %>
          <%
            const image = product.imageUrl || '/images/no-image.png';
            const basePrice = Number(product.price || 0);
            const vatPrice = basePrice * (1 + Number(vatRate || 0));
          %>

          <div class="col-6 col-md-4 col-lg-3">
            <a
              href="/store/product/<%= product.customId %>"
              class="text-decoration-none text-reset d-block h-100"
              aria-label="Open <%= product.name || 'product' %>"
            >
              <div class="product-card position-relative h-100">
                <div class="image-holder">
                  <img
                    src="<%= image %>"
                    alt="<%= product.name %>"
                    class="img-fluid"
                    loading="lazy"
                  >
                </div>

                <div class="card-detail">
                  <h3 class="card-title text-uppercase">
                    <span><%= product.name || 'Untitled Product' %></span>
                  </h3>
                  <span class="item-price text-primary">R<%= vatPrice.toFixed(2) %></span>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>

      <% if (typeof hasPrevPage !== 'undefined' || typeof hasNextPage !== 'undefined') { %>
        <div class="d-flex justify-content-between align-items-center mt-4 sales-pager">
          <% if (hasPrevPage) { %>
            <a
              href="/products/sales?<%= new URLSearchParams({
                q: selectedQ || '',
                cat: selectedCat || '',
                page: String(currentPage - 1)
              }).toString() %>"
              class="btn btn-outline-dark"
            >
              Previous
            </a>
          <% } else { %>
            <span></span>
          <% } %>

          <% if (hasNextPage) { %>
            <a
              href="/products/sales?<%= new URLSearchParams({
                q: selectedQ || '',
                cat: selectedCat || '',
                page: String(currentPage + 1)
              }).toString() %>"
              class="btn btn-dark"
            >
              Next
            </a>
          <% } else { %>
            <span></span>
          <% } %>
        </div>
      <% } %>
    <% } %>

    <% if (selectedQ && relatedProducts && relatedProducts.length) { %>
      <div class="related-products-wrap">
        <div class="mx-auto text-center mb-4" style="max-width: 700px;">
          <h4 class="related-products-title">Related Products</h4>
          <p class="mb-0 text-muted">
            You searched with purpose — here are more products closely related to your interest. Explore similar picks, find the one that fits your style, needs, and budget best.
          </p>
        </div>

        <div class="row g-2 g-md-3 mt-1 related-grid">       
          <% relatedProducts.forEach(product => { %>
            <%
              const relatedImage = product.imageUrl || '/images/no-image.png';
              const relatedBasePrice = Number(product.price || 0);
              const relatedVatPrice = relatedBasePrice * (1 + Number(vatRate || 0));
            %>

            <div class="col-6 col-md-4 col-lg-3">
              <a
                href="/store/product/<%= product.customId %>"
                class="text-decoration-none text-reset d-block h-100"
                aria-label="Open <%= product.name || 'product' %>"
              >
                <div class="product-card position-relative h-100">
                  <div class="image-holder">
                    <img
                      src="<%= relatedImage %>"
                      alt="<%= product.name %>"
                      class="img-fluid"
                      loading="lazy"
                    >
                  </div>

                  <div class="card-detail">
                    <h3 class="card-title text-uppercase">
                      <span><%= product.name || 'Untitled Product' %></span>
                    </h3>
                    <span class="item-price text-primary">R<%= relatedVatPrice.toFixed(2) %></span>
                  </div>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <script nonce="<%= nonce %>">
    (function () {
        const keywordInput = document.getElementById('salesKeywordInput');
        const categorySelect = document.getElementById('salesCategorySelect');
        const keywordBtn = document.getElementById('salesKeywordSearchBtn');

        if (!keywordInput || !categorySelect) return;

        function goToSales(categoryValue) {
        const params = new URLSearchParams();
        const keyword = String(keywordInput.value || '').trim();
        const category = String(categoryValue != null ? categoryValue : categorySelect.value || '').trim();

        if (keyword) {
            params.set('q', keyword);
        }

        if (category) {
            params.set('cat', category);
        }

        const queryString = params.toString();
        window.location.href = queryString ? '/products/sales?' + queryString : '/products/sales';
        }

        categorySelect.addEventListener('change', function () {
        goToSales(categorySelect.value);
        });

        keywordInput.addEventListener('input', function () {
        const keyword = String(keywordInput.value || '').trim();
        const category = String(categorySelect.value || '').trim();

        if (!keyword) {
            if (category) {
            goToSales(category);
            } else {
            window.location.href = '/products/sales';
            }
        }
        });

        keywordInput.addEventListener('keydown', function (event) {
        if (event.key === 'Enter') {
            event.preventDefault();
            goToSales(categorySelect.value);
        }
        });

        if (keywordBtn) {
        keywordBtn.addEventListener('click', function () {
            goToSales(categorySelect.value);
        });
        }
    })();
    </script>
</section>