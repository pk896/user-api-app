<!-- views/500.ejs -->
<%
  const errorId =
    (typeof req !== 'undefined' && req && req.id) ? String(req.id)
    : Math.random().toString(36).slice(2, 11).toUpperCase();
%>

<div class="min-vh-100 bg-body-tertiary d-flex align-items-center py-4">
  <div class="container-fluid px-0 px-md-1">
    <div class="mx-auto col-12 col-lg-10 col-xl-9 px-3 px-md-4">

      <div class="border rounded-3 bg-body shadow-sm overflow-hidden">
        <div class="p-3 p-md-4 border-bottom d-flex flex-wrap gap-3 align-items-start justify-content-between">
          <div>
            <h1 class="h4 fw-bold mb-1">
              <span aria-hidden="true" class="me-2">⚠️</span>
              Internal Server Error
            </h1>
            <p class="text-body-secondary mb-0">
              Our server hit an unexpected problem. Please try again.
            </p>
          </div>

          <span class="badge rounded-pill text-bg-danger align-self-start">
            500
          </span>
        </div>

        <div class="p-3 p-md-4">
          <div class="alert alert-warning mb-3" role="alert">
            <div class="fw-semibold mb-1">What you can do:</div>
            <ul class="mb-0 ps-3">
              <li>Retry the page</li>
              <li>Go back home and try again later</li>
              <li>Contact support if it keeps happening</li>
            </ul>
          </div>

          <div class="d-grid gap-2 d-md-flex">
            <button type="button" class="btn btn-danger" id="retryBtn">
              <span aria-hidden="true" class="me-2">🔄</span>
              Retry
            </button>

            <a class="btn btn-outline-secondary" href="/">
              <span aria-hidden="true" class="me-2">🏠</span>
              Home
            </a>

            <a class="btn btn-outline-secondary" href="/contact">
              <span aria-hidden="true" class="me-2">💬</span>
              Contact Support
            </a>
          </div>

          <hr class="my-4" />

          <div class="small text-body-secondary">
            <div class="mb-1">
              Error ID:
              <code class="ms-1"><%= errorId %></code>
            </div>
            <div>
              © <%= new Date().getFullYear() %> Unicoporate.com —
              <a class="link-secondary" href="mailto:support@unicoporate.com">support@unicoporate.com</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  document.addEventListener('DOMContentLoaded', function () {
    const btn = document.getElementById('retryBtn');
    if (!btn) return;

    btn.addEventListener('click', function () {
      window.location.reload();
    });
  });
</script>