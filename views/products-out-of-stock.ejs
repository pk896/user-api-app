    color: #991b1b;
    border: 1px solid #fecaca;
  }

  .out-stock-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 12px 0;
    gap: 8px;
    flex-wrap: wrap;
  }

  .out-stock-summary .summary-card {
    background: rgba(239, 68, 68, 0.06);
    border: 1px solid rgba(239, 68, 68, 0.25);
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 13px;
    color: #991b1b;
  }

  .out-stock-summary .summary-card strong {
    font-size: 16px;
    margin-right: 4px;
  }

  .btn-outline {
    padding: 6px 10px;
    border-radius: 6px;
    border: 1px solid #cbd5e1;
    background: #f8fafc;
    font-size: 12px;
    text-decoration: none;
    color: #0f172a;
    white-space: nowrap;
  }

  .btn-outline:hover {
    background: #e2e8f0;
  }

  .empty-state {
    margin-top: 1.5rem;
    padding: 1.5rem;
    border-radius: 10px;
    border: 1px dashed #cbd5f5;
    text-align: center;
    background: #f8fafc;
  }

  .empty-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .out-stock-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .product-card {
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    padding: 0.9rem;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .product-main {
    display: flex;
    gap: 0.75rem;
  }

  .product-image {
    width: 80px;
    height: 80px;
    border-radius: 10px;
    overflow: hidden;
    background: #f1f5f9;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-placeholder {
    font-size: 1.5rem;
    color: #94a3b8;
  }

  .product-info {
    flex: 1;
    min-width: 0;
  }

  .product-name {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    color: #0f172a;
  }

  .product-meta {
    font-size: 0.8rem;
    color: #64748b;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .meta-line {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .meta-label {
    font-weight: 500;
    color: #475569;
  }

  .meta-value {
    color: #0f172a;
  }

  .stock-zero {
    color: #b91c1c;
    font-weight: 700;
  }

  .stock-form {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    border-top: 1px solid #e2e8f0;
    padding-top: 0.6rem;
    margin-top: 0.3rem;
  }

  .stock-input-group {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 120px;
  }

  .stock-input-group label {
    font-size: 0.75rem;
    color: #64748b;
  }

  .stock-input-group input {
    padding: 0.3rem 0.5rem;
    font-size: 0.85rem;
    border-radius: 6px;
    border: 1px solid #cbd5e1;
    max-width: 120px;
  }

  .stock-input-group input:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 1px rgba(37, 99, 235, 0.2);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    padding: 0.4rem 0.8rem;
    font-size: 0.8rem;
    font-weight: 500;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    gap: 0.25rem;
  }

  .btn-primary {
    background: #2563eb;
    color: #ffffff;
    border-color: #1d4ed8;
  }

  .btn-primary:hover {
    background: #1d4ed8;
  }

  .no-id-warning {
    font-size: 0.75rem;
    color: #b45309;
    margin-top: 0.4rem;
  }

  @media (max-width: 480px) {
    .out-stock-page {
      padding: 0.75rem;
    }

    .product-main {
      flex-direction: row;
    }

    .stock-form {
      flex-direction: column;
      align-items: stretch;
    }

    .btn-primary {
      width: 100%;
      justify-content: center;
    }
  }
</style>