<!--views/products-out-of-stock.ejs-->
<section class="out-stock-page">
  <h1 class="page-title">📦 Out of Stock Products</h1>
  <p class="subtitle">
    These products currently have <strong>no stock</strong>. Update the stock
    quantity below to make them available again.
  </p>

  <% (success || []).forEach(msg => { %>
    <div class="flash flash-success">✅ <%= msg %></div>
  <% }) %>
  <% (error || []).forEach(msg => { %>
    <div class="flash flash-error">❌ <%= msg %></div>
  <% }) %>

  <%
    const items = Array.isArray(products) ? products : [];
  %>

  <% if (!items.length) { %>
    <div class="empty-state">
      <div class="empty-icon">🎉</div>
      <p>Great news! You have no products that are completely out of stock.</p>
      <a href="/products/all" class="btn btn-primary">← Back to My Products</a>
    </div>
  <% } else { %>
    <div class="out-stock-summary">
      <div class="summary-card">
        <strong><%= items.length %></strong>
        <span>products out of stock</span>
      </div>
      <a href="/products/all" class="btn-outline">← Back to My Products</a>
    </div>

    <div class="out-stock-grid">
      <% items.forEach(function (p) {
           const stock = Number(p.stock) || 0;
           const price = (p.price != null ? Number(p.price) : 0);
           const idVal = typeof p.customId === 'string' ? p.customId.trim() : '';
      %>
        <article class="product-card">
          <div class="product-main">
            <div class="product-image">
              <% if (p.imageUrl && p.imageUrl.trim() !== '') { %>
                <img src="<%= p.imageUrl %>" alt="<%= p.name %>" />
              <% } else { %>
                <div class="image-placeholder">📦</div>
              <% } %>
            </div>

            <div class="product-info">
              <h2 class="product-name"><%= p.name || 'Unnamed product' %></h2>
              <div class="product-meta">
                <div class="meta-line">
                  <span class="meta-label">Product ID:</span>
                  <span class="meta-value"><%= idVal || '—' %></span>
                </div>
                <div class="meta-line">
                  <span class="meta-label">Category:</span>
                  <span class="meta-value"><%= p.category || '—' %></span>
                </div>
                <div class="meta-line">
                  <span class="meta-label">Price:</span>
                  <span class="meta-value"><%= price.toFixed(2) %> ZAR</span>
                </div>
                <div class="meta-line">
                  <span class="meta-label">Current stock:</span>
                  <span class="meta-value stock-zero"><%= stock %></span>
                </div>
              </div>
            </div>
          </div>

          <% if (idVal) { %>
            <form
              class="stock-form"
              method="post"
              action="/products/edit/<%= encodeURIComponent(idVal) %>"
            >
              <div class="stock-input-group">
                <label for="stock-<%= idVal %>">New stock</label>
                <input
                  id="stock-<%= idVal %>"
                  type="number"
                  name="stock"
                  min="0"
                  step="1"
                  required
                  placeholder="e.g. 10"
                  value="10"
                />
              </div>

              <button type="submit" class="btn btn-primary">
                💾 Save Stock
              </button>

              <input type="hidden" name="source" value="out-of-stock-page" />
            </form>
          <% } else { %>
            <div class="no-id-warning">
              <small>⚠️ Cannot update stock: this product has no custom product ID.</small>
            </div>
          <% } %>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<style nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  .out-stock-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
