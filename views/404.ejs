<!-- views/404.ejs -->
<%
  const reqPath =
    (typeof path !== 'undefined' && path) ? String(path)
    : (typeof url !== 'undefined' && url) ? String(url)
    : '';

  const statusCode = (typeof status !== 'undefined' && status) ? String(status) : '404';
%>

<div class="min-vh-100 bg-body-tertiary d-flex align-items-center py-4">
  <div class="container-fluid px-0 px-md-1">
    <div class="mx-auto col-12 col-lg-10 col-xl-9 px-3 px-md-4">

      <div class="border rounded-3 bg-body shadow-sm overflow-hidden">
        <div class="p-3 p-md-4 border-bottom d-flex flex-wrap gap-3 align-items-start justify-content-between">
          <div>
            <h1 class="h4 fw-bold mb-1">
              <span aria-hidden="true" class="me-2">🧭</span>
              Page not found
            </h1>
            <p class="text-body-secondary mb-0">
              We couldn’t find the page you’re looking for.
            </p>
          </div>

          <span class="badge rounded-pill text-bg-warning align-self-start">
            <span aria-hidden="true" class="me-1">⚠️</span>
            <%= statusCode %>
          </span>
        </div>

        <div class="p-3 p-md-4">
          <p class="text-body-secondary mb-3">
            Try going back, or use one of the quick links below.
          </p>

          <div class="d-grid gap-2 d-md-flex">
            <a class="btn btn-primary" href="/sales">
              <span aria-hidden="true" class="me-2">🛍️</span>
              Browse Products
            </a>
            <a class="btn btn-outline-secondary" href="/">
              <span aria-hidden="true" class="me-2">🏠</span>
              Home
            </a>
            <a class="btn btn-outline-secondary" href="/contact">
              <span aria-hidden="true" class="me-2">💬</span>
              Contact Support
            </a>
          </div>

          <hr class="my-4" />

          <div class="small text-body-secondary">
            <div class="mb-1">
              Requested path:
              <code class="ms-1"><%= reqPath || '—' %></code>
            </div>
            <div>If this keeps happening, tell us what you clicked.</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>