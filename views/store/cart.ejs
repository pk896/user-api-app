<!-- Single Page Header start -->
<div class="container-fluid page-header py-5" style="<%= shopHeaderImage && shopHeaderImage.image ? '--page-header-image: url(' + shopHeaderImage.image + ')' : '' %>">
    <h1 class="text-center text-white display-6 wow fadeInUp" data-wow-delay="0.1s">Cart Page</h1>
    <ol class="breadcrumb justify-content-center mb-0 wow fadeInUp" data-wow-delay="0.3s">
        <li class="breadcrumb-item"><a href="/store">Shopping home</a></li>
        <li class="breadcrumb-item"><a href="/store/shop">Pages</a></li>
        <li class="breadcrumb-item active text-white">Cart Page</li>
    </ol>
</div>
<!-- Single Page Header End -->

<!-- Cart Page Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="table-responsive">
            <table class="table align-middle cart-table cart-table-brand mb-0">
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Model</th>
                        <th scope="col">Price</th>
                        <th scope="col">Quantity</th>
                        <th scope="col">Total</th>
                        <th scope="col">Handle</th>
                    </tr>
                </thead>
                <tbody id="cartTableBody">
                    <% if (!(cartItems || []).length) { %>
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <h5 class="mb-3">Your cart is empty</h5>
                                <a href="/store/shop" class="btn btn-primary rounded-pill px-4 py-2">Continue Shopping</a>
                            </td>
                        </tr>
                    <% } %>

                    <% (cartItems || []).forEach(function(item) { %>
                        <tr
                            class="cart-row"
                            data-pid="<%= item.customId %>"
                            data-variant-size="<%= item.variants && item.variants.size ? item.variants.size : '' %>"
                            data-variant-color="<%= item.variants && item.variants.color ? item.variants.color : '' %>"
                        >
                            <th scope="row">
                                <div class="py-3">
                                    <div class="cart-name-box rounded-3 p-3 text-white h-100">
                                        <p class="mb-2 fw-bold text-break"><%= item.name %></p>
                                        <% if (item.variants && (item.variants.size || item.variants.color)) { %>
                                            <div class="small text-white text-break">
                                                <% if (item.variants.size) { %><span class="fw-semibold">Size:</span> <%= item.variants.size %><% } %>
                                                <% if (item.variants.size && item.variants.color) { %> | <% } %>
                                                <% if (item.variants.color) { %><span class="fw-semibold">Color:</span> <%= item.variants.color %><% } %>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </th>
                            <td>
                                <div class="py-3">
                                    <div class="rounded-3 p-3 text-break fw-semibold">
                                        <%= item.customId || 'N/A' %>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <p class="mb-0 py-4">$<%= Number(item.price || 0).toFixed(2) %></p>
                            </td>
                            <td>
                                <div class="input-group quantity py-4" style="width: 100px;">
                                    <div class="input-group-btn">
                                        <button type="button" class="btn btn-sm btn-minus rounded-circle bg-light border js-cart-decrease">
                                            <i class="fa fa-minus"></i>
                                        </button>
                                    </div>
                                    <input
                                        type="text"
                                        class="form-control form-control-sm text-center border-0"
                                        value="<%= Number(item.quantity || 0) %>"
                                        readonly
                                    >
                                    <div class="input-group-btn">
                                        <button type="button" class="btn btn-sm btn-plus rounded-circle bg-light border js-cart-increase">
                                            <i class="fa fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <p class="mb-0 py-4">$<%= (Number(item.price || 0) * Number(item.quantity || 0)).toFixed(2) %></p>
                            </td>
                            <td class="py-4">
                                <button type="button" class="btn btn-md rounded-circle bg-light border js-cart-remove">
                                    <i class="fa fa-times text-danger"></i>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="mt-5">
            <input type="text" class="border-0 border-bottom rounded me-5 py-3 mb-4" placeholder="Coupon Code">
            <button class="btn btn-primary rounded-pill px-4 py-3" type="button">Apply Coupon</button>
        </div>

        <div class="row g-4 justify-content-end">
            <div class="col-8"></div>
            <div class="col-sm-8 col-md-7 col-lg-6 col-xl-4">
                <div class="bg-light rounded">
                    <div class="p-4">
                        <h1 class="display-6 mb-4">Cart <span class="fw-normal">Total</span></h1>

                        <div class="d-flex justify-content-between mb-3">
                            <h5 class="mb-0 me-4">Subtotal (excl. VAT):</h5>
                            <p class="mb-0" id="cartSubtotal">$<%= cartNetSubtotal.toFixed(2) %></p>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <h5 class="mb-0 me-4">VAT (<%= (VAT * 100).toFixed(0) %>%):</h5>
                            <p class="mb-0" id="cartVatTotal">$<%= cartVatAmount.toFixed(2) %></p>
                        </div>

                        <div class="d-flex justify-content-between mb-0">
                            <h5 class="mb-0 me-4">Total (incl. VAT):</h5>
                            <p class="mb-0 fw-bold" id="cartGrandTotal">$<%= cartGrossTotal.toFixed(2) %></p>
                        </div>

                        <div class="alert alert-info mt-4 mb-0 py-3 px-3" role="alert">
                            Shipping is not included in the cart total yet. You will select your shipping rate in Checkout.
                        </div>
                    </div>

                    <a href="/payment/checkout" class="btn btn-primary rounded-pill px-4 py-3 text-uppercase mb-4 ms-4">
                        Proceed Checkout
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Cart Page End -->

<style nonce="<%= nonce %>">
  .cart-table {
    table-layout: auto;
    width: 100%;
  }

  .cart-table th,
  .cart-table td {
    vertical-align: top;
  }

  .cart-table-brand {
    border-color: rgba(124, 58, 237, 0.25);
  }

  .cart-table-brand thead th {
    background-color: #7C3AED;
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.18);
    white-space: nowrap;
  }

  .cart-table-brand tbody th,
  .cart-table-brand tbody td {
    background-color: #7C3AED;
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.18);
  }

  .cart-table-brand p,
  .cart-table-brand small,
  .cart-table-brand span,
  .cart-table-brand .text-muted {
    color: inherit !important;
  }

  .cart-name-box {
    background-color: #22C55E;
  }

  @media (max-width: 767.98px) {
    .cart-table {
      min-width: 900px;
    }

    .cart-table th:nth-child(1),
    .cart-table td:nth-child(1) {
      min-width: 220px;
    }

    .cart-table th:nth-child(2),
    .cart-table td:nth-child(2) {
      min-width: 180px;
    }

    .cart-table th:nth-child(3),
    .cart-table td:nth-child(3),
    .cart-table th:nth-child(4),
    .cart-table td:nth-child(4),
    .cart-table th:nth-child(5),
    .cart-table td:nth-child(5),
    .cart-table th:nth-child(6),
    .cart-table td:nth-child(6) {
      min-width: 110px;
      white-space: nowrap;
    }

    .cart-table .text-break {
      word-break: break-word;
      overflow-wrap: anywhere;
      white-space: normal;
    }
  }
</style>

<%- include('partials/footer') %>

<script nonce="<%= nonce %>">
  (function () {
    const select = document.getElementById('cartCategorySelect');
    const links = Array.from(document.querySelectorAll('.cart-category-link'));

    function goToCategory(categoryValue) {
      const selected = String(categoryValue || '').trim().toLowerCase();
      const url = selected
        ? '/store/shop?category=' + encodeURIComponent(selected)
        : '/store/shop';

      window.location.href = url;
    }

    links.forEach(function (link) {
      link.addEventListener('click', function (event) {
        event.preventDefault();
        goToCategory(link.getAttribute('data-category') || '');
      });
    });

    if (select) {
      select.addEventListener('change', function () {
        goToCategory(select.value || '');
      });
    }
  })();
</script>

<%- include('partials/cart-script-cart-page') %>

