<%
  const VAT = (typeof vatRate !== 'undefined' && vatRate !== null)
    ? Number(vatRate)
    : 0.15;

  const cartGrossTotal = Number(cartSubtotal || 0);
  const cartNetSubtotal = VAT > 0 ? (cartGrossTotal / (1 + VAT)) : cartGrossTotal;
  const cartVatAmount = cartGrossTotal - cartNetSubtotal;
%>

