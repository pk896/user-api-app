                    <% if ((topRatedTagProducts || []).length > 0) { %>
                        <div class="row g-2 g-md-3 top-rated-sales-grid">
                            <% topRatedTagProducts.forEach(function(item) { %>
                                <div class="col-6 col-md-4 col-lg-12">
                                    <a
                                        href="<%= item.url %>"
                                        class="text-decoration-none text-reset d-block h-100"
                                        title="<%= item.name %>"
                                    >
                                        <div class="product-card position-relative h-100">
                                            <div class="image-holder">
                                                <img
                                                    src="<%= item.image %>"
                                                    alt="<%= item.name %>"
                                                    class="img-fluid"
                                                    loading="lazy"
                                                >
                                            </div>

                                            <div class="card-detail">
                                                <h3 class="card-title text-uppercase">
                                                    <span><%= item.name || 'Untitled Product' %></span>
                                                </h3>
                                                <span class="item-price text-primary">
                                                    <%= formatMoney(Number(item.price || 0) * (1 + VAT)) %>
                                                </span>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="small text-muted">No top rated products available right now.</div>
                    <% } %>
                </div>
            </div>

            <div class="col-lg-9 wow fadeInUp" data-wow-delay="0.1s">
                <% if (shopMainBanner) { %>
                    <div class="rounded mb-4 position-relative">
                        <img src="<%= shopMainBanner.image %>" class="img-fluid rounded w-100" style="height: 250px;" alt="<%= shopMainBanner.productName || shopMainBanner.title %>">
                        <div class="position-absolute rounded d-flex flex-column align-items-center justify-content-center text-center" style="width: 100%; height: 250px; top: 0; left: 0; background: rgba(242, 139, 0, 0.3);">
                            <h4 class="display-5 text-primary"><%= shopMainBanner.title %></h4>
                            <h3 class="display-4 text-white mb-4"><%= shopMainBanner.subtitle %></h3>
                            <span class="btn btn-primary rounded-pill"><%= shopMainBanner.buttonText || 'Shop Now' %></span>
