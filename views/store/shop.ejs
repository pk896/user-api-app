<script nonce="<%= nonce %>">
  (function () {
    const select = document.getElementById('shopCategorySelect');
    const sortSelect = document.getElementById('shopSortSelect');
    const keywordInput = document.getElementById('shopKeywordInput');
    const keywordInputSecondary = document.getElementById('shopKeywordInputSecondary');
    const keywordBtn = document.getElementById('shopKeywordSearchBtn');
    const keywordBtnSecondary = document.getElementById('shopKeywordSearchBtnSecondary');
    const links = Array.from(document.querySelectorAll('.shop-category-link'));

    if (!select) return;

    function getKeyword() {
      const primaryValue = keywordInput ? String(keywordInput.value || '').trim() : '';
      const secondaryValue = keywordInputSecondary ? String(keywordInputSecondary.value || '').trim() : '';
      return primaryValue || secondaryValue;
    }

    function syncKeywordInputs(keyword) {
      if (keywordInput) {
        keywordInput.value = keyword;
      }

      if (keywordInputSecondary) {
        keywordInputSecondary.value = keyword;
      }
    }

    function goToShop(categoryValue) {
        const params = new URLSearchParams();
        const keyword = getKeyword();
        const category = String(categoryValue != null ? categoryValue : select.value || '').trim();
        const sortValue = sortSelect ? String(sortSelect.value || 'default').trim() : 'default';

        syncKeywordInputs(keyword);

        if (keyword) {
            params.set('keyword', keyword);
        }

        if (category) {
            params.set('category', category);
        }

        if (sortValue && sortValue !== 'default') {
            params.set('sort', sortValue);
        }

        params.set('page', '1');

        const queryString = params.toString();
        window.location.href = queryString ? '/store/shop?' + queryString + '#shopProductsSection' : '/store/shop#shopProductsSection';
    }

    links.forEach(function (link) {
      link.addEventListener('click', function (event) {
        event.preventDefault();
        goToShop(link.getAttribute('data-category'));
      });
    });

    select.addEventListener('change', function () {
        goToShop(select.value);
        });

        if (sortSelect) {
        sortSelect.addEventListener('change', function () {
            goToShop(select ? select.value : '');
        });
    }

    if (keywordInput) {
        keywordInput.addEventListener('input', function () {
            const keyword = String(keywordInput.value || '').trim();
            const category = String(select ? (select.value || '') : '').trim();
            const sortValue = String(sortSelect ? (sortSelect.value || 'default') : 'default').trim();

            syncKeywordInputs(keyword);

            if (!keyword) {
            if (category || (sortValue && sortValue !== 'default')) {
                goToShop(category);
            } else {
                window.location.href = '/store/shop#shopProductsSection';
            }
            }
        });

        keywordInput.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
            event.preventDefault();
            goToShop(select.value);
            }
        });
        }

        if (keywordInputSecondary) {
        keywordInputSecondary.addEventListener('input', function () {
            const keyword = String(keywordInputSecondary.value || '').trim();
            const category = String(select ? (select.value || '') : '').trim();
            const sortValue = String(sortSelect ? (sortSelect.value || 'default') : 'default').trim();

            syncKeywordInputs(keyword);

            if (!keyword) {
            if (category || (sortValue && sortValue !== 'default')) {
                goToShop(category);
            } else {
                window.location.href = '/store/shop#shopProductsSection';
            }
            }
        });

        keywordInputSecondary.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
            event.preventDefault();
            goToShop(select.value);
            }
        });
    }

    if (keywordBtn) {
      keywordBtn.addEventListener('click', function () {
        goToShop(select.value);
      });
    }

    if (keywordBtnSecondary) {
      keywordBtnSecondary.addEventListener('click', function () {
        goToShop(select.value);
      });
    }
  })();
</script>

