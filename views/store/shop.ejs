                                <option value="popular" <%= selectedSort === 'popular' ? 'selected' : '' %>>Popularity</option>
                                <option value="newest" <%= selectedSort === 'newest' ? 'selected' : '' %>>Newness</option>
                                <option value="rating" <%= selectedSort === 'rating' ? 'selected' : '' %>>Average Rating</option>
                                <option value="price_asc" <%= selectedSort === 'price_asc' ? 'selected' : '' %>>Low to high</option>
                                <option value="price_desc" <%= selectedSort === 'price_desc' ? 'selected' : '' %>>High to low</option>
