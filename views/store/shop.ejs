<!-- views/store/shop.ejs -->
<%
  const VAT = (typeof vatRate !== 'undefined' && vatRate !== null)
    ? Number(vatRate)
    : 0.15;

  const CURRENCY = String(typeof baseCurrency !== 'undefined' ? baseCurrency : '').trim().toUpperCase() || 'USD';

  function formatMoney(amount) {
    const n = Number(amount || 0);

    const formatted = new Intl.NumberFormat(undefined, {
      style: 'currency',
      currency: CURRENCY,
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    }).format(n);

    if (CURRENCY === 'ZAR') {
      return formatted.replace(/^ZAR\s?/, 'R');
    }

    return formatted;
  }

  function storeProductPayload(product) {
    return encodeURIComponent(JSON.stringify({
      customId: product.customId || '',
      name: product.name || '',
      image: product.image || product.imageUrl || '',
      sizes: Array.isArray(product.sizes) ? product.sizes : [],
      colors: Array.isArray(product.colors) ? product.colors : [],
      colorImages: Array.isArray(product.colorImages) ? product.colorImages : []
    }));
  }

  function shopPageUrl(pageNumber) {
    const params = [];

    if (selectedKeyword) {
      params.push('keyword=' + encodeURIComponent(selectedKeyword));
    }

    if (selectedCategory) {
      params.push('category=' + encodeURIComponent(selectedCategory));
    }

    if (selectedSort && selectedSort !== 'default') {
      params.push('sort=' + encodeURIComponent(selectedSort));
    }

    params.push('page=' + encodeURIComponent(pageNumber));

    return '/store/shop?' + params.join('&') + '#shopProductsSection';
  }
%>

