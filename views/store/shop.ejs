                            <img src="<%= shopSidebarBanner.image %>" class="img-fluid w-100 rounded" alt="<%= shopSidebarBanner.productName || shopSidebarBanner.title %>">
                            <div class="text-center position-absolute d-flex flex-column align-items-center justify-content-center rounded p-4" style="width: 100%; height: 100%; top: 0; right: 0; background: rgba(242, 139, 0, 0.3);">
                                <h5 class="display-6 text-primary"><%= shopSidebarBanner.title %></h5>
                                <h4 class="text-secondary"><%= shopSidebarBanner.subtitle %></h4>
                                <span class="btn btn-primary rounded-pill px-4"><%= shopSidebarBanner.buttonText || 'Shop Now' %></span>
