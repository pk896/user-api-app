                    <% (featuredSidebarProducts || []).forEach(function(product) { %>
                        <a href="<%= product.url %>" class="featured-product-item mb-3 d-flex text-decoration-none text-dark">
                            <div class="rounded me-4" style="width: 100px; height: 100px;">
                                <img src="<%= product.image %>" class="img-fluid rounded" alt="<%= product.name %>">
                            </div>
                            <div>
                                <h6 class="mb-2"><%= product.category %></h6>
                                <div class="mb-2">
                                    <%- include('../partials/rating-stars', {
                                        avg: Number(product.avgRating || 0),
                                        count: Number(product.ratingsCount || 0),
                                        nonce
                                    }) %>
                                </div>
                                <div class="d-flex mb-2 align-items-center flex-wrap">
                                    <h5 class="fw-bold me-2 mb-0"><%= formatMoney(Number(product.price || 0) * (1 + VAT)) %></h5>
                                    <small class="text-muted me-2">incl. VAT</small>
                                    <% if (product.oldPrice) { %>
                                        <h5 class="text-danger text-decoration-line-through mb-0"><%= formatMoney(product.oldPrice) %></h5>
                                    <% } %>
                                </div>
                            </div>
                        </a>
                    <% }) %>

                    <div class="d-flex justify-content-center my-4">
                        <a href="/products/sales" class="btn btn-primary px-4 py-3 rounded-pill w-100">View More</a>
                    </div>
                </div>
