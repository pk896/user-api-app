<!--views/store/partials/cart-script-single.ejs-->
<script nonce="<%= nonce %>">
  (function () {
    let activeChooserCard = null;

    function round2(n) {
      return Math.round(Number(n || 0) * 100) / 100;
    }

    function getCartSummary(items) {
      const list = Array.isArray(items) ? items : [];

      return list.reduce(function (acc, item) {
        const quantity = Number(item.quantity || 0);
        const price = Number(item.price || 0);

        acc.count += quantity;
        acc.total += price * quantity;
        return acc;
      }, { count: 0, total: 0 });
    }

    function updateCartHeader(items) {
      const summary = getCartSummary(items);
      const totalEls = document.querySelectorAll('.store-cart-total');
      const mobileFloatingCart = document.getElementById('mobileFloatingCart');

      totalEls.forEach(function (el) {
        el.textContent = '$' + round2(summary.total).toFixed(2);
      });

      if (mobileFloatingCart) {
        if (summary.count > 0) {
          mobileFloatingCart.classList.remove('d-none');
        } else {
          mobileFloatingCart.classList.add('d-none');
        }
      }
    }

    function showCartMessage(message, type) {
      const wrapper = document.createElement('div');
      wrapper.className = 'position-fixed top-0 end-0 p-3';
      wrapper.style.zIndex = '1080';

      wrapper.innerHTML = [
        '<div class="alert alert-' + (type || 'success') + ' alert-dismissible fade show shadow-sm mb-0" role="alert">',
        '  ' + String(message || 'Done'),
        '  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>',
        '</div>'
      ].join('');

      document.body.appendChild(wrapper);

      window.setTimeout(function () {
        wrapper.remove();
      }, 3000);
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function normalizeArray(value) {
      if (!Array.isArray(value)) return [];
      return value
        .map(function (item) { return String(item || '').trim(); })
        .filter(Boolean);
    }

    function normalizeColorImages(value) {
      if (!Array.isArray(value)) return [];
      return value
        .map(function (entry) {
          return {
            color: String(entry && entry.color ? entry.color : '').trim(),
            imageUrl: String(entry && entry.imageUrl ? entry.imageUrl : '').trim()
          };
        })
        .filter(function (entry) {
          return entry.color && entry.imageUrl;
        });
    }

    function parseProductData(button) {
      if (!button) return null;

      const raw = button.getAttribute('data-product');
      if (!raw) return null;

      try {
        const decoded = decodeURIComponent(raw);
        const parsed = JSON.parse(decoded);
        parsed.sizes = normalizeArray(parsed.sizes);
        parsed.colors = normalizeArray(parsed.colors);
        parsed.colorImages = normalizeColorImages(parsed.colorImages);
        parsed.image = String(parsed.image || '').trim();
        parsed.customId = String(parsed.customId || '').trim();
        parsed.name = String(parsed.name || '').trim();
        return parsed;
      } catch (err) {
        console.error('Failed to parse product data:', err, raw);
        return null;
      }
    }

    function requiresChooser(product) {
      if (!product) return false;
      return (product.sizes && product.sizes.length > 0) || (product.colors && product.colors.length > 0);
    }

    function getColorImage(product, color) {
      const picked = String(color || '').trim().toLowerCase();
      if (!picked) return product.image || '';

      const match = (product.colorImages || []).find(function (entry) {
        return String(entry.color || '').trim().toLowerCase() === picked;
      });

      return (match && match.imageUrl) || product.image || '';
    }

    function getSingleQuantity() {
      const qtyInput = document.querySelector('.quantity input.form-control');
      const parsedQty = Number(qtyInput && qtyInput.value ? qtyInput.value : 1);

      if (!Number.isFinite(parsedQty) || parsedQty < 1) {
        return 1;
      }

      return Math.floor(parsedQty);
    }

    function applyChooserLayout(chooser, button) {
      if (!chooser) return;

      const gap = 10;
      const viewportPadding = 12;
      const isMobile = window.innerWidth < 576;

      chooser.style.position = 'fixed';
      chooser.style.right = 'auto';
      chooser.style.bottom = 'auto';
      chooser.style.transform = 'none';
      chooser.style.zIndex = '1095';
      chooser.style.width = isMobile ? 'calc(100vw - 32px)' : '340px';
      chooser.style.maxWidth = '340px';
      chooser.style.maxHeight = 'calc(100vh - 24px)';
      chooser.style.overflowY = 'auto';

      const body = chooser.querySelector('.card-body');
      if (body) {
        body.className = 'card-body p-2';
      }

      const status = chooser.querySelector('.js-variant-status');
      if (status) {
        status.className = 'js-variant-status small text-secondary mb-2';
      }

      chooser.querySelectorAll('.js-color-choice').forEach(function (btn) {
        btn.className = 'btn btn-sm rounded-pill d-inline-flex align-items-center gap-1 js-color-choice';
      });

      chooser.querySelectorAll('.js-size-choice').forEach(function (btn) {
        btn.className = 'btn btn-sm rounded-pill js-size-choice';
      });

      const confirmBtn = chooser.querySelector('.js-variant-confirm');
      if (confirmBtn) {
        confirmBtn.className = 'btn btn-sm rounded-pill js-variant-confirm';
      }

      const viewBtn = chooser.querySelector('.js-variant-view');
      if (viewBtn) {
        viewBtn.className = 'btn btn-sm rounded-pill js-variant-view';
      }

      if (isMobile || !button) {
        chooser.style.top = '50%';
        chooser.style.left = '50%';
        chooser.style.transform = 'translate(-50%, -50%)';
        return;
      }

      const buttonRect = button.getBoundingClientRect();
      const chooserRect = chooser.getBoundingClientRect();

      let left = buttonRect.left + (buttonRect.width / 2) - (chooserRect.width / 2);
      let top = buttonRect.bottom + gap;

      const fitsBelow = (buttonRect.bottom + gap + chooserRect.height + viewportPadding) <= window.innerHeight;
      const fitsAbove = (buttonRect.top - gap - chooserRect.height - viewportPadding) >= 0;

      if (!fitsBelow && fitsAbove) {
        top = buttonRect.top - chooserRect.height - gap;
      }

      if (left < viewportPadding) {
        left = viewportPadding;
      }

      if (left + chooserRect.width > window.innerWidth - viewportPadding) {
        left = window.innerWidth - chooserRect.width - viewportPadding;
      }

      if (top < viewportPadding) {
        top = viewportPadding;
      }

      if (top + chooserRect.height > window.innerHeight - viewportPadding) {
        top = window.innerHeight - chooserRect.height - viewportPadding;
      }

      chooser.style.left = left + 'px';
      chooser.style.top = top + 'px';
    }

    function getOrCreateChooser(card, isSingle) {
      if (!card) return null;

      let chooser = card.querySelector('.js-variant-chooser');
      if (chooser) return chooser;

      chooser = document.createElement('div');
      chooser.className = 'js-variant-chooser card shadow border-0 d-none';
      chooser.style.position = 'fixed';
      chooser.style.top = '50%';
      chooser.style.left = '50%';
      chooser.style.right = 'auto';
      chooser.style.bottom = 'auto';
      chooser.style.transform = 'translate(-50%, -50%)';
      chooser.style.zIndex = '1095';
      chooser.style.width = 'calc(100vw - 32px)';
      chooser.style.maxWidth = '340px';
      chooser.style.maxHeight = 'calc(100vh - 24px)';
      chooser.style.overflowY = 'auto';

      chooser.innerHTML = [
        '<div class="card-body p-2">',
        '  <div class="border rounded-3 overflow-hidden mb-2 d-flex align-items-center justify-content-center bg-white" style="height: 144px; border-color: #7C3AED !important;">',
        '    <img src="" alt="Variant preview" class="js-variant-preview img-fluid w-100 h-100" style="object-fit: contain;">',
        '  </div>',
        '  <div class="js-variant-title fw-semibold small mb-1" style="color: #7C3AED;"></div>',
        '  <div class="js-variant-status small text-secondary mb-2">Choose required options</div>',
        '  <div class="js-color-wrap d-none mb-2">',
        '    <div class="fw-semibold small mb-1" style="color: #7C3AED;">Color</div>',
        '    <div class="js-color-options d-flex flex-wrap gap-1"></div>',
        '  </div>',
        '  <div class="js-size-wrap d-none mb-2">',
        '    <div class="fw-semibold small mb-1" style="color: #7C3AED;">Size</div>',
        '    <div class="js-size-options d-flex flex-wrap gap-1"></div>',
        '  </div>',
        '  <div class="d-grid gap-1">',
        '    <button type="button" class="btn btn-sm rounded-pill js-variant-confirm" disabled style="background-color: #7C3AED; border-color: #7C3AED; color: #fff;">',
        '      <i class="fas fa-shopping-cart me-1"></i>Add To Cart',
        '    </button>',
        '    <a href="#" class="btn btn-sm rounded-pill js-variant-view" style="border-color: #D4AF37; color: #7C3AED; background-color: #fff;">',
        '      <i class="fas fa-eye me-1"></i>View Product',
        '    </a>',
        '  </div>',
        '</div>'
      ].join('');

      if (isSingle) {
        const anchorButton = card.querySelector('.js-single-add-to-cart');
        if (anchorButton && anchorButton.parentNode) {
          anchorButton.insertAdjacentElement('afterend', chooser);
        } else {
          card.appendChild(chooser);
        }
      } else {
        card.appendChild(chooser);
      }

      return chooser;
    }

    function updateChooserStatus(chooser, product) {
      if (!chooser) return;

      const selectedColor = String(chooser.getAttribute('data-selected-color') || '').trim();
      const selectedSize = String(chooser.getAttribute('data-selected-size') || '').trim();
      const status = chooser.querySelector('.js-variant-status');
      const preview = chooser.querySelector('.js-variant-preview');
      const confirmBtn = chooser.querySelector('.js-variant-confirm');

      const needsColor = Array.isArray(product.colors) && product.colors.length > 0;
      const needsSize = Array.isArray(product.sizes) && product.sizes.length > 0;

      if (preview) {
        preview.src = getColorImage(product, selectedColor) || product.image || '';
        preview.style.objectFit = 'contain';
      }

      if (status) {
        if (needsColor && needsSize) {
          if (selectedColor && selectedSize) {
            status.textContent = 'Ready: ' + selectedColor + ' / ' + selectedSize;
          } else if (selectedColor) {
            status.textContent = 'Color selected. Choose size.';
          } else if (selectedSize) {
            status.textContent = 'Size selected. Choose color.';
          } else {
            status.textContent = 'Choose color and size';
          }
        } else if (needsColor) {
          status.textContent = selectedColor ? ('Ready: ' + selectedColor) : 'Choose color';
        } else if (needsSize) {
          status.textContent = selectedSize ? ('Ready: ' + selectedSize) : 'Choose size';
        } else {
          status.textContent = 'Ready to add';
        }
      }

      if (confirmBtn) {
        const ready =
          (!needsColor || !!selectedColor) &&
          (!needsSize || !!selectedSize);

        confirmBtn.disabled = !ready;
      }
    }

    function setChooserState(card, product, sourceButton, isSingle) {
      const chooser = getOrCreateChooser(card, isSingle);
      if (!chooser) return;

      const preview = chooser.querySelector('.js-variant-preview');
      const title = chooser.querySelector('.js-variant-title');
      const colorWrap = chooser.querySelector('.js-color-wrap');
      const colorOptions = chooser.querySelector('.js-color-options');
      const sizeWrap = chooser.querySelector('.js-size-wrap');
      const sizeOptions = chooser.querySelector('.js-size-options');
      const confirmBtn = chooser.querySelector('.js-variant-confirm');
      const viewLink = chooser.querySelector('.js-variant-view');

      chooser.setAttribute('data-pid', product.customId || '');
      chooser.setAttribute('data-selected-color', '');
      chooser.setAttribute('data-selected-size', '');
      chooser.setAttribute('data-is-single', isSingle ? '1' : '0');

      if (viewLink) {
        viewLink.setAttribute('href', '/store/product/' + encodeURIComponent(product.customId || ''));
      }

      if (preview) preview.src = product.image || '';
      if (title) title.textContent = product.name || 'Product';

      if (colorWrap) {
        colorWrap.classList.toggle('d-none', !(product.colors && product.colors.length > 0));
      }

      if (sizeWrap) {
        sizeWrap.classList.toggle('d-none', !(product.sizes && product.sizes.length > 0));
      }

      if (colorOptions) {
        colorOptions.innerHTML = (product.colors || []).map(function (color) {
          const img = getColorImage(product, color);
          return [
            '<button type="button" class="btn btn-sm rounded-pill d-inline-flex align-items-center gap-1 js-color-choice" data-color="' + escapeHtml(color) + '" style="border-color: #7C3AED; color: #7C3AED; background-color: #fff;">',
            img
              ? '<span class="rounded-circle border overflow-hidden d-inline-flex align-items-center justify-content-center bg-white" style="width: 22px; height: 22px; border-color: #D4AF37 !important;">' +
                  '<img src="' + escapeHtml(img) + '" alt="' + escapeHtml(color) + '" style="width: 100%; height: 100%; object-fit: contain;">' +
                '</span>'
              : '',
            '<span class="small">' + escapeHtml(color) + '</span>',
            '</button>'
          ].join('');
        }).join('');
      }

      if (sizeOptions) {
        sizeOptions.innerHTML = (product.sizes || []).map(function (size) {
          return '<button type="button" class="btn btn-sm rounded-pill js-size-choice" data-size="' + escapeHtml(size) + '" style="border-color: #D4AF37; color: #7C3AED; background-color: #fff;">' + escapeHtml(size) + '</button>';
        }).join('');
      }

      if (confirmBtn) {
        confirmBtn.setAttribute('data-pid', product.customId || '');
        confirmBtn.setAttribute('data-source', isSingle ? 'single' : 'listing');
        confirmBtn.setAttribute('data-origin-button-class', sourceButton && sourceButton.classList.contains('js-single-add-to-cart') ? 'js-single-add-to-cart' : 'js-add-to-cart');
      }

      updateChooserStatus(chooser, product);
    }

    function closeChooser(card) {
      if (!card) return;
      const chooser = card.querySelector('.js-variant-chooser');
      if (chooser) chooser.classList.add('d-none');
      if (activeChooserCard === card) activeChooserCard = null;
    }

    function openChooser(card, button, product, isSingle) {
      if (!card || !button || !product || !requiresChooser(product)) return;

      if (activeChooserCard && activeChooserCard !== card) {
        closeChooser(activeChooserCard);
      }

      setChooserState(card, product, button, isSingle);

      const chooser = getOrCreateChooser(card, isSingle);
      if (!chooser) return;

      chooser.classList.remove('d-none');
      applyChooserLayout(chooser, button);

      window.requestAnimationFrame(function () {
        applyChooserLayout(chooser, button);

        const preview = chooser.querySelector('.js-variant-preview');
        if (preview) {
          if (preview.complete) {
            applyChooserLayout(chooser, button);
          } else {
            preview.onload = function () {
              applyChooserLayout(chooser, button);
            };
          }
        }
      });

      activeChooserCard = card;
    }

    function getSelectedVariants(chooser) {
      const variants = {};
      const color = String(chooser.getAttribute('data-selected-color') || '').trim();
      const size = String(chooser.getAttribute('data-selected-size') || '').trim();

      if (color) variants.color = color;
      if (size) variants.size = size;

      return variants;
    }

    async function refreshCartHeader() {
      try {
        const res = await fetch('/api/cart', {
          headers: { 'Accept': 'application/json' }
        });

        const data = await res.json();
        updateCartHeader((data && data.items) || []);
      } catch (err) {
        console.error('Failed to refresh cart header:', err);
      }
    }

    async function addToCart(pid, qty, variants) {
      let url =
        '/api/cart/add?pid=' +
        encodeURIComponent(pid) +
        '&qty=' +
        encodeURIComponent(qty || 1) +
        '&json=1';

      if (variants && variants.color) {
        url += '&color=' + encodeURIComponent(variants.color);
      }

      if (variants && variants.size) {
        url += '&size=' + encodeURIComponent(variants.size);
      }

      const res = await fetch(url, {
        method: 'GET',
        headers: { 'Accept': 'application/json' }
      });

      const data = await res.json();

      if (!res.ok || data.success === false) {
        throw new Error(data.message || 'Failed to add to cart.');
      }

      const items = (data.cart && data.cart.items) || [];
      updateCartHeader(items);
      return data;
    }

    async function changeCartQuantity(pid, mode, variants) {
      const endpoint = mode === 'decrease' ? '/api/cart/decrease' : '/api/cart/increase';

      const res = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          pid: pid,
          variants: variants || {}
        })
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.message || 'Failed to update cart quantity.');
      }

      const items = Array.isArray(data.items) ? data.items : [];
      updateCartHeader(items);
      return items;
    }

    function safeParseVariants(raw) {
      if (!raw) return {};
      try {
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === 'object' ? parsed : {};
      } catch (err) {
        return {};
      }
    }

    function normVariants(v) {
      const source = v && typeof v === 'object' ? v : {};
      const output = {};
      Object.keys(source).sort().forEach(function (key) {
        output[key] = String(source[key] == null ? '' : source[key]).trim();
      });
      return output;
    }

    function variantsEqual(a, b) {
      return JSON.stringify(normVariants(a)) === JSON.stringify(normVariants(b));
    }

    function cartLineMatches(item, pid, variants) {
      if (!item) return false;

      const samePid =
        String(item.customId || '').trim() === String(pid || '').trim();

      if (!samePid) return false;

      const itemVariants = item.variants || {};
      const wantedVariants = variants || {};

      return variantsEqual(itemVariants, wantedVariants);
    }

    function getMatchingCartQuantity(items, pid, variants) {
      const list = Array.isArray(items) ? items : [];
      const match = list.find(function (item) {
        return cartLineMatches(item, pid, variants);
      });

      return match ? Number(match.quantity || 1) : 0;
    }

    document.addEventListener('click', async function (event) {
      const minusBtn = event.target.closest('.btn-minus');
      const plusBtn = event.target.closest('.btn-plus');
      const qtyInput = document.querySelector('.quantity input.form-control');
      const addBtn = document.querySelector('.js-single-add-to-cart');

      if (!qtyInput) return;

      if (minusBtn) {
        event.preventDefault();

        const current = Number(qtyInput.value || 1);
        const currentSafe = Number.isFinite(current) && current > 0 ? Math.floor(current) : 1;

        if (!addBtn || addBtn.getAttribute('data-in-cart') !== '1') {
          qtyInput.value = Math.max(1, currentSafe - 1);
          return;
        }

        const pid = addBtn.getAttribute('data-pid');
        const variants = safeParseVariants(addBtn.getAttribute('data-cart-variants'));

        minusBtn.classList.add('disabled');
        minusBtn.setAttribute('aria-disabled', 'true');

        try {
          const items = await changeCartQuantity(pid, 'decrease', variants);
          const nextQty = getMatchingCartQuantity(items, pid, variants);

          if (nextQty <= 0) {
            qtyInput.value = 1;
            addBtn.setAttribute('data-in-cart', '0');
            addBtn.setAttribute('data-cart-variants', '');
          } else {
            qtyInput.value = nextQty;
          }
        } catch (err) {
          showCartMessage(err.message || 'Failed to decrease quantity.', 'danger');
        } finally {
          minusBtn.classList.remove('disabled');
          minusBtn.removeAttribute('aria-disabled');
        }

        return;
      }

      if (plusBtn) {
        event.preventDefault();

        const current = Number(qtyInput.value || 1);
        const currentSafe = Number.isFinite(current) && current > 0 ? Math.floor(current) : 1;

        if (!addBtn || addBtn.getAttribute('data-in-cart') !== '1') {
          qtyInput.value = Math.max(1, currentSafe + 1);
          return;
        }

        const pid = addBtn.getAttribute('data-pid');
        const variants = safeParseVariants(addBtn.getAttribute('data-cart-variants'));

        plusBtn.classList.add('disabled');
        plusBtn.setAttribute('aria-disabled', 'true');

        try {
          const items = await changeCartQuantity(pid, 'increase', variants);
          const nextQty = getMatchingCartQuantity(items, pid, variants);
          qtyInput.value = nextQty > 0 ? nextQty : currentSafe + 1;
        } catch (err) {
          showCartMessage(err.message || 'Failed to increase quantity.', 'danger');
        } finally {
          plusBtn.classList.remove('disabled');
          plusBtn.removeAttribute('aria-disabled');
        }
      }
    });

    document.addEventListener('click', function (event) {
      const colorBtn = event.target.closest('.js-color-choice');
      if (colorBtn) {
        event.preventDefault();
        const chooser = colorBtn.closest('.js-variant-chooser');
        if (!chooser) return;

        const card = chooser.parentElement;
        const trigger = card && (card.querySelector('.js-single-add-to-cart') || card.querySelector('.js-add-to-cart'));
        const product = parseProductData(trigger);
        if (!product) return;

        chooser.setAttribute('data-selected-color', colorBtn.getAttribute('data-color') || '');

        chooser.querySelectorAll('.js-color-choice').forEach(function (btn) {
          btn.classList.remove('active');
        });
        colorBtn.classList.add('active');

        updateChooserStatus(chooser, product);
        return;
      }

      const sizeBtn = event.target.closest('.js-size-choice');
      if (sizeBtn) {
        event.preventDefault();
        const chooser = sizeBtn.closest('.js-variant-chooser');
        if (!chooser) return;

        const card = chooser.parentElement;
        const trigger = card && (card.querySelector('.js-single-add-to-cart') || card.querySelector('.js-add-to-cart'));
        const product = parseProductData(trigger);
        if (!product) return;

        chooser.setAttribute('data-selected-size', sizeBtn.getAttribute('data-size') || '');

        chooser.querySelectorAll('.js-size-choice').forEach(function (btn) {
          btn.classList.remove('active');
        });
        sizeBtn.classList.add('active');

        updateChooserStatus(chooser, product);
      }
    });

    document.addEventListener('click', async function (event) {
      const confirmBtn = event.target.closest('.js-variant-confirm');
      if (confirmBtn) {
        event.preventDefault();

        const chooser = confirmBtn.closest('.js-variant-chooser');
        if (!chooser) return;

        const card = chooser.parentElement;
        const trigger = card && (card.querySelector('.js-single-add-to-cart') || card.querySelector('.js-add-to-cart'));
        const product = parseProductData(trigger);
        const pid = confirmBtn.getAttribute('data-pid');

        if (!product || !pid) return;

        const qty = confirmBtn.getAttribute('data-source') === 'single' ? getSingleQuantity() : 1;
        const variants = getSelectedVariants(chooser);

        const originalHtml = confirmBtn.innerHTML;
        confirmBtn.classList.add('disabled');
        confirmBtn.setAttribute('aria-disabled', 'true');
        confirmBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Adding...';

        try {
          const data = await addToCart(pid, qty, variants);

          if (trigger && trigger.classList.contains('js-single-add-to-cart')) {
            const cartItems = (data && data.cart && Array.isArray(data.cart.items)) ? data.cart.items : [];

            trigger.setAttribute('data-in-cart', '1');
            trigger.setAttribute('data-cart-variants', JSON.stringify(variants || {}));

            const qtyInput = document.querySelector('.quantity input.form-control');
            const actualQty = getMatchingCartQuantity(cartItems, pid, variants || {});
            if (qtyInput) qtyInput.value = actualQty > 0 ? actualQty : qty;
          }

          showCartMessage(data.message || 'Added to cart.', 'success');
          closeChooser(card);
        } catch (err) {
          showCartMessage(err.message || 'Failed to add to cart.', 'danger');
        } finally {
          confirmBtn.classList.remove('disabled');
          confirmBtn.removeAttribute('aria-disabled');
          confirmBtn.innerHTML = originalHtml;
        }
        return;
      }

      const button = event.target.closest('.js-single-add-to-cart, .js-add-to-cart');
      if (!button) return;

      event.preventDefault();

      const pid = button.getAttribute('data-pid');
      if (!pid) return;

      const product = parseProductData(button);
      const isSingle = button.classList.contains('js-single-add-to-cart');

      if (product && requiresChooser(product)) {
        const card = isSingle
          ? button.closest('.js-single-product-card')
          : button.closest('.js-store-product-card');

        openChooser(card, button, product, isSingle);
        return;
      }

      const qty = isSingle ? getSingleQuantity() : 1;

      const originalHtml = button.innerHTML;
      button.classList.add('disabled');
      button.setAttribute('aria-disabled', 'true');
      button.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Adding...';

      try {
        const data = await addToCart(pid, qty);

        if (isSingle) {
          const emptyVariants = {};
          const cartItems = (data && data.cart && Array.isArray(data.cart.items)) ? data.cart.items : [];

          button.setAttribute('data-in-cart', '1');
          button.setAttribute('data-cart-variants', JSON.stringify(emptyVariants));

          const qtyInput = document.querySelector('.quantity input.form-control');
          const actualQty = getMatchingCartQuantity(cartItems, pid, emptyVariants);
          if (qtyInput) qtyInput.value = actualQty > 0 ? actualQty : qty;
        }

        showCartMessage(data.message || 'Added to cart.', 'success');
      } catch (err) {
        showCartMessage(err.message || 'Failed to add to cart.', 'danger');
      } finally {
        button.classList.remove('disabled');
        button.removeAttribute('aria-disabled');
        button.innerHTML = originalHtml;
      }
    });

    document.addEventListener('click', function (event) {
      if (event.target.closest('.js-variant-chooser')) return;
      if (event.target.closest('.js-single-add-to-cart')) return;
      if (event.target.closest('.js-add-to-cart')) return;

      if (activeChooserCard) {
        closeChooser(activeChooserCard);
      }
    });

    window.addEventListener('resize', function () {
      if (!activeChooserCard) return;

      const chooser = activeChooserCard.querySelector('.js-variant-chooser');
      const button =
        activeChooserCard.querySelector('.js-single-add-to-cart') ||
        activeChooserCard.querySelector('.js-add-to-cart');

      if (!chooser || chooser.classList.contains('d-none')) return;

      applyChooserLayout(chooser, button);
    });

    window.addEventListener('scroll', function () {
      if (!activeChooserCard) return;
      closeChooser(activeChooserCard);
    }, true);

    refreshCartHeader();
  })();
</script>