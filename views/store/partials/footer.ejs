<!--views/store/partials/footer.ejs-->
<!-- Footer Start -->
<div class="container-fluid footer py-5 wow fadeIn" data-wow-delay="0.2s">
    <div class="container py-4">
        <div class="row g-4 align-items-center justify-content-between">
            <div class="col-lg-6">
                <div class="d-flex flex-wrap align-items-center gap-3">
                    <a href="/home" class="d-inline-flex align-items-center gap-2 text-decoration-none">
                        <img
                            src="/images/branding/logo-unincorporate.png"
                            alt="Unicoporate"
                            width="34"
                            height="34"
                            style="border-radius: 8px; object-fit: contain; box-shadow: 0 1px 6px rgba(15,23,42,.14);"
                            loading="lazy"
                            decoding="async"
                        >
                        <span class="h5 mb-0 text-white fw-semibold">Unicoporate</span>
                    </a>

                    <span class="text-white-50">
                        Your trusted marketplace for products, suppliers, and business growth.
                    </span>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="d-flex flex-wrap justify-content-lg-end gap-3 gap-md-4">
                    <a class="text-white text-decoration-none" href="/contact">Contact</a>
                    <a class="text-white text-decoration-none" href="/privacy">Privacy</a>
                    <a class="text-white text-decoration-none" href="/terms">Terms</a>
                    <a class="text-white text-decoration-none" href="/users/about">About</a>
                    <a class="text-white text-decoration-none" href="/products/sales">Shop</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Footer End -->

<!-- Copyright Start -->
<div class="container-fluid copyright py-4">
    <div class="container">
        <div class="row g-3 align-items-center">
            <div class="col-md-6 text-center text-md-start">
                <span class="text-white">
                    © <span id="store-footer-year"></span>
                    <a href="/home" class="border-bottom text-white">Unicoporate</a>.
                    All rights reserved.
                </span>
            </div>
            <div class="col-md-6 text-center text-md-end">
                <span class="text-white">
                    Built for modern commerce, trusted by buyers and sellers.
                </span>
            </div>
        </div>
    </div>
</div>
<!-- Copyright End -->

<script nonce="<%= nonce %>">
  (function () {
    const el = document.getElementById('store-footer-year');
    if (el) el.textContent = new Date().getFullYear();
  })();
</script>
