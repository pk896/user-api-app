// views/store/order-tracking.ejs
<%
  const CURRENCY = String(typeof baseCurrency !== 'undefined' ? baseCurrency : '').trim().toUpperCase() || 'USD';

  const orderData = typeof publicOrder !== 'undefined' ? publicOrder : null;
  const formData = typeof form !== 'undefined' ? form : {};
  const wasSearched = !!searched;
  const pageError = typeof errorMessage !== 'undefined' ? errorMessage : '';
%>

<!-- Spinner Start -->
<div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
  <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
    <span class="sr-only">Loading...</span>
  </div>
</div>
<!-- Spinner End -->

<!-- Topbar Start -->
<div class="container-fluid px-5 d-none border-bottom d-lg-block">
  <div class="row gx-0 align-items-center">
    <div class="col-lg-4 text-center text-lg-start mb-lg-0">
      <div class="d-inline-flex align-items-center" style="height: 45px;">
        <a href="#" class="text-muted me-2"> Help</a><small> / </small>
        <a href="#" class="text-muted mx-2"> Support</a><small> / </small>
        <a href="/store/contact" class="text-muted ms-2"> Contact</a>
      </div>
    </div>

    <div class="col-lg-4 text-center d-flex align-items-center justify-content-center">
      <small class="text-dark">Call Us:</small>
      <a href="#" class="text-muted">(+012) 1234 567890</a>
    </div>

    <div class="col-lg-4 text-center text-lg-end">
      <div class="d-inline-flex align-items-center" style="height: 45px;">
        <div class="dropdown">
          <a href="#" class="dropdown-toggle text-muted me-2" data-bs-toggle="dropdown">
            <small><%= CURRENCY === 'ZAR' ? 'R' : CURRENCY %></small>
          </a>
          <div class="dropdown-menu rounded">
            <a href="#" class="dropdown-item"> Euro</a>
            <a href="#" class="dropdown-item"> Dolar</a>
          </div>
        </div>

        <div class="dropdown">
          <a href="#" class="dropdown-toggle text-muted mx-2" data-bs-toggle="dropdown">
            <small>English</small>
          </a>
          <div class="dropdown-menu rounded">
            <a href="#" class="dropdown-item"> English</a>
            <a href="#" class="dropdown-item"> Turkish</a>
            <a href="#" class="dropdown-item"> Spanol</a>
            <a href="#" class="dropdown-item"> Italiano</a>
          </div>
        </div>

        <div class="dropdown">
          <a href="#" class="dropdown-toggle text-muted ms-2" data-bs-toggle="dropdown">
            <small><i class="fa fa-home me-2"></i> My Dashboard</small>
          </a>
          <div class="dropdown-menu rounded">
            <a href="#" class="dropdown-item"> Login</a>
            <a href="#" class="dropdown-item"> Wishlist</a>
            <a href="/store/cart" class="dropdown-item"> My Cart</a>
            <a href="/store/order-tracking" class="dropdown-item"> Order status</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container-fluid px-5 py-4 d-none d-lg-block">
  <div class="row gx-0 align-items-center text-center">
    <div class="col-md-4 col-lg-3 text-center text-lg-start">
      <div class="d-inline-flex align-items-center">
        <a href="/store" class="navbar-brand p-0 d-inline-flex align-items-center">
          <img
            src="/images/branding/logo-unincorporate.png"
            alt="Unicoporate.com"
            class="img-fluid me-2"
            style="max-height: 52px; width: auto;"
          >
          <span class="fw-bold text-primary" style="font-size: 1.5rem; line-height: 1;">
            Unicoporate.com
          </span>
        </a>
      </div>
    </div>

    <div class="col-md-4 col-lg-6 text-center">
      <div class="text-primary fw-semibold">
        Track your order safely using your order number and email address.
      </div>
    </div>

    <div class="col-md-4 col-lg-3 text-center text-lg-end">
      <div class="d-inline-flex align-items-center">
        <a href="/store/cart" class="text-muted d-flex align-items-center justify-content-center store-cart-link">
          <span class="rounded-circle btn-md-square border">
            <i class="fas fa-shopping-cart"></i>
          </span>
          <span class="text-dark ms-2 store-cart-total">0.00</span>
        </a>
      </div>
    </div>
  </div>
</div>
<!-- Topbar End -->

<!-- Navbar Start -->
<div class="container-fluid nav-bar p-0">
  <div class="row gx-0 bg-primary px-3 px-lg-5 align-items-center">
    <div class="col-12">
      <nav class="navbar navbar-expand-lg navbar-light bg-primary w-100 px-3 px-lg-0 justify-content-between flex-nowrap">
        <a href="/store" class="navbar-brand d-flex d-lg-none align-items-center m-0 me-2 flex-grow-1 overflow-hidden">
          <img
            src="/images/branding/logo-unincorporate.png"
            alt="Unicoporate.com"
            class="img-fluid me-2 flex-shrink-0"
            style="max-height: 38px; width: auto;"
          >
          <span class="h5 text-white m-0 text-truncate fw-bold">
            Unicoporate.com
          </span>
        </a>

        <button class="navbar-toggler ms-2 flex-shrink-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
          <span class="fa fa-bars fa-1x"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarCollapse">
          <div class="navbar-nav ms-auto py-0">
            <a href="/store" class="nav-item nav-link">Shopping home</a>
            <a href="/store/shop" class="nav-item nav-link">Shop</a>
            <a href="/products/sales" class="nav-item nav-link">Fast liner</a>
            <a href="/store/bestseller" class="nav-item nav-link">Bestseller</a>
            <a href="/store/cart" class="nav-item nav-link">Cart</a>
            <a href="/store/order-tracking" class="nav-item nav-link active">Order status</a>
            <a href="/store/contact" class="nav-item nav-link me-2">Contact</a>
          </div>
        </div>
      </nav>
    </div>
  </div>
</div>
<!-- Navbar End -->

<!-- Header Start -->
<div class="container-fluid page-header py-5" style="<%= shopHeaderImage && shopHeaderImage.image ? '--page-header-image: url(' + shopHeaderImage.image + ')' : '' %>">
  <h1 class="text-center text-white display-6 wow fadeInUp" data-wow-delay="0.1s">Track Your Order</h1>
  <ol class="breadcrumb justify-content-center mb-0 wow fadeInUp" data-wow-delay="0.3s">
    <li class="breadcrumb-item"><a href="/store">Shopping home</a></li>
    <li class="breadcrumb-item active text-white">Order status</li>
  </ol>
</div>
<!-- Header End -->

<div class="container-fluid py-5">
  <div class="container py-5">
    <div class="row g-4 justify-content-center">
      <div class="col-12 col-lg-5">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-primary text-white">
            <h2 class="h5 mb-0 text-white">Find your order</h2>
          </div>

          <div class="card-body p-4">
            <% if (pageError) { %>
              <div class="alert alert-danger" role="alert">
                <%= pageError %>
              </div>
            <% } %>

            <form action="/store/order-tracking" method="POST" class="d-grid gap-3">
              <div>
                <label for="orderId" class="form-label text-primary fw-semibold">Order number</label>
                <input
                  id="orderId"
                  name="orderId"
                  type="text"
                  class="form-control"
                  value="<%= formData.orderId || '' %>"
                  placeholder="Example: PAYPAL-ORDER-ID"
                  required
                >
              </div>

              <div>
                <label for="email" class="form-label text-primary fw-semibold">Email address used at checkout</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  class="form-control"
                  value="<%= formData.email || '' %>"
                  placeholder="you@example.com"
                  required
                >
              </div>

              <button type="submit" class="btn btn-primary rounded-pill py-3">
                Track Order
              </button>

              <div class="small text-muted">
                For privacy, we only show tracking details when the order number and email match.
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-7">
        <% if (!wasSearched) { %>
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4 d-flex flex-column justify-content-center">
              <h2 class="h4 text-primary mb-3">Order tracking</h2>
              <p class="mb-0">
                Enter your order number and checkout email to see your order status, shipment status, carrier, tracking number, and latest tracking updates.
              </p>
            </div>
          </div>
        <% } %>

        <% if (orderData) { %>
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
              <h2 class="h5 mb-0 text-white">Order summary</h2>
            </div>

            <div class="card-body p-4">
              <div class="row g-3">
                <div class="col-12 col-md-6">
                  <div class="border rounded-3 p-3 h-100">
                    <div class="small text-primary fw-semibold text-uppercase">Order number</div>
                    <div class="fw-bold text-break"><%= orderData.orderId || '—' %></div>
                  </div>
                </div>

                <div class="col-12 col-md-6">
                  <div class="border rounded-3 p-3 h-100">
                    <div class="small text-primary fw-semibold text-uppercase">Customer email</div>
                    <div class="fw-bold"><%= orderData.customerEmail || '—' %></div>
                  </div>
                </div>

                <div class="col-12 col-md-4">
                  <div class="border rounded-3 p-3 h-100">
                    <div class="small text-primary fw-semibold text-uppercase">Payment</div>
                    <span class="badge bg-<%= orderData.paymentStatusClass %> text-white">
                      <%= orderData.paymentStatus %>
                    </span>
                  </div>
                </div>

                <div class="col-12 col-md-4">
                  <div class="border rounded-3 p-3 h-100">
                    <div class="small text-primary fw-semibold text-uppercase">Fulfillment</div>
                    <span class="badge bg-<%= orderData.fulfillmentStatusClass %> text-white">
                      <%= orderData.fulfillmentStatus %>
                    </span>
                  </div>
                </div>

                <div class="col-12 col-md-4">
                  <div class="border rounded-3 p-3 h-100">
                    <div class="small text-primary fw-semibold text-uppercase">Tracking</div>
                    <span class="badge bg-<%= orderData.trackingStatusClass %> text-white">
                      <%= orderData.trackingStatus %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
              <h2 class="h5 mb-0 text-white">Shipping details</h2>
            </div>

            <div class="card-body p-4">
              <div class="row g-3">
                <div class="col-12 col-md-6">
                  <div class="border rounded-3 p-3 h-100">
                    <div class="small text-primary fw-semibold text-uppercase">Carrier</div>
                    <div class="fw-bold"><%= orderData.carrier || 'Not available yet' %></div>
                    <% if (orderData.service) { %>
                      <div class="small text-muted mt-1"><%= orderData.service %></div>
                    <% } %>
                  </div>
                </div>

                <div class="col-12 col-md-6">
                  <div class="border rounded-3 p-3 h-100">
                    <div class="small text-primary fw-semibold text-uppercase">Tracking number</div>
                    <div class="fw-bold text-break"><%= orderData.trackingNumber || 'Not available yet' %></div>
                  </div>
                </div>

                <div class="col-12 col-md-6">
                  <div class="border rounded-3 p-3 h-100">
                    <div class="small text-primary fw-semibold text-uppercase">Estimated delivery</div>
                    <div class="fw-bold"><%= orderData.estimatedDelivery || 'Not available yet' %></div>
                  </div>
                </div>

                <div class="col-12 col-md-6">
                  <div class="border rounded-3 p-3 h-100">
                    <div class="small text-primary fw-semibold text-uppercase">Last update</div>
                    <div class="fw-bold"><%= orderData.lastTrackingUpdate || orderData.updatedAt || '—' %></div>
                  </div>
                </div>

                <% if (orderData.trackingUrl) { %>
                  <div class="col-12">
                    <a href="<%= orderData.trackingUrl %>" target="_blank" rel="noopener noreferrer" class="btn btn-success rounded-pill px-4">
                      Open carrier tracking
                    </a>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
              <h2 class="h5 mb-0 text-white">Items in this order</h2>
            </div>

            <div class="card-body p-4">
              <div class="d-grid gap-3">
                <% (orderData.items || []).forEach(function(item) { %>
                  <div class="border rounded-3 p-3">
                    <div class="d-flex gap-3 align-items-center">
                      <% if (item.imageUrl) { %>
                        <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="rounded border" style="width:64px;height:64px;object-fit:cover;">
                      <% } %>
                      <div class="flex-grow-1">
                        <div class="fw-bold"><%= item.name %></div>
                        <div class="small text-muted">
                          Qty: <%= item.quantity %>
                          <% if (item.size) { %> | Size: <%= item.size %><% } %>
                          <% if (item.color) { %> | Color: <%= item.color %><% } %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>

          <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white">
              <h2 class="h5 mb-0 text-white">Tracking updates</h2>
            </div>

            <div class="card-body p-4">
              <% if ((orderData.events || []).length) { %>
                <div class="d-grid gap-3">
                  <% orderData.events.forEach(function(event) { %>
                    <div class="border rounded-3 p-3">
                      <div class="d-flex flex-column flex-md-row justify-content-md-between gap-2">
                        <span class="fw-bold text-primary"><%= event.status || 'Update' %></span>
                        <span class="small text-muted"><%= event.date || '' %></span>
                      </div>
                      <% if (event.details) { %>
                        <div class="mt-2"><%= event.details %></div>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="alert alert-light border mb-0">
                  No public tracking updates are available yet. Please check again later.
                </div>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<style nonce="<%= nonce %>">
  .store-cart-link.cart-flash-active .fa-shopping-cart{
    animation: cartPurpleFlash 3s infinite;
    position: relative;
    z-index: 1;
  }

  .store-cart-link.cart-flash-active .rounded-circle{
    animation: cartCirclePurpleFlash 3s infinite;
  }

  @keyframes cartPurpleFlash{
    0%, 100%{
      color: inherit;
    }

    50%{
      color: #fff;
    }
  }

  @keyframes cartCirclePurpleFlash{
    0%, 100%{
      background-color: transparent;
      border-color: inherit;
    }

    50%{
      background-color: #7C3AED;
      border-color: #7C3AED;
    }
  }
</style>

<!-- Mobile Floating Cart Start -->
<div id="mobileFloatingCart" class="d-none d-lg-none position-fixed bottom-0 start-0 mb-3 ms-3" style="z-index: 1080;">
  <a href="/store/cart" class="btn btn-primary rounded-pill shadow-sm d-inline-flex align-items-center px-2 py-1 store-cart-link" style="font-size: 0.85rem;">
    <span class="rounded-circle bg-white text-primary d-inline-flex align-items-center justify-content-center me-1" style="width: 24px; height: 24px;">
      <i class="fas fa-shopping-cart" style="font-size: 0.75rem;"></i>
    </span>
    <span class="store-cart-total text-white fw-semibold">0.00</span>
  </a>
</div>
<!-- Mobile Floating Cart End -->

<%- include('partials/cart-script-static-page') %>

<!-- Back to Top -->
<a href="#" class="btn btn-primary btn-lg-square back-to-top">
  <i class="fa fa-arrow-up"></i>
</a>
