<!-- Carousel Start -->
<div class="container-fluid carousel bg-light px-0">
    <div class="row g-0 justify-content-end">
        <div class="col-12 col-lg-7 col-xl-9">
            <div class="header-carousel owl-carousel bg-light py-5">
                <% if ((heroSlides || []).length > 0) { %>
                    <% heroSlides.forEach(function(slide) { %>
                        <div class="row g-0 header-carousel-item align-items-center">
                            <div class="col-xl-6 carousel-img wow fadeInLeft" data-wow-delay="0.1s">
                                <img src="<%= slide.image %>" class="img-fluid w-100" alt="<%= slide.title %>">
                            </div>
                            <div class="col-xl-6 carousel-content p-4">
                                <% if (slide.subtitle) { %>
                                    <h4 class="text-uppercase fw-bold mb-4 wow fadeInRight" data-wow-delay="0.1s" style="letter-spacing: 3px;">
                                        <%= slide.subtitle %>
                                    </h4>
                                <% } %>

                                <h1 class="display-3 text-capitalize mb-4 wow fadeInRight" data-wow-delay="0.3s">
                                    <%= slide.title %>
                                </h1>

                                <% if (slide.description) { %>
                                    <p class="text-dark wow fadeInRight" data-wow-delay="0.5s">
                                        <%= slide.description %>
                                    </p>
                                <% } %>

                                <a class="btn btn-primary rounded-pill py-3 px-5 wow fadeInRight" data-wow-delay="0.7s" href="<%= slide.buttonUrl %>">
                                    <%= slide.buttonText || 'Shop Now' %>
                                </a>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="row g-0 header-carousel-item align-items-center">
                        <div class="col-xl-6 carousel-img wow fadeInLeft" data-wow-delay="0.1s">
                            <img src="/electro/img/carousel-1.png" class="img-fluid w-100" alt="Default slide">
                        </div>
                        <div class="col-xl-6 carousel-content p-4">
                            <h4 class="text-uppercase fw-bold mb-4 wow fadeInRight" data-wow-delay="0.1s" style="letter-spacing: 3px;">
                                Welcome
                            </h4>
                            <h1 class="display-3 text-capitalize mb-4 wow fadeInRight" data-wow-delay="0.3s">
                                Explore Our Latest Products
                            </h1>
                            <p class="text-dark wow fadeInRight" data-wow-delay="0.5s">
                                Shop top deals and featured collections.
                            </p>
                            <a class="btn btn-primary rounded-pill py-3 px-5 wow fadeInRight" data-wow-delay="0.7s" href="/store/shop">
                                Shop Now
                            </a>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="col-12 col-lg-5 col-xl-3 wow fadeInRight" data-wow-delay="0.1s">
            <% if (sideBannerProduct) { %>
                <div class="carousel-header-banner h-100">
                    <img src="<%= sideBannerProduct.image %>" class="img-fluid w-100 h-100" style="object-fit: cover;" alt="<%= sideBannerProduct.name %>">

                    <div class="carousel-banner-offer">
                        <p class="bg-primary text-white rounded fs-5 py-2 px-4 mb-0 me-3">
                            <%= sideBannerProduct.badgeText || 'Special Offer' %>
                        </p>
                        <p class="text-primary fs-5 fw-bold mb-0">
                            <%= sideBannerProduct.offerText || 'Featured Product' %>
                        </p>
                    </div>

                    <div class="carousel-banner">
                        <div class="carousel-banner-content text-center p-4">
                            <a href="<%= sideBannerProduct.url %>" class="d-block mb-2">
                                <%= sideBannerProduct.category %>
                            </a>
                            <a href="<%= sideBannerProduct.url %>" class="d-block text-white fs-3">
                                <%= sideBannerProduct.name %>
                            </a>

                            <% if (sideBannerProduct.oldPrice) { %>
                                <del class="me-2 text-white fs-5">
                                    $<%= sideBannerProduct.oldPrice.toFixed(2) %>
                                </del>
                            <% } %>

                            <span class="text-primary fs-5">
                                $<%= sideBannerProduct.price.toFixed(2) %>
                            </span>
                        </div>

                        <a href="<%= sideBannerProduct.url %>" class="btn btn-primary rounded-pill py-2 px-4">
                            <i class="fas fa-shopping-cart me-2"></i> View Product
                        </a>
                    </div>
                </div>
            <% } else { %>
                <div class="carousel-header-banner h-100">
                    <img src="/electro/img/header-img.jpg" class="img-fluid w-100 h-100" style="object-fit: cover;" alt="Featured banner">
                    <div class="carousel-banner-offer">
                        <p class="bg-primary text-white rounded fs-5 py-2 px-4 mb-0 me-3">Featured</p>
                        <p class="text-primary fs-5 fw-bold mb-0">Special Offer</p>
                    </div>
                    <div class="carousel-banner">
                        <div class="carousel-banner-content text-center p-4">
                            <a href="/store/shop" class="d-block mb-2">Products</a>
                            <a href="/store/shop" class="d-block text-white fs-3">Shop Our Featured Items</a>
                        </div>
                        <a href="/store/shop" class="btn btn-primary rounded-pill py-2 px-4">
                            <i class="fas fa-shopping-cart me-2"></i> Shop Now
                        </a>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>
<!-- Carousel End -->

<!-- Services Start -->
<div class="container-fluid px-0">
    <div class="row g-0 justify-content-center">
        <div class="col-6 col-lg-4 border-start border-end wow fadeInUp" data-wow-delay="0.1s">
            <div class="p-4">
                <div class="d-flex align-items-center">
                    <i class="fas fa-life-ring fa-2x text-primary"></i>
                    <div class="ms-4">
                        <h6 class="text-uppercase mb-2">Support 24/7</h6>
                        <p class="mb-0">We support online 24 hrs a day</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-4 border-end wow fadeInUp" data-wow-delay="0.2s">
            <div class="p-4">
                <div class="d-flex align-items-center">
                    <i class="fas fa-lock fa-2x text-primary"></i>
                    <div class="ms-4">
                        <h6 class="text-uppercase mb-2">Secure Payment</h6>
                        <p class="mb-0">We Value Your Security</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Services End -->

<!-- Products Offer Start -->
<div class="container-fluid bg-light py-5">
    <div class="container">
        <div class="row g-4">
            <% if (promoOfferLeft) { %>
                <div class="col-lg-6 wow fadeInLeft" data-wow-delay="0.2s">
                    <a href="<%= promoOfferLeft.url %>" class="d-flex align-items-center justify-content-between border bg-white rounded p-4">
                        <div>
                            <p class="text-muted mb-3"><%= promoOfferLeft.eyebrowText %></p>
                            <h3 class="text-primary"><%= promoOfferLeft.title %></h3>

                            <% if (promoOfferLeft.discountText) { %>
                                <% const leftDiscountParts = promoOfferLeft.discountText.trim().split(' '); %>
                                <h1 class="display-3 text-secondary mb-0">
                                    <%= leftDiscountParts[0] || '' %>
                                    <span class="text-primary fw-normal">
                                        <%= leftDiscountParts.slice(1).join(' ') || '' %>
                                    </span>
                                </h1>
                            <% } %>
                        </div>
                        <img src="<%= promoOfferLeft.image %>" class="img-fluid" alt="<%= promoOfferLeft.productName %>">
                    </a>
                </div>
            <% } %>

            <% if (promoOfferRight) { %>
                <div class="col-lg-6 wow fadeInRight" data-wow-delay="0.3s">
                    <a href="<%= promoOfferRight.url %>" class="d-flex align-items-center justify-content-between border bg-white rounded p-4">
                        <div>
                            <p class="text-muted mb-3"><%= promoOfferRight.eyebrowText %></p>
                            <h3 class="text-primary"><%= promoOfferRight.title %></h3>

                            <% if (promoOfferRight.discountText) { %>
                                <% const rightDiscountParts = promoOfferRight.discountText.trim().split(' '); %>
                                <h1 class="display-3 text-secondary mb-0">
                                    <%= rightDiscountParts[0] || '' %>
                                    <span class="text-primary fw-normal">
                                        <%= rightDiscountParts.slice(1).join(' ') || '' %>
                                    </span>
                                </h1>
                            <% } %>
                        </div>
                        <img src="<%= promoOfferRight.image %>" class="img-fluid" alt="<%= promoOfferRight.productName %>">
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</div>
<!-- Products Offer End -->

<!-- Our Products Start -->
<div class="container-fluid product py-5">
    <div class="container py-5">
        <div class="tab-class">
            <div class="row g-4">
                <div class="col-lg-4 text-start wow fadeInLeft" data-wow-delay="0.1s">
                    <h1>Our Products</h1>
                </div>
                <div class="col-lg-8 text-end wow fadeInRight" data-wow-delay="0.1s">
                    <ul class="nav nav-pills d-inline-flex text-center mb-5">
                        <li class="nav-item mb-4">
                            <a class="d-flex mx-2 py-2 bg-light rounded-pill active" data-bs-toggle="pill"
                                href="#tab-1">
                                <span class="text-dark" style="width: 130px;">All Products</span>
                            </a>
                        </li>
                        <li class="nav-item mb-4">
                            <a class="d-flex py-2 mx-2 bg-light rounded-pill" data-bs-toggle="pill" href="#tab-2">
                                <span class="text-dark" style="width: 130px;">New Arrivals</span>
                            </a>
                        </li>
                        <li class="nav-item mb-4">
                            <a class="d-flex mx-2 py-2 bg-light rounded-pill" data-bs-toggle="pill" href="#tab-3">
                                <span class="text-dark" style="width: 130px;">Featured</span>
                            </a>
                        </li>
                        <li class="nav-item mb-4">
                            <a class="d-flex mx-2 py-2 bg-light rounded-pill" data-bs-toggle="pill" href="#tab-4">
                                <span class="text-dark" style="width: 130px;">Top Selling</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="tab-content">
                <div id="tab-1" class="tab-pane fade show p-0 active">
                    <div class="row g-4 product">
                        <% (allProducts || []).forEach(function(product) { %>
                            <div class="col-md-6 col-lg-3 wow fadeInUp store-filter-card" data-wow-delay="0.1s" data-category="<%= (product.category || '').toLowerCase() %>">
                                <div class="product-item rounded js-store-product-card">
                                    <div class="product-item-inner border rounded">
                                        <div class="product-item-inner-item">
                                            <img src="<%= product.image %>" class="img-fluid w-100 rounded-top" alt="<%= product.name %>">
                                            <% if (product.isNew) { %>
                                                <div class="product-new">New</div>
                                            <% } %>
                                            <% if (product.sale && !product.isNew) { %>
                                                <div class="product-sale">Sale</div>
                                            <% } %>
                                            <div class="product-details">
                                                <a href="<%= product.url %>"><i class="fa fa-eye fa-1x"></i></a>
                                            </div>
                                        </div>
                                        <div class="text-center rounded-bottom p-4">
                                            <a href="<%= product.url %>" class="d-block mb-2"><%= product.category %></a>
                                            <a href="<%= product.url %>" class="d-block h4"><%= product.name %></a>
                                            <% if (product.oldPrice) { %>
                                                <del class="me-2 fs-5">$<%= product.oldPrice.toFixed(2) %></del>
                                            <% } %>
                                            <span class="text-primary fs-5">$<%= product.price.toFixed(2) %></span>
                                        </div>
                                    </div>
                                    <div class="product-item-add border border-top-0 rounded-bottom text-center p-4 pt-0">
                                        <a
                                            href="/api/cart/add?pid=<%= encodeURIComponent(product.customId) %>&qty=1&json=1"
                                            class="btn btn-primary border-secondary rounded-pill py-2 px-4 mb-4 js-add-to-cart"
                                            data-pid="<%= product.customId %>"
                                            data-product='<%- storeProductPayload(product) %>'
                                        >
                                            <i class="fas fa-shopping-cart me-2"></i> Add To Cart
                                        </a>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex">
                                                <i class="fas fa-star text-primary"></i>
                                                <i class="fas fa-star text-primary"></i>
                                                <i class="fas fa-star text-primary"></i>
                                                <i class="fas fa-star text-primary"></i>
                                                <i class="fas fa-star"></i>
                                            </div>
                                            <div class="d-flex">
                                                <a href="#" class="text-primary d-flex align-items-center justify-content-center me-3">
                                                    <span class="rounded-circle btn-sm-square border"><i class="fas fa-random"></i></span>
                                                </a>
                                                <a href="#" class="text-primary d-flex align-items-center justify-content-center me-0">
                                                    <span class="rounded-circle btn-sm-square border"><i class="fas fa-heart"></i></span>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <div id="tab-2" class="tab-pane fade show p-0">
                    <div class="row g-4 product">
                        <% (newArrivals || []).forEach(function(product) { %>
