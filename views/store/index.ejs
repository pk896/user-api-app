<script nonce="<%= nonce %>">
  (function () {
    const btn = document.getElementById('backToTopBtn');
    if (!btn) return;

    function toggleBackToTop() {
      if (window.scrollY > 300) {
        btn.style.display = 'inline-flex';
        btn.style.alignItems = 'center';
        btn.style.justifyContent = 'center';
      } else {
        btn.style.display = 'none';
      }
    }

    btn.addEventListener('click', function (event) {
      event.preventDefault();
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });

    window.addEventListener('scroll', toggleBackToTop);
    toggleBackToTop();
  })();
</script>

<script nonce="<%= nonce %>">
  (function () {
    const select = document.getElementById('storeCategorySelect');
    const links = Array.from(document.querySelectorAll('.store-category-link'));
    const cards = Array.from(document.querySelectorAll('.store-filter-card'));

    if (!select || !cards.length) return;

    function normalize(value) {
      return String(value || '').trim().toLowerCase();
    }

    function applyCategoryFilter(categoryValue) {
      const selected = normalize(categoryValue);

      cards.forEach(function (card) {
        const cardCategory = normalize(card.getAttribute('data-category'));
        const show = !selected || cardCategory === selected;
        card.style.display = show ? '' : 'none';
      });

      if (select.value !== selected) {
        select.value = selected;
      }
    }

    links.forEach(function (link) {
      link.addEventListener('click', function (event) {
        event.preventDefault();
        applyCategoryFilter(link.getAttribute('data-category') || '');
      });
    });

    select.addEventListener('change', function () {
      applyCategoryFilter(select.value || '');
    });

    applyCategoryFilter('');
  })();
</script>

