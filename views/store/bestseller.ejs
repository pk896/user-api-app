<script nonce="<%= nonce %>">
  (function () {
    const select = document.getElementById('bestsellerCategorySelect');
    const links = Array.from(document.querySelectorAll('.bestseller-category-link'));
    const cards = Array.from(document.querySelectorAll('.bestseller-filter-card'));

    if (!select || !cards.length) return;

    function normalize(value) {
      return String(value || '').trim().toLowerCase();
    }

    function applyCategoryFilter(categoryValue) {
      const selected = normalize(categoryValue);

      cards.forEach(function (card) {
        const cardCategory = normalize(card.getAttribute('data-category'));
        const show = !selected || cardCategory === selected;
        card.style.display = show ? '' : 'none';
      });

      if (select.value !== selected) {
        select.value = selected;
      }
    }

    links.forEach(function (link) {
      link.addEventListener('click', function (event) {
        event.preventDefault();
        applyCategoryFilter(link.getAttribute('data-category') || '');
      });
    });

    select.addEventListener('change', function () {
      applyCategoryFilter(select.value || '');
    });

    applyCategoryFilter('');
  })();
</script>

