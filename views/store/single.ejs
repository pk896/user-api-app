                        type="button"
                        class="input-group-text p-3 border-0 bg-primary text-white"
                    >
                        <i class="fa fa-search"></i>
                    </button>
                </div>

                <% if (shopSidebarBanner) { %>
                    <a href="<%= shopSidebarBanner.url %>">
                        <div class="position-relative">
                            <img src="<%= shopSidebarBanner.image %>" class="img-fluid w-100 rounded" alt="<%= shopSidebarBanner.productName || shopSidebarBanner.title %>">
