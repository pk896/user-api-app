            <% (relatedProducts || []).forEach(function(item){ %>
            <div class="related-item rounded js-store-product-card">
                <div class="related-item-inner border rounded">
                    <div class="related-item-inner-item">
                        <img src="<%= item.image %>" class="img-fluid w-100 rounded-top" alt="<%= item.name %>">
                        <% if (item.isNew) { %>
                            <div class="related-new">New</div>
                        <% } %>
                        <div class="related-details">
                            <a href="<%= item.url %>"><i class="fa fa-eye fa-1x"></i></a>
                        </div>
                    </div>
                    <div class="text-center rounded-bottom p-4">
                        <a href="<%= item.url %>" class="d-block mb-2"><%= item.category %></a>
                        <a href="<%= item.url %>" class="d-block h4"><%= item.name %></a>
                        <% if (item.oldPrice) { %>
                            <del class="me-2 fs-5">$<%= item.oldPrice.toFixed(2) %></del>
                        <% } %>
                        <span class="text-primary fs-5">$<%= (Number(item.price || 0) * (1 + VAT)).toFixed(2) %></span>
                        <small class="text-muted ms-2">incl. VAT</small>
                    </div>
                </div>
                <div class="related-item-add border border-top-0 rounded-bottom text-center p-4 pt-0">
                    <a
                        href="/api/cart/add?pid=<%= encodeURIComponent(item.customId) %>&qty=1&json=1"
                        class="btn btn-primary border-secondary rounded-pill py-2 px-4 mb-4 js-add-to-cart"
                        data-pid="<%= item.customId %>"
                        data-product="<%= storeProductPayload(item) %>"
                    >
