<script nonce="<%= nonce %>">
  (function () {
    const select = document.getElementById('singleCategorySelect');
    const links = Array.from(document.querySelectorAll('.single-category-link'));

    function goToCategory(categoryValue) {
      const selected = String(categoryValue || '').trim().toLowerCase();
      const url = selected
        ? '/store/shop?category=' + encodeURIComponent(selected)
        : '/store/shop';

      window.location.href = url;
    }

    links.forEach(function (link) {
      link.addEventListener('click', function (event) {
        event.preventDefault();
        goToCategory(link.getAttribute('data-category') || '');
      });
    });

    if (select) {
      select.addEventListener('change', function () {
        goToCategory(select.value || '');
      });
    }
  })();
</script>

