                    <div class="related-item-inner-item">
                        <img src="<%= item.image %>" class="img-fluid w-100 rounded-top" alt="<%= item.name %>">
                        <% if (item.isNew) { %>
                            <div class="related-new">New</div>
                        <% } %>
                        <div class="related-details">
                            <a href="<%= item.url %>"><i class="fa fa-eye fa-1x"></i></a>
                        </div>
                    </div>
                    <div class="text-center rounded-bottom p-4">
                        <a href="<%= item.url %>" class="d-block mb-2"><%= item.category %></a>
                        <a href="<%= item.url %>" class="d-block h4"><%= item.name %></a>
                        <% if (item.oldPrice) { %>
                            <del class="me-2 fs-5">$<%= item.oldPrice.toFixed(2) %></del>
                        <% } %>
                        <span class="text-primary fs-5">$<%= item.price.toFixed(2) %></span>
                    </div>
                </div>
                <div class="related-item-add border border-top-0 rounded-bottom text-center p-4 pt-0">
                    <a href="/store/cart" class="btn btn-primary border-secondary rounded-pill py-2 px-4 mb-4"><i
                            class="fas fa-shopping-cart me-2"></i> Add To Cart</a>
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex">
                            <i class="fas fa-star text-primary"></i>
                            <i class="fas fa-star text-primary"></i>
                            <i class="fas fa-star text-primary"></i>
                            <i class="fas fa-star text-primary"></i>
                            <i class="fas fa-star"></i>
                        </div>
                        <div class="d-flex">
                            <a href="#" class="text-primary d-flex align-items-center justify-content-center me-3"><span
                                    class="rounded-circle btn-sm-square border"><i
                                        class="fas fa-random"></i></span></a>
                            <a href="#" class="text-primary d-flex align-items-center justify-content-center me-0"><span
                                    class="rounded-circle btn-sm-square border"><i class="fas fa-heart"></i></span></a>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</div>
<!-- Related Product End -->

