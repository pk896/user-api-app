            <div class="tab-content">
                <div class="products tab-pane fade show p-0 active">
                    <div class="row g-4 product products-mini">
                        <% (relatedProducts || []).forEach(function(product) { %>
                            <div
                                class="col-lg-6 col-xl-4 wow fadeInUp bestseller-filter-card"
                                data-wow-delay="0.1s"
                                data-category="<%= String(product.category || '').trim().toLowerCase() %>"
                                data-search="<%= [
                                    product.name,
                                    product.category,
                                    product.type,
                                    product.manufacturer,
                                    product.description,
                                    Array.isArray(product.keywords) ? product.keywords.join(' ') : ''
                                ].filter(Boolean).join(' ').toLowerCase() %>"
                            >
                                <div class="products-mini-item border js-store-product-card">
