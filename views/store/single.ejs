<script nonce="<%= nonce %>">
  (function () {
    const topCart = document.getElementById('singleTopCartAmount');
    if (!topCart) return;

    const topCartTotal = topCart.querySelector('.store-cart-total');
    if (!topCartTotal) return;

    function cartAmountNumber() {
      const raw = String(topCartTotal.textContent || '').replace(/[^0-9.-]/g, '');
      const amount = Number(raw);
      return Number.isFinite(amount) ? amount : 0;
    }

    function syncTopCartSticky() {
        if (cartAmountNumber() > 0) {
            topCart.classList.add(
            'position-fixed',
            'top-0',
            'end-0',
            'mt-5',
            'me-5',
            'cart-flash-active'
            );
            topCart.style.zIndex = '1080';
        } else {
            topCart.classList.remove(
            'position-fixed',
            'top-0',
            'end-0',
            'mt-5',
            'me-5',
            'cart-flash-active'
            );
            topCart.style.zIndex = '';
        }
    }

    syncTopCartSticky();

    const observer = new MutationObserver(syncTopCartSticky);
    observer.observe(topCartTotal, {
      childList: true,
      characterData: true,
      subtree: true
    });

    window.addEventListener('pageshow', syncTopCartSticky);
  })();
</script>

<script nonce="<%= nonce %>">
  (function () {
    const select = document.getElementById('singleCategorySelect');
    const keywordInput = document.getElementById('singleKeywordInput');
    const keywordInputSecondary = document.getElementById('singleKeywordInputSecondary');
    const keywordBtn = document.getElementById('singleKeywordSearchBtn');
    const keywordBtnSecondary = document.getElementById('singleKeywordSearchBtnSecondary');
    const links = Array.from(document.querySelectorAll('.single-category-link'));

    function normalize(value) {
      return String(value || '').trim();
    }

    function goToShop(categoryValue, keywordValue) {
        const selectedCategory = normalize(categoryValue);
        const keyword = normalize(keywordValue);

        const params = new URLSearchParams();

        if (selectedCategory) {
            params.set('category', selectedCategory);
        }

        if (keyword) {
            params.set('keyword', keyword);
        }

        const query = params.toString();
        window.location.href = query ? `/store/shop?${query}#shopProductsSection` : '/store/shop#shopProductsSection';
    }

    function currentKeyword() {
      const primary = normalize(keywordInput ? keywordInput.value : '');
      const secondary = normalize(keywordInputSecondary ? keywordInputSecondary.value : '');
      return primary || secondary;
    }

    function syncInputs(source) {
      if (!keywordInput || !keywordInputSecondary) return;

      if (source === 'primary') {
        keywordInputSecondary.value = keywordInput.value;
      } else if (source === 'secondary') {
        keywordInput.value = keywordInputSecondary.value;
      }
    }

    links.forEach(function (link) {
      link.addEventListener('click', function (event) {
        event.preventDefault();
        goToShop(link.getAttribute('data-category') || '', currentKeyword());
      });
    });

    if (select) {
      select.addEventListener('change', function () {
        goToShop(select.value || '', currentKeyword());
      });
    }

    if (keywordInput) {
      keywordInput.addEventListener('input', function () {
        syncInputs('primary');
      });

      keywordInput.addEventListener('keydown', function (event) {
        if (event.key === 'Enter') {
          event.preventDefault();
          goToShop(select ? select.value : '', keywordInput.value);
        }
      });
    }

    if (keywordInputSecondary) {
      keywordInputSecondary.addEventListener('input', function () {
        syncInputs('secondary');
      });

      keywordInputSecondary.addEventListener('keydown', function (event) {
        if (event.key === 'Enter') {
          event.preventDefault();
          goToShop(select ? select.value : '', keywordInputSecondary.value);
        }
      });
    }

    if (keywordBtn) {
      keywordBtn.addEventListener('click', function () {
        goToShop(select ? select.value : '', currentKeyword());
      });
    }

    if (keywordBtnSecondary) {
      keywordBtnSecondary.addEventListener('click', function () {
        goToShop(select ? select.value : '', currentKeyword());
      });
    }
  })();
</script>

<script nonce="<%= nonce %>">
(function(){
  const $ = (s, c = document) => c.querySelector(s);

  const customIdEl = $('#pdCustomId');
  const customId = (customIdEl && customIdEl.value) ? String(customIdEl.value) : '';
  if (!customId) return;

  const ratingText = $('#ratingText');
  const reviewsList = $('#reviewsList');
  const loadingRow = $('#reviewsLoadingRow');
  const ratingStarsWrap = $('#ratingStarsWrap');

  function starsText(n) {
    const s = Math.max(0, Math.min(5, parseInt(n || 0, 10)));
    return '★★★★★'.slice(0, s) + '☆☆☆☆☆'.slice(0, 5 - s);
  }

  function renderAvgStars(avg, count) {
    const a = Number(avg || 0);
    const c = Number(count || 0);

    const full = Math.floor(a);
    const frac = a - full;
    const half = frac >= 0.5;

    let starsHtml = '';
    for (let i = 1; i <= 5; i++) {
      const isFull = i <= full;
      const isHalf = (!isFull && i === full + 1 && half);
      starsHtml += `<span class="rs-star ${isFull ? 'on' : (isHalf ? 'half' : 'off')}">★</span>`;
    }

    const aria = (c > 0)
      ? `Average rating ${a.toFixed(1)} out of 5 based on ${c} reviews`
      : `No ratings yet`;

    const meta = (c > 0)
      ? `<span class="rs-avg">${a.toFixed(1)}</span><span class="rs-count">(${c})</span>`
      : `<span class="rs-none">No ratings</span>`;

    return `
      <div class="rs" aria-label="${aria}">
        <div class="rs-stars" aria-hidden="true">${starsHtml}</div>
        <div class="rs-meta">${meta}</div>
      </div>
    `;
  }

  function formatDate(iso) {
    try {
      const d = new Date(iso);
      if (Number.isNaN(d.getTime())) return '';
      return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
    } catch {
      return '';
    }
  }

  function escapeHtml(str) {
    return String(str || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  async function loadRatings() {
    try {
      const url = `/api/products/${encodeURIComponent(customId)}/ratings?fresh=1&limit=3&page=1`;
      const res = await fetch(url, { credentials: 'same-origin' });
      const data = await res.json();

      if (!res.ok || !data || !data.ok) {
        throw new Error((data && data.error) ? data.error : 'Failed');
      }

      const avg = Number((data.product && data.product.avgRating) ? data.product.avgRating : 0);
      const cnt = Number((data.product && data.product.ratingsCount) ? data.product.ratingsCount : 0);

      if (ratingText) {
        ratingText.textContent = (cnt > 0)
          ? `${avg.toFixed(1)} • ${cnt} review${cnt === 1 ? '' : 's'}`
          : 'No reviews yet';
      }

      if (ratingStarsWrap) {
        ratingStarsWrap.innerHTML = renderAvgStars(avg, cnt);
      }

      if (!reviewsList) return;
      if (loadingRow) loadingRow.remove();

      const items = Array.isArray(data.items) ? data.items : [];

      if (!items.length) {
        reviewsList.innerHTML = `
          <div class="review-item">
            <div class="review-stars">☆☆☆☆☆</div>
            <p class="review-text mb-1">No reviews yet. Be the first to rate this product.</p>
            <span class="review-author"></span>
          </div>
        `;
        return;
      }

      reviewsList.innerHTML = items.map((item) => {
        const title = item.title ? `<h6 class="mb-1">${escapeHtml(item.title)}</h6>` : '';
        const body = item.body ? `<p class="review-text mb-1">${escapeHtml(item.body)}</p>` : '<p class="review-text mb-1">No written comment.</p>';
        const who = item.raterType === 'business' ? 'Business buyer' : (item.raterType === 'user' ? 'Customer' : 'Guest');
        const when = formatDate(item.createdAt);

        return `
          <div class="review-item mb-3">
            <div class="review-stars">${starsText(item.stars)}</div>
            ${title}
            ${body}
            <span class="review-author d-block text-muted">${escapeHtml(who)}${when ? ` • ${escapeHtml(when)}` : ''}</span>
          </div>
        `;
      }).join('');
    } catch (err) {
      if (reviewsList) {
        reviewsList.innerHTML = `
          <div class="review-item">
            <div class="review-stars">Error</div>
            <p class="review-text mb-1">Could not load ratings right now.</p>
            <span class="review-author"></span>
          </div>
        `;
      }
    }
  }

  loadRatings();
})();
</script>

<script nonce="<%= nonce %>">
  (function () {
    const shareWrap = document.querySelector('.js-product-share-wrap');
    if (!shareWrap) return;

    function cleanText(value) {
      return String(value || '').replace(/\s+/g, ' ').trim();
    }

    document.querySelectorAll('.js-product-native-share').forEach(function (button) {
      button.addEventListener('click', async function () {
        const title = cleanText(shareWrap.getAttribute('data-share-title')) || document.title;
        const text = cleanText(shareWrap.getAttribute('data-share-text')) || title;
        const url = cleanText(shareWrap.getAttribute('data-share-url')) || window.location.href;
        const fullText = cleanText(text + ' - View product: ' + url);

        if (navigator.share) {
          try {
            await navigator.share({
              title: title,
              text: text,
              url: url
            });
            return;
          } catch (error) {
            if (error && error.name === 'AbortError') return;
          }
        }

        try {
          await navigator.clipboard.writeText(fullText);

          const originalText = button.innerHTML;
          button.innerHTML = '<i class="fas fa-check me-1"></i> Product Copied';

          setTimeout(function () {
            button.innerHTML = originalText;
          }, 2000);
        } catch (error) {
          window.prompt('Copy this product share text:', fullText);
        }
      });
    });
  })();
</script>

