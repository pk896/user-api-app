                                <h5 class="fw-bold me-2">$<%= item.price.toFixed(2) %></h5>
                                <% if (item.oldPrice) { %>
                                    <h5 class="text-danger text-decoration-line-through">$<%= item.oldPrice.toFixed(2) %></h5>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    <% }) %>

