                                <h4 class="text-secondary"><%= shopSidebarBanner.subtitle %></h4>
                                <span class="btn btn-primary rounded-pill px-4"><%= shopSidebarBanner.buttonText || 'Shop Now' %></span>
                            </div>
                        </div>
                    </a>
                <% } %>
            </div>

                        <div class="col-lg-7 col-xl-9 order-1 order-xl-1 wow fadeInUp" data-wow-delay="0.1s">
                <div class="row g-4 single-product">
                    <div class="col-xl-6">
                        <div class="single-carousel owl-carousel">
                            <div class="single-item"
                                data-dot="<img class='img-fluid' src='<%= product.image %>' alt='<%= product.name %>'>">
                                <div class="single-inner bg-light rounded">
                                    <img src="<%= product.image %>" class="img-fluid rounded" alt="<%= product.name %>">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-6 js-single-product-card">
                        <h4 class="fw-bold mb-3"><%= product.name %></h4>
                        <p class="mb-3">Category: <%= product.category %></p>
                        <h5 class="fw-bold mb-1"><%= formatMoney(Number(product.price || 0) * (1 + VAT)) %></h5>
                        <p class="text-muted mb-3">incl. VAT</p>   
                        <div class="d-flex mb-4">
                            <%- include('../partials/rating-stars', {
                                avg: Number(product.avgRating || 0),
                                count: Number(product.ratingsCount || 0),
                                nonce
                            }) %> 
                        </div>

                        <%
                            const SHARE_SITE_URL = String(typeof siteUrl !== 'undefined' ? siteUrl : '').replace(/\/+$/, '');

                            function shareAbsoluteUrl(value) {
                                const raw = String(value || '').trim();

                                if (!raw) return '';
                                if (/^https?:\/\//i.test(raw)) return raw;
                                if (!SHARE_SITE_URL) return raw;

                                return SHARE_SITE_URL + '/' + raw.replace(/^\/+/, '');
                            }

                            const shareProductUrl = shareAbsoluteUrl(product.url || ('/store/product/' + (product.customId || '')));
                            const shareProductImage = shareAbsoluteUrl(product.shareImageUrl || product.image || product.imageUrl || '');
                            const shareProductText = 'Check out ' + (product.name || 'this product') + ' - Category: ' + (product.category || 'Product') + ' - Price: ' + formatMoney(Number(product.price || 0) * (1 + VAT)) + ' incl. VAT';
                            const shareProductFullText = shareProductText + ' - View product: ' + shareProductUrl;
                        %>

                        <div class="mb-3 d-flex flex-wrap gap-2 js-product-share-wrap"
                            data-share-title="<%= product.name || 'Product' %>"
                            data-share-text="<%= shareProductText %>"
                            data-share-url="<%= shareProductUrl %>"
                            data-share-image="<%= shareProductImage %>"
                        >
                            <a
                                href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(shareProductUrl) %>"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn btn-primary d-inline-block rounded text-white py-1 px-4"
                                aria-label="Share <%= product.name %> on Facebook"
                            >
                                <i class="fab fa-facebook-f me-1"></i> Facebook
                            </a>

                            <a
                                href="https://api.whatsapp.com/send?text=<%= encodeURIComponent(shareProductFullText) %>"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn btn-success d-inline-block rounded text-white py-1 px-4"
                                aria-label="Share <%= product.name %> on WhatsApp"
                            >
                                <i class="fab fa-whatsapp me-1"></i> WhatsApp
                            </a>

                            <button
                                type="button"
                                class="btn btn-primary d-inline-block rounded text-white py-1 px-4 js-product-native-share"
                                aria-label="Share <%= product.name %> to other apps"
                            >
                                <i class="fas fa-share-alt me-1"></i> More
                            </button>
                        </div>

                        <div class="d-flex flex-column mb-3">
                            <small>Product SKU: <%= product.customId || 'N/A' %></small>
                            <small>Available: <strong class="text-primary"><%= product.stock %> items in stock</strong></small>
                        </div>
                        <p class="mb-4"><%= product.name %> is one of our available products.</p>
                        <p class="mb-4"><%= product.category %> product ready for viewing in the store.</p>

                        <div class="input-group quantity mb-5" style="width: 100px;">
                            <div class="input-group-btn">
                                <button class="btn btn-sm btn-minus rounded-circle bg-light border">
                                    <i class="fa fa-minus"></i>
                                </button>
                            </div>
                            <input type="text" class="form-control form-control-sm text-center border-0" value="1">
                            <div class="input-group-btn">
                                <button class="btn btn-sm btn-plus rounded-circle bg-light border">
                                    <i class="fa fa-plus"></i>
                                </button>
                            </div>
                        </div>
                        <a
                            href="/api/cart/add?pid=<%= encodeURIComponent(product.customId) %>&qty=1&json=1"
                            class="btn btn-primary border border-secondary rounded-pill px-4 py-2 mb-4 text-primary js-single-add-to-cart"
                            data-pid="<%= product.customId %>"
                            data-product="<%= storeProductPayload(product) %>"
                            data-in-cart="0"
                            data-cart-variants=""
                        >
                           <i class="fa fa-shopping-bag me-2 text-white"></i> Add to cart
                        </a>
                    </div>
                    <div class="col-lg-12">
                        <div class="reviews-card" id="reviewsCard">
                            <div class="reviews-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                                <h3 class="mb-0">Customer Reviews</h3>

                                <div class="rating-summary" id="ratingSummary">
                                    <div id="ratingStarsWrap">
                                        <%- include('../partials/rating-stars', { avg: avgRating, count: ratingsCount, nonce }) %>
                                    </div>
                                    <span class="rating-text d-block mt-2" id="ratingText"><%= ratingSummaryText %></span>
                                </div>
                            </div>

                            <div class="reviews-content mb-4" id="reviewsList">
                                <div class="review-item" id="reviewsLoadingRow">
                                    <div class="review-stars">Loading…</div>
                                    <p class="review-text mb-1">Fetching latest customer ratings.</p>
                                    <span class="review-author"></span>
                                </div>
                            </div>

                            <input type="hidden" id="pdCustomId" value="<%= product.customId %>">

                            <div class="rate-box" id="rateBox">
                                <div class="rate-box-head d-flex justify-content-between align-items-center mb-3">
                                    <h3 class="rate-title mb-0">Rate this product</h3>
                                    <a class="rate-jump text-decoration-none" href="#rateBox">Write a review</a>
                                </div>
                                <%- include('../partials/rating-form', {
                                    productId: product.customId,
                                    myRating: (typeof myRating !== 'undefined' ? myRating : null),
                                    nonce
                                }) %>
                            </div>
                        </div>
                    </div>                   
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Single Products End -->

