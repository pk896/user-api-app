<!--views/admin/home-mid-banners/index.ejs-->
<div class="container py-4">
  <div class="row g-4">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
              <h1 class="h3 mb-1">Homepage Mid Banners</h1>
              <p class="text-body-secondary mb-0">
                Manage the 2 large homepage banners shown above "All Product Items".
              </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
              <a href="/admin/home-mid-banners/left/edit" class="btn btn-primary">
                Edit Left Banner
              </a>
              <a href="/admin/home-mid-banners/right/edit" class="btn btn-outline-primary">
                Edit Right Banner
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% const leftBanner = (banners || []).find(b => b.slot === 'left'); %>
    <% const rightBanner = (banners || []).find(b => b.slot === 'right'); %>

    <div class="col-12 col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <h2 class="h5 mb-0">Left Banner</h2>
            <a href="/admin/home-mid-banners/left/edit" class="btn btn-outline-primary btn-sm">
              Edit
            </a>
          </div>

          <% if (leftBanner && leftBanner.product) { %>
            <div class="row g-3 align-items-center">
              <div class="col-md-4">
                <img src="<%= leftBanner.image %>" alt="<%= leftBanner.title || leftBanner.product.name %>" class="img-fluid rounded border">
              </div>
              <div class="col-md-8">
                <div class="mb-2"><strong>Product:</strong> <%= leftBanner.product.name %></div>
                <div class="mb-2"><strong>Custom ID:</strong> <%= leftBanner.productCustomId %></div>
                <div class="mb-2"><strong>Title:</strong> <%= leftBanner.title || '-' %></div>
                <div class="mb-2"><strong>Subtitle:</strong> <%= leftBanner.subtitle || '-' %></div>
                <div class="mb-2"><strong>Price Text:</strong> <%= leftBanner.priceText || '-' %></div>
                <div class="mb-2"><strong>Button Text:</strong> <%= leftBanner.buttonText || 'Shop Now' %></div>
                <div class="mb-0">
                  <strong>Status:</strong>
                  <% if (leftBanner.active) { %>
                    <span class="badge bg-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Inactive</span>
                  <% } %>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="alert alert-light border mb-0">Left mid banner is not configured yet.</div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <h2 class="h5 mb-0">Right Banner</h2>
            <a href="/admin/home-mid-banners/right/edit" class="btn btn-outline-primary btn-sm">
              Edit
            </a>
          </div>

          <% if (rightBanner && rightBanner.product) { %>
            <div class="row g-3 align-items-center">
              <div class="col-md-4">
                <img src="<%= rightBanner.image %>" alt="<%= rightBanner.title || rightBanner.product.name %>" class="img-fluid rounded border">
              </div>
              <div class="col-md-8">
                <div class="mb-2"><strong>Product:</strong> <%= rightBanner.product.name %></div>
                <div class="mb-2"><strong>Custom ID:</strong> <%= rightBanner.productCustomId %></div>
                <div class="mb-2"><strong>Title:</strong> <%= rightBanner.title || '-' %></div>
                <div class="mb-2"><strong>Subtitle:</strong> <%= rightBanner.subtitle || '-' %></div>
                <div class="mb-2"><strong>Price Text:</strong> <%= rightBanner.priceText || '-' %></div>
                <div class="mb-2"><strong>Button Text:</strong> <%= rightBanner.buttonText || 'Shop Now' %></div>
                <div class="mb-0">
                  <strong>Status:</strong>
                  <% if (rightBanner.active) { %>
                    <span class="badge bg-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Inactive</span>
                  <% } %>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="alert alert-light border mb-0">Right mid banner is not configured yet.</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>