<!--views/admin/shop-main-banner/edit.ejs-->
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-9">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Edit Shop Main Banner</h1>
            <a href="/admin/shop-main-banner" class="btn btn-outline-secondary">Back</a>
          </div>

          <form action="/admin/shop-main-banner" method="POST" enctype="multipart/form-data" class="row g-3">
            <div class="col-12">
              <label class="form-label">Choose Product</label>
              <select name="productCustomId" class="form-select" required>
                <option value="">Select a product</option>
                <% (products || []).forEach(function(product) { %>
                  <option
                    value="<%= product.customId %>"
                    <%= banner && banner.productCustomId === product.customId ? 'selected' : '' %>
                  >
                    <%= product.name %> — <%= product.customId %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label">Title</label>
              <input
                type="text"
                name="title"
                class="form-control"
                value="<%= banner && banner.title ? banner.title : 'SALE' %>"
                placeholder="SALE"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Subtitle</label>
              <input
                type="text"
                name="subtitle"
                class="form-control"
                value="<%= banner && banner.subtitle ? banner.subtitle : 'Get UP To 50% Off' %>"
                placeholder="Get UP To 50% Off"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Button Text</label>
              <input
                type="text"
                name="buttonText"
                class="form-control"
                value="<%= banner && banner.buttonText ? banner.buttonText : 'Shop Now' %>"
                placeholder="Shop Now"
              >
            </div>

            <div class="col-md-6">
              <div class="form-check mt-md-4 pt-md-2">
                <input
                  class="form-check-input"
                  type="checkbox"
                  name="active"
                  id="active"
                  <%= !banner || banner.active !== false ? 'checked' : '' %>
                >
                <label class="form-check-label" for="active">Active</label>
              </div>
            </div>

            <div class="col-12">
              <label class="form-label">Banner Image</label>
              <input
                type="file"
                name="imageFile"
                accept="image/*"
                class="form-control"
                <%= !banner || !banner.image ? 'required' : '' %>
              >
              <div class="form-text">
                Upload a banner image. JPG, PNG, WEBP, GIF, or BMP.
              </div>
            </div>

            <% if (banner && banner.image) { %>
              <div class="col-12">
                <div class="border rounded p-3 bg-light">
                  <div class="small text-muted mb-2">Current Banner Image</div>
                  <img
                    src="<%= banner.image %>"
                    alt="Current banner image"
                    class="img-fluid rounded border"
                    style="max-height: 220px; object-fit: cover;"
                  >
                </div>
              </div>
            <% } %>

            <% if (banner && banner.product) { %>
              <div class="col-12">
                <div class="border rounded p-3 bg-light">
                  <div class="row g-3 align-items-center">
                    <div class="col-12 col-md-3">
                      <img
                        src="<%= banner.product.imageUrl %>"
                        alt="<%= banner.product.name %>"
                        class="img-fluid rounded border"
                        style="max-height: 120px; object-fit: cover;"
                      >
                    </div>
                    <div class="col-12 col-md-9">
                      <div><strong>Current Product:</strong> <%= banner.product.name %></div>
                      <div><strong>Product ID:</strong> <%= banner.product.customId %></div>
                      <div><strong>Price:</strong> $<%= Number(banner.product.price || 0).toFixed(2) %></div>
                    </div>
                  </div>
                </div>
              </div>
            <% } %>

            <div class="col-12">
              <button type="submit" class="btn btn-primary">
                Save Shop Main Banner
              </button>

              <% if (banner) { %>
                <a href="/admin/shop-main-banner/toggle" class="btn btn-outline-secondary ms-2">
                  <%= banner.active ? 'Deactivate' : 'Activate' %>
                </a>
              <% } %>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
