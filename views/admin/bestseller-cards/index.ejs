<!--views/admin/bestseller-cards/index.ejs-->

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Manage Bestseller Cards</h1>
      <p class="text-muted mb-0">
        Manage the two promo cards shown on the /store/bestseller page.
      </p>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline-secondary">Back</a>
  </div>

  <% if (success && success.length) { %>
    <div class="alert alert-success">
      <%= success[0] %>
    </div>
  <% } %>

  <% if (error && error.length) { %>
    <div class="alert alert-danger">
      <%= error[0] %>
    </div>
  <% } %>

  <div class="row g-4">
    <% ['left', 'right'].forEach(function(slot) { 
      const card = (cards || []).find(function(item) {
        return item.slot === slot;
      });
    %>
      <div class="col-12 col-lg-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div>
                <h2 class="h5 mb-1">
                  <%= slot === 'left' ? 'Left Card' : 'Right Card' %>
                </h2>
                <p class="text-muted mb-0">
                  <%= slot === 'left' ? 'Smart Camera card area' : 'Smart Watch card area' %>
                </p>
              </div>

              <% if (card) { %>
                <span class="badge <%= card.active ? 'bg-success' : 'bg-secondary' %>">
                  <%= card.active ? 'Active' : 'Inactive' %>
                </span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Not Configured</span>
              <% } %>
            </div>

            <% if (card) { %>
              <div class="border rounded p-3 bg-light mb-3">
                <div class="row g-3 align-items-center">
                  <div class="col-12 col-md-4">
                    <% if (card.product && card.product.imageUrl) { %>
                      <img
                        src="<%= card.product.imageUrl %>"
                        alt="<%= card.product.name %>"
                        class="img-fluid rounded border"
                        style="max-height: 140px; object-fit: cover;"
                      >
                    <% } else { %>
                      <div class="border rounded bg-white d-flex align-items-center justify-content-center text-muted"
                           style="height: 140px;">
                        No product image
                      </div>
                    <% } %>
                  </div>

                  <div class="col-12 col-md-8">
                    <div class="mb-2">
                      <strong>Product:</strong>
                      <%= card.product && card.product.name ? card.product.name : 'No linked product' %>
                    </div>

                    <div class="mb-2">
                      <strong>Product ID:</strong>
                      <%= card.productCustomId || '—' %>
                    </div>

                    <div class="mb-2">
                      <strong>Eyebrow:</strong>
                      <%= card.eyebrowText || '—' %>
                    </div>

                    <div class="mb-2">
                      <strong>Title:</strong>
                      <%= card.titleOverride || (card.product && card.product.name ? card.product.name : '—') %>
                    </div>

                    <div class="mb-0">
                      <strong>Discount:</strong>
                      <%= card.discountText || '—' %>
                    </div>
                  </div>
                </div>
              </div>
            <% } else { %>
              <div class="alert alert-light border mb-3">
                No card configured for this slot yet.
              </div>
            <% } %>

            <div class="d-flex flex-wrap gap-2">
              <a href="/admin/bestseller-cards/<%= slot %>/edit" class="btn btn-primary">
                <%= card ? 'Edit' : 'Set Up' %> <%= slot === 'left' ? 'Left' : 'Right' %> Card
              </a>

              <% if (card) { %>
                <a href="/admin/bestseller-cards/<%= slot %>/toggle" class="btn btn-outline-secondary">
                  <%= card.active ? 'Deactivate' : 'Activate' %>
                </a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>