<!--views/admin/bestseller-cards/edit.ejs-->
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-9">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
              Edit <%= slot === 'left' ? 'Left' : 'Right' %> Bestseller Card
            </h1>
            <a href="/admin/bestseller-cards" class="btn btn-outline-secondary">Back</a>
          </div>

          <form action="/admin/bestseller-cards/<%= slot %>" method="POST" class="row g-3">
            <div class="col-12">
              <label class="form-label">Choose Product</label>
              <select name="productCustomId" class="form-select" required>
                <option value="">Select a product</option>
                <% (products || []).forEach(function(product) { %>
                  <option
                    value="<%= product.customId %>"
                    <%= card && card.productCustomId === product.customId ? 'selected' : '' %>
                  >
                    <%= product.name %> — <%= product.customId %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label">Eyebrow Text</label>
              <input
                type="text"
                name="eyebrowText"
                class="form-control"
                value="<%= card && card.eyebrowText ? card.eyebrowText : '' %>"
                placeholder="<%= slot === 'left' ? 'Find The Best Camera for You!' : 'Find The Best Watches for You!' %>"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Title Override</label>
              <input
                type="text"
                name="titleOverride"
                class="form-control"
                value="<%= card && card.titleOverride ? card.titleOverride : '' %>"
                placeholder="Leave blank to use product name"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Discount Text</label>
              <input
                type="text"
                name="discountText"
                class="form-control"
                value="<%= card && card.discountText ? card.discountText : '' %>"
                placeholder="<%= slot === 'left' ? '40% Off' : '20% Off' %>"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Sort Order</label>
              <input
                type="number"
                name="sortOrder"
                class="form-control"
                value="<%= card && typeof card.sortOrder !== 'undefined' ? card.sortOrder : (slot === 'left' ? 1 : 2) %>"
              >
            </div>

            <div class="col-12">
              <div class="form-check">
                <input
                  class="form-check-input"
                  type="checkbox"
                  name="active"
                  id="active"
                  <%= !card || card.active !== false ? 'checked' : '' %>
                >
                <label class="form-check-label" for="active">Active</label>
              </div>
            </div>

            <% if (card && card.product) { %>
              <div class="col-12">
                <div class="border rounded p-3 bg-light">
                  <div class="row g-3 align-items-center">
                    <div class="col-12 col-md-3">
                      <img
                        src="<%= card.product.imageUrl %>"
                        alt="<%= card.product.name %>"
                        class="img-fluid rounded border"
                        style="max-height: 120px; object-fit: cover;"
                      >
                    </div>
                    <div class="col-12 col-md-9">
                      <div><strong>Current Product:</strong> <%= card.product.name %></div>
                      <div><strong>Product ID:</strong> <%= card.product.customId %></div>
                      <div><strong>Price:</strong> $<%= Number(card.product.price || 0).toFixed(2) %></div>
                    </div>
                  </div>
                </div>
              </div>
            <% } %>

            <div class="col-12">
              <button type="submit" class="btn btn-primary">
                Save <%= slot === 'left' ? 'Left' : 'Right' %> Bestseller Card
              </button>

              <% if (card) { %>
                <a href="/admin/bestseller-cards/<%= slot %>/toggle" class="btn btn-outline-secondary ms-2">
                  <%= card.active ? 'Deactivate' : 'Activate' %>
                </a>
              <% } %>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
