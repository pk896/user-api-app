<!--views/admin/go-to-admin-dashboard.ejs-->
<div class="row justify-content-center">
  <div class="col-12 col-xl-10">
    <div class="card shadow-sm border-0 mt-4">
      <div class="card-body p-4 p-md-5">

        <h1 class="h3 mb-3 text-primary">Admin Dashboard Access</h1>

        <p class="text-body-secondary mb-4">
          Use the links below to open the admin dashboard interface and manage admin operations safely.
        </p>

        <div class="d-grid gap-2 d-sm-flex flex-wrap mb-4">
          <a href="/admin-ui/" class="btn btn-primary btn-lg">
            Open Admin Dashboard
          </a>

          <form action="/admin/logout" method="POST" class="m-0">
            <button type="submit" class="btn btn-outline-danger btn-lg">
              Logout
            </button>
          </form>

          <% if (admin && admin.role === 'super_admin') { %>
            <a href="/admin/admins" class="btn btn-outline-primary btn-lg">
              Manage Admins
            </a>

            <a href="/admin/admins/new" class="btn btn-outline-primary btn-lg">
              Create Admin
            </a>
          <% } %>

          <a href="/admin/home-banners" class="btn btn-outline-primary btn-lg">
            Manage Homepage Banners & Edit Promo Offers
          </a>

          <a href="/admin/bestseller-cards" class="btn btn-outline-primary btn-lg">
            Manage Bestseller Cards
          </a>

          <a href="/admin/bestseller-bottom-banners" class="btn btn-outline-primary btn-lg">
            Manage Bestseller Bottom Banners
          </a>

          <a href="/admin/shop-sidebar-banner" class="btn btn-outline-primary btn-lg">
            Manage Shop Sidebar Banner
          </a>

          <a href="/admin/shop-main-banner" class="btn btn-outline-primary btn-lg">
            Manage Shop Main Banner
          </a>

          <a href="/admin/shop-header-image" class="btn btn-outline-primary btn-lg">
            Manage Shop Header Image
          </a>
        </div>

        <% if (admin) { %>
          <div class="alert alert-info mb-3" role="alert">
            <strong>Logged in as:</strong>
            <span><%= admin.fullName || admin.name || admin.username || 'Admin' %></span>
            <% if (admin.role) { %>
              <span class="ms-2 badge bg-primary"><%= admin.role %></span>
            <% } %>
          </div>
        <% } %>

        <% if (admin && admin.role === 'super_admin') { %>
          <div class="alert alert-success mb-3" role="alert">
            <strong>Super Admin:</strong> You can now create admins, reset admin passwords, and enable or disable admin accounts from
            <a href="/admin/admins" class="alert-link">Manage Admins</a>.
          </div>
        <% } %>

        <div class="alert alert-warning mb-3" role="alert">
          <strong>Warning:</strong> Administrative access is sensitive. Review every action carefully before proceeding.
        </div>

        <div class="alert alert-danger mb-0" role="alert">
          <strong>Important:</strong> Unauthorized, destructive, fraudulent, or corrupt actions may trigger investigation, account restrictions, termination of access, and serious legal consequences.
        </div>

      </div>
    </div>
  </div>
</div>