<!--views/admin/home-promo-offers/edit.ejs-->
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-9">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
              Edit <%= slot === 'left' ? 'Left' : 'Right' %> Promo Offer
            </h1>
            <a href="/admin/home-promo-offers" class="btn btn-outline-secondary">Back</a>
          </div>

          <form action="/admin/home-promo-offers/<%= slot %>" method="POST" class="row g-3">
            <div class="col-12">
              <label class="form-label">Choose Product</label>
              <select name="productCustomId" class="form-select" required>
                <option value="">Select a product</option>
                <% (products || []).forEach(function(product) { %>
                  <option
                    value="<%= product.customId %>"
                    <%= offer && offer.productCustomId === product.customId ? 'selected' : '' %>
                  >
                    <%= product.name %> — <%= product.customId %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label">Eyebrow Text</label>
              <input
                type="text"
                name="eyebrowText"
                class="form-control"
                value="<%= offer?.eyebrowText || '' %>"
                placeholder="Find The Best Camera for You!"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Title Override</label>
              <input
                type="text"
                name="titleOverride"
                class="form-control"
                value="<%= offer?.titleOverride || '' %>"
                placeholder="Leave blank to use product name"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Discount Text</label>
              <input
                type="text"
                name="discountText"
                class="form-control"
                value="<%= offer?.discountText || '' %>"
                placeholder="40% Off"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Sort Order</label>
              <input
                type="number"
                name="sortOrder"
                class="form-control"
                value="<%= offer?.sortOrder ?? (slot === 'left' ? 1 : 2) %>"
              >
            </div>

            <div class="col-12">
              <div class="form-check">
                <input
                  class="form-check-input"
                  type="checkbox"
                  name="active"
                  id="active"
                  <%= offer?.active !== false ? 'checked' : '' %>
                >
                <label class="form-check-label" for="active">Active</label>
              </div>
            </div>

            <div class="col-12">
              <button type="submit" class="btn btn-primary">
                Save <%= slot === 'left' ? 'Left' : 'Right' %> Promo Offer
              </button>

              <% if (offer) { %>
                <a href="/admin/home-promo-offers/<%= slot %>/toggle" class="btn btn-outline-secondary ms-2">
                  <%= offer.active ? 'Deactivate' : 'Activate' %>
                </a>
              <% } %>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
