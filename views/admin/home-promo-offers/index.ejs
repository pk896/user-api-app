<!--views/admin/home-promo-offers/index.ejs-->
<div class="container py-4">
  <div class="row g-4">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
              <h1 class="h3 mb-1">Homepage Promo Offers</h1>
              <p class="text-body-secondary mb-0">
                Manage the 2 homepage promo cards shown above the "Our Products" section.
              </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
              <a href="/admin/home-promo-offers/left/edit" class="btn btn-primary">
                Edit Left Card
              </a>
              <a href="/admin/home-promo-offers/right/edit" class="btn btn-outline-primary">
                Edit Right Card
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% const leftOffer = (offers || []).find(o => o.slot === 'left'); %>
    <% const rightOffer = (offers || []).find(o => o.slot === 'right'); %>

    <div class="col-12 col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0">Left Card</h2>
            <a href="/admin/home-promo-offers/left/edit" class="btn btn-outline-primary btn-sm">Edit</a>
          </div>

          <% if (leftOffer && leftOffer.product) { %>
            <div class="row g-3 align-items-center">
              <div class="col-md-4">
                <img src="<%= leftOffer.product.imageUrl %>" alt="<%= leftOffer.product.name %>" class="img-fluid rounded border">
              </div>
              <div class="col-md-8">
                <div class="mb-2"><strong>Product:</strong> <%= leftOffer.product.name %></div>
                <div class="mb-2"><strong>Custom ID:</strong> <%= leftOffer.product.customId %></div>
                <div class="mb-2"><strong>Eyebrow Text:</strong> <%= leftOffer.eyebrowText || '-' %></div>
                <div class="mb-2"><strong>Title Override:</strong> <%= leftOffer.titleOverride || '-' %></div>
                <div class="mb-2"><strong>Discount Text:</strong> <%= leftOffer.discountText || '-' %></div>
                <div class="mb-2"><strong>Sort Order:</strong> <%= leftOffer.sortOrder %></div>
                <div class="mb-0">
                  <strong>Status:</strong>
                  <% if (leftOffer.active) { %>
                    <span class="badge bg-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Inactive</span>
                  <% } %>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="alert alert-light border mb-0">Left promo card is not configured yet.</div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0">Right Card</h2>
            <a href="/admin/home-promo-offers/right/edit" class="btn btn-outline-primary btn-sm">Edit</a>
          </div>

          <% if (rightOffer && rightOffer.product) { %>
            <div class="row g-3 align-items-center">
              <div class="col-md-4">
                <img src="<%= rightOffer.product.imageUrl %>" alt="<%= rightOffer.product.name %>" class="img-fluid rounded border">
              </div>
              <div class="col-md-8">
                <div class="mb-2"><strong>Product:</strong> <%= rightOffer.product.name %></div>
                <div class="mb-2"><strong>Custom ID:</strong> <%= rightOffer.product.customId %></div>
                <div class="mb-2"><strong>Eyebrow Text:</strong> <%= rightOffer.eyebrowText || '-' %></div>
                <div class="mb-2"><strong>Title Override:</strong> <%= rightOffer.titleOverride || '-' %></div>
                <div class="mb-2"><strong>Discount Text:</strong> <%= rightOffer.discountText || '-' %></div>
                <div class="mb-2"><strong>Sort Order:</strong> <%= rightOffer.sortOrder %></div>
                <div class="mb-0">
                  <strong>Status:</strong>
                  <% if (rightOffer.active) { %>
                    <span class="badge bg-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Inactive</span>
                  <% } %>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="alert alert-light border mb-0">Right promo card is not configured yet.</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>