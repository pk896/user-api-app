<!--views/admin/shop-header-image/edit.ejs-->
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-9">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Edit Shop Header Image</h1>
            <a href="/admin/shop-header-image" class="btn btn-outline-secondary">Back</a>
          </div>

          <form action="/admin/shop-header-image" method="POST" enctype="multipart/form-data" class="row g-3">
            <div class="col-md-6">
              <div class="form-check mt-md-4 pt-md-2">
                <input
                  class="form-check-input"
                  type="checkbox"
                  name="active"
                  id="active"
                  <%= !headerImage || headerImage.active !== false ? 'checked' : '' %>
                >
                <label class="form-check-label" for="active">Active</label>
              </div>
            </div>

            <div class="col-12">
              <label class="form-label">Header Image</label>
              <input
                type="file"
                name="imageFile"
                accept="image/*"
                class="form-control"
                <%= !headerImage || !headerImage.image ? 'required' : '' %>
              >
              <div class="form-text">
                Upload the shop header background image. JPG, PNG, WEBP, GIF, or BMP.
              </div>
            </div>

            <% if (headerImage && headerImage.image) { %>
              <div class="col-12">
                <div class="border rounded p-3 bg-light">
                  <div class="small text-muted mb-2">Current Header Image</div>
                  <img
                    src="<%= headerImage.image %>"
                    alt="Current header image"
                    class="img-fluid rounded border"
                    style="max-height: 220px; object-fit: cover;"
                  >
                </div>
              </div>
            <% } %>

            <div class="col-12">
              <button type="submit" class="btn btn-primary">
                Save Shop Header Image
              </button>

              <% if (headerImage) { %>
                <a href="/admin/shop-header-image/toggle" class="btn btn-outline-secondary ms-2">
                  <%= headerImage.active ? 'Deactivate' : 'Activate' %>
                </a>
              <% } %>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
