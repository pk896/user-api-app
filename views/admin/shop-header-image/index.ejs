<!--views/admin/shop-header-image/index.ejs-->
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Manage Shop Header Image</h1>
      <p class="text-muted mb-0">
        Manage the large top header image shown on the /store/shop page.
      </p>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline-secondary">Back</a>
  </div>

  <% if (success && success.length) { %>
    <div class="alert alert-success">
      <%= success[0] %>
    </div>
  <% } %>

  <% if (error && error.length) { %>
    <div class="alert alert-danger">
      <%= error[0] %>
    </div>
  <% } %>

  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
          <h2 class="h5 mb-1">Shop Header Image</h2>
          <p class="text-muted mb-0">Single admin-managed image for the shop page header background.</p>
        </div>

        <% if (headerImage) { %>
          <span class="badge <%= headerImage.active ? 'bg-success' : 'bg-secondary' %>">
            <%= headerImage.active ? 'Active' : 'Inactive' %>
          </span>
        <% } else { %>
          <span class="badge bg-warning text-dark">Not Configured</span>
        <% } %>
      </div>

      <% if (headerImage && headerImage.image) { %>
        <div class="border rounded p-3 bg-light mb-3">
          <div class="small text-muted mb-2">Current Header Image</div>
          <img
            src="<%= headerImage.image %>"
            alt="Current shop header image"
            class="img-fluid rounded border"
            style="max-height: 220px; object-fit: cover;"
          >
        </div>
      <% } else { %>
        <div class="alert alert-light border mb-3">
          No shop header image configured yet.
        </div>
      <% } %>

      <div class="d-flex flex-wrap gap-2">
        <a href="/admin/shop-header-image/edit" class="btn btn-primary">
          <%= headerImage ? 'Edit' : 'Set Up' %> Shop Header Image
        </a>

        <% if (headerImage) { %>
          <a href="/admin/shop-header-image/toggle" class="btn btn-outline-secondary">
            <%= headerImage.active ? 'Deactivate' : 'Activate' %>
          </a>
        <% } %>
      </div>
    </div>
  </div>
</div>
