<!--views/admin/home-banners/featured-banner.ejs-->
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-9">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0 text-primary">Featured Banner</h1>
            <a href="/admin/home-banners" class="btn btn-outline-secondary">Back</a>
          </div>

          <form action="/admin/home-banners/featured-banner" method="POST" class="row g-3">
            <div class="col-12">
              <label for="productSearch" class="form-label fw-semibold text-primary">Choose Product</label>

              <input
                type="hidden"
                name="productCustomId"
                id="productCustomId"
                value="<%= banner?.productCustomId || '' %>"
                required
              >

              <div class="position-relative">
                <input
                  type="text"
                  id="productSearch"
                  class="form-control border-primary"
                  placeholder="Search by product custom ID or name"
                  autocomplete="off"
                  value="<%= selectedProduct ? `${selectedProduct.name} — ${selectedProduct.customId}` : '' %>"
                  required
                >

                <div
                  id="productSearchResults"
                  class="list-group position-absolute top-100 start-0 end-0 shadow-sm d-none"
                  style="z-index: 1050;"
                ></div>
              </div>

              <div class="form-text text-primary mt-2">
                Start typing the product custom ID or product name, then click the correct result.
              </div>

              <div
                id="selectedProductBox"
                class="mt-3 <%= selectedProduct ? '' : 'd-none' %>"
              >
                <div class="card border-primary shadow-sm">
                  <div class="card-body py-2 px-3">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                      <div>
                        <div class="fw-semibold text-primary" id="selectedProductName">
                          <%= selectedProduct?.name || '' %>
                        </div>
                        <div class="small text-body-secondary" id="selectedProductMeta">
                          <%= selectedProduct ? `Custom ID: ${selectedProduct.customId}` : '' %>
                        </div>
                      </div>
                      <button
                        type="button"
                        id="clearSelectedProduct"
                        class="btn btn-sm btn-outline-secondary"
                      >
                        Clear
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <label class="form-label">Badge Text</label>
              <input
                type="text"
                name="badgeText"
                class="form-control"
                value="<%= banner?.badgeText || 'Special Offer' %>"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Offer Text</label>
              <input
                type="text"
                name="offerText"
                class="form-control"
                value="<%= banner?.offerText || 'Featured Product' %>"
              >
            </div>

            <div class="col-12">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="active" id="active" <%= banner?.active !== false ? 'checked' : '' %>>
                <label class="form-check-label" for="active">Active</label>
              </div>
            </div>

            <div class="col-12">
              <button type="submit" class="btn btn-primary">Save Featured Banner</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%
  scripts = `
  <script nonce="${nonce}">
    document.addEventListener('DOMContentLoaded', function () {
      const searchInput = document.getElementById('productSearch');
      const hiddenInput = document.getElementById('productCustomId');
      const resultsBox = document.getElementById('productSearchResults');
      const selectedProductBox = document.getElementById('selectedProductBox');
      const selectedProductName = document.getElementById('selectedProductName');
      const selectedProductMeta = document.getElementById('selectedProductMeta');
      const clearSelectedProductBtn = document.getElementById('clearSelectedProduct');

      let debounceTimer = null;

      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function hideResults() {
        resultsBox.classList.add('d-none');
        resultsBox.innerHTML = '';
      }

      function showSelectedProduct(product) {
        hiddenInput.value = product.customId;
        searchInput.value = product.name + ' — ' + product.customId;
        selectedProductName.textContent = product.name;
        selectedProductMeta.textContent = 'Custom ID: ' + product.customId;
        selectedProductBox.classList.remove('d-none');
        hideResults();
      }

      function clearSelectedProduct() {
        hiddenInput.value = '';
        searchInput.value = '';
        selectedProductName.textContent = '';
        selectedProductMeta.textContent = '';
        selectedProductBox.classList.add('d-none');
        hideResults();
        searchInput.focus();
      }

      async function searchProducts(query) {
        try {
          const response = await fetch('/admin/home-banners/products/search?q=' + encodeURIComponent(query), {
            headers: {
              'X-Requested-With': 'XMLHttpRequest'
            }
          });

          const data = await response.json();

          if (!data.success || !Array.isArray(data.products)) {
            hideResults();
            return;
          }

          if (data.products.length === 0) {
            resultsBox.innerHTML = '<button type="button" class="list-group-item list-group-item-action disabled">No matching products found</button>';
            resultsBox.classList.remove('d-none');
            return;
          }

          resultsBox.innerHTML = data.products.map(function (product) {
            return \`
              <button
                type="button"
                class="list-group-item list-group-item-action"
                data-custom-id="\${escapeHtml(product.customId)}"
                data-name="\${escapeHtml(product.name)}"
              >
                <div class="d-flex justify-content-between align-items-start gap-2">
                  <div>
                    <div class="fw-semibold text-primary">\${escapeHtml(product.name)}</div>
                    <div class="small text-body-secondary">Custom ID: \${escapeHtml(product.customId)}</div>
                  </div>
                  \${product.isOnSale ? '<span class="badge bg-success">Sale</span>' : ''}
                </div>
              </button>
            \`;
          }).join('');

          resultsBox.classList.remove('d-none');
        } catch (err) {
          console.error('Featured banner product search failed:', err);
          hideResults();
        }
      }

      searchInput.addEventListener('input', function () {
        const query = searchInput.value.trim();

        hiddenInput.value = '';

        if (query.length < 1) {
          hideResults();
          return;
        }

        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(function () {
          searchProducts(query);
        }, 250);
      });

      resultsBox.addEventListener('click', function (event) {
        const button = event.target.closest('button[data-custom-id]');
        if (!button) return;

        showSelectedProduct({
          customId: button.getAttribute('data-custom-id'),
          name: button.getAttribute('data-name')
        });
      });

      if (clearSelectedProductBtn) {
        clearSelectedProductBtn.addEventListener('click', clearSelectedProduct);
      }

      document.addEventListener('click', function (event) {
        const insideSearch =
          event.target.closest('#productSearch') ||
          event.target.closest('#productSearchResults');

        if (!insideSearch) {
          hideResults();
        }
      });

      const form = searchInput.closest('form');
      if (form) {
        form.addEventListener('submit', function (event) {
          if (!hiddenInput.value.trim()) {
            event.preventDefault();
            searchInput.focus();
            alert('Please search and select a product first.');
          }
        });
      }
    });
  </script>
  `;
%>