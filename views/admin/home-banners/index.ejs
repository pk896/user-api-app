<!--views/admin/home-banners/index.ejs-->
<div class="container py-4">
  <div class="row g-4">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
              <h1 class="h3 mb-1">Homepage Banners</h1>
              <p class="text-body-secondary mb-0">
                Manage the top hero slides and the featured banner shown on the store homepage.
              </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
              <a href="/admin/home-banners/slides/new" class="btn btn-primary">
                Add Hero Slide
              </a>
              <a href="/admin/home-banners/featured-banner" class="btn btn-outline-primary">
                Edit Featured Banner
              </a>
              <a href="/admin/home-promo-offers" class="btn btn-outline-dark">
                Edit Promo Offers
              </a>
              <a href="/admin/home-mid-banners" class="btn btn-outline-secondary">
                Edit Mid Banners
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h2 class="h5 mb-3">Hero Slides</h2>

          <% if (!slides || slides.length === 0) { %>
            <div class="alert alert-light border mb-0">No hero slides found yet.</div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th>Preview</th>
                    <th>Title</th>
                    <th>Subtitle</th>
                    <th>Sort Order</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% slides.forEach(function(slide) { %>
                    <tr>
                      <td style="width: 120px;">
                        <img src="<%= slide.image %>" alt="<%= slide.title %>" class="img-fluid rounded border">
                      </td>
                      <td><%= slide.title %></td>
                      <td><%= slide.subtitle || '-' %></td>
                      <td><%= slide.sortOrder %></td>
                      <td>
                        <% if (slide.active) { %>
                          <span class="badge bg-success">Active</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Inactive</span>
                        <% } %>
                      </td>
                      <td class="text-end">
                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                          <a href="/admin/home-banners/slides/<%= slide._id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                          <a href="/admin/home-banners/slides/<%= slide._id %>/toggle" class="btn btn-sm btn-outline-secondary">
                            <%= slide.active ? 'Deactivate' : 'Activate' %>
                          </a>
                          <a
                            href="/admin/home-banners/slides/<%= slide._id %>/delete"
                            class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Delete this hero slide?');"
                          >
                            Delete
                          </a>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <h2 class="h5 mb-0">Featured Right-side Banner</h2>
            <a href="/admin/home-banners/featured-banner" class="btn btn-outline-primary btn-sm">
              Change Banner
            </a>
          </div>

          <% if (featuredBanner && featuredProduct) { %>
            <div class="row g-3 align-items-center">
              <div class="col-md-3">
                <img src="<%= featuredProduct.imageUrl %>" alt="<%= featuredProduct.name %>" class="img-fluid rounded border">
              </div>
              <div class="col-md-9">
                <div class="mb-2"><strong>Product:</strong> <%= featuredProduct.name %></div>
                <div class="mb-2"><strong>Custom ID:</strong> <%= featuredBanner.productCustomId %></div>
                <div class="mb-2"><strong>Badge Text:</strong> <%= featuredBanner.badgeText || '-' %></div>
                <div class="mb-2"><strong>Offer Text:</strong> <%= featuredBanner.offerText || '-' %></div>
                <div class="mb-0">
                  <strong>Status:</strong>
                  <% if (featuredBanner.active) { %>
                    <span class="badge bg-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Inactive</span>
                  <% } %>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="alert alert-light border mb-0">No featured banner configured yet.</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>