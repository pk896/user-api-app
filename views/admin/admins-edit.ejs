// views/admin/admins-edit.ejs
<%
  const target = adminTarget || {};
%>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-7">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
          <h1 class="h3 mb-1 text-primary">Edit Admin</h1>
          <p class="text-muted mb-0">Update admin name, email, and username.</p>
        </div>

        <div class="d-flex gap-2">
          <a href="/admin/admins" class="btn btn-outline-primary">Back to Admins</a>
        </div>
      </div>

      <% if (success && success.length) { %>
        <div class="alert alert-success"><%= success[0] %></div>
      <% } %>

      <% if (error && error.length) { %>
        <div class="alert alert-danger"><%= error[0] %></div>
      <% } %>

      <% if (info && info.length) { %>
        <div class="alert alert-info"><%= info[0] %></div>
      <% } %>

      <% if (warning && warning.length) { %>
        <div class="alert alert-warning"><%= warning[0] %></div>
      <% } %>

      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <form action="/admin/admins/<%= target._id %>/edit" method="POST" novalidate>
            <div class="mb-3">
              <label for="fullName" class="form-label">Full Name</label>
              <input
                type="text"
                class="form-control"
                id="fullName"
                name="fullName"
                value="<%= target.fullName || '' %>"
                required
              >
            </div>

            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                value="<%= target.email || '' %>"
                required
              >
            </div>

            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input
                type="text"
                class="form-control"
                id="username"
                name="username"
                value="<%= target.username || '' %>"
                required
              >
            </div>

            <div class="mb-3">
              <label class="form-label">Role</label>
              <input
                type="text"
                class="form-control"
                value="<%= target.role || '' %>"
                readonly
              >
              <div class="form-text">Role is not changed on this page.</div>
            </div>

            <div class="mb-4">
              <label class="form-label">Status</label>
              <input
                type="text"
                class="form-control"
                value="<%= target.isActive ? 'Active' : 'Disabled' %>"
                readonly
              >
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">Save Changes</button>
              <a href="/admin/admins" class="btn btn-outline-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
