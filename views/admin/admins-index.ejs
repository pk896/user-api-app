<!--views/admin/admins-index.ejs-->
<%
  const NONCE = typeof nonce !== 'undefined' ? nonce : '';
  const adminsList = Array.isArray(admins) ? admins : [];
  const currentId = typeof currentAdminId !== 'undefined' ? String(currentAdminId) : '';
%>

<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1 text-primary">Admin Management</h1>
      <p class="text-muted mb-0">Manage all admin accounts and roles.</p>
    </div>

    <div class="d-flex gap-2">
      <a href="/admin/dashboard" class="btn btn-outline-primary">Back to Dashboard</a>
      <a href="/admin/admins/new" class="btn btn-primary">Create Admin</a>
    </div>
  </div>

  <% if (success && success.length) { %>
    <div class="alert alert-success"><%= success[0] %></div>
  <% } %>

  <% if (error && error.length) { %>
    <div class="alert alert-danger"><%= error[0] %></div>
  <% } %>

  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Username</th>
              <th>Role</th>
              <th>Status</th>
              <th>Last Login</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!adminsList.length) { %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">No admins found.</td>
              </tr>
            <% } %>

            <% adminsList.forEach(function(a) { %>
              <tr>
                <td><%= a.fullName || '—' %></td>
                <td><%= a.email || '—' %></td>
                <td><%= a.username || '—' %></td>
                <td><span class="badge bg-primary"><%= a.role || '—' %></span></td>
                <td>
                  <% if (a.isActive) { %>
                    <span class="badge bg-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-danger">Disabled</span>
                  <% } %>
                </td>
                <td>
                  <%= a.lastLoginAt ? new Date(a.lastLoginAt).toLocaleString() : 'Never' %>
                </td>
                <td class="text-end">
                  <div class="d-flex justify-content-end gap-2 flex-wrap">
                    <a href="/admin/admins/<%= a._id %>/reset-password" class="btn btn-sm btn-outline-primary">
                      Reset Password
                    </a>

                    <% if (a.role !== 'super_admin') { %>
                      <form action="/admin/admins/<%= a._id %>/toggle-active" method="POST" class="m-0">
                        <button type="submit" class="btn btn-sm <%= a.isActive ? 'btn-outline-danger' : 'btn-outline-success' %>">
                          <%= a.isActive ? 'Disable' : 'Enable' %>
                        </button>
                      </form>
                    <% } %>

                    <% if (!a.isActive && a.role !== 'super_admin' && String(a._id) !== currentId) { %>
                      <form
                        action="/admin/admins/<%= a._id %>/delete"
                        method="POST"
                        class="m-0"
                        onsubmit="return confirm('This will permanently delete this disabled admin account. This cannot be undone. Continue?');"
                      >
                        <button type="submit" class="btn btn-sm btn-danger">
                          Delete
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
