<!--views/admin/warehousingDispense.ejs-->
<%
  const isEdit = mode === 'edit';
  const isNew = mode === 'new';

  function value(path, fallback = '') {
    const parts = String(path || '').split('.');
    let current = warehouse || {};
    for (const part of parts) {
      if (!current || typeof current !== 'object') return fallback;
      current = current[part];
    }
    return current === undefined || current === null ? fallback : current;
  }

  function listValue(path) {
    const v = value(path, []);
    return Array.isArray(v) ? v.join(', ') : '';
  }
%>

<div class="container py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h3 text-primary mb-1">Warehouse Management</h1>
      <p class="text-muted mb-0">Create, update, enable, disable, and delete shipping warehouses.</p>
    </div>

    <div class="d-flex gap-2">
      <a href="/admin/go-to-admin-dashboard" class="btn btn-outline-primary">
        Back to Admin
      </a>

      <% if (!isNew) { %>
        <a href="/admin/warehouses/new" class="btn btn-primary">
          Create Warehouse
        </a>
      <% } %>
    </div>
  </div>

  <% if ((success || []).length) { %>
    <% success.forEach(function(message) { %>
      <div class="alert alert-success" role="alert"><%= message %></div>
    <% }) %>
  <% } %>

  <% if ((error || []).length) { %>
    <% error.forEach(function(message) { %>
      <div class="alert alert-danger" role="alert"><%= message %></div>
    <% }) %>
  <% } %>

  <% if (isNew || isEdit) { %>
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h2 class="h5 text-primary mb-4"><%= isEdit ? 'Edit Warehouse' : 'Create Warehouse' %></h2>

        <form action="<%= formAction %>" method="POST">
          <div class="row g-3">
            <div class="col-12 col-md-6">
              <label class="form-label">Warehouse Name</label>
              <input
                type="text"
                name="name"
                class="form-control"
                value="<%= value('name') %>"
                required
              >
            </div>

            <div class="col-12 col-md-3">
              <label class="form-label">Code</label>
              <input
                type="text"
                name="code"
                class="form-control text-uppercase"
                value="<%= value('code') %>"
                required
              >
            </div>

            <div class="col-12 col-md-3">
              <label class="form-label">Priority</label>
              <input
                type="number"
                name="priority"
                class="form-control"
                value="<%= value('priority', 100) %>"
                min="0"
                max="9999"
              >
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label">Country Code</label>
              <input
                type="text"
                name="country"
                class="form-control text-uppercase"
                value="<%= value('country', 'ZA') %>"
                maxlength="2"
                required
              >
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label">Province / State</label>
              <input
                type="text"
                name="province"
                class="form-control"
                value="<%= value('province') %>"
              >
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label">Province Code</label>
              <input
                type="text"
                name="provinceCode"
                class="form-control text-uppercase"
                value="<%= value('provinceCode') %>"
              >
            </div>

            <div class="col-12">
              <hr>
              <h3 class="h6 text-primary mb-3">Shippo FROM Address</h3>
            </div>

            <div class="col-12 col-md-8">
              <label class="form-label">Street Address</label>
              <input
                type="text"
                name="street1"
                class="form-control"
                value="<%= value('address.street1') %>"
                required
              >
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label">Street Address 2</label>
              <input
                type="text"
                name="street2"
                class="form-control"
                value="<%= value('address.street2') %>"
              >
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label">City</label>
              <input
                type="text"
                name="city"
                class="form-control"
                value="<%= value('address.city') %>"
                required
              >
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label">Address Province / State</label>
              <input
                type="text"
                name="state"
                class="form-control"
                value="<%= value('address.state') %>"
                required
              >
            </div>

            <div class="col-12 col-md-2">
              <label class="form-label">Postal Code</label>
              <input
                type="text"
                name="zip"
                class="form-control"
                value="<%= value('address.zip') %>"
                required
              >
            </div>

            <div class="col-12 col-md-2">
              <label class="form-label">Address Country</label>
              <input
                type="text"
                name="addressCountry"
                class="form-control text-uppercase"
                value="<%= value('address.country', value('country', 'ZA')) %>"
                maxlength="2"
                required
              >
            </div>

            <div class="col-12">
              <hr>
              <h3 class="h6 text-primary mb-3">Contact & Routing</h3>
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label">Phone</label>
              <input
                type="text"
                name="phone"
                class="form-control"
                value="<%= value('phone') %>"
              >
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label">Email</label>
              <input
                type="email"
                name="email"
                class="form-control"
                value="<%= value('email') %>"
              >
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label">Supported Countries</label>
              <input
                type="text"
                name="supportedCountries"
                class="form-control"
                value="<%= listValue('supportedCountries') %>"
                placeholder="ZA, US, GB"
              >
              <div class="form-text">Separate countries with commas.</div>
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label">Supported Provinces</label>
              <input
                type="text"
                name="supportedProvinces"
                class="form-control"
                value="<%= listValue('supportedProvinces') %>"
                placeholder="Gauteng, GP"
              >
              <div class="form-text">Separate provinces or province codes with commas.</div>
            </div>

            <div class="col-12">
              <label class="form-label">Notes</label>
              <textarea name="notes" class="form-control" rows="3"><%= value('notes') %></textarea>
            </div>

            <div class="col-12">
              <div class="form-check form-switch mb-2">
                <input
                  class="form-check-input"
                  type="checkbox"
                  name="isActive"
                  id="isActive"
                  <%= value('isActive', true) ? 'checked' : '' %>
                >
                <label class="form-check-label" for="isActive">Active warehouse</label>
              </div>

              <div class="form-check form-switch">
                <input
                  class="form-check-input"
                  type="checkbox"
                  name="isDefault"
                  id="isDefault"
                  <%= value('isDefault', false) ? 'checked' : '' %>
                >
                <label class="form-check-label" for="isDefault">Default warehouse for this country</label>
              </div>
            </div>

            <div class="col-12 d-flex flex-wrap gap-2 mt-3">
              <button type="submit" class="btn btn-primary">
                <%= isEdit ? 'Save Changes' : 'Create Warehouse' %>
              </button>

              <a href="/admin/warehouses" class="btn btn-outline-secondary">
                Cancel
              </a>
            </div>
          </div>
        </form>
      </div>
    </div>
  <% } else { %>
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Code</th>
                <th>Warehouse</th>
                <th>Location</th>
                <th>Status</th>
                <th>Default</th>
                <th>Priority</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>

            <tbody>
              <% if ((warehouses || []).length) { %>
                <% warehouses.forEach(function(item) { %>
                  <tr>
                    <td>
                      <span class="badge bg-primary"><%= item.code %></span>
                    </td>

                    <td>
                      <div class="fw-semibold"><%= item.name %></div>
                      <div class="small text-muted"><%= item.phone || 'No phone' %></div>
                    </td>

                    <td>
                      <div><%= item.address?.city || '' %>, <%= item.province || item.address?.state || '' %></div>
                      <div class="small text-muted">
                        <%= item.address?.street1 || '' %>,
                        <%= item.address?.zip || '' %>,
                        <%= item.country || '' %>
                      </div>
                    </td>

                    <td>
                      <% if (item.isActive) { %>
                        <span class="badge bg-success">Active</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Disabled</span>
                      <% } %>
                    </td>

                    <td>
                      <% if (item.isDefault) { %>
                        <span class="badge bg-primary">Default</span>
                      <% } else { %>
                        <span class="text-muted">No</span>
                      <% } %>
                    </td>

                    <td><%= item.priority %></td>

                    <td>
                      <div class="d-flex justify-content-end flex-wrap gap-2">
                        <a href="/admin/warehouses/<%= item._id %>/edit" class="btn btn-sm btn-outline-primary">
                          Edit
                        </a>

                        <% if (item.isActive) { %>
                          <form action="/admin/warehouses/<%= item._id %>/disable" method="POST" class="m-0">
                            <button type="submit" class="btn btn-sm btn-outline-warning">
                              Disable
                            </button>
                          </form>
                        <% } else { %>
                          <form action="/admin/warehouses/<%= item._id %>/enable" method="POST" class="m-0">
                            <button type="submit" class="btn btn-sm btn-outline-success">
                              Enable
                            </button>
                          </form>
                        <% } %>

                        <form action="/admin/warehouses/<%= item._id %>/delete" method="POST" class="m-0">
                          <button type="submit" class="btn btn-sm btn-outline-danger">
                            Delete
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="text-center text-muted py-5">
                    No warehouses created yet.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% } %>
</div>
