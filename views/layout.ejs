<!--views/layout.ejs-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title ? `${title} | Unicoporate.com` : 'Unicoporate.com' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" />

  <!-- 📊 Chart.js for analytics dashboards -->
  <script
    src="https://cdn.jsdelivr.net/npm/chart.js"
    nonce="<%= nonce %>"
    defer
  ></script>

  <!-- ✅ Bootstrap 5 (CSS) -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />

  <%- typeof styles !== 'undefined' ? styles : '' %>

  <style>
    html, body {
      overflow-x: hidden;
    }
  </style>
</head>

<body class="<%= (themeCss && themeCss.includes('dark')) ? 'bg-dark text-light' : 'bg-body text-body' %>">

  <%- include('partials/navbar', {
    user: typeof user !== 'undefined' ? user : null,
    business: typeof business !== 'undefined' ? business : null,
    active: typeof active !== 'undefined' ? active : '',
    themeCss: typeof themeCss !== 'undefined' ? themeCss : '',
    nonce: typeof nonce !== 'undefined' ? nonce : ''
  }) %>

  <div class="container mt-0">
    <%- include('partials/massage', {
      success: success || [],
      error: error || [],
      info: info || [],
      warning: warning || [],
      errors: errors || [],
      nonce: typeof nonce !== 'undefined' ? nonce : ''
    }) %>
  </div>

  <main class="container pt-0 pb-4">
    <%- body %>
  </main>

  <div class="border-top px-0">
    <div class="container-fluid px-0">
      <%- include('partials/footer', {
        nonce: typeof nonce !== 'undefined' ? nonce : ''
      }) %>
    </div>
  </div>

  <%- typeof scripts !== 'undefined' ? scripts : '' %>

  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    defer
  ></script>

  <script nonce="<%= nonce %>">
    document.addEventListener("DOMContentLoaded", () => {
      console.log("✅ Layout loaded (Bootstrap only)");
    });
  </script>
</body>
</html>