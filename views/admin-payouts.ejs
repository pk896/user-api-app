<!-- views/admin-payouts.ejs -->
<%
  const NONCE = typeof nonce !== 'undefined' ? nonce : (typeof NONCE !== 'undefined' ? NONCE : '');
  const payoutList = Array.isArray(payouts) ? payouts : [];
  const KPIS = (typeof kpis === 'object' && kpis) ? kpis : {};
  const preview = Array.isArray(previewSellers) ? previewSellers : [];

  function esc(s) {
    return String(s ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function money(cents) {
    const n = Math.round(Number(cents || 0));
    return (n / 100).toFixed(2);
  }

  function badgeClass(status) {
    const v = String(status || '').trim().toUpperCase();
    if (v === 'COMPLETED' || v === 'SUCCESS') return 'bg-success-subtle text-success border border-success-subtle';
    if (v === 'FAILED' || v === 'DENIED') return 'bg-danger-subtle text-danger border border-danger-subtle';
    return 'text-white brand-purple-bg border-0';
  }

  function yesNoPill(ok, yesText, noText) {
    return ok
      ? ('<span class="badge rounded-pill text-bg-success">' + esc(yesText || 'YES') + '</span>')
      : ('<span class="badge rounded-pill text-bg-danger">' + esc(noText || 'NO') + '</span>');
  }

  function maskEmailLocal(email = '') {
    const [name, domain] = String(email || '').split('@');
    if (!name || !domain) return String(email || '');
    const maskedName =
      name.length <= 2
        ? name[0] + '*'
        : name[0] + '*'.repeat(Math.max(1, name.length - 2)) + name[name.length - 1];

    const parts = domain.split('.');
    const domName = parts[0] || '';
    const domExt = parts.slice(1).join('.') || '';

    const maskedDomain =
      domName.length <= 2
        ? (domName[0] || '*') + '*'
        : domName[0] + '*'.repeat(Math.max(1, domName.length - 2)) + domName[domName.length - 1];

    return `${maskedName}@${maskedDomain}${domExt ? '.' + domExt : ''}`;
  }

  const previewCurrency = String(KPIS.previewCurrency || 'USD').toUpperCase();

  const totalBatches = (typeof KPIS.totalBatches !== 'undefined') ? KPIS.totalBatches : payoutList.length;
  const totalPaidOut = KPIS.totalPaidOut ? KPIS.totalPaidOut : '—';
  const lastStatus   = KPIS.lastStatus ? KPIS.lastStatus : (payoutList[0] && payoutList[0].status ? payoutList[0].status : '—');

  const eligibleSellers = (KPIS.eligibleSellers ?? 0);
  const eligibleTotal   = (KPIS.eligibleTotal ?? '0.00');
%>

<section class="py-3 brand-page-bg min-vh-100">
  <div class="container-fluid px-2 px-md-3 px-xl-4">

    <!-- hero -->
    <div class="card border-0 shadow-sm mb-3 text-white brand-purple-bg">
      <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-column flex-lg-row align-items-start justify-content-between gap-3">
          <div class="d-flex align-items-start gap-3 flex-grow-1 min-w-0">
            <div class="rounded-4 px-3 py-2 bg-white bg-opacity-10 border border-white border-opacity-25 fs-5 flex-shrink-0">
              💸
            </div>
            <div class="min-w-0">
              <h1 class="h4 fw-bold mb-2 text-break">Seller Payouts</h1>
              <p class="mb-0 small text-white text-opacity-75">
                Preview balances, create PayPal payout batches, then sync to update statuses.
                Failed items auto-credit back automatically.
              </p>
            </div>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <span class="badge rounded-pill bg-white text-dark px-3 py-2">Purple <strong>#7C3AED</strong></span>
            <span class="badge rounded-pill bg-white text-dark px-3 py-2">Green <strong>#22C55E</strong></span>
          </div>
        </div>
      </div>
    </div>

    <!-- kpis -->
    <div class="row g-2 g-md-3 mb-3">
      <div class="col-12 col-md-4">
        <div class="card h-100 border-0 shadow-sm border-top border-4 brand-purple-top">
          <div class="card-body brand-kpi-soft-purple">
            <div class="small text-secondary fw-semibold">Total Batches</div>
            <div class="fs-4 fw-bold brand-purple-text"><%= esc(String(totalBatches)) %></div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-4">
        <div class="card h-100 border-0 shadow-sm border-top border-4 brand-purple-top">
          <div class="card-body brand-kpi-soft-purple">
            <div class="small text-secondary fw-semibold">Total Paid Out</div>
            <div class="fs-4 fw-bold brand-purple-text"><%= esc(String(totalPaidOut)) %></div>
            <div class="small text-muted">All-time (best-effort)</div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-4">
        <div class="card h-100 border-0 shadow-sm border-top border-4 brand-green-top">
          <div class="card-body brand-kpi-soft-green">
            <div class="small text-secondary fw-semibold">Last Batch Status</div>
            <div class="fs-4 fw-bold brand-purple-text"><%= esc(String(lastStatus)) %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- preview -->
    <div class="card border-0 shadow-sm mb-3 overflow-hidden">
      <div class="card-header border-0 brand-soft-purple py-3">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3">
          <div class="min-w-0">
            <h2 class="h5 fw-bold mb-1 brand-purple-text">Seller payout preview</h2>
            <p class="mb-0 small text-secondary">
              Currency: <strong><%= esc(previewCurrency) %></strong>.
              Shows each seller’s available balance.
            </p>
          </div>

          <div class="row g-2 w-100 w-lg-auto">
            <div class="col-6 col-sm-auto">
              <div class="card border-0 h-100 brand-kpi-soft-purple">
                <div class="card-body py-2 px-3">
                  <div class="small text-muted fw-semibold">Eligible sellers</div>
                  <div class="fw-bold brand-purple-text"><%= esc(String(eligibleSellers)) %></div>
                </div>
              </div>
            </div>
            <div class="col-6 col-sm-auto">
              <div class="card border-0 h-100 brand-kpi-soft-green">
                <div class="card-body py-2 px-3">
                  <div class="small text-muted fw-semibold">Eligible total</div>
                  <div class="fw-bold brand-purple-text text-break">
                    <%= esc(String(eligibleTotal)) %>
                    <span class="small text-muted"><%= esc(previewCurrency) %></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- desktop table -->
      <div class="d-none d-lg-block">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="brand-soft-purple">
              <tr>
                <th class="brand-purple-text">Seller</th>
                <th class="brand-purple-text">Payouts enabled</th>
                <th class="brand-purple-text">PayPal email</th>
                <th class="brand-purple-text">Available</th>
                <th class="brand-purple-text">Eligible now</th>
              </tr>
            </thead>
            <tbody>
              <% if (!preview.length) { %>
                <tr>
                  <td colspan="5" class="text-center text-muted py-4">No sellers found.</td>
                </tr>
              <% } else { %>
                <% preview.forEach(function(s){ %>
                  <tr>
                    <td>
                      <div class="fw-bold text-break"><%= esc(s.name || '—') %></div>
                      <div class="small text-muted text-break">businessId: <%= esc(s.businessId) %></div>
                    </td>

                    <td><%- yesNoPill(!!s.enabled, 'ENABLED', 'DISABLED') %></td>

                    <td>
                      <% if (s.hasPaypal) { %>
                        <span class="badge rounded-pill brand-soft-purple text-dark border text-wrap"><%= esc(s.paypalEmailMasked || maskEmailLocal(s.paypalEmail || '')) %></span>
                      <% } else { %>
                        <span class="badge rounded-pill text-bg-danger">NOT SET</span>
                      <% } %>
                    </td>

                    <td>
                      <div class="fw-bold brand-purple-text">
                        <%= money(s.availableCents) %> <span class="small text-muted"><%= esc(previewCurrency) %></span>
                      </div>
                      <div class="small text-muted">cents: <%= Number(s.availableCents||0) %></div>
                    </td>

                    <td>
                      <% if (s.eligible) { %>
                        <span class="badge rounded-pill text-bg-success">YES</span>
                      <% } else { %>
                        <span class="badge rounded-pill text-bg-secondary">NO</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- mobile / tablet cards -->
      <div class="card-body d-lg-none p-2 p-md-3">
        <% if (!preview.length) { %>
          <div class="text-center text-muted py-3">No sellers found.</div>
        <% } else { %>
          <div class="row g-2 g-md-3">
            <% preview.forEach(function(s){ %>
              <div class="col-12">
                <div class="card border-0 shadow-sm h-100 brand-soft-purple">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2 flex-wrap">
                      <div class="min-w-0 flex-grow-1">
                        <div class="fw-bold brand-purple-text text-break"><%= esc(s.name || '—') %></div>
                        <div class="small text-muted text-break">businessId: <%= esc(s.businessId) %></div>
                      </div>
                      <div class="flex-shrink-0">
                        <% if (s.eligible) { %>
                          <span class="badge rounded-pill text-bg-success">YES</span>
                        <% } else { %>
                          <span class="badge rounded-pill text-bg-secondary">NO</span>
                        <% } %>
                      </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-start gap-2 py-2 border-top flex-wrap">
                      <span class="small text-muted fw-semibold">Payouts</span>
                      <span><%- yesNoPill(!!s.enabled, 'ENABLED', 'DISABLED') %></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-start gap-2 py-2 border-top flex-wrap">
                      <span class="small text-muted fw-semibold">PayPal</span>
                      <div class="text-end">
                        <% if (s.hasPaypal) { %>
                          <span class="badge rounded-pill brand-kpi-soft-purple text-dark border text-wrap"><%= esc(s.paypalEmailMasked || maskEmailLocal(s.paypalEmail || '')) %></span>
                        <% } else { %>
                          <span class="badge rounded-pill text-bg-danger">NOT SET</span>
                        <% } %>
                      </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-start gap-2 py-2 border-top flex-wrap">
                      <span class="small text-muted fw-semibold">Available</span>
                      <span class="fw-bold brand-purple-text text-break">
                        <%= money(s.availableCents) %> <span class="small text-muted"><%= esc(previewCurrency) %></span>
                      </span>
                    </div>

                    <div class="d-flex justify-content-between align-items-start gap-2 pt-2 border-top flex-wrap">
                      <span class="small text-muted fw-semibold">Cents</span>
                      <span class="small text-muted text-break"><%= Number(s.availableCents||0) %></span>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="card-footer bg-white small text-muted">
        Note: “Eligible now” means payouts enabled + PayPal email set + available balance &gt; 0 in
        <strong><%= esc(previewCurrency) %></strong>.
      </div>
    </div>

    <!-- create + sync -->
    <div class="card border-0 shadow-sm mb-3 overflow-hidden">
      <div class="card-header border-0 text-white brand-purple-bg py-3">
        <h2 class="h5 fw-bold mb-1">Auto pay sellers now</h2>
        <p class="mb-0 small text-white text-opacity-75">
          Pays all eligible sellers and creates PayPal batch + local payout record.
        </p>
      </div>

      <div class="card-body p-3">
        <div class="row g-3">
          <div class="col-12 col-xl-8">
            <form method="POST" action="/admin/payouts/create" autocomplete="off">
              <div class="row g-3">
                <div class="col-12 col-md-6">
                  <label for="currency" class="form-label fw-semibold brand-purple-text">Currency</label>
                  <select id="currency" name="currency" class="form-select brand-input">
                    <option value="<%= esc(previewCurrency) %>" selected><%= esc(previewCurrency) %> (recommended)</option>
                    <option value="USD">USD</option>
                    <option value="ZAR">ZAR</option>
                    <option value="EUR">EUR</option>
                    <option value="GBP">GBP</option>
                  </select>
                  <div class="form-text">Keep it consistent with your ledger currency.</div>
                </div>

                <div class="col-12 col-md-6">
                  <label for="minCents" class="form-label fw-semibold brand-purple-text">Minimum payout (cents)</label>
                  <input
                    id="minCents"
                    name="minCents"
                    class="form-control brand-input"
                    placeholder="0 (example: 5000 = 50.00)"
                    inputmode="numeric"
                    value="0"
                    autocomplete="off"
                  />
                  <div class="form-text">Only sellers with available ≥ minCents will be paid.</div>
                </div>

                <div class="col-12">
                  <label for="note" class="form-label fw-semibold brand-purple-text">Note</label>
                  <input
                    id="note"
                    name="note"
                    class="form-control brand-input"
                    placeholder="Seller payout (for internal records)"
                    value="Seller payout"
                    autocomplete="off"
                  />
                </div>

                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="autoSync" value="1" checked id="autoSync">
                    <label class="form-check-label brand-purple-text" for="autoSync">
                      Auto-sync immediately after create
                    </label>
                  </div>
                  <div class="form-text">Updates item statuses quickly. You can still sync later below.</div>
                </div>

                <div class="col-12 d-flex flex-column flex-sm-row gap-2 align-items-start">
                  <button class="btn text-white brand-purple-bg border-0 px-4 w-100 w-sm-auto" type="submit">Auto Pay Now</button>
                  <div class="small text-muted">
                    Creates PayPal payout batch and debits each seller with <code>PAYOUT_DEBIT</code>.
                  </div>
                </div>
              </div>
            </form>
          </div>

          <div class="col-12 col-xl-4">
            <form method="POST" action="/admin/payouts/sync-recent" class="card border-0 shadow-sm h-100 brand-kpi-soft-green" autocomplete="off">
              <div class="card-body d-flex flex-column justify-content-center">
                <input type="hidden" name="limit" value="10" />
                <button class="btn text-white brand-green-bg border-0 w-100 w-sm-auto" type="submit">Sync Recent Batches</button>
                <div class="form-text mt-2">
                  Syncs the most recent batches. You can also sync per batch below.
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- history -->
    <div class="card border-0 shadow-sm overflow-hidden">
      <div class="card-header border-0 brand-soft-purple py-3">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3">
          <div>
            <h2 class="h5 fw-bold mb-1 brand-purple-text">Payout history</h2>
            <p class="mb-0 small text-secondary">
              Sync any batch to refresh item statuses.
            </p>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <span class="badge rounded-pill text-bg-success">COMPLETED</span>
            <span class="badge rounded-pill text-white brand-purple-bg">PROCESSING</span>
            <span class="badge rounded-pill text-bg-danger">FAILED</span>
          </div>
        </div>
      </div>

      <div class="card-body p-2 p-md-3">
        <% if (!payoutList.length) { %>
          <div class="text-center py-4">
            <div class="fs-2">📭</div>
            <div class="fw-bold mt-2 brand-purple-text">No payout batches yet</div>
            <div class="text-muted small">Use “Auto Pay Now” above.</div>
          </div>
        <% } else { %>

          <div class="row g-2 g-md-3">
            <% payoutList.forEach(function(p, idx){
              const items = Array.isArray(p.items) ? p.items : [];
              const sent = items.filter(i => String(i.status||'').toUpperCase()==='SENT').length;
              const failed = items.filter(i => String(i.status||'').toUpperCase()==='FAILED').length;
              const pending = items.filter(i => String(i.status||'').toUpperCase()==='PENDING').length;
              const collapseId = 'payoutItems-' + idx;
            %>
              <div class="col-12">
                <div class="card border-0 shadow-sm h-100 brand-kpi-soft-purple">
                  <div class="card-body p-3">
                    <div class="row g-3">
                      <div class="col-12 col-xl-8">
                        <div class="row g-3">
                          <div class="col-12 col-md-6 col-lg-4">
                            <div class="small text-muted fw-semibold">Created</div>
                            <div class="fw-bold text-break brand-purple-text"><%= p.createdAt ? new Date(p.createdAt).toLocaleString() : '—' %></div>
                            <div class="small text-muted">Admin payouts</div>
                          </div>

                          <div class="col-6 col-md-3 col-lg-2">
                            <div class="small text-muted fw-semibold">Mode</div>
                            <div><span class="badge rounded-pill bg-white text-dark border"><%= esc(p.mode || 'SANDBOX') %></span></div>
                          </div>

                          <div class="col-6 col-md-3 col-lg-3">
                            <div class="small text-muted fw-semibold">Status</div>
                            <div><span class="badge rounded-pill <%= badgeClass(p.status) %>"><%= esc(p.status || '—') %></span></div>
                          </div>

                          <div class="col-6 col-md-3 col-lg-1">
                            <div class="small text-muted fw-semibold">Currency</div>
                            <div class="fw-bold brand-purple-text"><%= esc(p.currency || 'USD') %></div>
                          </div>

                          <div class="col-6 col-md-3 col-lg-2">
                            <div class="small text-muted fw-semibold">Total</div>
                            <div class="fw-bold brand-purple-text"><%= money(p.totalCents) %></div>
                            <div class="small text-muted">cents: <%= Number(p.totalCents||0) %></div>
                          </div>

                          <div class="col-12 col-lg-6">
                            <div class="small text-muted fw-semibold">Batch IDs</div>
                            <div class="small text-break">
                              <div><strong>batchId:</strong> <%= esc(p.batchId || '—') %></div>
                              <div><strong>senderBatchId:</strong> <%= esc(p.senderBatchId || '—') %></div>
                            </div>
                          </div>

                          <div class="col-12 col-lg-6">
                            <div class="small text-muted fw-semibold mb-1">Items</div>
                            <div class="d-flex flex-wrap gap-2">
                              <span class="badge rounded-pill text-bg-success">SENT: <strong class="ms-1"><%= sent %></strong></span>
                              <span class="badge rounded-pill text-white brand-purple-bg">PENDING: <strong class="ms-1"><%= pending %></strong></span>
                              <span class="badge rounded-pill text-bg-danger">FAILED: <strong class="ms-1"><%= failed %></strong></span>
                            </div>
                          </div>
                        </div>
                      </div>

                      <div class="col-12 col-xl-4">
                        <div class="d-flex flex-column flex-sm-row flex-xl-column gap-2">
                          <form method="POST" action="/admin/payouts/<%= esc(p._id) %>/sync" class="m-0">
                            <button class="btn brand-soft-purple brand-purple-text border w-100" type="submit">Sync</button>
                          </form>

                          <button
                            class="btn brand-kpi-soft-green brand-purple-text border w-100"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#<%= collapseId %>"
                            aria-expanded="false"
                            aria-controls="<%= collapseId %>"
                          >
                            View Items (<%= items.length %>)
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="collapse" id="<%= collapseId %>">
                    <div class="card-footer border-0 brand-soft-purple p-3">
                      <% if (!items.length) { %>
                        <div class="text-muted small">No items for this payout batch.</div>
                      <% } else { %>
                        <div class="row g-2 g-md-3">
                          <% items.forEach(function(it){
                            const st = String(it.status||'PENDING').toUpperCase();
                            const receiverRaw = String(it.receiver || '').trim();
                            const receiverMasked = receiverRaw ? maskEmailLocal(receiverRaw) : '—';
                          %>
                            <div class="col-12 col-md-6 col-xl-4">
                              <div class="card border-0 shadow-sm h-100 bg-white">
                                <div class="card-body p-3">
                                  <div class="d-flex justify-content-between align-items-start gap-2 mb-2 flex-wrap">
                                    <span class="badge rounded-pill brand-soft-purple text-dark border"><%= esc(it.currency || p.currency || 'USD') %></span>
                                    <span class="badge rounded-pill <%= st==='SENT' ? 'text-bg-success' : (st==='FAILED' ? 'text-bg-danger' : 'text-white brand-purple-bg') %>">
                                      <%= esc(st) %>
                                    </span>
                                  </div>

                                  <div class="fw-bold fs-5 brand-purple-text"><%= money(it.amountCents) %></div>
                                  <div class="mt-1 fw-semibold text-break"><%= esc(receiverMasked) %></div>
                                  <div class="small text-muted mt-1 text-break">businessId: <%= esc(it.businessId) %></div>

                                  <% if (it.error) { %>
                                    <div class="alert alert-danger py-2 px-3 small mt-3 mb-2">
                                      Error: <%= esc(it.error) %>
                                    </div>
                                  <% } %>

                                  <div class="small text-muted mt-2 text-break">
                                    paypalItemId: <%= esc(it.paypalItemId || '—') %>
                                  </div>
                                </div>
                              </div>
                            </div>
                          <% }) %>
                        </div>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>

        <% } %>
      </div>
    </div>

  </div>
</section>

<%
  styles = `
<style nonce="${NONCE}">
  .brand-page-bg { background-color: #f6f0ff; }
  .brand-purple-bg { background-color: #7C3AED !important; }
  .brand-green-bg { background-color: #22C55E !important; }
  .brand-soft-purple { background-color: rgba(124,58,237,.12) !important; }
  .brand-kpi-soft-purple { background-color: rgba(124,58,237,.08) !important; }
  .brand-kpi-soft-green { background-color: rgba(34,197,94,.10) !important; }
  .brand-purple-text { color: #7C3AED !important; }
  .brand-purple-top { border-top-color: #7C3AED !important; }
  .brand-green-top { border-top-color: #22C55E !important; }

  .min-w-0 { min-width: 0; }

  .brand-input {
    background-color: rgba(124,58,237,.06);
    border-color: rgba(124,58,237,.25);
  }

  .brand-input:focus {
    border-color: #7C3AED;
    box-shadow: 0 0 0 .25rem rgba(124,58,237,.15);
  }
</style>
`;
%>