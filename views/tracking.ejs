<!-- views/tracking.ejs -->
<%
  const PAGE_NONCE = typeof nonce !== 'undefined' ? nonce : '';
  const BASE = (typeof baseUrl !== 'undefined' && baseUrl) ? baseUrl : '/orders/tracking';
  const o = order || {};
  const t = o.shippingTracking || {};
  const events = Array.isArray(t.liveEvents) ? t.liveEvents : [];

  function niceDate(d) {
    try {
      if (!d) return '';
      return new Date(d).toLocaleString('en-ZA', { timeZone: 'Africa/Johannesburg' });
    } catch {
      return String(d || '');
    }
  }

  const pickEventDate = (ev) => {
    if (!ev) return null;
    return (
      ev.datetime ||
      ev.date ||
      ev.status_date ||
      ev.event_datetime ||
      ev.timestamp ||
      ev.created_at ||
      ev.updated_at ||
      null
    );
  };

  const eventsSorted = [...events].sort((a, b) => {
    const da = new Date(pickEventDate(a) || 0).getTime();
    const db = new Date(pickEventDate(b) || 0).getTime();
    return db - da;
  });

  const lastUpdateRaw =
    pickEventDate(eventsSorted[0]) ||
    t.lastTrackingUpdate ||
    t.lastUpdate ||
    t.lastUpdatedAt ||
    t.updatedAt ||
    o.updatedAt ||
    null;

  const etaRaw =
    t.eta ||
    t.estimatedDelivery ||
    t.estimated_delivery ||
    t.expected_delivery_date ||
    t.tracking_status?.eta ||
    null;

  const lastUpdateText = lastUpdateRaw ? niceDate(lastUpdateRaw) : '—';

  const currentStatus =
    t.liveStatus ||
    t.status ||
    liveTracking?.status ||
    eventsSorted[0]?.status ||
    o.fulfillmentStatus ||
    (t.trackingNumber ? 'SHIPPED' : '');

  const rateDays =
    o?.shippo?.chosenRate?.estimatedDays ??
    o?.shippo?.chosenRate?.estimated_days ??
    null;

  const labelDate =
    o?.shippo?.labelPurchasedAt ||
    o?.shippo?.transactionCreatedAt ||
    o?.updatedAt ||
    o?.createdAt ||
    null;

  const approxEtaRaw =
    (!etaRaw && rateDays != null && labelDate)
      ? new Date(new Date(labelDate).getTime() + (Number(rateDays) * 24 * 60 * 60 * 1000))
      : null;

  const etaFinalText = etaRaw
    ? niceDate(etaRaw)
    : (approxEtaRaw ? (niceDate(approxEtaRaw) + ' (approx)') : '—');

  const prettyCarrier = (v) => {
    const s = String(v || '').trim();
    if (!s) return '';
    const m = {
      usps: 'USPS',
      ups: 'UPS',
      fedex: 'FedEx',
      dhl_express: 'DHL Express',
      dhl: 'DHL',
      shippo: 'Shippo (Test)',
      COURIER_GUY: 'The Courier Guy',
      FASTWAY: 'Fastway',
      ARAMEX: 'Aramex',
      OTHER: 'Other',
    };
    return m[s] || m[s.toUpperCase()] || s;
  };

  const prettyStatus = (v) => {
    const s = String(v || '').trim().toUpperCase();
    const m = {
      PENDING: 'Pending',
      PROCESSING: 'Processing',
      LABEL_CREATED: 'Label created',
      SHIPPED: 'Shipped',
      IN_TRANSIT: 'In transit',
      OUT_FOR_DELIVERY: 'Out for delivery',
      DELIVERED: 'Delivered',
      CANCELLED: 'Cancelled',
      RETURNED: 'Returned',
      FAILURE: 'Tracking error',
      UNKNOWN: 'Unknown',
    };
    return m[s] || (s ? s.replace(/_/g, ' ').toLowerCase().replace(/^\w/, c => c.toUpperCase()) : '—');
  };

  const statusTag = (v) => String(prettyStatus(v) || '—');

  const statusClass = (v) => {
    const s = String(v || '').trim().toUpperCase();

    if (s === 'DELIVERED') return 'trk-badge-ok';

    if (s === 'OUT_FOR_DELIVERY') return 'trk-badge-ship';
    if (s === 'IN_TRANSIT') return 'trk-badge-ship';
    if (s === 'SHIPPED') return 'trk-badge-ship';
    if (s === 'LABEL_CREATED') return 'trk-badge-ship';

    if (s === 'CANCELLED') return 'trk-badge-bad';
    if (s === 'RETURNED') return 'trk-badge-bad';
    if (s === 'FAILURE') return 'trk-badge-bad';

    if (s === 'PROCESSING') return 'trk-badge-muted';
    if (s === 'PENDING') return 'trk-badge-muted';
    if (s === 'UNKNOWN') return 'trk-badge-muted';

    return 'trk-badge-muted';
  };

  const eventDetails = (ev) => {
    const d = String(ev?.details || '').trim();
    const r = String(ev?.rawStatus || '').trim();
    return d || r || prettyStatus(ev?.status);
  };

  const eventLocationLine = (loc) => {
    if (!loc || typeof loc !== 'object') return '';
    const city = String(loc?.city || '').trim();
    const state = String(loc?.state || '').trim();
    const country = String(loc?.country || loc?.country_code || '').trim();
    const parts = [city, state, country].filter(Boolean);
    return parts.join(', ');
  };

  const toArray = (v) => {
    if (!v) return [];
    if (Array.isArray(v)) return v;
    return [String(v)];
  };

  const buildCarrierTrackingUrl = (carrierToken, trackingNumber) => {
    const c = String(carrierToken || '').trim().toLowerCase();
    const tn = encodeURIComponent(String(trackingNumber || '').trim());
    if (!c || !tn) return '';

    if (c === 'usps') {
      return `https://tools.usps.com/go/TrackConfirmAction?tLabels=${tn}`;
    }
    if (c === 'ups') {
      return `https://www.ups.com/track?tracknum=${tn}`;
    }
    if (c === 'fedex') {
      return `https://www.fedex.com/fedextrack/?trknbr=${tn}`;
    }
    if (c.includes('dhl')) {
      return `https://www.dhl.com/global-en/home/tracking/tracking-express.html?submit=1&tracking-id=${tn}`;
    }

    return '';
  };

  const trackingUrlFinal =
    String(t.trackingUrl || '').trim() ||
    buildCarrierTrackingUrl(t.carrierToken || t.carrier, t.trackingNumber);

  const labelUrlFinal =
    String(
      o?.shippo?.labelUrl ||
      o?.shippo?.label_url ||
      o?.shippo?.labelPdfUrl ||
      o?.shippo?.label_pdf ||
      t?.labelUrl ||
      ''
    ).trim();

  const successList = toArray(success);
  const errorList = toArray(error);
%>

<!-- Spinner Start -->
<div
  id="spinner"
  class="show fade bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center"
  style="z-index: 9999;"
>
  <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
    <span class="visually-hidden">Loading...</span>
  </div>
</div>
<!-- Spinner End -->

<div class="container-fluid px-2 px-sm-3 px-lg-4 py-3 py-lg-4 tracking-page-bg">
  <div class="row justify-content-center mx-0">
    <div class="col-12 col-xl-11 px-0">

      <div class="card border-brand-purple shadow-sm overflow-hidden mb-3 mb-lg-4">
        <div class="card-body p-0">
          <div class="bg-brand-purple text-white p-3 p-lg-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
              <div class="w-100">
                <div class="small fw-semibold text-uppercase tracking-head-kicker mb-2">Shipment progress</div>
                <h1 class="h3 fw-bold mb-2">Order Tracking</h1>
                <div class="d-flex flex-column gap-1">
                  <div class="small text-white-50">
                    OrderId:
                    <span class="font-monospace fw-semibold text-white"><%= o.orderId || '—' %></span>
                  </div>
                  <div class="small text-white-50">
                    Created: <%= niceDate(o.createdAt) %>
                  </div>
                </div>
              </div>

              <div class="d-flex flex-column flex-sm-row gap-2 w-100 w-lg-auto">
                <a class="btn btn-light text-brand-purple fw-semibold" href="<%= isAdmin ? '/admin/shippo' : '/orders' %>">
                  ← Back
                </a>
                <button class="btn btn-brand-green" type="button" id="btnRefresh">
                  Refresh live tracking
                </button>
              </div>
            </div>
          </div>

          <div class="px-3 px-lg-4 py-3 bg-brand-purple-soft border-top border-brand-purple-soft">
            <div class="d-flex flex-column flex-md-row align-items-md-center gap-2 gap-md-3">
              <div class="small fw-semibold text-brand-purple text-uppercase">Current status</div>
              <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="badge rounded-pill trk-badge-solid <%= statusClass(currentStatus) %>">
                  <%= statusTag(currentStatus) %>
                </span>
                <% if (t.status && currentStatus && String(t.status).toUpperCase() !== String(currentStatus).toUpperCase()) { %>
                  <span class="badge rounded-pill <%= statusClass(t.status) %>">
                    <%= 'Saved: ' + statusTag(t.status) %>
                  </span>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <% successList.forEach(msg => { %>
        <div class="alert alert-success shadow-sm mb-3" role="alert">✅ <%= msg %></div>
      <% }) %>

      <% errorList.forEach(msg => { %>
        <div class="alert alert-danger shadow-sm mb-3" role="alert">❌ <%= msg %></div>
      <% }) %>

      <div class="row g-3 g-lg-4">
        <div class="col-12 col-lg-6">
          <div class="card border-brand-purple shadow-sm h-100 overflow-hidden">
            <div class="card-header bg-brand-purple text-white py-3">
              <h2 class="h5 fw-bold mb-0">Current tracking</h2>
            </div>

            <div class="card-body p-3 p-lg-4">

              <div class="tracking-field rounded-3 p-3 mb-3">
                <div class="small fw-semibold text-uppercase text-brand-purple mb-2">Carrier</div>
                <div class="fw-semibold fs-5 text-dark">
                  <%= (t.carrierLabel || prettyCarrier(t.carrier) || '—') %>
                  <% if (t.carrierToken) { %>
                    <span class="badge rounded-pill trk-badge-base ms-2"><%= prettyCarrier(t.carrierToken) %></span>
                  <% } %>
                </div>
              </div>

              <% if (trackingUrlFinal) { %>
                <div class="tracking-field rounded-3 p-3 mb-3">
                  <div class="small fw-semibold text-uppercase text-brand-purple mb-2">Tracking link</div>
                  <a class="btn btn-outline-brand-purple fw-semibold" href="<%= trackingUrlFinal %>" target="_blank" rel="noopener noreferrer">
                    Open carrier tracking ↗
                  </a>
                </div>
              <% } %>

              <% if (labelUrlFinal) { %>
                <div class="tracking-field rounded-3 p-3 mb-3">
                  <div class="small fw-semibold text-uppercase text-brand-purple mb-2">Shipping label</div>
                  <a class="btn btn-outline-brand-purple fw-semibold" href="<%= labelUrlFinal %>" target="_blank" rel="noopener noreferrer">
                    Open shipping label ↗
                  </a>
                </div>
              <% } %>

              <div class="tracking-field rounded-3 p-3 mb-3">
                <div class="small fw-semibold text-uppercase text-brand-purple mb-2">Last update</div>
                <div class="fw-semibold text-dark"><%= lastUpdateText %></div>
              </div>

              <div class="tracking-field rounded-3 p-3 <%= isAdmin ? 'mb-4' : 'mb-0' %>">
                <div class="small fw-semibold text-uppercase text-brand-purple mb-2">ETA</div>
                <div class="fw-semibold text-dark"><%= etaFinalText %></div>
              </div>

              <% if (isAdmin) { %>
                <div class="pt-2">
                  <h2 class="h5 fw-bold text-brand-purple mb-3">Admin: set tracking</h2>

                  <form method="POST" action="<%= BASE %>/<%= o._id %>" class="row g-3">
                    <div class="col-12">
                      <label class="form-label fw-semibold text-brand-purple">Carrier (Shippo token)</label>
                      <select name="carrier" class="form-select tracking-input" required>
                        <option value="">Choose…</option>
                        <option value="usps" <%= t.carrierToken === 'usps' ? 'selected' : '' %>>USPS</option>
                        <option value="ups" <%= t.carrierToken === 'ups' ? 'selected' : '' %>>UPS</option>
                        <option value="fedex" <%= t.carrierToken === 'fedex' ? 'selected' : '' %>>FedEx</option>
                        <option value="dhl_express" <%= t.carrierToken === 'dhl_express' ? 'selected' : '' %>>DHL Express</option>
                      </select>
                    </div>

                    <div class="col-12">
                      <label class="form-label fw-semibold text-brand-purple">Tracking number</label>
                      <input
                        name="trackingNumber"
                        class="form-control tracking-input"
                        value="<%= t.trackingNumber || '' %>"
                        placeholder="Enter tracking number"
                        required
                      />
                    </div>

                    <div class="col-12">
                      <label class="form-label fw-semibold text-brand-purple">Carrier display name (optional)</label>
                      <input
                        name="carrierLabel"
                        class="form-control tracking-input"
                        value="<%= t.carrierLabel || '' %>"
                        placeholder="Name shown on page (e.g. DHL Express South Africa)"
                      />
                    </div>

                    <div class="col-12">
                      <div class="small text-body-secondary">
                        Tracking link is auto-shown from the saved URL, or generated from carrier + tracking number if URL is missing.
                      </div>
                    </div>

                    <div class="col-12">
                      <% if (labelUrlFinal) { %>
                        <div class="small text-body-secondary">
                          Shipping label is available above as a clickable link.
                        </div>
                      <% } else { %>
                        <div class="small text-body-secondary">
                          Shipping label will appear automatically after a label URL is saved from your shipping flow.
                        </div>
                      <% } %>
                    </div>

                    <div class="col-12">
                      <button class="btn btn-brand-purple fw-semibold" type="submit">Save tracking</button>
                    </div>

                    <div class="col-12">
                      <div class="small text-body-secondary">
                        We save the real carrier in <span class="font-monospace">carrierToken</span>. This field only changes the display name shown on this page.
                      </div>
                    </div>
                  </form>
                </div>
              <% } %>

            </div>
          </div>
        </div>

        <div class="col-12 col-lg-6">
          <div class="card border-brand-purple shadow-sm h-100 overflow-hidden">
            <div class="card-header bg-brand-purple text-white py-3">
              <h2 class="h5 fw-bold mb-0">Tracking events</h2>
            </div>

            <div class="card-body p-3 p-lg-4">
              <div id="liveMsg" class="small text-body-secondary mb-3"></div>

              <% if (!events.length) { %>
                <div class="tracking-empty rounded-3 p-3">
                  No live events yet. Click “Refresh live tracking”.
                </div>
              <% } else { %>
                <div class="d-grid gap-3" id="eventsBox">
                  <% events.slice().reverse().forEach(ev => { %>
                    <div class="tracking-field rounded-3 p-3">
                      <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-2">
                        <span class="badge rounded-pill <%= statusClass(ev.status) %>">
                          <%= statusTag(ev.status) %>
                        </span>
                        <span class="small text-body-secondary">
                          <%= niceDate(pickEventDate(ev) || ev.date) %>
                        </span>
                      </div>

                      <div class="fw-semibold text-dark mb-2"><%= eventDetails(ev) %></div>

                      <% const locLine = eventLocationLine(ev.location); %>
                      <% if (locLine) { %>
                        <div class="small text-body-secondary">📍 <%= locLine %></div>
                      <% } else if (ev.location) { %>
                        <div class="small text-body-secondary"><%= JSON.stringify(ev.location) %></div>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style nonce="<%= PAGE_NONCE %>">
  .tracking-page-bg {
    background-color: #f8f5ff !important;
  }

  .text-brand-purple { color: #7C3AED !important; }
  .bg-brand-purple { background-color: #7C3AED !important; }
  .bg-brand-purple-soft { background-color: rgba(124, 58, 237, 0.10) !important; }
  .border-brand-purple { border-color: rgba(124, 58, 237, 0.35) !important; }
  .border-brand-purple-soft { border-color: rgba(124, 58, 237, 0.18) !important; }

  .tracking-head-kicker {
    color: rgba(255, 255, 255, 0.82) !important;
    letter-spacing: 0.08em;
  }

  .tracking-field {
    background-color: rgba(124, 58, 237, 0.08) !important;
    border: 1px solid rgba(124, 58, 237, 0.18) !important;
  }

  .tracking-empty {
    background-color: rgba(124, 58, 237, 0.08) !important;
    border: 1px dashed rgba(124, 58, 237, 0.28) !important;
    color: #6b7280 !important;
  }

  .tracking-input {
    border-color: rgba(124, 58, 237, 0.25) !important;
    background-color: rgba(124, 58, 237, 0.04) !important;
  }

  .tracking-input:focus {
    border-color: rgba(124, 58, 237, 0.55) !important;
    box-shadow: 0 0 0 0.25rem rgba(124, 58, 237, 0.12) !important;
    background-color: #fff !important;
  }

  .btn-brand-purple {
    background-color: #7C3AED !important;
    border-color: #7C3AED !important;
    color: #fff !important;
  }

  .btn-brand-purple:hover,
  .btn-brand-purple:focus {
    background-color: #6D28D9 !important;
    border-color: #6D28D9 !important;
    color: #fff !important;
  }

  .btn-outline-brand-purple {
    color: #7C3AED !important;
    border-color: #7C3AED !important;
    background-color: rgba(124, 58, 237, 0.06) !important;
  }

  .btn-outline-brand-purple:hover,
  .btn-outline-brand-purple:focus {
    background-color: #7C3AED !important;
    border-color: #7C3AED !important;
    color: #fff !important;
  }

  .btn-brand-green {
    background-color: #22C55E !important;
    border-color: #22C55E !important;
    color: #fff !important;
  }

  .btn-brand-green:hover,
  .btn-brand-green:focus {
    background-color: #16A34A !important;
    border-color: #16A34A !important;
    color: #fff !important;
  }

  .trk-badge-base {
    background-color: rgba(124, 58, 237, 0.12) !important;
    border: 1px solid rgba(124, 58, 237, 0.25) !important;
    color: #7C3AED !important;
  }

  .trk-badge-solid {
    border: 1px solid transparent !important;
  }

  .trk-badge-ok {
    background-color: rgba(34, 197, 94, 0.14) !important;
    border: 1px solid rgba(34, 197, 94, 0.30) !important;
    color: #166534 !important;
  }

  .trk-badge-ship {
    background-color: rgba(124, 58, 237, 0.14) !important;
    border: 1px solid rgba(124, 58, 237, 0.30) !important;
    color: #7C3AED !important;
  }

  .trk-badge-muted {
    background-color: rgba(107, 114, 128, 0.12) !important;
    border: 1px solid rgba(107, 114, 128, 0.24) !important;
    color: #4b5563 !important;
  }

  .trk-badge-bad {
    background-color: rgba(239, 68, 68, 0.12) !important;
    border: 1px solid rgba(239, 68, 68, 0.28) !important;
    color: #991B1B !important;
  }
</style>

<script nonce="<%= PAGE_NONCE %>">
document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('btnRefresh');
  const msg = document.getElementById('liveMsg');

  async function refresh() {
    if (msg) msg.textContent = 'Refreshing…';
    if (btn) btn.disabled = true;

    let r, data;
    try {
      r = await fetch('<%= BASE %>/<%= o._id %>/refresh', {
        method: 'GET',
        headers: { 'Accept': 'application/json' }
      });
      data = await r.json().catch(() => ({}));
    } catch (e) {
      if (btn) btn.disabled = false;
      if (msg) msg.textContent = '❌ Network error. Please try again.';
      return;
    }

    if (btn) btn.disabled = false;

    if (!r.ok || !data.ok) {
      if (msg) msg.textContent = '❌ ' + (data.message || 'Failed to refresh');
      return;
    }

    if (msg) msg.textContent = '✅ Updated. Reloading…';
    window.location.reload();
  }

  if (btn) btn.addEventListener('click', refresh);

  const pageSpinner = document.getElementById('spinner');

  if (pageSpinner) {
    window.addEventListener('load', function () {
      setTimeout(function () {
        pageSpinner.classList.remove('show');

        setTimeout(function () {
          pageSpinner.classList.add('d-none');
        }, 300);
      }, 700);
    });
  }
});
</script>