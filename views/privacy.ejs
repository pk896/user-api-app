<!-- views/privacy.ejs -->
<% const NONCE = typeof nonce !== 'undefined' ? nonce : '' %>
<!-- Spinner Start -->
<div
  id="spinner"
  class="show fade bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center"
  style="z-index: 9999;"
>
  <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
    <span class="visually-hidden">Loading...</span>
  </div>
</div>
<!-- Spinner End -->

<div class="min-vh-100 bg-body-tertiary py-4" id="top">
  <!-- Full width on mobile, padded on md+ -->
  <div class="container-fluid px-0 px-md-3">
    <!-- Bootstrap-only max width using grid breakpoints -->
    <div class="mx-auto col-12 col-lg-10 col-xl-8">

      <!-- Header (full width on mobile, clean section style) -->
      <header class="bg-body border-bottom shadow-sm px-3 px-md-4 py-4 py-md-5 text-center">
        <div class="d-flex justify-content-center mb-3">
          <span class="badge rounded-pill text-bg-primary px-3 py-2">
            🔒 Privacy &amp; Security
          </span>
        </div>

        <h1 class="h2 fw-bold mb-3">Privacy Policy</h1>

        <p class="text-body-secondary mb-0">
          Your privacy matters to us at <span class="fw-semibold">Unicoporate.com</span>.
          This Privacy Policy explains how we collect, use, store, and protect your personal information
          when you interact with our platform, products, and services.
        </p>
      </header>

      <!-- Sections -->
      <div class="d-flex flex-column">

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">1</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">Who We Are</h2>
              <p class="mb-0">
                <strong>Unicoporate.com</strong> is a technology-driven e-commerce ecosystem founded by
                <strong>Phakisi Lighten Moteane</strong> and <strong>Moteane Kabelo</strong>.
                Our mission is to empower individuals and businesses while maintaining transparency, integrity, and data responsibility.
              </p>
            </div>
          </div>
        </section>

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">2</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">Information We Collect</h2>
              <p class="mb-2">We collect only the data necessary to provide excellent service, such as:</p>
              <ul class="mb-0">
                <li><strong>Personal details</strong> — name, email, contact information.</li>
                <li><strong>Transaction data</strong> — order details, payment confirmations, and shipping info.</li>
                <li><strong>Technical data</strong> — IP address, browser type, device info, and cookies.</li>
              </ul>
            </div>
          </div>
        </section>

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">3</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">How We Use Your Information</h2>
              <p class="mb-2">Your data helps us:</p>
              <ul class="mb-0">
                <li>Process and deliver orders efficiently.</li>
                <li>Communicate with you about products, updates, or support.</li>
                <li>Improve our services and personalize your experience.</li>
                <li>Ensure the security and reliability of our platform.</li>
              </ul>
            </div>
          </div>
        </section>

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">4</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">Protecting Your Data</h2>
              <p class="mb-0">
                We use advanced security measures, encryption, and secure data centers to protect your information.
                Only authorized staff and trusted partners can access your data when necessary to provide services.
                While we take every precaution, no online system is completely invulnerable, and we encourage you to protect your credentials responsibly.
              </p>
            </div>
          </div>
        </section>

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">5</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">Sharing and Third-Party Services</h2>
              <p class="mb-2">
                We do <strong>not sell</strong> your personal data.
                We may share limited data only with:
              </p>
              <ul class="mb-0">
                <li><strong>Payment providers</strong> (e.g., PayPal) to process transactions securely.</li>
                <li><strong>Delivery and logistics partners</strong> for shipment coordination.</li>
                <li><strong>Regulatory bodies</strong> when required by law.</li>
              </ul>
            </div>
          </div>
        </section>

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">6</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">Cookies and Tracking</h2>
              <p class="mb-0">
                Our site uses cookies to remember your preferences, improve site speed, and deliver personalized experiences.
                You can manage or disable cookies in your browser settings.
              </p>
            </div>
          </div>
        </section>

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">7</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">Your Rights</h2>
              <p class="mb-2">You have the right to:</p>
              <ul class="mb-2">
                <li>Access or request a copy of your data.</li>
                <li>Correct inaccurate information.</li>
                <li>Request deletion of your account or personal data.</li>
                <li>Opt out of marketing communications at any time.</li>
              </ul>
              <p class="mb-0">
                To exercise these rights, contact us at
                📧 <a class="text-decoration-none" href="mailto:support@phakisiglobal.com">support@phakisiglobal.com</a>.
              </p>
            </div>
          </div>
        </section>

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">8</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">International Users</h2>
              <p class="mb-0">
                As a global platform, your data may be processed in different regions.
                All data handling complies with applicable privacy and data protection laws in those regions.
              </p>
            </div>
          </div>
        </section>

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">9</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">Policy Updates</h2>
              <p class="mb-0">
                We may update this Privacy Policy periodically to reflect improvements or legal changes.
                Updates will be posted here with a revised date at the top of the page.
              </p>
            </div>
          </div>
        </section>

        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <div class="d-flex align-items-start gap-3">
            <span class="badge text-bg-success rounded-pill px-3 py-2 flex-shrink-0">10</span>
            <div class="flex-grow-1">
              <h2 class="h5 fw-bold text-primary mb-2">Contact Us</h2>
              <p class="mb-0">
                If you have any questions, please reach out to our team.
              </p>
            </div>
          </div>
        </section>

        <!-- Founders (still not "cards", just border + padding) -->
        <section class="bg-body border-bottom px-3 px-md-4 py-4">
          <h3 class="h5 fw-bold mb-3">Founders</h3>

          <div class="row g-3">
            <div class="col-12 col-md-6">
              <div class="border rounded-3 p-3 h-100">
                <div class="fw-semibold mb-2">👨‍💻 Founder – Phakisi Lighten Moteane</div>
                <div class="small mb-2">
                  📧 <a class="text-decoration-none" href="mailto:phakisingxongxela@gmail.com">phakisingxongxela@gmail.com</a>
                </div>
                <div class="small">
                  📘 <a class="text-decoration-none" href="https://www.facebook.com/profile.php?id=100083397021296" target="_blank" rel="noopener">Facebook Profile</a>
                </div>
              </div>
            </div>

            <div class="col-12 col-md-6">
              <div class="border rounded-3 p-3 h-100">
                <div class="fw-semibold mb-2">🤝 Co-Founder – Moteane Kabelo</div>
                <div class="small mb-2">
                  📧 <a class="text-decoration-none" href="mailto:moteanekabelo37@gmail.com">moteanekabelo37@gmail.com</a>
                </div>
                <div class="small">
                  📘 <a class="text-decoration-none" href="https://www.facebook.com/profile.php?id=100094603932435" target="_blank" rel="noopener">Facebook Profile</a>
                </div>
              </div>
            </div>
          </div>
        </section>

      </div>

      <!-- Footer -->
      <footer class="bg-body border-top shadow-sm px-3 px-md-4 py-4">
        <a href="#top" class="btn btn-outline-secondary btn-sm">↑ Back to top</a>
      </footer>

    </div>
  </div>
</div>

<script nonce="<%= NONCE %>">
  document.addEventListener('DOMContentLoaded', function () {
    const pageSpinner = document.getElementById('spinner');

    if (pageSpinner) {
      setTimeout(function () {
        pageSpinner.classList.remove('show');

        setTimeout(function () {
          pageSpinner.classList.add('d-none');
        }, 300);
      }, 700);
    }
  });
</script>
