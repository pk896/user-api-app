  /* ==========================================================
   * ✅ FULL WIDTH PAGE LOCK
   * Page: views/wholesale/supplier-profile.ejs only
   * Purpose: edge-to-edge layout without horizontal swipe
   * ======================================================== */

  .wholesale-supplier-page,
  .wholesale-supplier-page * {
    box-sizing: border-box;
  }

  .wholesale-supplier-page {
    width: 100%;
    max-width: 100%;
    min-width: 0;
