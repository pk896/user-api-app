<!--views/wholesale/supplier-profile.ejs-->
<div class="container py-4">
  <div class="mb-4">
    <a href="/wholesale/suppliers" class="text-decoration-none text-primary">
      ← Back to Suppliers
    </a>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex flex-column flex-md-row align-items-md-center gap-3">
        <% if (supplier.logoUrl) { %>
          <img src="<%= supplier.logoUrl %>" alt="<%= supplier.name %>" class="rounded-circle" style="width: 82px; height: 82px; object-fit: cover;">
        <% } else { %>
          <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold fs-3" style="width: 82px; height: 82px;">
            <%= String(supplier.name || 'S').charAt(0).toUpperCase() %>
          </div>
        <% } %>

        <div>
          <h1 class="h3 fw-bold text-primary mb-1"><%= supplier.name %></h1>
          <p class="text-muted mb-2">
            <%= supplier.city || '' %>
            <%= supplier.country ? ', ' + supplier.country : '' %>
          </p>
          <span class="badge text-bg-success">Verified Supplier</span>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h5 fw-bold text-primary mb-0">Wholesale Products</h2>
    <a href="/wholesale" class="btn btn-outline-primary btn-sm">Marketplace</a>
  </div>

  <% if (!products || products.length === 0) { %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <h3 class="h6 fw-bold text-primary">No active wholesale products</h3>
        <p class="text-muted mb-0">This supplier has not published active wholesale products yet.</p>
      </div>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% products.forEach((product) => { %>
        <div class="col-12 col-md-6 col-xl-4">
          <div class="card h-100 border-0 shadow-sm">
            <% if (product.imageUrl) { %>
              <div class="ratio ratio-4x3 bg-light">
                <img
                  src="<%= product.imageUrl %>"
                  class="card-img-top w-100 h-100 object-fit-contain p-2"
                  alt="<%= product.name %>"
                >
              </div>
            <% } else { %>
              <div class="ratio ratio-4x3 bg-light">
                <div class="d-flex align-items-center justify-content-center w-100 h-100">
                  <span class="text-muted">No image</span>
                </div>
              </div>
            <% } %>

            <div class="card-body">
              <h3 class="h6 fw-bold text-primary"><%= product.name %></h3>
              <p class="small text-muted mb-3"><%= product.category || 'Uncategorized' %></p>

              <div class="d-flex justify-content-between small mb-3">
                <span>Wholesale:</span>
                <strong>R <%= Number(product.wholesalePrice || 0).toFixed(2) %></strong>
              </div>

              <div class="d-flex justify-content-between small mb-3">
                <span>MOQ:</span>
                <strong><%= product.minimumOrderQuantity || 1 %></strong>
              </div>

              <% if (business && business.role === 'seller') { %>
                <% const moq = Number(product.minimumOrderQuantity || 1); %>
                <% const available = Number(product.availableQuantity || 0); %>

                <% if (available > 0) { %>
                  <form method="POST" action="/wholesale/cart/add/<%= product._id %>" class="d-grid gap-2">
                    <div class="input-group input-group-sm">
                      <span class="input-group-text">Qty</span>
                      <input
                        type="number"
                        name="quantity"
                        class="form-control"
                        min="<%= moq %>"
                        max="<%= available %>"
                        value="<%= moq %>"
                        required
                      >
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                      Add to Wholesale Request
                    </button>
                  </form>

                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary w-100 mt-2">
                    View Product
                  </a>
                <% } else { %>
                  <button type="button" class="btn btn-outline-secondary w-100" disabled>
                    Out of Stock
                  </button>

                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary w-100 mt-2">
                    View Product
                  </a>
                <% } %>
              <% } else { %>
                <a href="/wholesale/products/<%= product._id %>" class="btn btn-primary w-100">
                  View Product
                </a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
