<!--views/wholesale/supplier-profile.ejs-->
<div class="container-fluid px-2 px-sm-3 px-lg-4 py-3">
  <div class="mb-3">
    <a href="/wholesale/suppliers" class="text-decoration-none text-primary small fw-semibold">
      ← Back to Suppliers
    </a>
  </div>

  <!-- Supplier card -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
      <div class="d-flex align-items-center gap-3">
        <% if (supplier.logoUrl) { %>
          <img
            src="<%= supplier.logoUrl %>"
            alt="<%= supplier.name %>"
            class="rounded-circle"
            style="width: 58px; height: 58px; object-fit: cover;"
            loading="lazy"
            decoding="async"
            onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';"
          >
        <% } else { %>
          <div
            class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold fs-5"
            style="width: 58px; height: 58px;"
          >
            <%= String(supplier.name || 'S').charAt(0).toUpperCase() %>
          </div>
        <% } %>

        <div class="min-w-0">
          <h1 class="h5 fw-bold text-primary mb-1 text-truncate">
            <%= supplier.name %>
          </h1>

          <p class="text-muted small mb-1">
            <%= supplier.city || '' %>
            <%= supplier.country ? ', ' + supplier.country : '' %>
          </p>

          <span class="badge text-bg-success">Verified Supplier</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Section header -->
  <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
    <h2 class="h6 fw-bold text-primary mb-0">Wholesale Products</h2>

    <a href="/wholesale" class="btn btn-outline-primary btn-sm">
      Marketplace
    </a>
  </div>

  <% if (!products || products.length === 0) { %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <h3 class="h6 fw-bold text-primary">No active wholesale products</h3>
        <p class="text-muted small mb-0">
          This supplier has not published active wholesale products yet.
        </p>
      </div>
    </div>
  <% } else { %>
    <!--
      Mobile: 2 columns
      Tablet: 3 columns
      Desktop: 4 columns
    -->
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2 g-lg-3">
      <% products.forEach((product) => { %>
        <% const moq = Number(product.minimumOrderQuantity || 1); %>
        <% const available = Number(product.availableQuantity || 0); %>

        <div class="col">
          <div class="card h-100 border-0 shadow-sm overflow-hidden">
            <!-- Image -->
            <a href="/wholesale/products/<%= product._id %>" class="text-decoration-none">
              <% if (product.imageUrl) { %>
                <div class="ratio ratio-4x3 bg-light">
                  <img
                    src="<%= product.imageUrl %>"
                    class="w-100 h-100 object-fit-contain p-1 p-sm-2"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';"
                  >
                </div>
              <% } else { %>
                <div class="ratio ratio-4x3 bg-light">
                  <div class="d-flex align-items-center justify-content-center w-100 h-100">
                    <span class="text-muted small">No image</span>
                  </div>
                </div>
              <% } %>
            </a>

            <!-- Body -->
            <div class="card-body p-2">
              <h3 class="small fw-bold text-primary mb-1 text-truncate">
                <%= product.name %>
              </h3>

              <p class="small text-muted mb-1 text-truncate">
                <%= product.category || 'Uncategorized' %>
              </p>

              <!-- Compact product info -->
              <div class="small mb-2">
                <div class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
                  <span class="text-muted">Wholesale</span>
                  <strong class="text-dark text-end">
                    R <%= Number(product.wholesalePrice || 0).toFixed(2) %>
                  </strong>
                </div>

                <div class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
                  <span class="text-muted">MOQ</span>
                  <strong class="text-dark text-end">
                    <%= product.minimumOrderQuantity || 1 %>
                  </strong>
                </div>

                <div class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
                  <span class="text-muted">Available</span>
                  <strong class="text-dark text-end">
                    <%= product.availableQuantity || 0 %>
                  </strong>
                </div>

                <div class="d-flex justify-content-between align-items-center py-1 gap-2">
                  <span class="text-muted">Lead</span>
                  <strong class="text-dark text-end">
                    <%= product.leadTimeDays || 0 %>d
                  </strong>
                </div>
              </div>

              <!-- Seller actions -->
              <% if (business && business.role === 'seller') { %>
                <% if (available > 0) { %>
                  <form method="POST" action="/wholesale/cart/add/<%= product._id %>" class="d-grid gap-1">
                    <div class="input-group input-group-sm">
                      <span class="input-group-text px-2">Qty</span>
                      <input
                        type="number"
                        name="quantity"
                        class="form-control"
                        min="<%= moq %>"
                        max="<%= available %>"
                        value="<%= moq %>"
                        required
                      >
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm w-100">
                      Request
                    </button>
                  </form>

                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary btn-sm w-100 mt-1">
                    View
                  </a>
                <% } else { %>
                  <button type="button" class="btn btn-outline-secondary btn-sm w-100" disabled>
                    Out of Stock
                  </button>

                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary btn-sm w-100 mt-1">
                    View
                  </a>
                <% } %>
              <% } else { %>
                <a href="/wholesale/products/<%= product._id %>" class="btn btn-primary btn-sm w-100">
                  View
                </a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>