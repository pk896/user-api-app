<div class="wholesale-supplier-page w-100 px-0 py-3">

  <!-- Supplier hero card -->
  <section class="supplier-hero-card shadow-sm mb-3 mb-lg-4">
    <div class="supplier-hero-content p-3 p-sm-4">
      <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">

        <!-- Supplier identity -->
        <div class="d-flex align-items-center gap-3 min-w-0">
          <div class="supplier-logo-wrap">
            <% if (supplier.logoUrl) { %>
              <img
                src="<%= supplier.logoUrl %>"
                alt="<%= supplier.name %>"
                class="supplier-logo-img"
                loading="lazy"
                decoding="async"
                onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';"
              >
            <% } else { %>
              <div class="supplier-logo-fallback">
                <%= String(supplier.name || 'S').charAt(0).toUpperCase() %>
              </div>
            <% } %>
          </div>

          <div class="min-w-0">
            <h1 class="supplier-hero-title h4 fw-bold mb-1 text-truncate">
              <%= supplier.name %>
            </h1>

            <p class="supplier-hero-location small mb-0">
              <%= supplier.city || '' %>
              <%= supplier.country ? ', ' + supplier.country : '' %>
            </p>
          </div>
        </div>

        <!-- Compact actions -->
        <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-md-end">
          <span class="badge rounded-pill text-bg-light text-primary px-3 py-2 fw-bold">
            Products:
            <%= products && products.length ? products.length : 0 %>
          </span>

          <a href="/wholesale/suppliers" class="btn btn-light btn-sm supplier-market-btn">
            Suppliers
          </a>

          <a href="/wholesale" class="btn btn-light btn-sm supplier-market-btn">
            Marketplace
          </a>
        </div>

      </div>
    </div>
  </section>

  <% if (!products || products.length === 0) { %>
    <div class="card supplier-empty-card shadow-sm">
      <div class="card-body text-center py-5">
        <div
          class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 text-primary"
          style="width: 64px; height: 64px;"
        >
          <span class="fw-bold fs-4">0</span>
        </div>

        <h3 class="h6 fw-bold text-primary mb-1">
          No active wholesale products
        </h3>

        <p class="text-muted small mb-0">
          This supplier has not published active wholesale products yet.
        </p>
      </div>
    </div>
  <% } else { %>

    <!--
      Mobile: 2 columns
      Tablet: 3 columns
      Desktop: 4 columns
    -->
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2 g-lg-3">
      <% products.forEach((product) => { %>
        <% const moq = Number(product.minimumOrderQuantity || 1); %>
        <% const available = Number(product.availableQuantity || 0); %>
        <% const leadTime = Number(product.leadTimeDays || 0); %>

        <div class="col">
          <div class="card h-100 supplier-product-card shadow-sm">

            <!-- Image -->
            <a href="/wholesale/products/<%= product._id %>" class="text-decoration-none">
              <div class="ratio ratio-4x3 supplier-img-wrap position-relative">
                <% if (available > 0) { %>
                  <span class="supplier-stock-pill">
                    In stock
                  </span>
                <% } else { %>
                  <span class="supplier-stock-pill out">
                    Sold out
                  </span>
                <% } %>

                <% if (product.imageUrl) { %>
                  <img
                    src="<%= product.imageUrl %>"
                    class="w-100 h-100 object-fit-contain p-2 p-sm-3"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';"
                  >
                <% } else { %>
                  <div class="d-flex align-items-center justify-content-center w-100 h-100">
                    <div class="text-center px-2">
                      <div class="fw-bold text-primary small mb-1">
                        No image
                      </div>
                      <div class="text-muted" style="font-size: 0.72rem;">
                        Product preview unavailable
                      </div>
                    </div>
                  </div>
                <% } %>
              </div>
            </a>

            <!-- Body -->
            <div class="card-body p-2 p-sm-3 d-flex flex-column">
              <h3 class="small fw-bold supplier-product-title mb-2">
                <%= product.name %>
              </h3>

              <div class="mb-2">
                <span class="supplier-category-pill text-truncate">
                  <%= product.category || 'Uncategorized' %>
                </span>
              </div>

              <!-- Price -->
              <div class="supplier-price-box p-2 mb-2">
                <span class="d-block text-muted fw-bold" style="font-size: 0.68rem;">
                  Wholesale price
                </span>
                <strong class="supplier-price d-block fs-6">
                  <%= money(product.wholesalePrice) %>
                </strong>
              </div>

              <!-- Product stats -->
              <div class="supplier-meta-grid mb-2">
                <div class="supplier-meta-item">
                  <span class="supplier-meta-label">MOQ</span>
                  <span class="supplier-meta-value"><%= moq %></span>
                </div>

                <div class="supplier-meta-item">
                  <span class="supplier-meta-label">Stock</span>
                  <span class="supplier-meta-value"><%= available %></span>
                </div>

                <div class="supplier-meta-item">
                  <span class="supplier-meta-label">Lead</span>
                  <span class="supplier-meta-value"><%= leadTime %>d</span>
                </div>
              </div>

              <!-- Seller actions -->
              <div class="mt-auto">
                <% if (business && business.role === 'seller') { %>
                  <% if (available > 0) { %>
                    <form method="POST" action="/wholesale/cart/add/<%= product._id %>" class="d-grid gap-2">
                      <div class="input-group input-group-sm supplier-qty-group">
                        <span class="input-group-text px-2">Qty</span>
                        <input
                          type="number"
                          name="quantity"
                          class="form-control"
                          min="<%= moq %>"
                          max="<%= available %>"
                          value="<%= moq %>"
                          required
                        >
                      </div>

                      <button type="submit" class="btn btn-primary btn-sm w-100 supplier-card-btn">
                        Request Supply
                      </button>
                    </form>

                    <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary btn-sm w-100 mt-2 supplier-card-btn">
                      View Details
                    </a>
                  <% } else { %>
                    <button type="button" class="btn btn-outline-secondary btn-sm w-100 supplier-card-btn" disabled>
                      Out of Stock
                    </button>

                    <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary btn-sm w-100 mt-2 supplier-card-btn">
                      View Details
                    </a>
                  <% } %>
                <% } else { %>
                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-primary btn-sm w-100 supplier-card-btn">
                    View Details
                  </a>
                <% } %>
              </div>
            </div>

          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>