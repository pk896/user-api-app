<!--views/wholesale/product.ejs-->

<style nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  .wholesale-product-page {
    background:
      radial-gradient(circle at top left, rgba(13, 110, 253, 0.11), transparent 30%),
      radial-gradient(circle at top right, rgba(255, 193, 7, 0.14), transparent 28%),
      linear-gradient(180deg, #f6f9ff 0%, #ffffff 48%, #f8fafc 100%);
    min-height: 100vh;
  }

  .wholesale-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #0d6efd;
    font-weight: 800;
    text-decoration: none;
    border-radius: 999px;
    padding: 0.5rem 0.8rem;
    background: rgba(13, 110, 253, 0.08);
    border: 1px solid rgba(13, 110, 253, 0.12);
    transition: all 0.18s ease;
  }

  .wholesale-back-link:hover {
    color: #084298;
    background: rgba(13, 110, 253, 0.13);
    transform: translateX(-2px);
  }

  .wholesale-main-card,
  .wholesale-info-card,
  .wholesale-request-card,
  .wholesale-login-card {
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    overflow: hidden;
    background: #fff;
  }

  .wholesale-image-card {
    position: sticky;
    top: 1rem;
  }

  .wholesale-image-wrap {
    background:
      radial-gradient(circle at center, rgba(13, 110, 253, 0.08), transparent 45%),
      linear-gradient(135deg, #f8fbff, #eef5ff);
  }

  .wholesale-image-wrap img {
    transition: transform 0.22s ease;
  }

  .wholesale-image-card:hover .wholesale-image-wrap img {
    transform: scale(1.035);
  }

  .wholesale-product-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.38rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 800;
    background: rgba(13, 110, 253, 0.1);
    color: #0d6efd;
    border: 1px solid rgba(13, 110, 253, 0.14);
  }

  .wholesale-product-title {
    color: #0f172a;
    letter-spacing: -0.04em;
  }

  .wholesale-product-description {
    color: #64748b;
    line-height: 1.65;
  }

  .wholesale-stat-card {
    border-radius: 18px;
    border: 1px solid rgba(15, 23, 42, 0.07);
    background: #f8fafc;
    padding: 1rem;
    min-height: 96px;
  }

  .wholesale-stat-card.price {
    background:
      linear-gradient(135deg, rgba(13, 110, 253, 0.09), rgba(255, 193, 7, 0.16));
    border-color: rgba(13, 110, 253, 0.13);
  }

  .wholesale-stat-label {
    color: #64748b;
    font-size: 0.76rem;
    font-weight: 800;
    margin-bottom: 0.3rem;
  }

  .wholesale-stat-value {
    color: #0f172a;
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.2;
  }

  .wholesale-stat-card.price .wholesale-stat-value {
    color: #071f4a;
    font-size: 1.25rem;
  }

  .wholesale-supplier-box {
    border-radius: 20px;
    border: 1px solid rgba(13, 110, 253, 0.12);
    background:
      linear-gradient(135deg, rgba(13, 110, 253, 0.07), rgba(255, 255, 255, 0.92));
    padding: 1rem;
  }

  .wholesale-supplier-avatar {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    background: linear-gradient(135deg, #0d6efd, #6f42c1);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    flex: 0 0 auto;
  }

  .wholesale-request-card .card-header {
    background:
      linear-gradient(135deg, #071f4a, #0d6efd);
    color: #fff;
    border: 0;
    padding: 1rem 1.25rem;
  }

  .wholesale-request-card .form-control {
    border-radius: 14px;
    border-color: rgba(15, 23, 42, 0.12);
  }

  .wholesale-request-card .form-control:focus {
    border-color: rgba(13, 110, 253, 0.55);
    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.12);
  }

  .wholesale-form-label {
    color: #0f172a;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .wholesale-primary-btn {
    border-radius: 16px;
    font-weight: 900;
    padding-top: 0.7rem;
    padding-bottom: 0.7rem;
    box-shadow: 0 12px 24px rgba(13, 110, 253, 0.2);
  }

  .wholesale-outline-btn {
    border-radius: 14px;
    font-weight: 800;
  }

  .wholesale-alert {
    border: 1px solid rgba(220, 53, 69, 0.2);
    border-radius: 18px;
  }

  .wholesale-login-card {
    background:
      linear-gradient(135deg, rgba(13, 110, 253, 0.08), rgba(255, 193, 7, 0.12));
  }

  @media (max-width: 991.98px) {
    .wholesale-image-card {
      position: static;
    }
  }

  @media (max-width: 575.98px) {
    .wholesale-product-page {
      padding-left: 0.5rem !important;
      padding-right: 0.5rem !important;
    }

    .wholesale-main-card,
    .wholesale-info-card,
    .wholesale-request-card,
    .wholesale-login-card {
      border-radius: 18px;
    }

    .wholesale-product-title {
      font-size: 1.35rem;
    }

    .wholesale-stat-card {
      padding: 0.8rem;
      min-height: 84px;
    }

    .wholesale-stat-value {
      font-size: 0.9rem;
    }

    .wholesale-stat-card.price .wholesale-stat-value {
      font-size: 1.05rem;
    }
  }
</style>

<div class="container py-4 wholesale-product-page">

  <div class="mb-3 mb-lg-4">
    <a href="/wholesale" class="wholesale-back-link">
      ← Back to Wholesale Marketplace
    </a>
  </div>

  <% if (errors && errors.length) { %>
    <div class="alert alert-danger wholesale-alert shadow-sm">
      <strong>Please fix these errors:</strong>
      <ul class="mb-0 mt-2">
        <% errors.forEach((error) => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="row g-3 g-lg-4">

    <!-- Product Image -->
    <div class="col-12 col-lg-6">
      <div class="card wholesale-main-card wholesale-image-card shadow-sm">
        <% if (product.imageUrl) { %>
          <div class="ratio ratio-4x3 wholesale-image-wrap">
            <img
              src="<%= product.imageUrl %>"
              class="card-img-top w-100 h-100 object-fit-contain p-3 p-sm-4"
              alt="<%= product.name %>"
              loading="lazy"
              decoding="async"
              onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';"
            >
          </div>
        <% } else { %>
          <div class="ratio ratio-4x3 wholesale-image-wrap">
            <div class="d-flex align-items-center justify-content-center w-100 h-100">
              <div class="text-center">
                <div class="fw-bold text-primary mb-1">No image</div>
                <div class="text-muted small">Product preview unavailable</div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Product Info -->
    <div class="col-12 col-lg-6">
      <div class="card wholesale-info-card shadow-sm mb-3">
        <div class="card-body p-3 p-sm-4">

          <span class="wholesale-product-badge mb-2">
            Wholesale Product
          </span>

          <h1 class="h3 fw-bold wholesale-product-title mb-2">
            <%= product.name %>
          </h1>

          <p class="wholesale-product-description mb-3">
            <%= product.description || 'No description provided.' %>
          </p>

          <div class="row g-2 mb-3">
            <div class="col-6">
              <div class="wholesale-stat-card price">
                <div class="wholesale-stat-label">Wholesale Price</div>
                <div class="wholesale-stat-value">
                  R <%= Number(product.wholesalePrice || 0).toFixed(2) %>
                </div>
              </div>
            </div>

            <div class="col-6">
              <div class="wholesale-stat-card">
                <div class="wholesale-stat-label">Minimum Order</div>
                <div class="wholesale-stat-value">
                  <%= product.minimumOrderQuantity || 1 %> <%= product.unit || 'units' %>
                </div>
              </div>
            </div>

            <div class="col-6">
              <div class="wholesale-stat-card">
                <div class="wholesale-stat-label">Available</div>
                <div class="wholesale-stat-value">
                  <%= product.availableQuantity || 0 %> <%= product.unit || 'units' %>
                </div>
              </div>
            </div>

            <div class="col-6">
              <div class="wholesale-stat-card">
                <div class="wholesale-stat-label">Lead Time</div>
                <div class="wholesale-stat-value">
                  <%= product.leadTimeDays || 0 %> days
                </div>
              </div>
            </div>
          </div>

          <div class="wholesale-supplier-box">
            <div class="d-flex align-items-start gap-3">
              <div class="wholesale-supplier-avatar">
                <%= (product.supplier?.name || 'S').charAt(0).toUpperCase() %>
              </div>

              <div class="min-w-0 flex-grow-1">
                <div class="fw-bold text-primary mb-1">Supplier</div>

                <div class="fw-bold text-dark text-truncate">
                  <%= product.supplier?.name || 'Supplier' %>
                </div>

                <div class="small text-muted">
                  <%= product.supplier?.city || '' %>
                  <%= product.supplier?.country ? ', ' + product.supplier.country : '' %>
                </div>

                <% if (product.supplier?._id) { %>
                  <a href="/wholesale/suppliers/<%= product.supplier._id %>" class="btn btn-outline-primary btn-sm mt-3 wholesale-outline-btn">
                    View Supplier
                  </a>
                <% } %>
              </div>
            </div>
          </div>

        </div>
      </div>

      <% if (business && business.role === 'seller') { %>
        <form method="POST" action="/wholesale/products/<%= product._id %>/request" class="card wholesale-request-card shadow-sm">
          <div class="card-header">
            <div class="fw-bold">
              Send Supply Request
            </div>
            <div class="small opacity-75">
              Tell the supplier what quantity you need and where you want it delivered.
            </div>
          </div>

          <div class="card-body p-3 p-sm-4">
            <div class="mb-3">
              <label class="form-label wholesale-form-label">Requested Quantity</label>
              <input
                type="number"
                min="<%= product.minimumOrderQuantity || 1 %>"
                name="requestedQuantity"
                class="form-control"
                value="<%= form.requestedQuantity || product.minimumOrderQuantity || 1 %>"
                required
              >
              <div class="form-text">
                Minimum order quantity: <%= product.minimumOrderQuantity || 1 %>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label wholesale-form-label">Message to Supplier</label>
              <textarea
                name="message"
                rows="4"
                class="form-control"
                placeholder="Tell the supplier what you need..."
              ><%= form.message || '' %></textarea>
            </div>

            <div class="row g-2">
              <div class="col-12 col-md-6">
                <label class="form-label wholesale-form-label">Contact Name</label>
                <input
                  type="text"
                  name="contactName"
                  class="form-control"
                  value="<%= form.contactName || business.name || '' %>"
                >
              </div>

              <div class="col-12 col-md-6">
                <label class="form-label wholesale-form-label">Contact Email</label>
                <input
                  type="email"
                  name="contactEmail"
                  class="form-control"
                  value="<%= form.contactEmail || business.email || '' %>"
                >
              </div>

              <div class="col-12 col-md-6">
                <label class="form-label wholesale-form-label">Contact Phone</label>
                <input
                  type="text"
                  name="contactPhone"
                  class="form-control"
                  value="<%= form.contactPhone || '' %>"
                >
              </div>

              <div class="col-12 col-md-3">
                <label class="form-label wholesale-form-label">Delivery Country</label>
                <input
                  type="text"
                  name="deliveryCountry"
                  class="form-control"
                  value="<%= form.deliveryCountry || '' %>"
                >
              </div>

              <div class="col-12 col-md-3">
                <label class="form-label wholesale-form-label">Delivery City</label>
                <input
                  type="text"
                  name="deliveryCity"
                  class="form-control"
                  value="<%= form.deliveryCity || '' %>"
                >
              </div>
            </div>
          </div>

          <div class="card-footer bg-white border-0 p-3 p-sm-4 pt-0">
            <button type="submit" class="btn btn-primary w-100 wholesale-primary-btn">
              Send Request
            </button>
          </div>
        </form>
      <% } else if (business && business.role === 'supplier') { %>
        <div class="alert alert-info rounded-4 shadow-sm">
          You are logged in as a supplier. Only seller accounts can send supply requests.
        </div>
      <% } else { %>
        <div class="card wholesale-login-card shadow-sm">
          <div class="card-body p-3 p-sm-4">
            <h2 class="h6 fw-bold text-primary mb-1">
              Want to request this supply?
            </h2>

            <p class="text-muted mb-3">
              Log in with a seller account to send a supply request.
            </p>

            <a href="/business/login" class="btn btn-primary wholesale-primary-btn">
              Business Login
            </a>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>