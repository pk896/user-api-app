<!--views/wholesale/index.ejs-->
<div class="container-fluid px-2 px-sm-3 px-lg-4 py-3 wholesale-market-page">
  <!-- Header -->
  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-2 gap-lg-3 mb-3">
    <div class="min-w-0">
      <h1 class="h4 fw-bold text-primary mb-1">Wholesale Marketplace</h1>
      <p class="text-muted mb-0 small">
        Find supplier products and send supply requests directly on the platform.
      </p>
    </div>

    <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-lg-end">
      <a href="/wholesale/suppliers" class="btn btn-outline-primary btn-sm">
        View Suppliers
      </a>

      <% if (business && business.role === 'seller') { %>
        <a href="/wholesale/checkout" class="btn btn-outline-primary btn-sm">
          Wholesale Checkout
        </a>

        <a href="/wholesale/my-requests" class="btn btn-primary btn-sm">
          My Requests
        </a>
      <% } %>
    </div>
  </div>

  <!-- Search -->
  <form method="GET" action="/wholesale" class="card border-0 shadow-sm mb-3">
    <div class="card-body p-2 p-sm-3">
      <div class="row g-2 align-items-center">
        <div class="col-12 col-md-6">
          <input
            type="search"
            name="q"
            class="form-control form-control-sm"
            value="<%= q || '' %>"
            placeholder="Search wholesale products..."
          >
        </div>

        <div class="col-12 col-md-4">
          <select name="category" class="form-select form-select-sm">
            <option value="">All categories</option>
            <% (categories || []).forEach((item) => { %>
              <option value="<%= item %>" <%= category === item ? 'selected' : '' %>>
                <%= item %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="col-12 col-md-2">
          <button type="submit" class="btn btn-primary btn-sm w-100">
            Search
          </button>
        </div>
      </div>
    </div>
  </form>

  <% if (!products || products.length === 0) { %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <h2 class="h6 fw-bold text-primary">No wholesale products found</h2>
        <p class="text-muted mb-0 small">Try another search or category.</p>
      </div>
    </div>
  <% } else { %>
    <!--
      Mobile: 2 columns
      Tablet: 3 columns
      Desktop: 4 columns
    -->
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2 g-lg-3">
      <% products.forEach((product) => { %>
        <% const moq = Number(product.minimumOrderQuantity || 1); %>
        <% const available = Number(product.availableQuantity || 0); %>

        <div class="col">
          <div class="card h-100 border-0 shadow-sm overflow-hidden">
            <!-- Image -->
            <a href="/wholesale/products/<%= product._id %>" class="text-decoration-none">
              <% if (product.imageUrl) { %>
                <div class="ratio ratio-4x3 bg-light">
                  <img
                    src="<%= product.imageUrl %>"
                    class="w-100 h-100 object-fit-contain p-1 p-sm-2"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';"
                  >
                </div>
              <% } else { %>
                <div class="ratio ratio-4x3 bg-light">
                  <div class="d-flex align-items-center justify-content-center w-100 h-100">
                    <span class="text-muted small">No image</span>
                  </div>
                </div>
              <% } %>
            </a>

            <!-- Body -->
            <div class="card-body p-2">
              <h2 class="small fw-bold text-primary mb-1 text-truncate">
                <%= product.name %>
              </h2>

              <p class="small text-muted mb-1 text-truncate">
                <a
                  href="/wholesale/suppliers/<%= product.supplier?._id %>"
                  class="text-primary text-decoration-none fw-semibold"
                >
                  <%= product.supplier?.name || 'Supplier' %>
                </a>
              </p>

              <!-- Compact product info -->
              <div class="small mb-2">
                <div class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
                  <span class="text-muted">Wholesale</span>
                  <strong class="text-dark text-end">
                    R <%= Number(product.wholesalePrice || 0).toFixed(2) %>
                  </strong>
                </div>

                <div class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
                  <span class="text-muted">MOQ</span>
                  <strong class="text-dark text-end">
                    <%= product.minimumOrderQuantity || 1 %>
                  </strong>
                </div>

                <div class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
                  <span class="text-muted">Available</span>
                  <strong class="text-dark text-end">
                    <%= product.availableQuantity || 0 %>
                  </strong>
                </div>

                <div class="d-flex justify-content-between align-items-center py-1 gap-2">
                  <span class="text-muted">Lead</span>
                  <strong class="text-dark text-end">
                    <%= product.leadTimeDays || 0 %>d
                  </strong>
                </div>
              </div>

              <!-- Seller actions -->
              <% if (business && business.role === 'seller') { %>
                <% if (available > 0) { %>
                  <form method="POST" action="/wholesale/cart/add/<%= product._id %>" class="d-grid gap-1">
                    <div class="input-group input-group-sm">
                      <span class="input-group-text px-2">Qty</span>
                      <input
                        type="number"
                        name="quantity"
                        class="form-control"
                        min="<%= moq %>"
                        max="<%= available %>"
                        value="<%= moq %>"
                        required
                      >
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm w-100">
                      Request
                    </button>
                  </form>

                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary btn-sm w-100 mt-1">
                    View
                  </a>
                <% } else { %>
                  <button type="button" class="btn btn-outline-secondary btn-sm w-100" disabled>
                    Out of Stock
                  </button>

                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary btn-sm w-100 mt-1">
                    View
                  </a>
                <% } %>
              <% } else { %>
                <a href="/wholesale/products/<%= product._id %>" class="btn btn-primary btn-sm w-100">
                  View
                </a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>