<div class="wholesale-market-page w-100 px-0 py-3">

  <!-- Polished Header -->
  <section class="wholesale-hero shadow-sm mb-3 mb-lg-4">
    <div class="wholesale-hero-content p-3 p-sm-4">
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
        <div class="min-w-0">
          <span class="wholesale-hero-badge mb-2">
            Wholesale Marketplace
          </span>

          <h1 class="wholesale-hero-title h3 fw-bold mb-2">
            Source quality supplier products for your store
          </h1>

          <p class="wholesale-hero-text mb-0 small">
            Find wholesale products, compare MOQ, check available stock, and send supply requests directly on the platform.
          </p>
        </div>

        <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-lg-end">
          <a href="/wholesale/suppliers" class="btn btn-light btn-sm wholesale-action-btn">
            View Suppliers
          </a>

          <% if (business && business.role === 'seller') { %>
            <a href="/wholesale/checkout" class="btn btn-warning btn-sm wholesale-action-btn text-dark">
              Wholesale Checkout
            </a>

            <a href="/wholesale/my-requests" class="btn btn-outline-light btn-sm wholesale-action-btn">
              My Requests
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- Search / Filter -->
  <form method="GET" action="/wholesale#wholesale-products" class="card wholesale-search-card shadow-sm mb-3 mb-lg-4">
    <div class="card-body p-2 p-sm-3">
      <div class="row g-2 align-items-center">
        <div class="col-12 col-lg-6">
          <label class="form-label small fw-bold text-muted mb-1">
            Search products
          </label>
          <input
            id="wholesaleSearchInput"
            type="search"
            name="q"
            class="form-control form-control-sm"
            value="<%= q || '' %>"
            placeholder="Search wholesale products..."
          >
        </div>

        <div class="col-12 col-sm-7 col-lg-4">
          <label class="form-label small fw-bold text-muted mb-1">
            Category
          </label>
          <select id="wholesaleCategorySelect" name="category" class="form-select form-select-sm">
            <option value="">All categories</option>
            <% (categories || []).forEach((item) => { %>
              <option value="<%= item %>" <%= category === item ? 'selected' : '' %>>
                <%= item %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="col-12 col-sm-5 col-lg-2">
          <label class="form-label small fw-bold text-muted mb-1 d-none d-sm-block">
            &nbsp;
          </label>
          <button type="submit" class="btn btn-primary btn-sm w-100 wholesale-card-btn">
            Search
          </button>
        </div>
      </div>
    </div>
  </form>

  <div id="wholesale-products"></div>

  <% if (!products || products.length === 0) { %>
    <div class="card wholesale-empty-card shadow-sm">
      <div class="card-body text-center py-5">
        <div
          class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 text-primary"
          style="width: 64px; height: 64px;"
        >
          <span class="fw-bold fs-4">0</span>
        </div>

        <h2 class="h6 fw-bold text-primary mb-1">
          No wholesale products found
        </h2>

        <p class="text-muted mb-0 small">
          Try another search word or choose a different category.
        </p>
      </div>
    </div>
  <% } else { %>

    <div class="wholesale-products-summary d-flex justify-content-between align-items-center mb-2 mb-lg-3 px-3 px-sm-4 px-lg-5">
      <div class="min-w-0">
        <h2 class="h6 fw-bold text-dark mb-0">
          Available wholesale products
        </h2>
        <p class="text-muted small mb-0">
          <%= products.length %> product<%= products.length === 1 ? '' : 's' %> found
        </p>
      </div>
    </div>

    <!--
      Mobile: 2 columns
      Tablet: 3 columns
      Desktop: 4 columns
    -->
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2 g-lg-3">
      <% products.forEach((product) => { %>
        <% const moq = Number(product.minimumOrderQuantity || 1); %>
        <% const available = Number(product.availableQuantity || 0); %>
        <% const leadTime = Number(product.leadTimeDays || 0); %>
        <% const supplierId = product.supplier?._id || product.supplier || ''; %>
        <% const supplierName = product.supplier?.name || 'Supplier'; %>

        <div class="col">
          <div class="card h-100 wholesale-product-card shadow-sm">

            <!-- Image -->
            <a href="/wholesale/products/<%= product._id %>" class="text-decoration-none">
              <div class="ratio ratio-4x3 wholesale-img-wrap position-relative">
                <% if (available > 0) { %>
                  <span class="wholesale-stock-pill">
                    In stock
                  </span>
                <% } else { %>
                  <span class="wholesale-stock-pill out">
                    Sold out
                  </span>
                <% } %>

                <% if (product.imageUrl) { %>
                  <img
                    src="<%= product.imageUrl %>"
                    class="w-100 h-100 object-fit-contain p-2 p-sm-3"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';"
                  >
                <% } else { %>
                  <div class="d-flex align-items-center justify-content-center w-100 h-100">
                    <div class="text-center px-2">
                      <div class="fw-bold text-primary small mb-1">
                        No image
                      </div>
                      <div class="text-muted" style="font-size: 0.72rem;">
                        Product preview unavailable
                      </div>
                    </div>
                  </div>
                <% } %>
              </div>
            </a>

            <!-- Body -->
            <div class="card-body p-2 p-sm-3 d-flex flex-column">

              <h2 class="small fw-bold wholesale-product-title mb-1">
                <%= product.name %>
              </h2>

              <p class="small text-muted mb-2 text-truncate">
                <% if (supplierId) { %>
                  <a
                    href="/wholesale/suppliers/<%= supplierId %>"
                    class="wholesale-supplier-link text-decoration-none"
                  >
                    <%= supplierName %>
                  </a>
                <% } else { %>
                  <span class="fw-semibold">
                    <%= supplierName %>
                  </span>
                <% } %>
              </p>

              <!-- Price -->
              <div class="wholesale-price-box p-2 mb-2">
                <span class="d-block text-muted fw-bold" style="font-size: 0.68rem;">
                  Wholesale price
                </span>
                <strong class="wholesale-price d-block fs-6">
                  <%= money(product.wholesalePrice) %>
                </strong>
              </div>

              <!-- Product stats -->
              <div class="wholesale-meta-grid mb-2">
                <div class="wholesale-meta-item">
                  <span class="wholesale-meta-label">MOQ</span>
                  <span class="wholesale-meta-value"><%= moq %></span>
                </div>

                <div class="wholesale-meta-item">
                  <span class="wholesale-meta-label">Stock</span>
                  <span class="wholesale-meta-value"><%= available %></span>
                </div>

                <div class="wholesale-meta-item">
                  <span class="wholesale-meta-label">Lead</span>
                  <span class="wholesale-meta-value"><%= leadTime %>d</span>
                </div>
              </div>

              <!-- Actions -->
              <div class="mt-auto">
                <% if (business && business.role === 'seller') { %>
                  <% if (available > 0) { %>
                    <form method="POST" action="/wholesale/cart/add/<%= product._id %>" class="d-grid gap-2">
                      <div class="input-group input-group-sm wholesale-qty-group">
                        <span class="input-group-text px-2">Qty</span>
                        <input
                          type="number"
                          name="quantity"
                          class="form-control"
                          min="<%= moq %>"
                          max="<%= available %>"
                          value="<%= moq %>"
                          required
                        >
                      </div>

                      <button type="submit" class="btn btn-primary btn-sm w-100 wholesale-card-btn">
                        Request Supply
                      </button>
                    </form>

                    <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary btn-sm w-100 mt-2 wholesale-card-btn">
                      View Details
                    </a>
                  <% } else { %>
                    <button type="button" class="btn btn-outline-secondary btn-sm w-100 wholesale-card-btn" disabled>
                      Out of Stock
                    </button>

                    <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary btn-sm w-100 mt-2 wholesale-card-btn">
                      View Details
                    </a>
                  <% } %>
                <% } else { %>
                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-primary btn-sm w-100 wholesale-card-btn">
                    View Details
                  </a>
                <% } %>
              </div>

            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  (function () {
    const searchInput = document.getElementById('wholesaleSearchInput');
    const categorySelect = document.getElementById('wholesaleCategorySelect');

    if (!searchInput) return;

    let clearedRefreshDone = false;

    function refreshWholesaleWhenSearchIsEmpty() {
      const keyword = String(searchInput.value || '').trim();
      const category = categorySelect ? String(categorySelect.value || '').trim() : '';

      if (keyword) {
        clearedRefreshDone = false;
        return;
      }

      if (clearedRefreshDone) return;
      clearedRefreshDone = true;

      const params = new URLSearchParams();

      if (category) {
        params.set('category', category);
      }

      const queryString = params.toString();

      window.location.href = queryString
        ? '/wholesale?' + queryString + '#wholesale-products'
        : '/wholesale#wholesale-products';
    }

    searchInput.addEventListener('input', refreshWholesaleWhenSearchIsEmpty);
  })();
</script>
