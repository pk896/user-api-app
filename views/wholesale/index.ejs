<!--views/wholesale/index.ejs-->
<div class="container py-4">
  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
      <h1 class="h3 fw-bold text-primary mb-1">Wholesale Marketplace</h1>
      <p class="text-muted mb-0">Find supplier products and send supply requests directly on the platform.</p>
    </div>

    <div class="d-flex gap-2">
      <a href="/wholesale/suppliers" class="btn btn-outline-primary">
        View Suppliers
      </a>

      <% if (business && business.role === 'seller') { %>
        <a href="/wholesale/checkout" class="btn btn-outline-primary">
          Wholesale Checkout
        </a>

        <a href="/wholesale/my-requests" class="btn btn-primary">
          My Requests
        </a>
      <% } %>
    </div>
  </div>

  <form method="GET" action="/wholesale" class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-2">
        <div class="col-12 col-md-6">
          <input
            type="search"
            name="q"
            class="form-control"
            value="<%= q || '' %>"
            placeholder="Search wholesale products..."
          >
        </div>

        <div class="col-12 col-md-4">
          <select name="category" class="form-select">
            <option value="">All categories</option>
            <% (categories || []).forEach((item) => { %>
              <option value="<%= item %>" <%= category === item ? 'selected' : '' %>>
                <%= item %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="col-12 col-md-2">
          <button type="submit" class="btn btn-primary w-100">
            Search
          </button>
        </div>
      </div>
    </div>
  </form>

  <% if (!products || products.length === 0) { %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <h2 class="h5 fw-bold text-primary">No wholesale products found</h2>
        <p class="text-muted mb-0">Try another search or category.</p>
      </div>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% products.forEach((product) => { %>
        <div class="col-12 col-md-6 col-xl-4">
          <div class="card h-100 border-0 shadow-sm">
            <% if (product.imageUrl) { %>
              <div class="ratio ratio-4x3 bg-light">
                <img
                  src="<%= product.imageUrl %>"
                  class="card-img-top w-100 h-100 object-fit-contain p-2"
                  alt="<%= product.name %>"
                >
              </div>
            <% } else { %>
              <div class="ratio ratio-4x3 bg-light">
                <div class="d-flex align-items-center justify-content-center w-100 h-100">
                  <span class="text-muted">No image</span>
                </div>
              </div>
            <% } %>

            <div class="card-body">
              <h2 class="h6 fw-bold text-primary mb-1">
                <%= product.name %>
              </h2>

              <p class="small text-muted mb-2">
                Supplier:
                <a href="/wholesale/suppliers/<%= product.supplier?._id %>" class="text-primary text-decoration-none fw-semibold">
                  <%= product.supplier?.name || 'Supplier' %>
                </a>
              </p>

              <div class="row g-2 small mb-3">
                <div class="col-6">
                  <div class="border rounded p-2">
                    <div class="text-muted">Wholesale</div>
                    <div class="fw-bold">R <%= Number(product.wholesalePrice || 0).toFixed(2) %></div>
                  </div>
                </div>

                <div class="col-6">
                  <div class="border rounded p-2">
                    <div class="text-muted">MOQ</div>
                    <div class="fw-bold"><%= product.minimumOrderQuantity || 1 %></div>
                  </div>
                </div>

                <div class="col-6">
                  <div class="border rounded p-2">
                    <div class="text-muted">Available</div>
                    <div class="fw-bold"><%= product.availableQuantity || 0 %></div>
                  </div>
                </div>

                <div class="col-6">
                  <div class="border rounded p-2">
                    <div class="text-muted">Lead Time</div>
                    <div class="fw-bold"><%= product.leadTimeDays || 0 %> days</div>
                  </div>
                </div>
              </div>

              <% if (business && business.role === 'seller') { %>
                <% const moq = Number(product.minimumOrderQuantity || 1); %>
                <% const available = Number(product.availableQuantity || 0); %>

                <% if (available > 0) { %>
                  <form method="POST" action="/wholesale/cart/add/<%= product._id %>" class="d-grid gap-2">
                    <div class="input-group input-group-sm">
                      <span class="input-group-text">Qty</span>
                      <input
                        type="number"
                        name="quantity"
                        class="form-control"
                        min="<%= moq %>"
                        max="<%= available %>"
                        value="<%= moq %>"
                        required
                      >
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                      Add to Wholesale Request
                    </button>
                  </form>

                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary w-100 mt-2">
                    View Product
                  </a>
                <% } else { %>
                  <button type="button" class="btn btn-outline-secondary w-100" disabled>
                    Out of Stock
                  </button>

                  <a href="/wholesale/products/<%= product._id %>" class="btn btn-outline-primary w-100 mt-2">
                    View Product
                  </a>
                <% } %>
              <% } else { %>
                <a href="/wholesale/products/<%= product._id %>" class="btn btn-primary w-100">
                  View Product
                </a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
