<!--views/wholesale/suppliers.ejs-->

<style nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  .wholesale-suppliers-page {
    background:
      radial-gradient(circle at top left, rgba(13, 110, 253, 0.11), transparent 30%),
      radial-gradient(circle at top right, rgba(255, 193, 7, 0.14), transparent 28%),
      linear-gradient(180deg, #f6f9ff 0%, #ffffff 48%, #f8fafc 100%);
    min-height: 100vh;
  }

  .suppliers-hero {
    border: 1px solid rgba(13, 110, 253, 0.12);
    background:
      linear-gradient(135deg, rgba(8, 31, 74, 0.96), rgba(13, 110, 253, 0.92)),
      radial-gradient(circle at top right, rgba(255, 193, 7, 0.35), transparent 30%);
    border-radius: 24px;
    overflow: hidden;
    position: relative;
  }

  .suppliers-hero::after {
    content: "";
    position: absolute;
    width: 230px;
    height: 230px;
    right: -90px;
    top: -90px;
    border-radius: 999px;
    background: rgba(255, 193, 7, 0.28);
  }

  .suppliers-hero-content {
    position: relative;
    z-index: 2;
  }

  .suppliers-hero-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    font-size: 0.76rem;
    font-weight: 900;
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(10px);
  }

  .suppliers-hero-title {
    color: #fff;
    letter-spacing: -0.04em;
  }

  .suppliers-hero-text {
    color: rgba(255, 255, 255, 0.82);
    max-width: 680px;
  }

  .suppliers-hero-btn {
    border-radius: 999px;
    font-weight: 800;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.16);
  }

  .suppliers-search-card {
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(14px);
  }

  .suppliers-search-card .form-control {
    border-radius: 14px;
    border-color: rgba(15, 23, 42, 0.12);
    background-color: #fff;
  }

  .suppliers-search-card .form-control:focus {
    border-color: rgba(13, 110, 253, 0.55);
    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.12);
  }

  .suppliers-card {
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 22px;
    background: #fff;
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .suppliers-card:hover {
    transform: translateY(-4px);
    border-color: rgba(13, 110, 253, 0.22);
    box-shadow: 0 18px 42px rgba(15, 23, 42, 0.13) !important;
  }

  .supplier-card-top {
    background:
      linear-gradient(135deg, rgba(13, 110, 253, 0.08), rgba(255, 193, 7, 0.12));
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  }

  .supplier-logo-frame {
    width: 68px;
    height: 68px;
    border-radius: 999px;
    padding: 4px;
    background: #fff;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.13);
    flex: 0 0 auto;
  }

  .supplier-logo-img,
  .supplier-logo-fallback {
    width: 100%;
    height: 100%;
    border-radius: 999px;
    object-fit: cover;
  }

  .supplier-logo-fallback {
    background: linear-gradient(135deg, #0d6efd, #6f42c1);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 1.4rem;
  }

  .supplier-name {
    color: #0f172a;
    line-height: 1.25;
    min-height: 2.5em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .supplier-location {
    color: #64748b;
  }

  .supplier-verified-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.35rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 900;
    color: #052e16;
    background: rgba(25, 135, 84, 0.13);
    border: 1px solid rgba(25, 135, 84, 0.18);
  }

  .supplier-card-btn {
    border-radius: 14px;
    font-weight: 900;
  }

  .suppliers-empty-card {
    border-radius: 24px;
    border: 1px dashed rgba(13, 110, 253, 0.25);
    background: #fff;
  }

  @media (max-width: 575.98px) {
    .wholesale-suppliers-page {
      padding-left: 0 !important;
      padding-right: 0 !important;
    }

    .suppliers-hero,
    .suppliers-search-card,
    .suppliers-empty-card,
    .suppliers-card {
      border-radius: 0;
    }

    .suppliers-hero-title {
      font-size: 1.35rem;
    }

    .suppliers-hero-text {
      font-size: 0.84rem;
    }

    .supplier-logo-frame {
      width: 60px;
      height: 60px;
    }
  }

  /* ==========================================================
   * ✅ FULL WIDTH PAGE LOCK
   * Page: views/wholesale/suppliers.ejs only
   * Purpose: edge-to-edge layout without horizontal swipe
   * ======================================================== */

  .wholesale-suppliers-page,
  .wholesale-suppliers-page * {
    box-sizing: border-box;
  }

  .wholesale-suppliers-page {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    margin-left: 0;
    margin-right: 0;
    overflow-x: hidden;
  }

  .wholesale-suppliers-page .row {
    margin-left: 0;
    margin-right: 0;
  }

  .wholesale-suppliers-page [class*="col-"] {
    min-width: 0;
  }

  .wholesale-suppliers-page img,
  .wholesale-suppliers-page svg,
  .wholesale-suppliers-page table,
  .wholesale-suppliers-page iframe,
  .wholesale-suppliers-page canvas {
    max-width: 100%;
  }

  .wholesale-suppliers-page a,
  .wholesale-suppliers-page p,
  .wholesale-suppliers-page span,
  .wholesale-suppliers-page strong,
  .wholesale-suppliers-page h1,
  .wholesale-suppliers-page h2,
  .wholesale-suppliers-page h3,
  .wholesale-suppliers-page h4,
  .wholesale-suppliers-page .badge,
  .wholesale-suppliers-page .small,
  .wholesale-suppliers-page .text-muted,
  .wholesale-suppliers-page .supplier-name,
  .wholesale-suppliers-page .supplier-location {
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  @media (max-width: 767.98px) {
    .wholesale-suppliers-page {
      width: 100%;
      max-width: 100%;
      padding-left: 0 !important;
      padding-right: 0 !important;
      overflow-x: hidden;
    }

    .suppliers-hero,
    .suppliers-search-card,
    .suppliers-empty-card,
    .suppliers-card {
      border-radius: 0;
      margin-left: 0;
      margin-right: 0;
    }

    .suppliers-hero-content,
    .suppliers-search-card .card-body,
    .suppliers-empty-card .card-body,
    .suppliers-card .card-body,
    .supplier-card-top {
      padding-left: 1rem !important;
      padding-right: 1rem !important;
    }

    .wholesale-suppliers-page .d-flex,
    .wholesale-suppliers-page form {
      min-width: 0;
      max-width: 100%;
    }

    .wholesale-suppliers-page .btn,
    .wholesale-suppliers-page input,
    .wholesale-suppliers-page select {
      max-width: 100%;
      white-space: normal;
    }
  }
</style>

<div class="wholesale-suppliers-page w-100 px-0 py-3">

  <!-- Header -->
  <section class="suppliers-hero shadow-sm mb-3 mb-lg-4">
    <div class="suppliers-hero-content p-3 p-sm-4">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3">
        <div class="min-w-0">
          <span class="suppliers-hero-badge mb-2">
            Find trusted wholesale suppliers
          </span>

          <h1 class="suppliers-hero-title h3 fw-bold mb-2">
            Find trusted wholesale suppliers
          </h1>

          <p class="suppliers-hero-text mb-0 small">
            Search suppliers by name, city, or country and open their wholesale catalogue.
          </p>
        </div>

        <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-md-end">
          <a href="/wholesale" class="btn btn-light btn-sm suppliers-hero-btn">
            View Products
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Search -->
  <form method="GET" action="/wholesale/suppliers" class="card suppliers-search-card shadow-sm mb-3 mb-lg-4">
    <div class="card-body p-2 p-sm-3">
      <div class="row g-2 align-items-center">
        <div class="col-12 col-md-10">
          <label class="form-label small fw-bold text-muted mb-1">
            Search suppliers
          </label>

          <input
            type="search"
            name="q"
            class="form-control form-control-sm"
            value="<%= q || '' %>"
            placeholder="Search supplier name, country, or city..."
          >
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label small fw-bold text-muted mb-1 d-none d-md-block">
            &nbsp;
          </label>

          <button type="submit" class="btn btn-primary btn-sm w-100 supplier-card-btn">
            Search
          </button>
        </div>
      </div>
    </div>
  </form>

  <% if (!suppliers || suppliers.length === 0) { %>
    <div class="card suppliers-empty-card shadow-sm">
      <div class="card-body text-center py-5">
        <div
          class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 text-primary"
          style="width: 64px; height: 64px;"
        >
          <span class="fw-bold fs-4">0</span>
        </div>

        <h2 class="h5 fw-bold text-primary mb-1">
          No suppliers found
        </h2>

        <p class="text-muted mb-0">
          Try a different supplier name, city, or country.
        </p>
      </div>
    </div>
  <% } else { %>

    <div class="suppliers-directory-summary d-flex justify-content-between align-items-end mb-3 px-3 px-sm-4 px-lg-5">
      <div class="min-w-0">
        <h2 class="h6 fw-bold text-dark mb-0">
          Supplier Directory
        </h2>

        <p class="text-muted small mb-0">
          <%= suppliers.length %> supplier<%= suppliers.length === 1 ? '' : 's' %> found
        </p>
      </div>
    </div>

    <div class="row g-3">
      <% suppliers.forEach((supplier) => { %>
        <div class="col-12 col-md-6 col-xl-4">
          <div class="card h-100 suppliers-card shadow-sm">
            
            <div class="supplier-card-top p-3">
              <div class="d-flex align-items-center gap-3">
                <div class="supplier-logo-frame">
                  <% if (supplier.logoUrl) { %>
                    <img
                      src="<%= supplier.logoUrl %>"
                      alt="<%= supplier.name %>"
                      class="supplier-logo-img"
                      loading="lazy"
                      decoding="async"
                      onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';"
                    >
                  <% } else { %>
                    <div class="supplier-logo-fallback">
                      <%= String(supplier.name || 'S').charAt(0).toUpperCase() %>
                    </div>
                  <% } %>
                </div>

                <div class="min-w-0">
                  <h2 class="h6 fw-bold supplier-name mb-1">
                    <%= supplier.name %>
                  </h2>

                  <div class="small supplier-location text-truncate">
                    <%= supplier.city || '' %>
                    <%= supplier.country ? ', ' + supplier.country : '' %>
                  </div>
                </div>
              </div>
            </div>

            <div class="card-body p-3 d-flex flex-column">
              <div class="mb-3">
                <span
                  class="supplier-verified-badge"
                  title="Official number verified"
                >
                  Official No.: Verified
                </span>
              </div>

              <p class="text-muted small mb-3">
                Open this supplier profile to view their active wholesale products and request supply.
              </p>

              <div class="mt-auto">
                <a href="/wholesale/suppliers/<%= supplier._id %>" class="btn btn-primary w-100 supplier-card-btn">
                  View Supplier
                </a>
              </div>
            </div>

          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>