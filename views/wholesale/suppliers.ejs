<!--views/wholesale/suppliers.ejs-->
<div class="container py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h3 fw-bold text-primary mb-1">Suppliers</h1>
      <p class="text-muted mb-0">Search verified suppliers on the platform.</p>
    </div>

    <a href="/wholesale" class="btn btn-outline-primary">
      View Products
    </a>
  </div>

  <form method="GET" action="/wholesale/suppliers" class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-2">
        <div class="col-12 col-md-10">
          <input
            type="search"
            name="q"
            class="form-control"
            value="<%= q || '' %>"
            placeholder="Search supplier name, country, or city..."
          >
        </div>

        <div class="col-12 col-md-2">
          <button type="submit" class="btn btn-primary w-100">
            Search
          </button>
        </div>
      </div>
    </div>
  </form>

  <% if (!suppliers || suppliers.length === 0) { %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <h2 class="h5 fw-bold text-primary">No suppliers found</h2>
        <p class="text-muted mb-0">Try a different search.</p>
      </div>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% suppliers.forEach((supplier) => { %>
        <div class="col-12 col-md-6 col-xl-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
              <div class="d-flex align-items-center gap-3 mb-3">
                <% if (supplier.logoUrl) { %>
                  <img src="<%= supplier.logoUrl %>" alt="<%= supplier.name %>" class="rounded-circle" style="width: 56px; height: 56px; object-fit: cover;">
                <% } else { %>
                  <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" style="width: 56px; height: 56px;">
                    <%= String(supplier.name || 'S').charAt(0).toUpperCase() %>
                  </div>
                <% } %>

                <div>
                  <h2 class="h6 fw-bold text-primary mb-1"><%= supplier.name %></h2>
                  <div class="small text-muted">
                    <%= supplier.city || '' %>
                    <%= supplier.country ? ', ' + supplier.country : '' %>
                  </div>
                </div>
              </div>

              <span class="badge text-bg-success mb-3">Verified Supplier</span>

              <a href="/wholesale/suppliers/<%= supplier._id %>" class="btn btn-primary w-100">
                View Supplier
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
