<%
  const CURRENCY = String(typeof baseCurrency !== 'undefined' ? baseCurrency : '').trim().toUpperCase() || 'USD';

  function money(amount) {
    if (typeof formatMoney === 'function') {
      return formatMoney(amount);
    }

    const n = Number(amount || 0);

    try {
      const formatted = new Intl.NumberFormat(undefined, {
        style: 'currency',
        currency: CURRENCY,
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(n);

      if (CURRENCY === 'ZAR') {
        return formatted.replace(/^ZAR\s?/, 'R');
      }

      return formatted;
    } catch {
      return CURRENCY + ' ' + n.toFixed(2);
    }
  }

  function niceDate(value) {
    if (!value) return 'Not recorded';

    try {
      return new Date(value).toLocaleDateString(undefined, {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
      });
    } catch {
      return 'Not recorded';
    }
  }

  function shortText(value, fallback = 'Not provided') {
    const clean = String(value || '').trim();
    return clean || fallback;
  }

  function trackingLabel(row) {
    const tracking = row?.tracking || {};
    const shippo = row?.shippo || {};

    return (
      tracking.trackingNumber ||
      shippo.trackingNumber ||
      'No tracking yet'
    );
  }

  function trackingStatus(row) {
    const tracking = row?.tracking || {};
    const shippo = row?.shippo || {};

    return (
      tracking.status ||
      tracking.liveStatus ||
      shippo.status ||
      'Pending'
    );
  }
%>

<style nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  .supplier-imported-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(124, 58, 237, 0.14), transparent 30%),
      radial-gradient(circle at top right, rgba(34, 197, 94, 0.12), transparent 28%),
      linear-gradient(180deg, #f6f2ff 0%, #ffffff 48%, #f8fafc 100%);
  }

  .supplier-imported-hero {
    border-radius: 24px;
    background:
      linear-gradient(135deg, rgba(91, 33, 182, 0.98), rgba(124, 58, 237, 0.96)),
      radial-gradient(circle at top right, rgba(34, 197, 94, 0.26), transparent 32%);
    overflow: hidden;
    position: relative;
  }

  .supplier-imported-hero::after {
    content: "";
    position: absolute;
    width: 230px;
    height: 230px;
    right: -90px;
    top: -90px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.18);
  }

  .supplier-imported-hero-content {
    position: relative;
    z-index: 2;
  }

  .supplier-imported-card {
    border-radius: 22px;
    border: 1px solid rgba(124, 58, 237, 0.14);
    overflow: hidden;
  }

  .supplier-imported-img {
    width: 82px;
    height: 82px;
    object-fit: contain;
    border-radius: 18px;
    background:
      radial-gradient(circle at center, rgba(124, 58, 237, 0.08), transparent 48%),
      linear-gradient(135deg, #ffffff, #f3efff);
    border: 1px solid rgba(124, 58, 237, 0.14);
  }

  .supplier-imported-green {
    color: #22C55E !important;
  }

  .supplier-imported-green-bg {
    background-color: #22C55E !important;
  }

  .supplier-imported-box {
    border-radius: 18px;
    border: 1px solid rgba(124, 58, 237, 0.12);
    background: rgba(124, 58, 237, 0.045);
  }

  /* ==========================================================
   * ✅ FULL WIDTH PAGE LOCK
   * Page: views/supplier-products/imported-sales.ejs only
   * Purpose: edge-to-edge layout on mobile and all screen sizes
   * ======================================================== */

  .supplier-imported-page,
  .supplier-imported-page * {
    box-sizing: border-box;
  }

  .supplier-imported-page {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    margin-left: 0;
    margin-right: 0;
    padding-left: 0 !important;
    padding-right: 0 !important;
    overflow-x: hidden;
  }

  .supplier-imported-page .row {
    margin-left: 0;
    margin-right: 0;
  }

  .supplier-imported-page [class*="col-"] {
    min-width: 0;
  }

  .supplier-imported-page img,
  .supplier-imported-page svg,
  .supplier-imported-page iframe,
  .supplier-imported-page canvas {
    max-width: 100%;
  }

  .supplier-imported-page a,
  .supplier-imported-page p,
  .supplier-imported-page span,
  .supplier-imported-page strong,
  .supplier-imported-page h1,
  .supplier-imported-page h2,
  .supplier-imported-page h3,
  .supplier-imported-page h4,
  .supplier-imported-page .badge,
  .supplier-imported-page .small,
  .supplier-imported-page .text-muted {
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  /* ==========================================================
  * SELLER-SIDE STOCK TABLE
  * Keep product and seller details aligned on narrow screens.
  * Bootstrap .table-responsive provides horizontal scrolling.
  * ======================================================== */

  .supplier-imported-stock-table {
    width: 100%;
    min-width: 1080px;
    table-layout: auto;
  }

  .supplier-imported-stock-table th,
  .supplier-imported-stock-table td {
    vertical-align: middle;
  }

  .supplier-imported-stock-table th {
    white-space: nowrap;
  }

  .supplier-imported-product-cell {
    width: 260px;
    min-width: 260px;
  }

  .supplier-imported-seller-cell {
    width: 230px;
    min-width: 230px;
  }

  .supplier-imported-product-info,
  .supplier-imported-seller-info {
    min-width: 0;
  }

  .supplier-imported-product-name,
  .supplier-imported-seller-name {
    line-height: 1.25;
    white-space: normal;
    overflow-wrap: break-word;
    word-break: normal;
  }

  .supplier-imported-seller-email,
  .supplier-imported-product-id {
    line-height: 1.25;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .supplier-imported-stock-table .supplier-imported-number-cell,
  .supplier-imported-stock-table .supplier-imported-badge-cell,
  .supplier-imported-stock-table .supplier-imported-value-cell,
  .supplier-imported-stock-table .supplier-imported-date-cell {
    white-space: nowrap;
  }

  /* ==========================================================
  * PAID ORDERS TABLE
  * Keep all columns wide and use horizontal scrolling on mobile.
  * ======================================================== */

  .supplier-imported-orders-scroll {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
  }

  .supplier-imported-orders-table {
    width: 1310px !important;
    min-width: 1310px !important;
    max-width: none !important;
    table-layout: fixed;
    margin-bottom: 0;
  }

  .supplier-imported-orders-table th,
  .supplier-imported-orders-table td {
    vertical-align: middle;
  }

  .supplier-imported-orders-table th {
    white-space: nowrap;
  }

  .supplier-imported-order-date-cell {
    width: 135px;
    min-width: 135px;
    max-width: 135px;
    white-space: nowrap;
  }

  .supplier-imported-order-number-cell {
    width: 180px;
    min-width: 180px;
    max-width: 180px;
  }

  .supplier-imported-order-product-cell {
    width: 230px;
    min-width: 230px;
    max-width: 230px;
  }

  .supplier-imported-order-seller-cell {
    width: 230px;
    min-width: 230px;
    max-width: 230px;
  }

  .supplier-imported-order-qty-cell {
    width: 70px;
    min-width: 70px;
    max-width: 70px;
    white-space: nowrap;
  }

  .supplier-imported-order-money-cell {
    width: 130px;
    min-width: 130px;
    max-width: 130px;
    white-space: nowrap;
  }

  .supplier-imported-order-tracking-cell {
    width: 205px;
    min-width: 205px;
    max-width: 205px;
  }

  .supplier-imported-order-info,
  .supplier-imported-order-product-info,
  .supplier-imported-order-seller-info,
  .supplier-imported-order-tracking-info {
    display: block;
    width: 100%;
    min-width: 0;
  }

  .supplier-imported-orders-table .supplier-imported-order-id,
  .supplier-imported-orders-table .supplier-imported-order-product-name,
  .supplier-imported-orders-table .supplier-imported-order-seller-name {
    line-height: 1.3;
    white-space: normal;
    overflow-wrap: normal;
    word-break: normal;
  }

  .supplier-imported-orders-table .supplier-imported-order-product-id,
  .supplier-imported-orders-table .supplier-imported-order-seller-email,
  .supplier-imported-orders-table .supplier-imported-order-tracking-number,
  .supplier-imported-orders-table .supplier-imported-order-tracking-status {
    line-height: 1.3;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  @media (max-width: 767.98px) {
    .supplier-imported-hero,
    .supplier-imported-card {
      border-radius: 0;
      margin-left: 0;
      margin-right: 0;
    }

    .supplier-imported-page .card-body,
    .supplier-imported-page .card-header,
    .supplier-imported-page .card-footer,
    .supplier-imported-hero-content {
      padding-left: 1rem !important;
      padding-right: 1rem !important;
    }

    .supplier-imported-page .supplier-imported-orders-body {
      padding-left: 0 !important;
      padding-right: 0 !important;
    }

    .supplier-imported-orders-scroll {
      padding-left: 0 !important;
      padding-right: 0 !important;
    }

    .supplier-imported-page .d-flex {
      min-width: 0;
    }

    .supplier-imported-page .btn {
      max-width: 100%;
      white-space: normal;
    }

    .supplier-imported-img {
      width: 68px;
      height: 68px;
      border-radius: 16px;
    }
  }
</style>

<div class="supplier-imported-page w-100 px-0 py-3">

  <!-- Header -->
  <section class="supplier-imported-hero shadow-sm mb-3 mb-lg-4">
    <div class="supplier-imported-hero-content p-3 p-sm-4">
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
        <div class="min-w-0">
          <span class="badge rounded-pill text-bg-light text-primary px-3 py-2 mb-2">
            Supplier Tracking
          </span>

          <h1 class="h3 fw-bold text-white mb-2">
            Imported Product Tracking
          </h1>

          <p class="text-white-50 small mb-0">
            See which sellers imported your wholesale products, remaining seller-side stock, paid sales, and delivery tracking.
          </p>
        </div>

        <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-lg-end">
          <a href="/wholesale/supplier/products" class="btn btn-light btn-sm rounded-pill fw-bold px-3">
            My Wholesale Products
          </a>

          <a href="/wholesale/supplier/requests" class="btn btn-outline-light btn-sm rounded-pill fw-bold px-3">
            Supply Requests
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- KPI cards -->
  <div class="row g-2 g-lg-3 mb-3">
    <div class="col-6 col-lg-3">
      <div class="card supplier-imported-card shadow-sm h-100">
        <div class="card-body p-3">
          <div class="small text-muted fw-bold mb-1">Imported Products</div>
          <div class="h4 fw-bold text-primary mb-0">
            <%= totals?.importedProducts || 0 %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-6 col-lg-3">
      <div class="card supplier-imported-card shadow-sm h-100">
        <div class="card-body p-3">
          <div class="small text-muted fw-bold mb-1">Seller Stock Left</div>
          <div class="h4 fw-bold text-primary mb-0">
            <%= totals?.currentSellerStock || 0 %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-6 col-lg-3">
      <div class="card supplier-imported-card shadow-sm h-100">
        <div class="card-body p-3">
          <div class="small text-muted fw-bold mb-1">Sold Units</div>
          <div class="h4 fw-bold supplier-imported-green mb-0">
            <%= totals?.soldCount || 0 %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-6 col-lg-3">
      <div class="card supplier-imported-card shadow-sm h-100">
        <div class="card-body p-3">
          <div class="small text-muted fw-bold mb-1">Wholesale Value</div>
          <div class="h5 fw-bold text-primary mb-0">
            <%= money(totals?.supplierValueEstimate || 0) %>
          </div>
          <div class="small text-muted">
            Tracking only
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if (!productStats || productStats.length === 0) { %>
  <div class="card supplier-imported-card shadow-sm">
    <div class="card-body text-center py-5">
      <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 text-primary" style="width: 76px; height: 76px;">
        <span class="fs-2">📦</span>
      </div>

      <h2 class="h5 fw-bold text-primary mb-2">
        No imported seller products yet
      </h2>

      <p class="text-muted mb-4">
        When a seller imports one of your approved wholesale products, it will appear here.
      </p>

      <a href="/wholesale/supplier/requests" class="btn btn-primary rounded-pill fw-bold px-4">
        View Supply Requests
      </a>
    </div>
  </div>
  <% } else { %>

  <!-- Imported product stock summary -->
  <div class="card supplier-imported-card shadow-sm mb-3">
    <div class="card-header bg-primary text-white border-0">
      <div class="fw-bold">
        Seller-side stock for your imported products
      </div>
      <div class="small text-white-50">
        This stock is from the seller's imported Product records.
      </div>
    </div>

    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table align-middle mb-0 supplier-imported-stock-table">
          <thead class="table-light">
            <tr>
              <th class="supplier-imported-product-cell">Product</th>
              <th class="supplier-imported-seller-cell">Seller</th>
              <th>Imported Qty</th>
              <th>Stock Left</th>
              <th>Sold</th>
              <th>Wholesale Value</th>
              <th>Status</th>
              <th>Latest Paid Sale</th>
            </tr>
          </thead>

          <tbody>
            <% productStats.forEach((row) => { %>
            <% const product = row.product || {}; %>
            <% const seller = row.seller || {}; %>

            <tr>
              <td class="supplier-imported-product-cell">
                <div class="d-flex align-items-center gap-3">
                  <img src="<%= product.imageUrl || '/images/branding/logo-unincorporate.png' %>" alt="<%= product.name || 'Imported product' %>" class="supplier-imported-img p-2 flex-shrink-0" loading="lazy" decoding="async" onerror="this.onerror=null;this.src='/images/branding/logo-unincorporate.png';">

                  <div class="supplier-imported-product-info">
                    <div class="fw-bold text-primary supplier-imported-product-name">
                      <%= product.name || 'Imported Product' %>
                    </div>

                    <div class="small text-muted mt-1 supplier-imported-product-id">
                      <%= product.customId || '' %>
                    </div>
                  </div>
                </div>
              </td>

              <td class="supplier-imported-seller-cell">
                <div class="supplier-imported-seller-info">
                  <div class="fw-bold supplier-imported-seller-name">
                    <%= seller.name || 'Seller' %>
                  </div>

                  <div class="small text-muted mt-1 supplier-imported-seller-email">
                    <%= seller.email || '' %>
                  </div>
                </div>
              </td>

              <td class="fw-bold supplier-imported-number-cell">
                <%= row.estimatedImportedQuantity || 0 %>
              </td>

              <td class="supplier-imported-badge-cell">
                <% if (Number(row.currentSellerStock || 0) > 0) { %>
                <span class="badge rounded-pill bg-primary px-3 py-2">
                  <%= row.currentSellerStock || 0 %> left
                </span>
                <% } else { %>
                <span class="badge rounded-pill text-bg-danger px-3 py-2">
                  Out of stock
                </span>
                <% } %>
              </td>

              <td class="supplier-imported-badge-cell">
                <span class="badge rounded-pill text-white supplier-imported-green-bg px-3 py-2">
                  <%= row.soldCount || 0 %> sold
                </span>
              </td>

              <td class="fw-bold text-primary supplier-imported-value-cell">
                <%= money(row.supplierValueEstimate || 0) %>
              </td>

              <td class="supplier-imported-badge-cell">
                <% if (row.deletedFromSeller) { %>
                <span class="badge rounded-pill text-bg-danger px-3 py-2">
                  Deleted by seller
                </span>

                <div class="small text-muted mt-1">
                  Returned:
                  <strong><%= Number(row.returnedQuantity || 0) %></strong>
                  item<%= Number(row.returnedQuantity || 0) === 1 ? '' : 's' %>
                </div>
                <% } else { %>
                <span class="badge rounded-pill text-white supplier-imported-green-bg px-3 py-2">
                  Active in seller store
                </span>
                <% } %>
              </td>

              <td class="small text-muted supplier-imported-date-cell">
                <%= niceDate(row.latestPaidOrderAt) %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Paid order rows -->
  <div class="card supplier-imported-card shadow-sm">
    <div class="card-header bg-white border-0">
      <div class="d-flex flex-column flex-sm-row justify-content-between gap-2">
        <div>
          <h2 class="h6 fw-bold text-primary mb-1">
            Paid orders containing your imported products
          </h2>
          <p class="small text-muted mb-0">
            These are paid customer orders where the seller sold an imported product that came from you.
          </p>
        </div>

        <span class="badge rounded-pill bg-primary align-self-start px-3 py-2">
          <%= orderRows?.length || 0 %> order item<%= (orderRows?.length || 0) === 1 ? '' : 's' %>
        </span>
      </div>
    </div>

    <% if (!orderRows || orderRows.length === 0) { %>
    <div class="card-body text-center py-5">
      <h3 class="h6 fw-bold text-primary mb-2">
        No paid sales yet
      </h3>

      <p class="text-muted mb-0">
        Imported products exist, but no paid customer order has been found yet.
      </p>
    </div>
    <% } else { %>
    <div class="card-body p-0 supplier-imported-orders-body">
      <div class="table-responsive supplier-imported-orders-scroll">
        <table class="table align-middle mb-0 supplier-imported-orders-table">  
          <thead class="table-light">
            <tr>
              <th class="supplier-imported-order-date-cell">Date</th>
              <th class="supplier-imported-order-number-cell">Order</th>
              <th class="supplier-imported-order-product-cell">Product</th>
              <th class="supplier-imported-order-seller-cell">Seller</th>
              <th class="supplier-imported-order-qty-cell">Qty</th>
              <th class="supplier-imported-order-money-cell">Retail Total</th>
              <th class="supplier-imported-order-money-cell">Supplier Value</th>
              <th class="supplier-imported-order-tracking-cell">Tracking</th>
            </tr>
          </thead>

          <tbody>
            <% orderRows.forEach((row) => { %>
            <% const product = row.product || {}; %>
            <% const seller = row.seller || {}; %>

            <tr>
              <td class="small text-muted supplier-imported-order-date-cell">
                <%= niceDate(row.createdAt) %>
              </td>

              <td class="supplier-imported-order-number-cell">
                <div class="supplier-imported-order-info">
                  <div class="fw-bold text-primary supplier-imported-order-id">
                    <%= row.orderId || 'Order' %>
                  </div>

                  <div class="small text-muted mt-1">
                    <%= row.status || row.paymentStatus || 'Paid' %>
                  </div>
                </div>
              </td>

              <td class="supplier-imported-order-product-cell">
                <div class="supplier-imported-order-product-info">
                  <div class="fw-bold text-primary supplier-imported-order-product-name">
                    <%= product.name || 'Imported product' %>
                  </div>

                  <div class="small text-muted mt-1 supplier-imported-order-product-id">
                    <%= product.customId || '' %>
                  </div>
                </div>
              </td>

              <td class="supplier-imported-order-seller-cell">
                <div class="supplier-imported-order-seller-info">
                  <div class="fw-bold supplier-imported-order-seller-name">
                    <%= seller.name || 'Seller' %>
                  </div>

                  <div class="small text-muted mt-1 supplier-imported-order-seller-email">
                    <%= seller.email || '' %>
                  </div>
                </div>
              </td>

              <td class="fw-bold supplier-imported-order-qty-cell">
                <%= row.quantity || 0 %>
              </td>

              <td class="fw-bold text-primary supplier-imported-order-money-cell">
                <%= money(row.lineTotal || 0) %>
              </td>

              <td class="fw-bold supplier-imported-green supplier-imported-order-money-cell">
                <%= money(row.supplierValue || 0) %>
              </td>

              <td class="supplier-imported-order-tracking-cell">
                <div class="supplier-imported-order-tracking-info">
                  <div class="fw-bold small supplier-imported-order-tracking-number">
                    <%= trackingLabel(row) %>
                  </div>

                  <div class="small text-muted mt-1 supplier-imported-order-tracking-status">
                    <%= trackingStatus(row) %>
                  </div>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>
  </div>
  <% } %>
</div>

