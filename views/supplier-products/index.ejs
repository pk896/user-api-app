<!--views/supplier-products/index.ejs-->
<%
  const CURRENCY = String(typeof baseCurrency !== 'undefined' ? baseCurrency : '').trim().toUpperCase() || 'USD';

  function money(amount) {
    if (typeof formatMoney === 'function') {
      return formatMoney(amount);
    }

    const n = Number(amount || 0);

    try {
      const formatted = new Intl.NumberFormat(undefined, {
        style: 'currency',
        currency: CURRENCY,
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(n);

      if (CURRENCY === 'ZAR') {
        return formatted.replace(/^ZAR\s?/, 'R');
      }

      return formatted;
    } catch {
      return CURRENCY + ' ' + n.toFixed(2);
    }
  }
%>

<div class="container py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h3 fw-bold text-primary mb-1">My Wholesale Products</h1>
      <p class="text-muted mb-0">These products appear only in the wholesale marketplace, not in the normal store.</p>
    </div>

    <a href="/wholesale/supplier/products/new" class="btn btn-primary">
      Add Wholesale Product
    </a>
  </div>

  <% if (!products || products.length === 0) { %>
  <div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
      <h2 class="h5 text-primary fw-bold">No wholesale products yet</h2>
      <p class="text-muted mb-4">Add your first supplier product so sellers can find you.</p>
      <a href="/wholesale/supplier/products/new" class="btn btn-primary">
        Add Product
      </a>
    </div>
  </div>
  <% } else { %>
  <div class="row g-3">
    <% products.forEach((product) => { %>
    <div class="col-12 col-md-6 col-xl-4">
      <div class="card h-100 border-0 shadow-sm">
        <% if (product.imageUrl) { %>
        <div class="ratio ratio-4x3 bg-light">
          <img
            src="<%= product.imageUrl %>"
            class="card-img-top w-100 h-100 object-fit-contain p-2"
            alt="<%= product.name %>"
          >
        </div>
        <% } else { %>
        <div class="ratio ratio-4x3 bg-light">
          <div class="d-flex align-items-center justify-content-center w-100 h-100">
            <span class="text-muted">No image</span>
          </div>
        </div>
        <% } %>

        <div class="card-body">
          <div class="d-flex justify-content-between gap-2 mb-2">
            <h2 class="h6 fw-bold text-primary mb-0"><%= product.name %></h2>

            <% if (product.status === 'active') { %>
            <span class="badge text-bg-success">Active</span>
            <% } else if (product.status === 'paused') { %>
            <span class="badge text-bg-warning">Paused</span>
            <% } else if (product.status === 'draft') { %>
            <span class="badge text-bg-secondary">Draft</span>
            <% } else { %>
            <span class="badge text-bg-dark"><%= product.status %></span>
            <% } %>
          </div>

          <p class="text-muted small mb-3">
            <%= product.category || 'Uncategorized' %>
          </p>

          <div class="row g-2 small mb-3">
            <div class="col-6">
              <div class="border rounded p-2">
                <div class="text-muted">Wholesale Price</div>
                <div class="fw-bold"><%= money(product.wholesalePrice) %></div>
              </div>
            </div>

            <div class="col-6">
              <div class="border rounded p-2">
                <div class="text-muted">MOQ</div>
                <div class="fw-bold"><%= product.minimumOrderQuantity || 1 %> <%= product.unit || 'units' %></div>
              </div>
            </div>

            <div class="col-6">
              <div class="border rounded p-2">
                <div class="text-muted">Available</div>
                <div class="fw-bold"><%= product.availableQuantity || 0 %></div>
              </div>
            </div>

            <div class="col-6">
              <div class="border rounded p-2">
                <div class="text-muted">Lead Time</div>
                <div class="fw-bold"><%= product.leadTimeDays || 0 %> days</div>
              </div>
            </div>
          </div>

          <div class="d-flex gap-2">
            <a href="/wholesale/supplier/products/<%= product._id %>/edit" class="btn btn-outline-primary btn-sm flex-fill">
              Edit
            </a>

            <form method="POST" action="/wholesale/supplier/products/<%= product._id %>/delete" class="flex-fill" onsubmit="return confirm('Delete this wholesale product? This will also remove its image from S3.');">
              <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                Delete
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>