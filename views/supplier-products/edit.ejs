<!--views/supplier-products/edit.ejs-->
<%
  const old = form || product || {};

  function valueOf(name, fallback = '') {
    const value = old[name];
    return value === undefined || value === null ? fallback : value;
  }

  function arrayValue(name) {
    const value = old[name];
    if (Array.isArray(value)) return value.join(', ');
    return value || '';
  }

  const shipping = old.shipping || {};
  const weight = shipping.weight || {};
  const dimensions = shipping.dimensions || {};
  const colorImages = Array.isArray(product.colorImages) ? product.colorImages : [];
%>

<div class="container py-4">
  <div class="mb-4">
    <a href="/wholesale/supplier/products" class="text-decoration-none text-primary">
      ← Back to Wholesale Products
    </a>
    <h1 class="h3 fw-bold text-primary mt-3 mb-1">Edit Wholesale Product</h1>
    <p class="text-muted mb-0">Update this supplier product. It will still only appear on wholesale pages.</p>
  </div>

  <% if (errors && errors.length) { %>
  <div class="alert alert-danger">
    <strong>Please fix these errors:</strong>
    <ul class="mb-0 mt-2">
      <% errors.forEach((error) => { %>
      <li><%= error.msg %></li>
      <% }) %>
    </ul>
  </div>
  <% } %>

  <form method="POST" action="/wholesale/supplier/products/<%= product._id %>/edit" enctype="multipart/form-data" class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="row g-4">

        <div class="col-12">
          <h2 class="h5 fw-bold text-primary mb-3">Product Details</h2>
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Product Name</label>
          <input type="text" name="name" class="form-control" value="<%= valueOf('name') %>" required>
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Custom ID</label>
          <input type="text" name="customId" class="form-control" value="<%= valueOf('customId') %>" disabled>
          <div class="form-text">Custom ID is kept stable after creation.</div>
        </div>

        <div class="col-12">
          <label class="form-label fw-semibold text-primary">Description</label>
          <textarea name="description" rows="4" maxlength="3000" class="form-control"><%= valueOf('description') %></textarea>
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Category</label>
          <select name="category" class="form-select">
            <option value="">Choose category</option>
            <% if (Array.isArray(CATEGORIES)) { %>
            <% CATEGORIES.forEach(function(c) { %>
            <option value="<%= c.value %>" <%= valueOf('category') === c.value ? 'selected' : '' %>>
              <%= c.label %>
            </option>
            <% }) %>
            <% } %>
          </select>
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Matching Type</label>
          <select name="type" class="form-select" required>
            <option value="">Choose type</option>
            <% if (Array.isArray(PRODUCT_TYPES)) { %>
            <% PRODUCT_TYPES.forEach(function(t) { %>
            <option value="<%= t.value %>" <%= valueOf('type') === t.value ? 'selected' : '' %>>
              <%= t.label %>
            </option>
            <% }) %>
            <% } %>
          </select>
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold text-primary">Product Role</label>
          <select name="role" class="form-select">
            <option value="general" <%= valueOf('role', 'general') === 'general' ? 'selected' : '' %>>General</option>
            <option value="clothes" <%= valueOf('role') === 'clothes' ? 'selected' : '' %>>Clothes</option>
            <option value="shoes" <%= valueOf('role') === 'shoes' ? 'selected' : '' %>>Shoes</option>
            <option value="electronics" <%= valueOf('role') === 'electronics' ? 'selected' : '' %>>Electronics</option>
            <option value="home" <%= valueOf('role') === 'home' ? 'selected' : '' %>>Home</option>
            <option value="beauty" <%= valueOf('role') === 'beauty' ? 'selected' : '' %>>Beauty</option>
            <option value="groceries" <%= valueOf('role') === 'groceries' ? 'selected' : '' %>>Groceries</option>
          </select>
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold text-primary">Quality / Grade</label>
          <select name="quality" class="form-select">
            <option value="">Select quality</option>
            <option value="Premium" <%= valueOf('quality') === 'Premium' ? 'selected' : '' %>>Premium</option>
            <option value="Standard" <%= valueOf('quality') === 'Standard' ? 'selected' : '' %>>Standard</option>
            <option value="Economy" <%= valueOf('quality') === 'Economy' ? 'selected' : '' %>>Economy</option>
            <option value="Wholesale" <%= valueOf('quality') === 'Wholesale' ? 'selected' : '' %>>Wholesale</option>
          </select>
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold text-primary">Manufacturer</label>
          <input type="text" name="manufacturer" class="form-control" value="<%= valueOf('manufacturer') %>">
        </div>

        <div class="col-12">
          <label class="form-label fw-semibold text-primary">Search Keywords</label>
          <input type="text" name="keywords" class="form-control" value="<%= arrayValue('keywords') %>" placeholder="Separate keywords with commas">
        </div>

        <div class="col-12">
          <hr>
          <h2 class="h5 fw-bold text-primary mb-3">Wholesale Pricing & Stock</h2>
        </div>

        <div class="col-12 col-md-3">
          <label class="form-label fw-semibold text-primary">Wholesale Price</label>
          <div class="input-group">
            <span class="input-group-text">R</span>
            <input type="number" step="0.01" min="0" name="wholesalePrice" class="form-control" value="<%= valueOf('wholesalePrice') %>" required>
          </div>
        </div>

        <div class="col-12 col-md-3">
          <label class="form-label fw-semibold text-primary">Minimum Order Quantity</label>
          <input type="number" min="1" name="minimumOrderQuantity" class="form-control" value="<%= valueOf('minimumOrderQuantity', 1) %>">
        </div>

        <div class="col-12 col-md-3">
          <label class="form-label fw-semibold text-primary">Available Quantity</label>
          <input type="number" min="0" name="availableQuantity" class="form-control" value="<%= valueOf('availableQuantity', 0) %>">
        </div>

        <div class="col-12 col-md-3">
          <label class="form-label fw-semibold text-primary">Unit</label>
          <input type="text" name="unit" class="form-control" value="<%= valueOf('unit', 'units') %>" placeholder="units, boxes, kg">
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold text-primary">Lead Time Days</label>
          <input type="number" min="0" name="leadTimeDays" class="form-control" value="<%= valueOf('leadTimeDays', 3) %>">
        </div>

        <div class="col-12 col-md-4 d-flex align-items-end">
          <div class="form-check">
            <input type="hidden" name="acceptsBulkOrders" value="0">
            <input class="form-check-input" type="checkbox" name="acceptsBulkOrders" id="acceptsBulkOrders" value="on" <%= valueOf('acceptsBulkOrders') ? 'checked' : '' %>>
            <label class="form-check-label fw-semibold text-primary" for="acceptsBulkOrders">
              Accepts bulk orders
            </label>
          </div>
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold text-primary">Status</label>
          <select name="status" class="form-select">
            <option value="active" <%= valueOf('status', 'active') === 'active' ? 'selected' : '' %>>Active</option>
            <option value="draft" <%= valueOf('status') === 'draft' ? 'selected' : '' %>>Draft</option>
            <option value="paused" <%= valueOf('status') === 'paused' ? 'selected' : '' %>>Paused</option>
            <option value="archived" <%= valueOf('status') === 'archived' ? 'selected' : '' %>>Archived</option>
          </select>
        </div>

        <div class="col-12">
          <hr>
          <h2 class="h5 fw-bold text-primary mb-3">Country & Supply Location</h2>
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold text-primary">Made In</label>
          <select name="made" id="madeSelect" class="form-select" required>
            <option value="">Choose country</option>
            <% if (Array.isArray(COUNTRIES)) { %>
            <% COUNTRIES.forEach(function(c) { %>
            <option value="<%= c.name %>" data-code="<%= c.code %>" <%= valueOf('made') === c.name ? 'selected' : '' %>>
              <%= c.name %>
            </option>
            <% }) %>
            <% } %>
          </select>
          <input type="hidden" name="madeCode" id="madeCode" value="<%= valueOf('madeCode') %>">
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold text-primary">Supply Country</label>
          <select name="supplyCountry" class="form-select">
            <option value="">Choose country</option>
            <% if (Array.isArray(COUNTRIES)) { %>
            <% COUNTRIES.forEach(function(c) { %>
            <option value="<%= c.name %>" <%= old.supplyLocation?.country === c.name ? 'selected' : '' %>>
              <%= c.name %>
            </option>
            <% }) %>
            <% } %>
          </select>
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold text-primary">Supply City</label>
          <input type="text" name="supplyCity" class="form-control" value="<%= old.supplyLocation?.city || '' %>">
        </div>

        <div class="col-12">
          <hr>
          <h2 class="h5 fw-bold text-primary mb-3">Images & Variants</h2>
        </div>

        <div class="col-12">
          <label class="form-label fw-semibold text-primary">Current Main Image</label>
          <% if (product.imageUrl) { %>
          <div class="mb-3">
            <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="img-fluid rounded border" style="max-height: 220px; object-fit: cover;">
          </div>
          <% } else { %>
          <div class="border rounded p-3 text-muted mb-3">No image uploaded.</div>
          <% } %>

          <label class="form-label fw-semibold text-primary">Upload New Main Image Optional</label>
          <input type="file" name="imageFile" id="supplierProductImageInput" class="form-control" accept="image/png,image/jpeg,image/jpg,image/webp,image/gif,image/bmp">
          <div class="form-text">Only upload a new image if you want to replace the current main image.</div>

          <div id="supplierProductImagePreviewWrap" class="mt-3 d-none">
            <div class="border rounded p-2 bg-light">
              <div class="small text-muted mb-2">New main image preview</div>
              <img id="supplierProductImagePreview" src="" alt="Selected replacement product image preview" class="img-fluid rounded" style="max-height: 260px; object-fit: cover;">
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Default Color</label>
          <input type="text" name="color" class="form-control" value="<%= valueOf('color') %>" placeholder="Example: Black">
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Default Size</label>
          <input type="text" name="size" class="form-control" value="<%= valueOf('size') %>" placeholder="Example: M or 1L">
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Variant Sizes</label>
          <input type="text" name="sizes" class="form-control" value="<%= arrayValue('sizes') %>" placeholder="Example: S, M, L">
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Variant Colors</label>
          <input type="text" name="colors" class="form-control" value="<%= arrayValue('colors') %>" placeholder="Example: Black, Blue, Red">
        </div>

        <div class="col-12">
          <label class="form-label fw-semibold text-primary">Image Per Color</label>

          <div id="colorImageRows" class="d-flex flex-column gap-2">
            <% if (colorImages.length) { %>
            <% colorImages.forEach(function(entry, index) { %>
            <div class="row g-2 align-items-center color-image-row">
              <input type="hidden" name="colorImageRowIndexes" value="<%= index %>">
              <input type="hidden" name="colorImageExistingUrls" value="<%= entry.imageUrl %>">

              <div class="col-12 col-md-3">
                <input type="text" name="colorImageColors" value="<%= entry.color %>" placeholder="Color" class="form-control">
              </div>

              <div class="col-12 col-md-3">
                <img src="<%= entry.imageUrl %>" alt="<%= entry.color %>" class="img-fluid rounded border" style="max-height: 90px; object-fit: cover;">
              </div>

              <div class="col-12 col-md-4">
                <input type="file" name="colorImageFile_<%= index %>" accept="image/png,image/jpeg,image/jpg,image/webp,image/gif,image/bmp" class="form-control">
                <div class="form-text">Upload only if replacing this color image.</div>
              </div>

              <div class="col-12 col-md-2 d-grid">
                <button type="button" class="btn btn-outline-secondary js-remove-color-row">Remove</button>
              </div>
            </div>
            <% }) %>
            <% } else { %>
            <div class="row g-2 align-items-center color-image-row">
              <input type="hidden" name="colorImageRowIndexes" value="0">
              <input type="hidden" name="colorImageExistingUrls" value="">

              <div class="col-12 col-md-5">
                <input type="text" name="colorImageColors" placeholder="Color" class="form-control">
              </div>

              <div class="col-12 col-md-5">
                <input type="file" name="colorImageFile_0" accept="image/png,image/jpeg,image/jpg,image/webp,image/gif,image/bmp" class="form-control">
              </div>

              <div class="col-12 col-md-2 d-grid">
                <button type="button" class="btn btn-outline-secondary js-remove-color-row">Remove</button>
              </div>
            </div>
            <% } %>
          </div>

          <button type="button" id="addColorImageRow" class="btn btn-outline-primary mt-3">
            Add another color
          </button>
        </div>

        <div class="col-12">
          <hr>
          <h2 class="h5 fw-bold text-primary mb-2">Shipping & Package Info</h2>
          <p class="text-muted small mb-0">Required for Shippo/carrier rate calculation. Enter the size and weight of one item.</p>
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Item Weight</label>
          <div class="row g-2">
            <div class="col-8">
              <input type="number" name="shipWeightValue" step="0.001" min="0" class="form-control" value="<%= weight.value || '' %>" required>
            </div>
            <div class="col-4">
              <select name="shipWeightUnit" class="form-select">
                <option value="kg" <%= (weight.unit || 'kg') === 'kg' ? 'selected' : '' %>>kg</option>
                <option value="g" <%= weight.unit === 'g' ? 'selected' : '' %>>g</option>
                <option value="lb" <%= weight.unit === 'lb' ? 'selected' : '' %>>lb</option>
                <option value="oz" <%= weight.unit === 'oz' ? 'selected' : '' %>>oz</option>
              </select>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6">
          <label class="form-label fw-semibold text-primary">Packaging Hint</label>
          <input type="text" name="packagingHint" class="form-control" value="<%= shipping.packagingHint || '' %>" placeholder="small-box, tube, fragile">
        </div>

        <div class="col-12">
          <label class="form-label fw-semibold text-primary">Item Dimensions</label>
          <div class="row g-2">
            <div class="col-6 col-md-3">
              <input type="number" name="shipLength" step="0.1" min="0" class="form-control" placeholder="Length" value="<%= dimensions.length || '' %>" required>
            </div>
            <div class="col-6 col-md-3">
              <input type="number" name="shipWidth" step="0.1" min="0" class="form-control" placeholder="Width" value="<%= dimensions.width || '' %>" required>
            </div>
            <div class="col-6 col-md-3">
              <input type="number" name="shipHeight" step="0.1" min="0" class="form-control" placeholder="Height" value="<%= dimensions.height || '' %>" required>
            </div>
            <div class="col-6 col-md-3">
              <select name="shipDimUnit" class="form-select">
                <option value="cm" <%= (dimensions.unit || 'cm') === 'cm' ? 'selected' : '' %>>cm</option>
                <option value="in" <%= dimensions.unit === 'in' ? 'selected' : '' %>>in</option>
              </select>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="d-flex flex-wrap gap-3">
            <label class="form-check d-flex align-items-center gap-2">
              <input type="hidden" name="shipSeparately" value="0">
              <input class="form-check-input" type="checkbox" name="shipSeparately" value="on" <%= shipping.shipSeparately ? 'checked' : '' %>>
              <span class="form-check-label">Ship separately</span>
            </label>

            <label class="form-check d-flex align-items-center gap-2">
              <input type="hidden" name="fragile" value="0">
              <input class="form-check-input" type="checkbox" name="fragile" value="on" <%= shipping.fragile ? 'checked' : '' %>>
              <span class="form-check-label">Fragile</span>
            </label>
          </div>
        </div>

      </div>
    </div>

    <div class="card-footer bg-white d-flex justify-content-end gap-2">
      <a href="/wholesale/supplier/products" class="btn btn-outline-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary">Save Changes</button>
    </div>
  </form>
</div>

<script nonce="<%= nonce %>">
  document.addEventListener('DOMContentLoaded', function() {
    const madeSelect = document.getElementById('madeSelect');
    const madeCodeInput = document.getElementById('madeCode');

    if (madeSelect && madeCodeInput) {
      madeSelect.addEventListener('change', function() {
        const selected = madeSelect.options[madeSelect.selectedIndex];
        madeCodeInput.value = selected ? (selected.dataset.code || '').toLowerCase() : '';
      });
    }

    const mainInput = document.getElementById('supplierProductImageInput');
    const mainWrap = document.getElementById('supplierProductImagePreviewWrap');
    const mainPreview = document.getElementById('supplierProductImagePreview');

    if (mainInput && mainWrap && mainPreview) {
      mainInput.addEventListener('change', function() {
        const file = mainInput.files && mainInput.files[0];

        if (!file || !file.type || !file.type.startsWith('image/')) {
          mainPreview.src = '';
          mainWrap.classList.add('d-none');
          return;
        }

        const previewUrl = URL.createObjectURL(file);
        mainPreview.src = previewUrl;
        mainWrap.classList.remove('d-none');

        mainPreview.onload = function() {
          URL.revokeObjectURL(previewUrl);
        };
      });
    }

    const rowsWrap = document.getElementById('colorImageRows');
    const addBtn = document.getElementById('addColorImageRow');

    function nextRowIndex() {
      const inputs = rowsWrap.querySelectorAll('input[name="colorImageRowIndexes"]');
      let max = -1;
      inputs.forEach(function(input) {
        const n = Number(input.value);
        if (Number.isFinite(n) && n > max) max = n;
      });
      return max + 1;
    }

    if (rowsWrap && addBtn) {
      addBtn.addEventListener('click', function() {
        const index = nextRowIndex();

        const row = document.createElement('div');
        row.className = 'row g-2 align-items-center color-image-row';
        row.innerHTML = `
          <input type="hidden" name="colorImageRowIndexes" value="${index}">
          <input type="hidden" name="colorImageExistingUrls" value="">

          <div class="col-12 col-md-5">
            <input type="text" name="colorImageColors" placeholder="Color" class="form-control">
          </div>

          <div class="col-12 col-md-5">
            <input type="file" name="colorImageFile_${index}" accept="image/png,image/jpeg,image/jpg,image/webp,image/gif,image/bmp" class="form-control">
          </div>

          <div class="col-12 col-md-2 d-grid">
            <button type="button" class="btn btn-outline-secondary js-remove-color-row">Remove</button>
          </div>
        `;

        rowsWrap.appendChild(row);
      });

      rowsWrap.addEventListener('click', function(event) {
        if (!event.target.classList.contains('js-remove-color-row')) return;
        const rows = rowsWrap.querySelectorAll('.color-image-row');
        if (rows.length <= 1) return;
        event.target.closest('.color-image-row').remove();
      });
    }
  });
</script>