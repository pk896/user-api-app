<!-- views/users-login.ejs -->
<section class="u-login-shell py-3 py-md-4">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-10 col-xl-9">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
          <div class="row g-0">
            <!-- HERO -->
            <div class="col-lg-6">
              <div class="u-login-hero bg-primary bg-gradient text-white h-100 p-4 p-md-5 d-flex">
                <div class="u-hero-inner w-100 d-flex flex-column gap-3">
                  <!-- Brand -->
                  <div class="u-hero-brand d-flex align-items-center gap-3">
                    <div class="u-hero-logo rounded-4 d-flex align-items-center justify-content-center bg-dark bg-opacity-25"
                         style="width:44px;height:44px;">
                      <svg viewBox="0 0 24 24" width="26" height="26" class="text-white">
                        <path fill="currentColor" d="M12 2C6.49 2 2 6.48 2 12s4.49 10 10 10 10-4.48 10-10S17.51 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                      </svg>
                    </div>

                    <div class="u-hero-text">
                      <div class="u-hero-sub small text-uppercase opacity-75" style="letter-spacing:.12em;">
                        User portal
                      </div>
                      <h1 class="u-hero-title h5 fw-bold mb-0">Unicoporate.com</h1>
                    </div>
                  </div>

                  <!-- Copy -->
                  <div class="u-hero-copy">
                    <h2 class="h6 fw-semibold mb-1">Welcome back 👋</h2>
                    <p class="mb-0 small opacity-75">
                      Sign in to access your dashboard, orders, and wishlist.
                    </p>
                  </div>

                  <!-- Pills -->
                  <div class="u-hero-pills d-none d-md-flex flex-column gap-2 mt-1">
                    <div class="u-hero-pill d-flex gap-2 align-items-start p-2 rounded-3 bg-dark bg-opacity-25">
                      <span class="u-dot rounded-circle mt-1 bg-success" style="width:8px;height:8px;"></span>
                      <div>
                        <div class="u-pill-title small fw-semibold">Secure sessions</div>
                        <div class="u-pill-text small opacity-75">Encrypted logins, device-aware.</div>
                      </div>
                    </div>

                    <div class="u-hero-pill d-flex gap-2 align-items-start p-2 rounded-3 bg-dark bg-opacity-25">
                      <span class="u-dot rounded-circle mt-1 bg-secondary" style="width:8px;height:8px;"></span>
                      <div>
                        <div class="u-pill-title small fw-semibold">Unified account</div>
                        <div class="u-pill-text small opacity-75">Track orders & payments easily.</div>
                      </div>
                    </div>

                    <div class="u-hero-pill d-flex gap-2 align-items-start p-2 rounded-3 bg-dark bg-opacity-25">
                      <span class="u-dot rounded-circle mt-1 bg-success" style="width:8px;height:8px;"></span>
                      <div>
                        <div class="u-pill-title small fw-semibold">Built for growth</div>
                        <div class="u-pill-text small opacity-75">For entrepreneurs & shoppers.</div>
                      </div>
                    </div>
                  </div>

                  <!-- Footer -->
                  <div class="u-hero-footer mt-auto pt-2 d-flex flex-wrap align-items-center gap-2 small">
                    <span class="opacity-75">New to the platform?</span>
                    <a href="/users/signup" class="u-btn-secondary btn btn-outline-light btn-sm rounded-pill d-inline-flex align-items-center gap-2">
                      <svg viewBox="0 0 24 24" width="16" height="16">
                        <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                      </svg>
                      Create account
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <!-- FORM -->
            <div class="col-lg-6">
              <div class="u-login-main bg-light p-4 p-md-5 h-100 d-flex align-items-stretch">
                <div class="u-login-main-inner w-100" style="max-width:420px;">
                  <header class="u-form-header mb-3">
                    <h2 class="h5 fw-bold mb-1">Sign in</h2>
                    <p class="text-secondary small mb-0">Use your username and password to continue.</p>
                  </header>

                  <!-- Page-local flash -->
                  <% (success || []).forEach(msg => { %>
                    <div class="u-flash u-flash-success alert alert-success d-flex align-items-center gap-2 py-2 mb-3" role="alert">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                      <span class="small"><%= msg %></span>
                    </div>
                  <% }) %>

                  <% (error || []).forEach(msg => { %>
                    <div class="u-flash u-flash-error alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" role="alert">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="15" y1="9" x2="9" y2="15"></line>
                        <line x1="9" y1="9" x2="15" y2="15"></line>
                      </svg>
                      <span class="small"><%= msg %></span>
                    </div>
                  <% }) %>

                  <form action="/users/login" method="POST" class="u-login-form" id="loginForm" novalidate>
                    <!-- Username -->
                    <div class="u-form-group mb-3">
                      <label for="login-username" class="u-form-label form-label small fw-semibold">
                        Username <span class="text-danger">*</span>
                      </label>

                      <div class="u-input-wrapper u-username-pill input-group">
                        <span class="u-username-prefix input-group-text">@</span>
                        <input
                          id="login-username"
                          type="text"
                          name="username"
                          class="u-form-input form-control"
                          autocomplete="username"
                          placeholder="e.g. phakisi.dev"
                          minlength="3"
                          maxlength="30"
                          required
                        />
                      </div>

                      <div class="u-form-hint form-text">
                        3–30 characters. Letters, numbers, dots (<code>.</code>), underscores (<code>_</code>) or dashes (<code>-</code>). No spaces.
                      </div>
                    </div>

                    <!-- Password -->
                    <div class="u-form-group mb-3">
                      <label for="login-password" class="u-form-label form-label small fw-semibold">
                        Password <span class="text-danger">*</span>
                      </label>

                      <div class="u-input-wrapper u-password-wrapper input-group">
                        <input
                          id="login-password"
                          type="password"
                          name="password"
                          class="u-form-input form-control"
                          autocomplete="current-password"
                          placeholder="Your password"
                          minlength="6"
                          required
                        />
                        <button
                          type="button"
                          class="u-toggle-password btn btn-outline-secondary"
                          id="showPasswordBtn"
                          aria-label="Toggle password visibility"
                        >
                          <svg class="u-eye-icon" viewBox="0 0 24 24" width="20" height="20">
                            <path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                          </svg>
                        </button>
                      </div>

                      <div class="u-form-actions-row d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mt-2">
                        <label class="u-checkbox-label form-check d-flex align-items-center gap-2 m-0">
                          <input type="checkbox" id="login-remember" name="remember" value="1" class="form-check-input mt-0" />
                          <span class="u-checkbox-custom d-none"></span>
                          <span class="u-checkbox-text form-check-label small">Remember this device</span>
                        </label>

                        <div class="u-links-row d-flex align-items-center gap-2 flex-wrap small">
                          <a href="/users/username/forgot" class="u-link-small link-primary fw-semibold text-decoration-none">Forgot username?</a>
                          <span class="u-link-dot text-secondary">·</span>
                          <a href="/users/password/forgot" class="u-link-small link-primary fw-semibold text-decoration-none">Forgot password?</a>
                        </div>
                      </div>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="u-btn-primary btn btn-primary w-100 rounded-pill d-inline-flex align-items-center justify-content-center gap-2">
                      <svg viewBox="0 0 24 24" width="18" height="18">
                        <path fill="currentColor" d="M10 17v-3H3v-4h7V7l5 5-5 5z"/>
                      </svg>
                      <span>Sign in</span>
                    </button>

                    <!-- Security note -->
                    <div class="u-security-note alert alert-info d-flex align-items-center gap-2 py-2 mt-3 mb-0" role="alert">
                      <svg viewBox="0 0 24 24" width="16" height="16">
                        <path fill="currentColor" d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                      </svg>
                      <span class="small mb-0">Your session is protected with secure encryption.</span>
                    </div>

                    <!-- Social Login -->
                    <div class="u-social-login mt-4">
                      <div class="u-divider d-flex align-items-center gap-2 text-secondary small mb-3">
                        <div class="flex-grow-1 border-top"></div>
                        <span>Or continue with</span>
                        <div class="flex-grow-1 border-top"></div>
                      </div>

                      <a href="/auth/google" class="u-social-btn btn btn-outline-secondary w-100 rounded-pill d-flex align-items-center justify-content-center gap-2">
                        <svg viewBox="0 0 24 24" width="18" height="18">
                          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        <span>Continue with Google</span>
                      </a>

                      <p class="u-social-note text-secondary small text-center mt-2 mb-0">
                        If you signed up with Google, use this option to sign in.
                      </p>
                    </div>

                    <!-- Demo credentials -->
                    <div class="u-demo-box mt-4">
                      <details class="u-demo-details">
                        <summary class="u-demo-summary d-flex align-items-center gap-2 fw-semibold">
                          <svg viewBox="0 0 24 24" width="16" height="16">
                            <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                          </svg>
                          <span>Quick demo login</span>
                        </summary>

                        <div class="u-demo-body mt-2 p-3 border rounded-3 bg-white">
                          <p class="mb-2 text-secondary small">Use these credentials in development/testing:</p>

                          <div class="u-demo-creds d-flex flex-column gap-2 mb-3">
                            <div class="u-cred-row d-flex justify-content-between align-items-center gap-3">
                              <span class="text-secondary small">Username</span>
                              <code class="border rounded px-2 py-1 bg-light">demo_user</code>
                            </div>
                            <div class="u-cred-row d-flex justify-content-between align-items-center gap-3">
                              <span class="text-secondary small">Password</span>
                              <code class="border rounded px-2 py-1 bg-light">demo123</code>
                            </div>
                          </div>

                          <button type="button" class="u-demo-btn btn btn-secondary w-100 rounded-pill" id="fillDemoBtn">
                            Fill demo credentials
                          </button>
                        </div>
                      </details>
                    </div>
                  </form>
                </div>
              </div>
            </div>

          </div><!-- /row -->
        </div><!-- /card -->
      </div>
    </div>
  </div>
</section>

<script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  (function () {
    'use strict';

    const usernameInput   = document.getElementById('login-username');
    const passwordInput   = document.getElementById('login-password');
    const showPasswordBtn = document.getElementById('showPasswordBtn');

    function clearInvalidState() {
      if (usernameInput) usernameInput.classList.remove('is-invalid');
      if (passwordInput) passwordInput.classList.remove('is-invalid');
    }

    // Toggle password visibility
    if (passwordInput && showPasswordBtn) {
      showPasswordBtn.addEventListener('click', function () {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';

        const eyeIcon = this.querySelector('.u-eye-icon');
        if (!eyeIcon) return;

        if (isPassword) {
          eyeIcon.innerHTML = '<path fill="currentColor" d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>';
        } else {
          eyeIcon.innerHTML = '<path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>';
        }
      });
    }

    // Demo credentials filler
    const fillDemoBtn = document.getElementById('fillDemoBtn');
    if (fillDemoBtn) {
      fillDemoBtn.addEventListener('click', function () {
        if (usernameInput) {
          usernameInput.value = 'demo_user';
          usernameInput.focus();
        }
        if (passwordInput) {
          passwordInput.value = 'demo123';
        }

        const msg = document.createElement('div');
        msg.className = 'u-flash u-flash-success alert alert-success d-flex align-items-center gap-2 py-2 mb-3 u-demo-inline';
        msg.innerHTML = `
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="small mb-0">Demo credentials filled. Press “Sign in”.</span>
        `;

        const container = document.querySelector('.u-login-main-inner');
        const form = document.getElementById('loginForm');
        if (container && form) {
          const existing = container.querySelector('.u-demo-inline');
          if (existing) existing.remove();
          container.insertBefore(msg, form);
        }
      });
    }

    // Client-side validation (Bootstrap-style)
    const loginForm = document.getElementById('loginForm');
    if (loginForm) {
      loginForm.addEventListener('submit', function (e) {
        clearInvalidState();

        const submitBtn   = this.querySelector('.u-btn-primary');
        const usernameVal = (usernameInput && usernameInput.value || '').trim();
        const passwordVal = (passwordInput && passwordInput.value || '').trim();

        let isValid = true;
        const usernameRegex = /^[a-zA-Z0-9._-]{3,30}$/;

        if (!usernameVal || !usernameRegex.test(usernameVal)) {
          isValid = false;
          if (usernameInput) usernameInput.classList.add('is-invalid');
        }

        if (!passwordVal || passwordVal.length < 6) {
          isValid = false;
          if (passwordInput) passwordInput.classList.add('is-invalid');
        }

        if (!isValid) {
          e.preventDefault();

          const existing = document.querySelector('.u-login-main-inner .u-flash-inline-error');
          if (existing) existing.remove();

          const err = document.createElement('div');
          err.className = 'u-flash u-flash-error alert alert-danger d-flex align-items-center gap-2 py-2 mb-3 u-flash-inline-error';
          err.innerHTML = `
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="15" y1="9"  x2="9"  y2="15"></line>
              <line x1="9"  y1="9"  x2="15" y2="15"></line>
            </svg>
            <span class="small mb-0">Enter a valid username (3–30, letters/numbers/._-) and a password of at least 6 characters.</span>
          `;

          const container = document.querySelector('.u-login-main-inner');
          if (container) {
            const header = container.querySelector('.u-form-header');
            container.insertBefore(err, header.nextSibling);
          }
          return;
        }

        // Loading state (Bootstrap spinner)
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.classList.add('opacity-75');
          submitBtn.innerHTML = `
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            <span>Signing in…</span>
          `;
        }
      });
    }

    // Remember me: save username in localStorage
    const rememberCheckbox = document.getElementById('login-remember');
    if (rememberCheckbox && usernameInput) {
      try {
        const saved = localStorage.getItem('login:username');
        if (saved) {
          usernameInput.value = saved;
          rememberCheckbox.checked = true;
        }
      } catch (err) {
        console.warn('Could not read saved username:', err);
      }

      usernameInput.addEventListener('input', function () {
        if (!rememberCheckbox.checked) return;
        const val = this.value.trim();
        try {
          if (val) localStorage.setItem('login:username', val);
        } catch (err) {
          console.warn('Could not save username:', err);
        }
      });

      rememberCheckbox.addEventListener('change', function () {
        try {
          if (!this.checked) {
            localStorage.removeItem('login:username');
          } else if (usernameInput.value.trim()) {
            localStorage.setItem('login:username', usernameInput.value.trim());
          }
        } catch (err) {
          console.warn('Remember me toggle error:', err);
        }
      });
    }

    // Autofocus username after render
    setTimeout(() => {
      if (usernameInput && !usernameInput.value) {
        usernameInput.focus();
      }
    }, 250);

    // Clear invalid state when typing
    if (usernameInput) usernameInput.addEventListener('input', clearInvalidState);
    if (passwordInput) passwordInput.addEventListener('input', clearInvalidState);
  })();
</script>