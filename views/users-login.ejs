<!-- views/users-login.ejs -->

<div class="min-vh-100 brand-page-bg py-4">
  <div class="container-fluid px-0 px-md-1">
    <div class="mx-auto col-12 col-lg-10 col-xl-9">

      <div class="row g-0 g-lg-4 justify-content-center align-items-stretch">

        <!-- HERO -->
        <div class="col-12 col-lg-6">
          <section class="text-white shadow-sm px-3 px-md-4 py-4 h-100 d-flex brand-hero">
            <div class="w-100 d-flex flex-column gap-3">

              <!-- Brand -->
              <div class="d-flex align-items-center gap-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center p-3 brand-hero-icon">
                  <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
                    <path fill="currentColor" d="M12 2C6.49 2 2 6.48 2 12s4.49 10 10 10 10-4.48 10-10S17.51 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                  </svg>
                </div>

                <div>
                  <div class="small text-uppercase text-white-50">
                    User portal
                  </div>
                  <h1 class="h5 fw-bold mb-0 text-white">Unicoporate.com</h1>
                </div>
              </div>

              <!-- Copy -->
              <div>
                <h2 class="h6 fw-semibold mb-1 text-white">Welcome back 👋</h2>
                <p class="mb-0 small text-white-50">
                  Sign in to access your dashboard, orders, and wishlist.
                </p>
              </div>

              <!-- Pills -->
              <div class="d-none d-md-flex flex-column gap-2 mt-1">
                <div class="d-flex gap-2 align-items-start p-2 rounded-3 brand-hero-pill">
                  <span class="rounded-circle mt-1 flex-shrink-0 p-1 brand-dot-green"></span>
                  <div>
                    <div class="small fw-semibold text-white">Secure sessions</div>
                    <div class="small text-white-50">Encrypted logins, device-aware.</div>
                  </div>
                </div>

                <div class="d-flex gap-2 align-items-start p-2 rounded-3 brand-hero-pill">
                  <span class="rounded-circle mt-1 flex-shrink-0 p-1 brand-dot-light"></span>
                  <div>
                    <div class="small fw-semibold text-white">Unified account</div>
                    <div class="small text-white-50">Track orders & payments easily.</div>
                  </div>
                </div>

                <div class="d-flex gap-2 align-items-start p-2 rounded-3 brand-hero-pill">
                  <span class="rounded-circle mt-1 flex-shrink-0 p-1 brand-dot-green"></span>
                  <div>
                    <div class="small fw-semibold text-white">Built for growth</div>
                    <div class="small text-white-50">For entrepreneurs & shoppers.</div>
                  </div>
                </div>
              </div>

              <!-- Footer -->
              <div class="mt-auto pt-2 d-flex flex-wrap align-items-center gap-2 small">
                <span class="text-white-50">New to the platform?</span>
                <a href="/users/signup" class="btn btn-light btn-sm rounded-pill d-inline-flex align-items-center gap-2 fw-semibold brand-purple-text">
                  <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                    <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                  </svg>
                  Create account
                </a>
              </div>

            </div>
          </section>
        </div>

        <!-- FORM -->
        <div class="col-12 col-lg-6">
          <section class="bg-white shadow-sm px-3 px-md-4 py-4 h-100 d-flex align-items-stretch">
            <div class="w-100">

              <header class="mb-3">
                <h2 class="h5 fw-bold mb-1 brand-purple-text">Sign in</h2>
                <p class="text-secondary small mb-0">Use your username and password to continue.</p>
              </header>

              <!-- Page-local flash -->
              <% (success || []).forEach(msg => { %>
                <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" role="alert">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span class="small"><%= msg %></span>
                </div>
              <% }) %>

              <% (error || []).forEach(msg => { %>
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" role="alert">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                  </svg>
                  <span class="small"><%= msg %></span>
                </div>
              <% }) %>

              <form action="/users/login" method="POST" id="loginForm" novalidate>

                <!-- Username -->
                <div class="mb-3">
                  <label for="login-username" class="form-label small fw-semibold brand-purple-text">
                    Username <span class="text-danger">*</span>
                  </label>

                  <div class="input-group">
                    <span class="input-group-text brand-input-icon">@</span>
                    <input
                      id="login-username"
                      type="text"
                      name="username"
                      class="form-control brand-focus"
                      autocomplete="username"
                      placeholder="e.g. phakisi.dev"
                      minlength="3"
                      maxlength="30"
                      required
                    />
                  </div>

                  <div class="form-text">
                    3–30 characters. Letters, numbers, dots (<code>.</code>), underscores (<code>_</code>) or dashes (<code>-</code>). No spaces.
                  </div>
                </div>

                <!-- Password -->
                <div class="mb-3">
                  <label for="login-password" class="form-label small fw-semibold brand-purple-text">
                    Password <span class="text-danger">*</span>
                  </label>

                  <div class="input-group">
                    <input
                      id="login-password"
                      type="password"
                      name="password"
                      class="form-control brand-focus"
                      autocomplete="current-password"
                      placeholder="Your password"
                      minlength="6"
                      required
                    />
                    <button
                      type="button"
                      class="btn btn-outline-secondary"
                      id="showPasswordBtn"
                      aria-label="Toggle password visibility"
                    >
                      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                        <path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                      </svg>
                    </button>
                  </div>

                  <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mt-2">
                    <label class="form-check d-flex align-items-center gap-2 m-0">
                      <input type="checkbox" id="login-remember" name="remember" value="1" class="form-check-input mt-0" />
                      <span class="form-check-label small">Remember this device</span>
                    </label>

                    <div class="d-flex align-items-center gap-2 flex-wrap small">
                      <a href="/users/username/forgot" class="fw-semibold text-decoration-none brand-link">Forgot username?</a>
                      <span class="text-secondary">·</span>
                      <a href="/users/password/forgot" class="fw-semibold text-decoration-none brand-link">Forgot password?</a>
                    </div>
                  </div>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn w-100 rounded-pill d-inline-flex align-items-center justify-content-center gap-2 text-white brand-btn-primary border-0">
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <path fill="currentColor" d="M10 17v-3H3v-4h7V7l5 5-5 5z"/>
                  </svg>
                  <span>Sign in</span>
                </button>

                <!-- Security note -->
                <div class="alert d-flex align-items-center gap-2 py-2 mt-3 mb-0 brand-alert-soft" role="alert">
                  <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                    <path fill="currentColor" d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                  </svg>
                  <span class="small mb-0">Your session is protected with secure encryption.</span>
                </div>

                <!-- Social Login -->
                <div class="mt-4">
                  <div class="d-flex align-items-center gap-2 text-secondary small mb-3">
                    <div class="flex-grow-1 border-top"></div>
                    <span>Or continue with</span>
                    <div class="flex-grow-1 border-top"></div>
                  </div>

                  <a href="/auth/google" class="btn btn-outline-secondary w-100 rounded-pill d-flex align-items-center justify-content-center gap-2">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    <span>Continue with Google</span>
                  </a>

                  <p class="text-secondary small text-center mt-2 mb-0">
                    If you signed up with Google, use this option to sign in.
                  </p>
                </div>

                <!-- Demo credentials -->
                <div class="mt-4">
                  <details>
                    <summary class="d-flex align-items-center gap-2 fw-semibold brand-purple-text">
                      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                        <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                      </svg>
                      <span>Quick demo login</span>
                    </summary>

                    <div class="mt-2 p-3 border rounded-3 bg-white">
                      <p class="mb-2 text-secondary small">Use these credentials in development/testing:</p>

                      <div class="d-flex flex-column gap-2 mb-3">
                        <div class="d-flex justify-content-between align-items-center gap-3">
                          <span class="text-secondary small">Username</span>
                          <code class="border rounded px-2 py-1 bg-light">demo_user</code>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3">
                          <span class="text-secondary small">Password</span>
                          <code class="border rounded px-2 py-1 bg-light">demo123</code>
                        </div>
                      </div>

                      <button type="button" class="btn btn-secondary w-100 rounded-pill" id="fillDemoBtn">
                        Fill demo credentials
                      </button>
                    </div>
                  </details>
                </div>

              </form>

            </div>
          </section>
        </div>

      </div>

    </div>
  </div>
</div>

<style nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  .brand-page-bg {
    background-color: #f8f5ff;
  }

  .brand-purple-text {
    color: #7C3AED !important;
  }

  .brand-link {
    color: #7C3AED !important;
  }

  .brand-link:hover,
  .brand-link:focus {
    color: #6d28d9 !important;
  }

  .brand-hero {
    background: linear-gradient(135deg, #7C3AED 0%, #6d28d9 100%);
    border-bottom: 4px solid #22C55E;
  }

  .brand-hero-icon {
    background-color: rgba(15, 23, 42, 0.18);
  }

  .brand-hero-pill {
    background-color: rgba(15, 23, 42, 0.18);
  }

  .brand-dot-green {
    background-color: #22C55E;
    width: 0.5rem;
    height: 0.5rem;
  }

  .brand-dot-light {
    background-color: rgba(255, 255, 255, 0.75);
    width: 0.5rem;
    height: 0.5rem;
  }

  .brand-input-icon {
    background-color: rgba(124, 58, 237, 0.08);
    color: #7C3AED;
    border-color: var(--bs-border-color);
  }

  .brand-focus:focus {
    border-color: #7C3AED;
    box-shadow: 0 0 0 0.25rem rgba(124, 58, 237, 0.18);
  }

  .brand-btn-primary {
    background-color: #7C3AED !important;
  }

  .brand-btn-primary:hover,
  .brand-btn-primary:focus {
    background-color: #6d28d9 !important;
  }

  .brand-alert-soft {
    background-color: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.22);
    color: #166534;
  }
</style>

<script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  (function () {
    'use strict';

    const usernameInput   = document.getElementById('login-username');
    const passwordInput   = document.getElementById('login-password');
    const showPasswordBtn = document.getElementById('showPasswordBtn');

    function clearInvalidState() {
      if (usernameInput) usernameInput.classList.remove('is-invalid');
      if (passwordInput) passwordInput.classList.remove('is-invalid');
    }

    // Toggle password visibility
    if (passwordInput && showPasswordBtn) {
      showPasswordBtn.addEventListener('click', function () {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';

        const eyeIcon = this.querySelector('svg');
        if (!eyeIcon) return;

        if (isPassword) {
          eyeIcon.innerHTML = '<path fill="currentColor" d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>';
        } else {
          eyeIcon.innerHTML = '<path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>';
        }
      });
    }

    // Demo credentials filler
    const fillDemoBtn = document.getElementById('fillDemoBtn');
    if (fillDemoBtn) {
      fillDemoBtn.addEventListener('click', function () {
        if (usernameInput) {
          usernameInput.value = 'demo_user';
          usernameInput.focus();
        }
        if (passwordInput) {
          passwordInput.value = 'demo123';
        }

        const msg = document.createElement('div');
        msg.className = 'alert alert-success d-flex align-items-center gap-2 py-2 mb-3';
        msg.id = 'demoInlineAlert';
        msg.innerHTML = `
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="small mb-0">Demo credentials filled. Press “Sign in”.</span>
        `;

        const container = document.getElementById('loginForm')?.parentElement;
        const form = document.getElementById('loginForm');
        if (container && form) {
          const existing = document.getElementById('demoInlineAlert');
          if (existing) existing.remove();
          container.insertBefore(msg, form);
        }
      });
    }

    // Client-side validation (Bootstrap-style)
    const loginForm = document.getElementById('loginForm');
    if (loginForm) {
      loginForm.addEventListener('submit', function (e) {
        clearInvalidState();

        const submitBtn   = this.querySelector('.btn.btn-primary');
        const usernameVal = (usernameInput && usernameInput.value || '').trim();
        const passwordVal = (passwordInput && passwordInput.value || '').trim();

        let isValid = true;
        const usernameRegex = /^[a-zA-Z0-9._-]{3,30}$/;

        if (!usernameVal || !usernameRegex.test(usernameVal)) {
          isValid = false;
          if (usernameInput) usernameInput.classList.add('is-invalid');
        }

        if (!passwordVal || passwordVal.length < 6) {
          isValid = false;
          if (passwordInput) passwordInput.classList.add('is-invalid');
        }

        if (!isValid) {
          e.preventDefault();

          const existing = document.getElementById('loginInlineError');
          if (existing) existing.remove();

          const err = document.createElement('div');
          err.className = 'alert alert-danger d-flex align-items-center gap-2 py-2 mb-3';
          err.id = 'loginInlineError';
          err.innerHTML = `
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="15" y1="9"  x2="9"  y2="15"></line>
              <line x1="9"  y1="9"  x2="15" y2="15"></line>
            </svg>
            <span class="small mb-0">Enter a valid username (3–30, letters/numbers/._-) and a password of at least 6 characters.</span>
          `;

          const header = document.querySelector('#loginForm')?.previousElementSibling;
          const container = document.querySelector('#loginForm')?.parentElement;
          if (container) {
            if (header) container.insertBefore(err, header.nextSibling);
            else container.insertBefore(err, loginForm);
          }
          return;
        }

        // Loading state
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.classList.add('opacity-75');
          submitBtn.innerHTML = `
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            <span>Signing in…</span>
          `;
        }
      });
    }

    // Remember me: save username in localStorage
    const rememberCheckbox = document.getElementById('login-remember');
    if (rememberCheckbox && usernameInput) {
      try {
        const saved = localStorage.getItem('login:username');
        if (saved) {
          usernameInput.value = saved;
          rememberCheckbox.checked = true;
        }
      } catch (err) {
        console.warn('Could not read saved username:', err);
      }

      usernameInput.addEventListener('input', function () {
        if (!rememberCheckbox.checked) return;
        const val = this.value.trim();
        try {
          if (val) localStorage.setItem('login:username', val);
        } catch (err) {
          console.warn('Could not save username:', err);
        }
      });

      rememberCheckbox.addEventListener('change', function () {
        try {
          if (!this.checked) {
            localStorage.removeItem('login:username');
          } else if (usernameInput.value.trim()) {
            localStorage.setItem('login:username', usernameInput.value.trim());
          }
        } catch (err) {
          console.warn('Remember me toggle error:', err);
        }
      });
    }

    setTimeout(() => {
      if (usernameInput && !usernameInput.value) {
        usernameInput.focus();
      }
    }, 250);

    if (usernameInput) usernameInput.addEventListener('input', clearInvalidState);
    if (passwordInput) passwordInput.addEventListener('input', clearInvalidState);
  })();
</script>