<!-- views/layouts/store.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">

  <%
    const layoutProduct = (typeof product !== 'undefined' && product) ? product : null;
    const layoutVatRate = (typeof vatRate !== 'undefined' && vatRate !== null) ? Number(vatRate) : 0.15;
    const layoutCurrency = String(typeof baseCurrency !== 'undefined' ? baseCurrency : 'USD').trim().toUpperCase() || 'USD';
    const layoutSiteUrl = String(typeof siteUrl !== 'undefined' ? siteUrl : '').replace(/\/+$/, '');

    function layoutMoney(amount) {
      const n = Number(amount || 0);

      try {
        const formatted = new Intl.NumberFormat(undefined, {
          style: 'currency',
          currency: layoutCurrency,
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(n);

        if (layoutCurrency === 'ZAR') {
          return formatted.replace(/^ZAR\s?/, 'R');
        }

        return formatted;
      } catch (error) {
        return layoutCurrency + ' ' + n.toFixed(2);
      }
    }

    function layoutAbsoluteUrl(value) {
      const raw = String(value || '').trim();

      if (!raw) return '';
      if (/^https?:\/\//i.test(raw)) return raw;
      if (!layoutSiteUrl) return raw;

      return layoutSiteUrl + '/' + raw.replace(/^\/+/, '');
    }

    const layoutProductName = layoutProduct ? String(layoutProduct.name || 'Product').trim() : '';
    const layoutProductCategory = layoutProduct ? String(layoutProduct.category || 'Product').trim() : '';
    const layoutProductPrice = layoutProduct ? layoutMoney(Number(layoutProduct.price || 0) * (1 + layoutVatRate)) : '';
    const layoutProductUrl = layoutProduct ? layoutAbsoluteUrl(layoutProduct.url || '') : '';
    const layoutProductImage = layoutProduct ? layoutAbsoluteUrl(layoutProduct.image || layoutProduct.imageUrl || '') : '';
    const layoutProductDescription = layoutProduct
      ? `Category: ${layoutProductCategory} - Price: ${layoutProductPrice} incl. VAT`
      : '';
  %>

  <title><%= layoutProduct ? layoutProductName + ' | Uni Store' : (title || 'Uni Store') %></title>
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <meta content="" name="keywords">
  <meta name="description" content="<%= layoutProduct ? layoutProductDescription : '' %>">

  <% if (layoutProduct) { %>
    <meta property="og:type" content="product">
    <meta property="og:title" content="<%= layoutProductName %>">
    <meta property="og:description" content="<%= layoutProductDescription %>">
    <meta property="og:url" content="<%= layoutProductUrl %>">
    <meta property="og:image" content="<%= layoutProductImage %>">
    <meta property="og:image:secure_url" content="<%= layoutProductImage %>">
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="<%= layoutProductName %>">
    <meta property="product:price:amount" content="<%= Number(layoutProduct.price || 0) * (1 + layoutVatRate) %>">
    <meta property="product:price:currency" content="<%= layoutCurrency %>">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= layoutProductName %>">
    <meta name="twitter:description" content="<%= layoutProductDescription %>">
    <meta name="twitter:image" content="<%= layoutProductImage %>">
    <meta name="twitter:image:alt" content="<%= layoutProductName %>">
  <% } %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

  <link href="/electro/lib/animate/animate.min.css" rel="stylesheet">
  <link href="/electro/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
  <link href="/electro/lib/lightbox/css/lightbox.min.css" rel="stylesheet">

  <link href="/electro/css/bootstrap.min.css" rel="stylesheet">
  <link href="/electro/css/style.css" rel="stylesheet">

  <style>
    html, body {
      overflow-x: hidden;
    }
  </style>
</head>
<body>
  <%- body %>

  <script nonce="<%= nonce %>" src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
  <script nonce="<%= nonce %>" src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
  <script nonce="<%= nonce %>" src="/electro/lib/wow/wow.min.js"></script>
  <script nonce="<%= nonce %>" src="/electro/lib/easing/easing.min.js"></script>
  <script nonce="<%= nonce %>" src="/electro/lib/waypoints/waypoints.min.js"></script>
  <script nonce="<%= nonce %>" src="/electro/lib/counterup/counterup.min.js"></script>
  <script nonce="<%= nonce %>" src="/electro/lib/owlcarousel/owl.carousel.min.js"></script>
  <script nonce="<%= nonce %>" src="/electro/lib/lightbox/js/lightbox.min.js"></script>
  <script nonce="<%= nonce %>" src="/electro/js/main.js"></script>
  <script nonce="<%= nonce %>" src="/electro/js/store-custom.js"></script>
</body>
</html>