<!--views/supply-requests/supplier-requests.ejs-->
<%
  const CURRENCY = String(typeof baseCurrency !== 'undefined' ? baseCurrency : '').trim().toUpperCase() || 'USD';

  function money(amount) {
    if (typeof formatMoney === 'function') {
      return formatMoney(amount);
    }

    const n = Number(amount || 0);

    try {
      const formatted = new Intl.NumberFormat(undefined, {
        style: 'currency',
        currency: CURRENCY,
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(n);

      if (CURRENCY === 'ZAR') {
        return formatted.replace(/^ZAR\s?/, 'R');
      }

      return formatted;
    } catch {
      return CURRENCY + ' ' + n.toFixed(2);
    }
  }

  function statusClass(status) {
    if (status === 'approved') return 'supply-status-approved';
    if (status === 'rejected') return 'supply-status-rejected';
    if (status === 'cancelled') return 'supply-status-cancelled';
    return 'supply-status-pending';
  }

  function statusLabel(status) {
    if (status === 'approved') return 'Approved';
    if (status === 'rejected') return 'Rejected';
    if (status === 'cancelled') return 'Cancelled';
    return 'Pending';
  }

  function officialStatusLabel(status) {
    const value = String(status || 'unverified').trim().toLowerCase();

    if (value === 'verified') return 'Verified';
    if (value === 'rejected') return 'Rejected';
    if (value === 'pending') return 'Pending';

    return 'Unverified';
  }

  function officialStatusBadgeClass(status) {
    const value = String(status || 'unverified').trim().toLowerCase();

    if (value === 'verified') return 'text-bg-success';
    if (value === 'rejected') return 'text-bg-danger';
    if (value === 'pending') return 'text-bg-warning text-dark';

    return 'text-bg-secondary';
  }
%>

<style nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  .supplier-requests-page {
    background:
      radial-gradient(circle at top left, rgba(124, 58, 237, 0.12), transparent 30%),
      radial-gradient(circle at top right, rgba(255, 193, 7, 0.16), transparent 28%),
      linear-gradient(180deg, #f7f8ff 0%, #ffffff 48%, #f8fafc 100%);
    min-height: 100vh;
  }

  .supply-hero {
    border-radius: 24px;
    border: 1px solid rgba(124, 58, 237, 0.14);
    background:
      linear-gradient(135deg, rgba(55, 30, 120, 0.96), rgba(124, 58, 237, 0.94)),
      radial-gradient(circle at top right, rgba(255, 193, 7, 0.34), transparent 32%);
