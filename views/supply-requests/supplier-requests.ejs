    height: 230px;
    right: -90px;
    top: -90px;
    border-radius: 999px;
    background: rgba(255, 193, 7, 0.26);
  }

  .supply-hero-content {
    position: relative;
    z-index: 2;
  }

  .supply-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    font-size: 0.76rem;
    font-weight: 900;
    color: #fff;
    background: rgba(255, 255, 255, 0.13);
    border: 1px solid rgba(255, 255, 255, 0.24);
    backdrop-filter: blur(10px);
  }

  .supply-hero-title {
    color: #fff;
    letter-spacing: -0.04em;
  }

  .supply-hero-text {
    color: rgba(255, 255, 255, 0.84);
