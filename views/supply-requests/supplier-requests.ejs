<!--views/supply-requests/supplier-requests.ejs-->
<div class="container py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h3 fw-bold text-primary mb-1">Supply Requests</h1>
      <p class="text-muted mb-0">Approve or reject seller supply requests.</p>
    </div>

    <a href="/wholesale/supplier/products" class="btn btn-primary">
      My Wholesale Products
    </a>
  </div>

  <% if (!requests || requests.length === 0) { %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <h2 class="h5 fw-bold text-primary">No supply requests yet</h2>
        <p class="text-muted mb-0">When sellers request your products, they will appear here.</p>
      </div>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% requests.forEach((request) => { %>
        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                <div>
                  <h2 class="h5 fw-bold text-primary mb-1">
                    <%= request.supplierProduct?.name || 'Wholesale Product' %>
                  </h2>

                  <p class="text-muted mb-2">
                    Seller: <strong><%= request.seller?.name || 'Seller' %></strong>
                  </p>

                  <div class="row g-2 small mb-3">
                    <div class="col-12 col-md-3">
                      <div class="border rounded p-2">
                        <div class="text-muted">Quantity</div>
                        <div class="fw-bold"><%= request.requestedQuantity %></div>
                      </div>
                    </div>

                    <div class="col-12 col-md-3">
                      <div class="border rounded p-2">
                        <div class="text-muted">Email</div>
                        <div class="fw-bold"><%= request.contactEmail || request.seller?.email || '-' %></div>
                      </div>
                    </div>

                    <div class="col-12 col-md-3">
                      <div class="border rounded p-2">
                        <div class="text-muted">Phone</div>
                        <div class="fw-bold"><%= request.contactPhone || request.seller?.phone || '-' %></div>
                      </div>
                    </div>

                    <div class="col-12 col-md-3">
                      <div class="border rounded p-2">
                        <div class="text-muted">Delivery</div>
                        <div class="fw-bold">
                          <%= request.deliveryCity || '-' %>
                          <%= request.deliveryCountry ? ', ' + request.deliveryCountry : '' %>
                        </div>
                      </div>
                    </div>
                  </div>

                  <% if (request.message) { %>
                    <div class="alert alert-light border small mb-3">
                      <strong>Seller message:</strong><br>
                      <%= request.message %>
                    </div>
                  <% } %>

                  <% if (request.supplierResponse) { %>
                    <div class="alert alert-light border small mb-3">
                      <strong>Your response:</strong><br>
                      <%= request.supplierResponse %>
                    </div>
                  <% } %>
                </div>

                <div class="text-lg-end">
                  <% if (request.status === 'approved') { %>
                    <span class="badge text-bg-success">Approved</span>
                  <% } else if (request.status === 'rejected') { %>
                    <span class="badge text-bg-danger">Rejected</span>
                  <% } else if (request.status === 'cancelled') { %>
                    <span class="badge text-bg-secondary">Cancelled</span>
                  <% } else { %>
                    <span class="badge text-bg-warning">Pending</span>
                  <% } %>
                </div>
              </div>

              <% if (request.status === 'pending') { %>
                <hr>

                <div class="row g-3">
                  <div class="col-12 col-lg-6">
                    <form method="POST" action="/wholesale/supplier/requests/<%= request._id %>/approve">
                      <label class="form-label fw-semibold text-primary">Approval Response</label>
                      <textarea name="supplierResponse" rows="3" class="form-control mb-2" placeholder="Example: Approved. Please contact us on WhatsApp/email to finalize delivery."></textarea>
                      <button type="submit" class="btn btn-success">
                        Approve Request
                      </button>
                    </form>
                  </div>

                  <div class="col-12 col-lg-6">
                    <form method="POST" action="/wholesale/supplier/requests/<%= request._id %>/reject">
                      <label class="form-label fw-semibold text-primary">Rejection Reason</label>
                      <textarea name="supplierResponse" rows="3" class="form-control mb-2" placeholder="Example: Sorry, this product is currently unavailable."></textarea>
                      <button type="submit" class="btn btn-outline-danger">
                        Reject Request
                      </button>
                    </form>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
